# Recon WO — environment variables.
#
# Copy this file to `.env` (gitignored) and fill in real values.
# Never commit the real `.env`. Never paste real keys into chat / commits / logs.
# Code reads everything via process.env.<NAME>.

# --- Server ---
PORT=3001
SESSION_SECRET=change-this-to-a-long-random-string-in-production
NODE_ENV=development

# --- Email (transactional) ---
# v0.6 default = file: writes .eml files to mail-outbox/.
# Switch to smtp + Resend creds when ready.
EMAIL_MODE=file
# When EMAIL_MODE=smtp:
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=587
# SMTP_USER=resend
# SMTP_PASS=re_xxxxx
# SMTP_SECURE=0
# EMAIL_FROM="Recon Construction <noreply@yourdomain>"

# --- AI (vendor-bill extraction, Round 7+) ---
# Provider can be 'deepseek', 'openai', 'anthropic'. Code maps to the right base URL.
AI_PROVIDER=deepseek
AI_API_KEY=

# --- Stripe (payments, future) ---
# STRIPE_SECRET_KEY=sk_test_xxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxx
# STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx

# --- Plaid (bank balances, future) ---
# PLAID_CLIENT_ID=
# PLAID_SECRET=
# PLAID_ENV=sandbox

# --- Supabase (when we cut over from sql.js, future) ---
# DATABASE_URL=postgresql://...
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
