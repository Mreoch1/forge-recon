<%# R37n: Vendor spend rollup — groups vendor_invoices by vendor, shows running
       total per vendor, expandable per-invoice list. Designed to handle the
       RPM-imported projects (Plymouth Square has 233 invoices across 17 vendors). %>

<%
function vfmt(n) { const num = Number(n); return isFinite(num) ? num.toFixed(2) : '0.00'; }
%>

<section id="vendor-spend-section" class="card mb-6">
  <header class="px-5 py-3 border-b border-recon-mist flex flex-wrap items-baseline justify-between gap-2">
    <div>
      <h3 class="font-semibold">Vendor spend</h3>
      <p class="text-xs text-recon-fog mt-0.5">
        <%= vendorInvoiceCount %> invoice<%= vendorInvoiceCount === 1 ? '' : 's' %> across
        <%= vendorSpend.length %> vendor<%= vendorSpend.length === 1 ? '' : 's' %>
        — total <strong class="text-recon-charcoal">$<%= vfmt(vendorInvoiceGrandTotal) %></strong>
      </p>
    </div>
  </header>

  <!-- Add vendor invoice form -->
  <div class="px-5 py-3 border-b border-recon-mist bg-recon-cloud">
    <form action="/projects/<%= jobId %>/vendor-invoices" method="post" class="flex flex-wrap items-end gap-3">
      <div class="flex-1 min-w-[140px]">
        <label class="text-xs text-recon-fog block mb-1">Vendor</label>
        <input type="text" name="vendor_name" list="contractor-list-<%= jobId %>" class="input text-sm" required placeholder="Start typing...">
        <datalist id="contractor-list-<%= jobId %>">
          <% (projectContractors || []).forEach(function(c){ %>
            <option value="<%= c.vendor_name %>">
          <% }); %>
        </datalist>
      </div>
      <div class="min-w-[110px]">
        <label class="text-xs text-recon-fog block mb-1">Invoice #</label>
        <input type="text" name="invoice_number" class="input text-sm" placeholder="INV-xxx">
      </div>
      <div class="flex-1 min-w-[160px]">
        <label class="text-xs text-recon-fog block mb-1">Description</label>
        <textarea name="description" rows="1" class="input text-sm" placeholder="What was this for?">
      </div>
      <div class="min-w-[100px]">
        <label class="text-xs text-recon-fog block mb-1">Amount</label>
        <div class="flex">
          <span class="text-sm text-recon-fog mr-1 pt-2">$</span>
          <input type="number" step="0.01" min="0.01" name="amount" class="input text-sm text-right" required placeholder="0.00" style="min-width:80px">
        </div>
      </div>
      <button type="submit" class="btn btn-primary text-sm" style="margin-bottom:1px">Add invoice</button>
    </form>
  </div>

  <% if (vendorSpend.length === 0) { %>
    <div class="p-6 text-center text-recon-fog text-sm italic">No vendor invoices on this project yet.</div>
  <% } else { %>
    <table class="data">
      <thead>
        <tr>
          <th>Vendor</th>
          <th class="text-right">Contract amount</th>
          <th class="text-right">Invoiced</th>
          <th class="text-right">Remaining</th>
          <th class="text-right">Invoices</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% vendorSpend.forEach(function(v, idx){ %>
          <tr class="row-link cursor-pointer" data-toggle="vs-rows-<%= idx %>">
            <td class="font-medium"><%= v.vendor_name %></td>
            <td class="text-right text-sm"><span class="contract-amount-display" data-vendor-id="<%= v.vendor_id %>"><%= v.contract_amount ? '$' + vfmt(v.contract_amount) : '—' %></span></td>
            <td class="text-right text-sm">$<%= vfmt(v.total) %></td>
            <td class="text-right text-sm <%= v.remaining > 0 ? 'text-green-700 font-medium' : 'text-recon-fog' %>"><%= v.contract_amount ? '$' + vfmt(v.remaining) : '—' %></td>
            <td class="text-right text-recon-fog text-sm"><%= v.invoices.length %></td>
            <td class="text-right text-sm text-recon-fog">
              <button type="button" class="vs-toggle-btn" data-target="vs-rows-<%= idx %>">▼ details</button>
            </td>
          </tr>
          <tr id="vs-rows-<%= idx %>" class="vs-detail-row" style="display:none;">
            <td colspan="6" class="bg-recon-cloud p-0">
              <table class="data" style="margin:0; box-shadow:none; background:transparent;">
                <thead>
                  <tr class="text-xs">
                    <th>Invoice #</th>
                    <th>Description</th>
                    <th class="text-right">Amount</th>
                    <th class="text-right">Logged</th>
                  </tr>
                </thead>
                <tbody>
                  <% v.invoices.forEach(function(inv){ %>
                    <tr>
                      <td class="font-mono text-xs"><%= inv.invoice_number || '—' %></td>
                      <td class="text-sm"><%= (inv.description || '').slice(0, 80) %></td>
                      <td class="text-right text-sm">$<%= vfmt(inv.amount) %></td>
                      <td class="text-right text-xs text-recon-fog">
                        <%= inv.created_at ? String(inv.created_at).slice(0,10) : '—' %>
                      </td>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            </td>
          </tr>
        <% }); %>
      </tbody>
      <tfoot class="bg-recon-cloud">
        <tr>
          <td class="text-right text-sm font-medium" colspan="4">Grand total</td>
          <td class="text-right font-bold text-recon-red" colspan="2">$<%= vfmt(vendorInvoiceGrandTotal) %></td>
        </tr>
      </tfoot>
    </table>
  <% } %>
</section>

<script>
(function(){
  document.querySelectorAll('#vendor-spend-section .vs-toggle-btn').forEach(function(btn){
    btn.addEventListener('click', function(ev){
      ev.stopPropagation();
      var id = btn.getAttribute('data-target');
      var row = document.getElementById(id);
      if (!row) return;
      var open = row.style.display !== 'none';
      row.style.display = open ? 'none' : '';
      btn.textContent = open ? '▼ details' : '▲ hide';
    });
  });
  // Allow clicking the summary row itself to toggle too
  document.querySelectorAll('#vendor-spend-section tr.row-link').forEach(function(tr){
    tr.addEventListener('click', function(ev){
      if (ev.target.closest('.vs-toggle-btn')) return;
      var btn = tr.querySelector('.vs-toggle-btn');
      if (btn) btn.click();
    });
  });
})();
</script>
