<%- include('../layouts/header', { title: title, currentUser: currentUser, flash: flash, activeNav: activeNav }) %>

<div class="ops-shell">
  <div class="ops-header">
    <div class="ops-title-block">
      <h1 class="page-h1">Projects</h1>
      <p class="page-sub"><%= total %> total<% if (q) { %> &middot; filter: "<%= q %>"<% } %><% if (status) { %> &middot; status: <%= status.replace('_',' ') %><% } %></p>
    </div>
    <div class="ops-actions">
      <a href="/projects/new" class="btn btn-primary">+ New project</a>
    </div>
  </div>

  <div class="ops-summary">
    <div class="ops-summary-item"><div class="ops-summary-label">Total</div><div class="ops-summary-value"><%= total %></div><div class="ops-summary-meta">projects</div></div>
    <div class="ops-summary-item"><div class="ops-summary-label">Estimating</div><div class="ops-summary-value"><%= jobs.filter(function(j){ return j.status === 'estimating'; }).length %></div><div class="ops-summary-meta">shown on page</div></div>
    <div class="ops-summary-item"><div class="ops-summary-label">In progress</div><div class="ops-summary-value"><%= jobs.filter(function(j){ return j.status === 'in_progress'; }).length %></div><div class="ops-summary-meta">shown on page</div></div>
    <div class="ops-summary-item"><div class="ops-summary-label">Shown</div><div class="ops-summary-value"><%= jobs.length %></div><div class="ops-summary-meta">current page</div></div>
  </div>

  <form method="get" action="/projects" class="list-utility-bar">
    <input type="text" name="q" value="<%= q %>" placeholder="Search title, address, customer..." class="list-search">
    <select name="status" class="list-filter">
      <option value="">All statuses</option>
      <% statuses.forEach(function(s){ %>
        <option value="<%= s %>" <%= status === s ? 'selected' : '' %>><%= s.replace('_',' ') %></option>
      <% }); %>
    </select>
    <button type="submit" class="btn btn-secondary">Filter</button>
    <% if (q || status) { %>
      <a href="/projects" class="list-clear">Clear</a>
    <% } %>
  </form>

  <div class="ops-panel ops-table">
    <div class="ops-panel-head">
      <div class="ops-panel-title">Project list</div>
      <div class="text-xs text-recon-fog"><%= jobs.length %> shown</div>
    </div>
    <div class="ops-panel-body">
    <% if (jobs.length === 0) { %>
      <div class="ops-empty">
        <% if (q || status) { %>
          No projects match those filters. <a href="/projects" class="text-recon-red underline">Clear</a>
        <% } else { %>
          No projects yet. <a href="/projects/new" class="text-recon-red underline">Create one</a>.
        <% } %>
      </div>
    <% } else { %>
      <table class="data">
        <thead>
          <tr>
            <th>Title</th>
            <th>Customer</th>
            <th>Location</th>
            <th>Status</th>
            <th>Created</th>
          </tr>
        </thead>
        <tbody>
          <% jobs.forEach(function(j){ %>
            <tr class="row-link" data-href="/projects/<%= j.id %>">
              <td class="font-medium"><%= j.title %></td>
              <td><%= j.customer_name %></td>
              <td><%= [j.address, j.city, j.state].filter(Boolean).join(', ') || '—' %></td>
              <td><span class="badge badge-<%= j.status %>"><%= j.status.replace('_',' ') %></span></td>
              <td><%= (j.created_at || '').slice(0,10) %></td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    <% } %>
    </div>
  </div>

  <% if (totalPages > 1) { %>
    <div class="flex items-center justify-center gap-2 mt-4">
      <% for (let p = 1; p <= totalPages; p++) { %>
        <% const qs = []; if (p) qs.push('page='+p); if (q) qs.push('q='+encodeURIComponent(q)); if (status) qs.push('status='+encodeURIComponent(status)); %>
        <% if (p === page) { %>
          <span class="btn btn-primary"><%= p %></span>
        <% } else { %>
          <a href="/projects?<%= qs.join('&') %>" class="btn btn-ghost"><%= p %></a>
        <% } %>
      <% } %>
    </div>
  <% } %>
</div>

<%- include('../layouts/footer') %>
