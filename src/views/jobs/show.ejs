<%- include('../layouts/header', { title: title, currentUser: currentUser, flash: flash, activeNav: activeNav }) %>
<%
var access = typeof projectAccess !== 'undefined' ? projectAccess : {
  canSeeBilling: true,
  canSeeOperations: true,
  canManageMembers: true,
  projectRole: 'admin'
};
%>

<div class="ops-shell">
  <div class="mb-4 flex flex-wrap items-center justify-between gap-3">
    <a href="/projects" class="text-sm text-recon-fog hover:text-recon-red">&larr; Projects</a>
    <div class="flex flex-wrap gap-2">
      <a href="/projects/<%= job.id %>/materials" class="btn btn-secondary text-sm">Materials</a>
      <a href="/projects/<%= job.id %>/export.xlsx" class="btn btn-secondary text-sm">Export Excel</a>
    </div>
  </div>

  <!-- D-007: Project header partial -->
  <%- include('_project_header', { job: job, projectManager: typeof projectManager !== 'undefined' ? projectManager : null, projectAccess: access }) %>
  <%- include('_project_tabs', { job: job, projectAccess: access, activeProjectTab: 'overview' }) %>

  <% if (access.projectRole === 'accountant') { %>
    <div class="card p-4 mb-6 border-l-4 border-recon-red">
      <p class="text-sm text-recon-charcoal m-0">Accountant view: showing project billing, cost, and financial records only.</p>
    </div>
  <% } else if (access.projectRole === 'superintendent') { %>
    <div class="card p-4 mb-6 border-l-4 border-recon-red">
      <p class="text-sm text-recon-charcoal m-0">Superintendent view: operational project details only. Billing and cost information is hidden.</p>
    </div>
  <% } %>

  <details class="chat-panel card mb-6 overflow-hidden" <%= (typeof chatOpen !== 'undefined' && chatOpen) ? 'open' : '' %>>
    <summary class="cursor-pointer px-5 py-4 hover:bg-recon-deeper/10 transition">
      <div class="flex items-center justify-between gap-4">
        <div>
          <h3 class="font-semibold m-0 flex items-center gap-2">
            <span>Project Chat</span>
            <span id="chat-unread" class="text-xs text-recon-fog hidden">new</span>
          </h3>
          <p class="text-xs text-recon-fog m-0 mt-0.5">Project communication and internal updates.</p>
        </div>
        <span class="text-recon-red text-sm font-medium">Open chat</span>
      </div>
    </summary>
    <div class="border-t border-recon-mist">
      <div id="chat-messages" class="overflow-y-auto p-4 space-y-2 text-sm" style="min-height:100px;max-height:360px;scroll-behavior:smooth">
        <div class="text-center text-recon-fog text-xs py-4">Loading messages...</div>
      </div>
      <div class="border-t border-recon-mist p-4">
        <form id="chat-form" class="flex gap-2">
          <div class="chat-mention-wrap">
            <input type="text" id="chat-input" class="input w-full text-sm" placeholder="Type a message... use @name to notify project team" autocomplete="off">
            <input type="hidden" id="chat-mention-ids" name="mention_user_ids" value="">
            <div id="chat-mention-menu" class="chat-mention-menu hidden"></div>
          </div>
          <input type="file" id="chat-photo-input" name="photo" accept="image/*" class="sr-only">
          <label for="chat-photo-input" class="btn btn-secondary text-sm cursor-pointer whitespace-nowrap" title="Attach a photo to this chat message">Photo</label>
          <button type="submit" class="btn btn-primary text-sm">Send</button>
        </form>
        <p id="chat-photo-label" class="text-xs text-recon-fog mt-2 hidden"></p>
      </div>
    </div>
  </details>

  <!-- D-141: Project Files tile -->
  <% if (access.canSeeOperations) { %>
  <div class="card mb-6">
    <a href="/files/projects/<%= job.id %>" class="block px-5 py-4 hover:bg-recon-deeper/10 transition rounded">
      <div class="flex items-center justify-between gap-4">
        <div class="flex items-center gap-3">
          <span class="text-2xl">📁</span>
          <div>
            <h3 class="font-semibold m-0">Project Files</h3>
            <p class="text-xs text-recon-fog m-0 mt-0.5">
              Folders, drawings, photos, RFI attachments, contracts, permits — anything project-related.
              <% if (typeof projectFileCounts !== 'undefined' && projectFileCounts) { %>
                <span class="ml-1"><%= projectFileCounts.folders %> folder<%= projectFileCounts.folders === 1 ? '' : 's' %> · <%= projectFileCounts.files %> file<%= projectFileCounts.files === 1 ? '' : 's' %></span>
              <% } %>
            </p>
          </div>
        </div>
        <span class="text-recon-red text-sm font-medium">Open files →</span>
      </div>
    </a>
    <% if (job.onedrive_folder_url) { %>
      <div class="px-5 pb-4 -mt-1">
        <a href="<%= job.onedrive_folder_url %>" target="_blank" rel="noopener" class="btn btn-secondary text-sm">Open OneDrive folder</a>
      </div>
    <% } %>
  </div>
  <% } %>

  <!-- D-024c: RFI / Decision log -->
  <details class="mb-6" open>
    <summary class="cursor-pointer text-sm font-medium text-recon-fog mb-2 hover:text-recon-red">RFI &amp; Decision log (<%= (decisions || []).length %>)</summary>
    <div class="mt-3">
      <%- include('_decisions_log', { jobId: job.id, decisions: decisions, users: typeof users !== 'undefined' ? users : [] }) %>
    </div>
  </details>

  <!-- D-007: Members -->
  <% if (access.canSeeOperations) { %>
  <details class="mb-6">
    <summary class="cursor-pointer text-sm font-medium text-recon-fog mb-2 hover:text-recon-red">Project team</summary>
    <div class="mt-3">
      <%- include('_members_list', { job: job, members: members, users: typeof users !== 'undefined' ? users : [], projectAccess: access }) %>
    </div>
  </details>
  <% } %>
</div>  <%# closes ops-shell %>

<script>
(function(){
  var projectId = <%= job.id %>;
  var userId = <%= typeof currentUser !== 'undefined' && currentUser ? currentUser.id : 'null' %>;
  var messagesEl = document.getElementById('chat-messages');
  var chatForm = document.getElementById('chat-form');
  var chatInput = document.getElementById('chat-input');
  var mentionInput = document.getElementById('chat-mention-ids');
  var mentionMenu = document.getElementById('chat-mention-menu');
  var photoInput = document.getElementById('chat-photo-input');
  var photoLabel = document.getElementById('chat-photo-label');
  var chatPanel = document.querySelector('.chat-panel');
  var unreadEl = document.getElementById('chat-unread');
  var mentionUsers = <%- JSON.stringify(chatMentionUsers || []).replace(/</g, '\\u003c') %>;
  var selectedMentionIds = new Set();
  var lastMessageId = null;
  var isLoading = false;
  var panelOpen = chatPanel && chatPanel.hasAttribute('open');
  var scrollPos = 'bottom';

  function scrollToBottom() {
    if (messagesEl) messagesEl.scrollTop = messagesEl.scrollHeight;
  }

  function formatTime(iso) {
    if (!iso) return '';
    var d = new Date(iso);
    return d.toLocaleString('en-US', { month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit' });
  }

  function appendMessage(msg, prepend) {
    if (!messagesEl) return false;
    var existing = messagesEl.querySelector('[data-msg-id="' + msg.id + '"]');
    if (existing) {
      updateSeenReceipt(existing, msg);
      return false;
    }
    var div = document.createElement('div');
    div.className = 'chat-msg' + (msg.user_id === userId ? ' chat-msg-self' : '');
    div.setAttribute('data-msg-id', msg.id);
    var attachmentHtml = '';
    if (msg.attachment_url) {
      attachmentHtml = '<a href="' + escapeAttr(msg.attachment_url) + '" target="_blank" rel="noopener" class="chat-photo-link">' +
        '<img src="' + escapeAttr(msg.attachment_url) + '" alt="' + escapeAttr(msg.attachment_original_name || 'Project chat photo') + '" class="chat-photo">' +
      '</a>';
    }
    var messageHtml = msg.message
      ? '<p class="text-sm m-0 whitespace-pre-wrap">' + highlightMentions(escapeHtml(msg.message)) + '</p>'
      : '';
    div.innerHTML = '<div class="flex items-baseline gap-2 mb-0.5">' +
      '<span class="font-medium text-xs ' + (msg.user_id === userId ? 'text-recon-red' : 'text-recon-charcoal') + '">' + escapeHtml(msg.users?.name || 'Unknown') + '</span>' +
      '<span class="text-xs text-recon-fog">' + formatTime(msg.created_at) + '</span>' +
      (msg.user_id === userId ? '<button class="ml-auto text-xs text-recon-fog hover:text-recon-red delete-msg" data-msg-id="' + msg.id + '" title="Delete message">&times;</button>' : '') +
      '</div>' +
      messageHtml +
      attachmentHtml +
      seenReceiptHtml(msg);
    if (prepend && messagesEl.firstChild) {
      messagesEl.insertBefore(div, messagesEl.firstChild);
    } else {
      messagesEl.appendChild(div);
    }
    if (!prepend) scrollToBottom();
    return true;
  }

  function seenReceiptHtml(msg) {
    if (!msg || Number(msg.user_id) !== Number(userId) || !Array.isArray(msg.seen_by) || !msg.seen_by.length) {
      return '';
    }
    var names = msg.seen_by.slice(0, 3).map(function(viewer) {
      return escapeHtml(viewer.name || viewer.email || 'User');
    }).join(', ');
    var extra = msg.seen_by.length > 3 ? ' +' + (msg.seen_by.length - 3) : '';
    return '<div class="chat-seen" data-seen-receipt>&#10003; Seen by ' + names + extra + '</div>';
  }

  function updateSeenReceipt(el, msg) {
    if (!el) return;
    var current = el.querySelector('[data-seen-receipt]');
    var next = seenReceiptHtml(msg);
    if (current && !next) current.remove();
    if (current && next) current.outerHTML = next;
    if (!current && next) el.insertAdjacentHTML('beforeend', next);
  }

  function escapeHtml(s) {
    if (typeof s !== 'string') return '';
    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }

  function escapeAttr(s) {
    return escapeHtml(String(s || '')).replace(/"/g, '&quot;');
  }

  function highlightMentions(html) {
    return html.replace(/(^|\s)(@[a-zA-Z0-9._-]+)/g, '$1<span class="chat-mention">$2</span>');
  }

  async function readJsonResponse(res) {
    var data = await res.json().catch(function(){ return {}; });
    if (!res.ok) throw new Error(data.error || 'Request failed.');
    return data;
  }

  function normalizeHandle(value) {
    return String(value || '').toLowerCase().replace(/[^a-z0-9._-]+/g, '');
  }

  function firstHandle(user) {
    var first = String(user.name || '').trim().split(/\s+/)[0] || String(user.email || '').split('@')[0];
    return normalizeHandle(first);
  }

  function syncMentionIds() {
    if (mentionInput) mentionInput.value = Array.from(selectedMentionIds).join(',');
  }

  function currentMentionToken() {
    if (!chatInput) return null;
    var pos = chatInput.selectionStart || 0;
    var before = chatInput.value.slice(0, pos);
    var match = before.match(/(^|\s)@([a-zA-Z0-9._-]*)$/);
    if (!match) return null;
    return {
      start: pos - match[2].length - 1,
      end: pos,
      query: normalizeHandle(match[2]),
    };
  }

  function hideMentionMenu() {
    if (mentionMenu) mentionMenu.classList.add('hidden');
  }

  function showMentionMenu(matches, token) {
    if (!mentionMenu) return;
    if (!token || !matches.length) {
      hideMentionMenu();
      return;
    }
    mentionMenu.innerHTML = matches.map(function(user) {
      return '<button type="button" class="chat-mention-option" data-user-id="' + user.id + '">' +
        '<span class="chat-mention-avatar">' + escapeHtml(String(user.name || '?').slice(0, 1).toUpperCase()) + '</span>' +
        '<span><strong>' + escapeHtml(user.name || user.email || 'User') + '</strong>' +
        '<small>@' + escapeHtml(user.handle || firstHandle(user)) + (user.email ? ' · ' + escapeHtml(user.email) : '') + '</small></span>' +
      '</button>';
    }).join('');
    mentionMenu.classList.remove('hidden');
  }

  function updateMentionMenu() {
    var token = currentMentionToken();
    if (!token) {
      hideMentionMenu();
      return;
    }
    var q = token.query;
    var matches = mentionUsers.filter(function(user) {
      var haystack = [
        user.name,
        user.email,
        user.handle,
        firstHandle(user),
      ].join(' ').toLowerCase();
      return !q || haystack.indexOf(q) !== -1;
    }).slice(0, 8);
    showMentionMenu(matches, token);
  }

  function selectMention(userId) {
    var user = mentionUsers.find(function(u){ return Number(u.id) === Number(userId); });
    var token = currentMentionToken();
    if (!user || !token || !chatInput) return;
    var handle = user.handle || firstHandle(user);
    var value = chatInput.value;
    chatInput.value = value.slice(0, token.start) + '@' + handle + ' ' + value.slice(token.end);
    var cursor = token.start + handle.length + 2;
    chatInput.setSelectionRange(cursor, cursor);
    selectedMentionIds.add(Number(user.id));
    syncMentionIds();
    hideMentionMenu();
    chatInput.focus();
  }

  function captureTypedMentionIds(text) {
    var aliases = new Map();
    mentionUsers.forEach(function(user) {
      [user.handle, firstHandle(user), normalizeHandle(String(user.email || '').split('@')[0])].forEach(function(alias) {
        if (!alias) return;
        var list = aliases.get(alias) || [];
        list.push(Number(user.id));
        aliases.set(alias, list);
      });
    });
    var matches = String(text || '').matchAll(/(^|\s)@([a-zA-Z0-9._-]+)/g);
    for (var match of matches) {
      var list = aliases.get(normalizeHandle(match[2])) || [];
      if (list.length === 1) selectedMentionIds.add(list[0]);
    }
    syncMentionIds();
  }

  async function loadMessages() {
    if (isLoading) return;
    isLoading = true;
    try {
      var url = '/projects/' + projectId + '/chat';
      var res = await fetch(url);
      var data = await res.json();
      if (data.messages && data.messages.length > 0) {
        var addedNew = false;
        data.messages.forEach(function(m) {
          if (appendMessage(m, true)) addedNew = true;
        });
        lastMessageId = data.messages[0].id;
        if (!panelOpen && addedNew && unreadEl) {
          unreadEl.classList.remove('hidden');
        }
      }
    } catch(e) { /* silent */ }
    isLoading = false;
  }

  // Initial load
  loadMessages().then(function(){
    // Clear loading placeholder
    var loading = messagesEl && messagesEl.querySelector('.text-center');
    if (loading) loading.remove();
    scrollToBottom();
  });

  // Auto-refresh every 3 seconds for near real-time updates
  setInterval(loadMessages, 3000);

  // Post message
  if (chatForm) {
    chatForm.addEventListener('submit', async function(e){
      e.preventDefault();
      var text = chatInput.value.trim();
      var photo = photoInput && photoInput.files && photoInput.files[0] ? photoInput.files[0] : null;
      if (!text && !photo) return;
      captureTypedMentionIds(text);
      chatInput.disabled = true;
      try {
        var formData = new FormData();
        formData.append('message', text);
        formData.append('mention_user_ids', mentionInput ? mentionInput.value : '');
        if (photo) {
          var params = new URLSearchParams({
            filename: photo.name,
            content_type: photo.type || 'image/jpeg',
            size: String(photo.size),
          });
          var uploadPrep = await readJsonResponse(await fetch('/projects/' + projectId + '/chat/photo-upload-url?' + params.toString()));
          var uploadRes = await fetch(uploadPrep.uploadUrl, {
            method: 'PUT',
            headers: { 'Content-Type': photo.type || 'image/jpeg' },
            body: photo,
          });
          if (!uploadRes.ok) {
            var uploadText = await uploadRes.text().catch(function(){ return ''; });
            throw new Error('Photo upload failed' + (uploadText ? ': ' + uploadText : '.'));
          }
          formData.append('photo_storage_key', uploadPrep.storageKey);
          formData.append('photo_mime_type', photo.type || 'image/jpeg');
          formData.append('photo_original_name', photo.name || 'photo');
          formData.append('photo_size_bytes', String(photo.size || 0));
        }
        var res = await fetch('/projects/' + projectId + '/chat', {
          method: 'POST',
          body: formData,
        });
        var data = await readJsonResponse(res);
        if (data.ok && data.message) {
          appendMessage(data.message);
          chatInput.value = '';
          if (photoInput) photoInput.value = '';
          if (photoLabel) {
            photoLabel.textContent = '';
            photoLabel.classList.add('hidden');
          }
          selectedMentionIds.clear();
          syncMentionIds();
          hideMentionMenu();
        } else if (data.error) {
          alert(data.error);
        }
      } catch(e) { alert(e && e.message ? e.message : 'Failed to send message.'); }
      chatInput.disabled = false;
      chatInput.focus();
    });
  }

  if (photoInput && photoLabel) {
    photoInput.addEventListener('change', function(){
      var photo = photoInput.files && photoInput.files[0] ? photoInput.files[0] : null;
      if (!photo) {
        photoLabel.textContent = '';
        photoLabel.classList.add('hidden');
        return;
      }
      photoLabel.textContent = 'Photo selected: ' + photo.name;
      photoLabel.classList.remove('hidden');
    });
  }

  if (chatInput) {
    chatInput.addEventListener('input', updateMentionMenu);
    chatInput.addEventListener('keyup', updateMentionMenu);
    chatInput.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') hideMentionMenu();
    });
  }

  if (mentionMenu) {
    mentionMenu.addEventListener('mousedown', function(e) {
      var option = e.target.closest('.chat-mention-option');
      if (!option) return;
      e.preventDefault();
      selectMention(option.getAttribute('data-user-id'));
    });
  }

  document.addEventListener('click', function(e) {
    if (!mentionMenu || !chatInput) return;
    if (e.target === chatInput || mentionMenu.contains(e.target)) return;
    hideMentionMenu();
  });

  // Delete message handler (delegated for dynamically added buttons)
  if (messagesEl) {
    messagesEl.addEventListener('click', async function(e) {
      var btn = e.target.closest('.delete-msg');
      if (!btn) return;
      var msgId = btn.getAttribute('data-msg-id');
      if (!msgId || !confirm('Delete this message?')) return;
      try {
        var res = await fetch('/projects/' + projectId + '/chat/' + msgId + '/delete', { method: 'POST' });
        var data = await res.json();
        if (data.ok) {
          var msgEl = btn.closest('[data-msg-id]');
          if (msgEl) msgEl.remove();
        } else if (data.error) {
          alert(data.error);
        }
      } catch(e) { alert('Failed to delete message.'); }
    });
  }

  // Track panel open/close for unread count
  if (chatPanel) {
    chatPanel.addEventListener('toggle', function(){
      panelOpen = chatPanel.hasAttribute('open');
      if (panelOpen && unreadEl) unreadEl.classList.add('hidden');
    });
  }

  // Scroll to bottom when messages update
  if (messagesEl) {
    messagesEl.addEventListener('DOMNodeInserted', function(){
      if (scrollPos === 'bottom') scrollToBottom();
    });
  }
})();
</script>

<style>
.chat-msg { padding: 6px 10px; border-radius: 8px; background: #f5f5f5; }
.chat-msg-self { background: #fef2f2; }
.chat-photo-link { display: inline-block; margin-top: .5rem; max-width: min(360px, 100%); }
.chat-photo { display: block; max-width: 100%; max-height: 320px; border-radius: 8px; border: 1px solid #e5e5e5; object-fit: contain; background: #fff; }
.chat-seen { margin-top: .25rem; font-size: .72rem; color: #777; }
.chat-mention-wrap { position: relative; flex: 1 1 auto; min-width: 0; }
.chat-mention { color: #c0202b; font-weight: 700; }
.chat-mention-menu {
  position: absolute;
  left: 0;
  right: 0;
  bottom: calc(100% + 6px);
  z-index: 40;
  max-height: 240px;
  overflow-y: auto;
  background: #fff;
  border: 1px solid #d9d9d9;
  border-radius: 8px;
  box-shadow: 0 12px 30px rgba(0,0,0,.16);
  padding: 6px;
}
.chat-mention-option {
  width: 100%;
  display: flex;
  align-items: center;
  gap: 10px;
  border: 0;
  background: transparent;
  border-radius: 6px;
  padding: 8px 10px;
  text-align: left;
  cursor: pointer;
}
.chat-mention-option:hover,
.chat-mention-option:focus {
  background: #f5f5f5;
}
.chat-mention-option strong {
  display: block;
  color: #1f1f1f;
  font-size: 13px;
}
.chat-mention-option small {
  display: block;
  color: #777;
  font-size: 11px;
  margin-top: 1px;
}
.chat-mention-avatar {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  background: #c0202b;
  color: #fff;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 12px;
  font-weight: 700;
  flex: 0 0 auto;
}
.chat-panel summary::-webkit-details-marker { display: none; }
.chat-panel[open] summary { border-bottom: 1px solid #e5e5e5; }
#chat-messages::-webkit-scrollbar { width: 4px; }
#chat-messages::-webkit-scrollbar-thumb { background: #d0d0d0; border-radius: 2px; }
@media (max-width: 1024px) {
  .chat-panel form { flex-direction: column; }
  .chat-mention-wrap { width: 100%; }
}
/* Dark mode overrides */
html.dark .chat-msg { background: var(--dark-elevated); color: var(--dark-text); }
html.dark .chat-msg-self { background: rgba(192,32,43,0.15); }
html.dark .chat-photo { border-color: var(--dark-border); background: var(--dark-surface); }
html.dark .chat-seen { color: var(--dark-muted); }
html.dark .chat-panel[open] summary { border-bottom-color: var(--dark-border); }
html.dark #chat-messages::-webkit-scrollbar-thumb { background: var(--dark-border-strong); }
html.dark .chat-mention-menu { background: var(--dark-surface); border-color: var(--dark-border); }
html.dark .chat-mention-option:hover,
html.dark .chat-mention-option:focus { background: var(--dark-elevated); }
html.dark .chat-mention-option strong { color: var(--dark-text); }
html.dark .chat-mention-option small { color: var(--dark-muted); }
</style>

<%- include('../layouts/footer') %>
