<%- include('../layouts/header', { title: title, currentUser: currentUser, flash: flash, activeNav: activeNav }) %>

<%
function fmt(n) { const num = Number(n); return isFinite(num) ? num.toFixed(2) : '0.00'; }
// Group root WOs and their subs for nested display
const roots = workOrders.filter(w => !w.parent_wo_id);
const subsByParent = {};
workOrders.filter(w => w.parent_wo_id).forEach(s => {
  (subsByParent[s.parent_wo_id] = subsByParent[s.parent_wo_id] || []).push(s);
});
%>

<div class="max-w-7xl mx-auto px-4 py-6">
  <div class="mb-4">
    <a href="/jobs" class="text-sm text-recon-fog hover:text-recon-red">&larr; Jobs</a>
  </div>

  <div class="flex items-baseline justify-between mb-6 flex-wrap gap-2">
    <div>
      <div class="flex items-center gap-3">
        <h1 class="page-h1"><%= job.title %></h1>
        <span class="badge badge-<%= job.status %>"><%= job.status.replace('_',' ') %></span>
      </div>
      <p class="page-sub">
        <a href="/customers/<%= job.customer_id %>" class="hover:text-recon-red"><%= job.customer_name %></a>
        &middot; Job #<%= job.id %> &middot; created <%= (job.created_at || '').slice(0,10) %>
      </p>
    </div>
    <div class="flex gap-2">
      <a href="/jobs/<%= job.id %>/edit" class="btn btn-secondary">Edit</a>
      <a href="/work-orders/new?job_id=<%= job.id %>" class="btn btn-primary">+ New work order</a>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-6">
    <div class="card p-5">
      <h3 class="text-sm font-semibold uppercase tracking-wide text-recon-fog mb-2">Job site</h3>
      <% if (job.address || job.city) { %>
        <p class="text-sm">
          <% if (job.address) { %><%= job.address %><br><% } %>
          <%= [job.city, job.state, job.zip].filter(Boolean).join(' ') %>
        </p>
      <% } else { %>
        <p class="text-sm text-recon-fog">No address on file.</p>
      <% } %>
    </div>
    <div class="card p-5">
      <h3 class="text-sm font-semibold uppercase tracking-wide text-recon-fog mb-2">Schedule</h3>
      <dl class="space-y-1 text-sm">
        <div><dt class="text-recon-fog text-xs inline">Date:</dt> <dd class="inline"><%= job.scheduled_date ? String(job.scheduled_date).slice(0,10) : '—' %></dd></div>
        <div><dt class="text-recon-fog text-xs inline">Time:</dt> <dd class="inline"><%= job.scheduled_time || '—' %></dd></div>
        <div><dt class="text-recon-fog text-xs inline">Assigned:</dt> <dd class="inline"><%= job.assigned_name || '—' %></dd></div>
      </dl>
    </div>
    <div class="card p-5">
      <h3 class="text-sm font-semibold uppercase tracking-wide text-recon-fog mb-2">Description</h3>
      <% if (job.description) { %>
        <p class="text-sm whitespace-pre-line"><%= job.description %></p>
      <% } else { %>
        <p class="text-sm text-recon-fog">No description.</p>
      <% } %>
    </div>
  </div>

  <div class="card overflow-hidden">
    <div class="px-5 py-3 border-b border-recon-mist flex items-center justify-between">
      <h3 class="font-semibold">Work Orders (<%= workOrders.length %>)</h3>
      <a href="/work-orders/new?job_id=<%= job.id %>" class="text-sm text-recon-red hover:underline">+ Add work order</a>
    </div>
    <% if (workOrders.length === 0) { %>
      <div class="p-8 text-center text-recon-fog text-sm">
        No work orders yet. <a href="/work-orders/new?job_id=<%= job.id %>" class="text-recon-red underline">Create one</a>.
      </div>
    <% } else { %>
      <table class="data">
        <thead>
          <tr><th>Number</th><th>Status</th><th>Scheduled</th><th>Completed</th><th>Created</th></tr>
        </thead>
        <tbody>
          <% roots.forEach(function(w){ %>
            <tr>
              <td class="font-medium">
                <a href="/work-orders/<%= w.id %>" class="hover:text-recon-red">WO-<%= w.display_number %></a>
              </td>
              <td><span class="badge badge-<%= w.status %>"><%= w.status.replace('_',' ') %></span></td>
              <td><%= w.scheduled_date ? String(w.scheduled_date).slice(0,10) : '—' %></td>
              <td><%= w.completed_date ? String(w.completed_date).slice(0,10) : '—' %></td>
              <td><%= (w.created_at || '').slice(0,10) %></td>
            </tr>
            <% (subsByParent[w.id] || []).forEach(function(s){ %>
              <tr>
                <td class="pl-8 text-sm">
                  <span class="text-recon-fog">└</span>
                  <a href="/work-orders/<%= s.id %>" class="hover:text-recon-red">WO-<%= s.display_number %></a>
                </td>
                <td><span class="badge badge-<%= s.status %>"><%= s.status.replace('_',' ') %></span></td>
                <td><%= s.scheduled_date ? String(s.scheduled_date).slice(0,10) : '—' %></td>
                <td><%= s.completed_date ? String(s.completed_date).slice(0,10) : '—' %></td>
                <td><%= (s.created_at || '').slice(0,10) %></td>
              </tr>
            <% }); %>
          <% }); %>
        </tbody>
      </table>
    <% } %>
  </div>
</div>

<%- include('../layouts/footer') %>
