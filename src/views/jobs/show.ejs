<%- include('../layouts/header', { title: title, currentUser: currentUser, flash: flash, activeNav: activeNav }) %>

<div class="max-w-7xl mx-auto px-4 py-6">
  <div class="mb-4 flex flex-wrap items-center justify-between gap-3">
    <a href="/projects" class="text-sm text-recon-fog hover:text-recon-red">&larr; Projects</a>
    <a href="/projects/<%= job.id %>/export.xlsx" class="btn btn-secondary text-sm">Export Excel</a>
  </div>

  <!-- D-007: Project header partial -->
  <%- include('_project_header', { job: job, projectManager: typeof projectManager !== 'undefined' ? projectManager : null }) %>

  <!-- D-007a: Financial Command Panel (replaces legacy Financial Overview) -->
  <%- include('_financial_panel', { financials: projectFinancials, financialsError: projectFinancialsError }) %>

  <!-- D-141: Project Files tile -->
  <div class="card mb-6">
    <a href="/files/projects/<%= job.id %>" class="block px-5 py-4 hover:bg-recon-deeper/10 transition rounded">
      <div class="flex items-center justify-between gap-4">
        <div class="flex items-center gap-3">
          <span class="text-2xl">📁</span>
          <div>
            <h3 class="font-semibold m-0">Project Files</h3>
            <p class="text-xs text-recon-fog m-0 mt-0.5">
              Folders, drawings, photos, RFI attachments, contracts, permits — anything project-related.
              <% if (typeof projectFileCounts !== 'undefined' && projectFileCounts) { %>
                <span class="ml-1"><%= projectFileCounts.folders %> folder<%= projectFileCounts.folders === 1 ? '' : 's' %> · <%= projectFileCounts.files %> file<%= projectFileCounts.files === 1 ? '' : 's' %></span>
              <% } %>
            </p>
          </div>
        </div>
        <span class="text-recon-red text-sm font-medium">Open files →</span>
      </div>
    </a>
  </div>

  <!-- F-011: Contractors & Vendors rollup -->
  <% if (typeof contractorRollup !== 'undefined' && contractorRollup.length > 0) { %>
  <details class="mb-6" open>
    <summary class="cursor-pointer text-sm font-medium text-recon-fog mb-2 hover:text-recon-red">Contractors &amp; Vendors (<%= contractorRollup.length %>)</summary>
    <div class="mt-3">
      <div class="card overflow-hidden">
        <table class="data">
          <thead>
            <tr>
              <th>Contractor</th>
              <th class="text-right">Contract</th>
              <th class="text-right">Billed</th>
              <th class="text-right">Remaining</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            <% contractorRollup.forEach(function(c){ %>
              <tr class="cursor-pointer" onclick="this.nextElementSibling.classList.toggle('hidden')">
                <td class="font-medium">
                  <%= c.vendor %>
                  <% if (c.vendor_id) { %>
                    <a href="/vendors/<%= c.vendor_id %>" class="text-recon-red text-xs hover:underline ml-1" onclick="event.stopPropagation()">View</a>
                  <% } %>
                </td>
                <td class="text-right">$<%= Number(c.contract_value).toFixed(2) %></td>
                <td class="text-right">$<%= Number(c.billed).toFixed(2) %></td>
                <td class="text-right font-medium <%= c.remaining >= 0 ? 'text-green-700' : 'text-recon-red' %>">$<%= Number(c.remaining).toFixed(2) %></td>
                <td>
                  <span class="badge <%= c.status === 'over_budget' ? 'badge-danger' : c.status === 'completed' ? 'badge-success' : c.status === 'active' ? 'badge-info' : 'badge-secondary' %> text-xs"><%= c.status.replace('_',' ') %></span>
                </td>
              </tr>
              <tr class="hidden">
                <td colspan="5" class="p-0">
                  <div class="bg-recon-cloud p-3 text-sm">
                    <% if (c.contact && (c.contact.email || c.contact.phone)) { %>
                      <p class="text-xs text-recon-fog mb-1">
                        Contact: <%= c.contact.email || '' %><%= c.contact.email && c.contact.phone ? ' · ' : '' %><%= c.contact.phone || '' %>
                      </p>
                    <% } %>
                    <% if (c.description_lines.length) { %>
                      <p class="text-xs text-recon-fog mb-1">
                        Scope: <%= c.description_lines.join('; ') %>
                      </p>
                    <% } %>
                    <% if (c.bills && c.bills.length) { %>
                      <table class="w-full text-xs mt-2">
                        <thead>
                          <tr class="text-recon-fog">
                            <th class="text-left">Bill #</th>
                            <th class="text-left">Date</th>
                            <th class="text-right">Amount</th>
                            <th>Status</th>
                          </tr>
                        </thead>
                        <tbody>
                          <% c.bills.forEach(function(b){ %>
                            <tr>
                              <td><a href="/bills/<%= b.id %>" class="text-recon-red hover:underline"><%= b.bill_number || '#' + b.id %></a></td>
                              <td><%= b.bill_date ? String(b.bill_date).slice(0,10) : '—' %></td>
                              <td class="text-right">$<%= Number(b.total).toFixed(2) %></td>
                              <td class="text-center"><span class="badge <%= b.status === 'paid' ? 'badge-success' : 'badge-info' %> text-xs"><%= b.status %></span></td>
                            </tr>
                          <% }); %>
                        </tbody>
                      </table>
                    <% } else { %>
                      <p class="text-xs text-recon-fog italic">No bills yet.</p>
                    <% } %>
                  </div>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </div>
  </details>
  <% } %>

  <!-- D-007: Members -->
  <details class="mb-6">
    <summary class="cursor-pointer text-sm font-medium text-recon-fog mb-2 hover:text-recon-red">Project team</summary>
    <div class="mt-3">
      <%- include('_members_list', { job: job, members: members, users: typeof users !== 'undefined' ? users : [] }) %>
    </div>
  </details>
</div>

<%- include('../layouts/footer') %>
