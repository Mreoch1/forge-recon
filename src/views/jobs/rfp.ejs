<%- include('../layouts/header', { title: 'RFP — ' + (job.title || job.name), currentUser: currentUser, flash: flash, activeNav: activeNav }) %>

<div class="ops-shell">
  <div class="mb-4 flex items-center justify-between gap-3 flex-wrap">
    <a href="/projects/<%= job.id %>" class="text-sm text-recon-fog hover:text-recon-red">&larr; Back to <%= job.title || job.name %></a>
  </div>

  <div class="mb-4 flex flex-wrap items-end justify-between gap-3">
    <div>
      <h1 class="page-h1">RFP / Bid Comparison</h1>
      <p class="text-sm text-recon-fog mt-1">Project: <a href="/projects/<%= job.id %>" class="text-recon-red hover:underline"><%= job.title || job.name %></a></p>
    </div>
    <div class="flex items-center gap-3">
      <span id="rfp-autosave-status" class="text-xs font-medium text-recon-fog">Autosave on</span>
      <button onclick="document.getElementById('rfp-new-form').classList.toggle('hidden')"
              class="btn btn-primary text-sm">+ Add category</button>
    </div>
  </div>

  <div class="rfp-action-bar mb-6">
    <div class="rfp-action-group">
      <span class="rfp-action-label">Export</span>
      <div class="rfp-action-buttons">
        <a href="/projects/<%= job.id %>/rfp/export.pdf" class="btn btn-secondary text-sm" target="_blank">PDF</a>
        <a href="/projects/<%= job.id %>/rfp/export.csv" class="btn btn-secondary text-sm" target="_blank">CSV</a>
        <a href="/projects/<%= job.id %>/rfp/export.xlsx" class="btn btn-secondary text-sm" target="_blank">XLSX</a>
      </div>
    </div>
    <form id="rfp-bid-request-form" action="/projects/<%= job.id %>/rfp/bid-request.pdf" method="GET" target="_blank" class="rfp-bid-request-tools">
      <label class="rfp-bid-recipient">
        <span class="rfp-action-label">Bid request</span>
        <input name="for" class="input text-sm" placeholder="Prepared for (optional)" list="rfp-line-entity-options">
      </label>
      <button id="rfp-bid-request-submit" type="submit" class="btn btn-secondary text-sm" disabled>Bid request PDF</button>
      <span id="rfp-bid-request-count" class="rfp-selected-count">0 selected</span>
    </form>
  </div>


  <!-- New category / scope area — user-defined names like "Cabinet", "Painting", "1st floor"
       per D-078 spec (matches Michael's Excel template). Contractor/vendor bids go INSIDE
       each tab as line items (see line-item form below). -->
  <div id="rfp-new-form" class="hidden card p-4 mb-6 bg-recon-deeper border-recon-mist">
    <h3 class="text-sm font-semibold mb-3">Add category</h3>
    <p class="text-xs text-recon-fog mb-3">Add a scope area (e.g. "Cabinet", "Painting", "1st floor"). Click into it to add line items per contractor/vendor.</p>
    <form action="/projects/<%= job.id %>/rfps" method="POST" class="flex gap-3 items-end flex-wrap">
      <div>
        <label class="block text-xs text-recon-fog mb-1">Category name</label>
        <input name="contractor_name" required class="input" placeholder="Pick from list or type custom" style="min-width:240px" maxlength="80" autocomplete="off" list="rfp-tab-presets">
        <datalist id="rfp-tab-presets">
          <option value="Cabinets">
          <option value="Concrete">
          <option value="Countertops">
          <option value="Demolition">
          <option value="Doors">
          <option value="Drywall">
          <option value="Electrical">
          <option value="Flooring">
          <option value="Framing">
          <option value="General">
          <option value="HVAC">
          <option value="Insulation">
          <option value="Landscaping">
          <option value="Painting">
          <option value="Plumbing">
          <option value="Roofing">
          <option value="Site Work">
          <option value="Tile">
          <option value="Trim / Finish">
          <option value="Windows">
        </datalist>
        <p class="text-xs text-recon-fog mt-1">Type any custom name (e.g. "1st floor", "Activities bldg") — picker is just a suggestion list.</p>
      </div>
      <button type="submit" class="btn btn-primary text-sm">Add category</button>
    </form>
  </div>

  <!-- Shared datalist for line-item vendor/contractor selection (used inside each RFP tab below) -->
  <datalist id="rfp-line-entity-options">
    <% (contractors || []).forEach(function(c) { %>
      <option value="<%= c.name %>" data-type="contractor"><%= c.name %> — Contractor<% if (c.trade) { %> (<%= c.trade %>)<% } %></option>
    <% }); %>
    <% (vendors || []).forEach(function(v) { %>
      <option value="<%= v.name %>" data-type="vendor"><%= v.name %> — Vendor</option>
    <% }); %>
  </datalist>

  <!-- RFP list -->
  <% if (!rfps || rfps.length === 0) { %>
    <div class="card p-12 text-center text-recon-fog text-sm">
      No categories yet. Click <strong>+ Add category</strong> to add a scope area.
    </div>
  <% } else { %>
    <% 
    // Calculate RFP-level totals for summary cards.
    // For parent/sub-line groups, count approved sub-lines once and never also
    // count the parent row. Standalone legacy rows still count when approved.
    function approvedRfpTotal(items) {
      var childrenByParent = {};
      (items || []).forEach(function(i) {
        if (i.parent_line_item_id) {
          (childrenByParent[i.parent_line_item_id] = childrenByParent[i.parent_line_item_id] || []).push(i);
        }
      });
      return (items || []).reduce(function(sum, i) {
        if (i.parent_line_item_id) return sum;
        var children = childrenByParent[i.id] || [];
        if (children.length > 0) {
          return sum + children.reduce(function(childSum, c) {
            return childSum + (c.approved ? Number(c.total_with_markup || 0) : 0);
          }, 0);
        }
        return sum + (i.approved ? Number(i.total_with_markup || 0) : 0);
      }, 0);
    }
    function approvedRfpCount(items) {
      var childrenByParent = {};
      (items || []).forEach(function(i) {
        if (i.parent_line_item_id) {
          (childrenByParent[i.parent_line_item_id] = childrenByParent[i.parent_line_item_id] || []).push(i);
        }
      });
      return (items || []).reduce(function(count, i) {
        if (i.parent_line_item_id) return count;
        var children = childrenByParent[i.id] || [];
        if (children.length > 0) {
          return count + children.filter(function(c) { return c.approved; }).length;
        }
        return count + (i.approved ? 1 : 0);
      }, 0);
    }
    var DEFAULT_RFP_MARKUP_PCT = 16;
    var DEFAULT_RFP_GENERAL_REQUIREMENTS_PCT = 4;
    function rfpParentRollupQty(item, approvedChildren) {
      var parentQty = Number(item && item.quantity);
      var childQtys = (approvedChildren || [])
        .map(function(c) { return Number(c.quantity) || 0; })
        .filter(function(q) { return q > 0; });
      if (parentQty > 0 && parentQty !== 1) return parentQty;
      if (!childQtys.length) return parentQty > 0 ? parentQty : 0;
      return childQtys.reduce(function(max, q) { return q > max ? q : max; }, 0);
    }
    function numberOrDefault(value, fallback) {
      var n = Number(value);
      return Number.isFinite(n) ? n : fallback;
    }
    function rfpComputedTotalCost(line) {
      var qty = numberOrDefault(line && line.quantity, 0);
      var splitUnit = numberOrDefault(line && line.contractor_cost, 0) + numberOrDefault(line && line.vendor_cost, 0);
      var unit = splitUnit > 0 ? splitUnit : numberOrDefault(line && line.unit_cost, 0);
      return unit * qty;
    }
    function rfpComputedTotalWithMarkup(line) {
      var totalCost = rfpComputedTotalCost(line);
      var markup = numberOrDefault(line && line.markup_pct, DEFAULT_RFP_MARKUP_PCT);
      var gr = numberOrDefault(line && line.general_requirements_pct, DEFAULT_RFP_GENERAL_REQUIREMENTS_PCT);
      return totalCost * (1 + ((markup + gr) / 100));
    }
    function rfpComputedFinalUnit(line) {
      var qty = numberOrDefault(line && line.quantity, 0);
      return qty > 0 ? rfpComputedTotalWithMarkup(line) / qty : 0;
    }
    function formatPercentValue(value) {
      var n = Number(value);
      if (!Number.isFinite(n)) return '';
      return Number.isInteger(n) ? String(n) : String(parseFloat(n.toFixed(4)));
    }
    function rfpPercentSummary(lines, field, fallback) {
      if (!lines || !lines.length) return '—';
      var values = [];
      lines.forEach(function(line) {
        var display = formatPercentValue(numberOrDefault(line && line[field], fallback));
        if (display !== '' && values.indexOf(display) === -1) values.push(display);
      });
      return values.length ? values.join(' / ') : '—';
    }
    var rfpTotals = {};
    var rfpApprovedCounts = {};
    rfps.forEach(function(r) { 
      var items = (rfpItemsMap && rfpItemsMap[r.id]) || [];
      rfpTotals[r.id] = approvedRfpTotal(items);
      rfpApprovedCounts[r.id] = approvedRfpCount(items);
    });
    %>

    <!-- D-104: RFP summary table (FORGE format — single card, table layout) -->
    <div class="card overflow-hidden mb-6">
      <div class="px-5 py-3 border-b border-recon-mist">
        <h3 class="font-semibold text-sm">Category / Bid Summary</h3>
      </div>
      <div class="px-5 py-3 border-b border-recon-mist bg-recon-deeper/20 flex flex-wrap items-end gap-3">
        <label class="block min-w-[14rem] flex-1">
          <span class="block text-[10px] font-semibold uppercase tracking-wider text-recon-fog mb-1">Search</span>
          <input id="rfp-filter-search" type="search" class="input text-sm" placeholder="Category or line item">
        </label>
        <label class="block w-40">
          <span class="block text-[10px] font-semibold uppercase tracking-wider text-recon-fog mb-1">Status</span>
          <select id="rfp-filter-status" class="input text-sm">
            <option value="">All statuses</option>
            <option value="pending">Pending</option>
            <option value="submitted">Submitted</option>
            <option value="awarded">Awarded</option>
            <option value="declined">Declined</option>
          </select>
        </label>
        <label class="inline-flex items-center gap-2 rounded border border-recon-mist bg-recon-deeper/30 px-3 py-2 text-sm">
          <input id="rfp-filter-approved-only" type="checkbox" class="h-4 w-4">
          <span>Show approved only</span>
        </label>
        <button type="button" id="rfp-filter-clear" class="btn btn-secondary text-sm">Clear</button>
      </div>
      <table class="data">
        <thead>
          <tr>
            <th>Category</th>
            <th>Status</th>
            <th class="text-right">Approved Total</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% rfps.forEach(function(rfp){ %>
            <tr id="rfp-row-<%= rfp.id %>" class="cursor-pointer hover:bg-recon-cloud/20" data-rfp-category-row data-rfp-id="<%= rfp.id %>" data-rfp-status="<%= rfp.status || 'pending' %>" data-rfp-approved-count="<%= rfpApprovedCounts[rfp.id] %>" data-rfp-category-name="<%= (rfp.contractor_name || '').toLowerCase() %>" data-rfp-search="<%= ((rfp.contractor_name || '') + ' ' + (rfp.notes || '') + ' ' + (((rfpItemsMap && rfpItemsMap[rfp.id]) || []).map(function(i){ return i.description || ''; }).join(' '))).toLowerCase() %>" onclick="var el=document.getElementById('rfp-items-<%= rfp.id %>');var icon=document.getElementById('rfp-chev-<%= rfp.id %>');el.classList.toggle('hidden');if(icon){icon.textContent=el.classList.contains('hidden')?'▶':'▼';}">
              <td>
                <div class="flex items-center gap-1">
                  <button type="button" id="rfp-chev-<%= rfp.id %>"
                          class="text-recon-fog hover:text-recon-red text-lg leading-none px-1.5 py-1 select-none"
                          style="min-width:1.75rem;"
                          onclick="event.stopPropagation();var el=document.getElementById('rfp-items-<%= rfp.id %>');el.classList.toggle('hidden');this.textContent=el.classList.contains('hidden')?'▶':'▼';"
                          aria-label="Toggle line items">▶</button>
                  <span class="font-semibold text-sm cursor-pointer hover:text-recon-red flex-1 rfp-rename-trigger"
                        onclick="var el=document.getElementById('rfp-items-<%= rfp.id %>');var icon=document.getElementById('rfp-chev-<%= rfp.id %>');el.classList.toggle('hidden');if(icon){icon.textContent=el.classList.contains('hidden')?'▶':'▼';}"
                        title="Click to expand/collapse line items">
                    <%= rfp.contractor_name %>
                  </span>
                  <button type="button" class="text-recon-fog hover:text-recon-red text-xs ml-1"
                          onclick="event.stopPropagation();var inp=this.parentElement.querySelector('.rename-input');var lbl=this.parentElement.querySelector('.rfp-rename-trigger');if(inp){inp.value=lbl.textContent.trim();inp.dataset.originalValue=inp.value;inp.style.display='inline';inp.focus();lbl.style.display='none';this.style.display='none';}"
                          title="Edit category name">✎</button>
                  <input name="contractor_name" class="input text-xs py-0.5 px-1 w-40 rename-input ml-1" style="display:none"
                         list="rfp-tab-presets" autocomplete="off"
                         data-rfp-autosave-category data-job-id="<%= job.id %>" data-rfp-id="<%= rfp.id %>" data-field="contractor_name" data-original-value="<%= rfp.contractor_name || '' %>">
                </div>
              </td>
              <td>
                <select name="status" onclick="event.stopPropagation()" class="text-xs border rounded px-1 py-0.5"
                        data-rfp-autosave-category data-job-id="<%= job.id %>" data-rfp-id="<%= rfp.id %>" data-field="status" data-original-value="<%= rfp.status || 'pending' %>">
                  <option value="pending" <%= rfp.status === 'pending' ? 'selected' : '' %>>Pending</option>
                  <option value="submitted" <%= rfp.status === 'submitted' ? 'selected' : '' %>>Submitted</option>
                  <option value="awarded" <%= rfp.status === 'awarded' ? 'selected' : '' %>>Awarded</option>
                  <option value="declined" <%= rfp.status === 'declined' ? 'selected' : '' %>>Declined</option>
                </select>
              </td>
              <td class="text-right font-semibold <%= rfp.status === 'awarded' ? 'text-green-700' : '' %>" data-rfp-summary-total="<%= rfp.id %>">$<%= rfpTotals[rfp.id].toFixed(2) %></td>
              <td class="text-right">
                <a href="/projects/<%= job.id %>/rfps/<%= rfp.id %>/export-ginosko.xlsx" target="_blank"
                   onclick="event.stopPropagation()" title="Download Ginosko Bid Sheet for this category"
                   class="text-recon-fog hover:text-recon-red text-xs mr-2">Ginosko</a>
                <button type="button"
                        onclick="event.stopPropagation();var el=document.getElementById('rfp-items-<%= rfp.id %>');var icon=document.getElementById('rfp-chev-<%= rfp.id %>');if(el){el.classList.remove('hidden');}if(icon){icon.textContent='▼';}"
                        class="text-recon-fog hover:text-recon-red text-xs mr-2">Select bid lines</button>
                <form action="/projects/<%= job.id %>/rfps/<%= rfp.id %>/delete" method="POST" onclick="event.stopPropagation()"
                      onsubmit="return confirm('Delete this category and all its line items?')" class="inline">
                  <button class="text-recon-fog hover:text-recon-red text-xs">&times;</button>
                </form>
              </td>
            </tr>
            <tr id="rfp-items-<%= rfp.id %>" class="hidden" data-rfp-items-row="<%= rfp.id %>">
              <td colspan="4" class="p-0">

    <!-- D-104: Line-item content for each RFP (inside summary table rows) -->
      <div>
        <div class="px-5 py-3 border-b border-recon-mist bg-recon-deeper/20" onclick="event.stopPropagation()">
          <div class="flex flex-wrap items-center justify-between gap-3 mb-2">
            <button type="button" class="flex items-start gap-2 text-left" onclick="toggleBidInstructions('<%= rfp.id %>')">
              <span id="bid-instructions-chevron-<%= rfp.id %>" class="text-recon-fog text-xs mt-0.5 select-none inline-block" style="transition:transform 0.15s;">▾</span>
              <div>
                <div class="text-xs font-semibold uppercase tracking-wide text-recon-fog">BuildingConnected bid instructions</div>
                <div class="text-xs text-recon-fog">Paste inclusions, exclusions, clarifications, acknowledgements, plan notes, and bid-form requirements for this trade.</div>
              </div>
            </button>
          </div>
          <div id="bid-instructions-body-<%= rfp.id %>">
            <textarea class="input w-full text-sm min-h-[6rem]"
                      name="notes"
                      placeholder="Example: Electrical contractor must include LV work, owner-furnished fixtures, emergency inverter, temp power, BuildingConnected acknowledgements..."
                      data-rfp-autosave-category data-job-id="<%= job.id %>" data-rfp-id="<%= rfp.id %>" data-field="notes" data-original-value="<%- (rfp.notes || '').replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/</g, '&lt;').replace(/>/g, '&gt;') %>"><%= rfp.notes || '' %></textarea>
          </div>
        </div>

        <div class="px-5 py-2 border-b border-recon-mist bg-recon-deeper/10 flex items-center justify-between">
          <span class="text-xs font-medium text-recon-fog">Line items — check Bid PDF boxes for the batch request</span>
          <div class="flex items-center gap-2">
            <button onclick="document.getElementById('rfp-item-form-<%= rfp.id %>').classList.toggle('hidden')"
                    class="btn btn-primary text-xs" style="padding:.3rem .7rem;">+ Add line item</button>
          </div>
        </div>

        <!-- D-134: Add item form — description only per Michael's direction. Pricing lives on sub-lines. -->
        <div id="rfp-item-form-<%= rfp.id %>" class="hidden p-3 bg-recon-deeper/30 border-b border-recon-mist">
          <form action="/projects/<%= job.id %>/rfps/<%= rfp.id %>/items" method="POST" class="flex gap-2 items-end text-xs">
            <div class="flex-1">
              <label class="block text-xs text-recon-fog mb-1">Item</label>
              <textarea name="description" placeholder="e.g. Demo, Install, Supply, Demo kitchen" class="input w-full" required maxlength="500" rows="1" data-autosize></textarea>
            </div>
            <input name="parent_id" type="hidden" value="">
            <button type="submit" class="btn btn-primary text-xs">Add Item</button>
          </form>
          <p class="text-xs text-recon-fog mt-2">Click into the item below to add sub-line items per contractor/vendor — costs, qty, markup, and totals roll up automatically from the sub-lines.</p>
        </div>

        <!-- Line items table -->
        <%
        var items = (rfpItemsMap && rfpItemsMap[rfp.id] ? rfpItemsMap[rfp.id].filter(function(i) { return !i.parent_line_item_id; }) : []);
        var subItems = {};
        if (rfpItemsMap && rfpItemsMap[rfp.id]) {
          rfpItemsMap[rfp.id].filter(function(i) { return i.parent_line_item_id; }).forEach(function(s) {
            (subItems[s.parent_line_item_id] = subItems[s.parent_line_item_id] || []).push(s);
          });
        }
        var allItems = (rfpItemsMap && rfpItemsMap[rfp.id]) || [];
        var grandTotal = approvedRfpTotal(allItems);
        var grandTotalAll = allItems.reduce(function(s, i) { return s + Number(i.total_with_markup || 0); }, 0);
        %>
        <div class="overflow-x-auto">
          <table class="data text-xs rfp-items-table" data-rfp-id="<%= rfp.id %>">
            <colgroup>
              <col style="width:3.5rem">
              <col style="width:28rem">
              <col style="width:5.5rem">
              <col style="width:9.5rem">
              <col style="width:10.5rem">
              <col style="width:6rem">
              <col style="width:5.5rem">
              <col style="width:11rem">
              <col style="width:8.5rem">
              <col style="width:3.5rem">
              <col style="width:5rem">
            </colgroup>
            <thead>
              <tr>
                <th class="w-10 text-center">Bid PDF</th>
                <th class="w-[28%]">Description</th>
                <th class="text-right">Qty</th>
                <th class="text-right">Unit Cost</th>
                <th class="text-right">Total Cost</th>
                <th class="text-right">Markup</th>
                <th class="text-right">GR %</th>
                <th class="text-right">Total w/ Markup</th>
                <th class="text-right">Final Unit</th>
                <th class="text-center">✓</th>
                <th class="text-right">Lines</th>
              </tr>
            </thead>
            <tbody>
              <% items.forEach(function(item){ %>
                <% var itemFormId = 'rfp-li-form-' + item.id; var itemDelFormId = 'rfp-li-del-' + item.id; var children = subItems[item.id] || []; %>
                <% var liHasSubs = children.length > 0; %>
                <% var apprChildren = children.filter(function(s){return s.approved;}); %>
                <% var liRollupChildren = liHasSubs ? apprChildren : []; %>
                <% var liQty = liHasSubs ? rfpParentRollupQty(item, liRollupChildren) : (Number(item.quantity) || 0); %>
                <% var liTotalCost = liRollupChildren.reduce(function(s,c){return s + rfpComputedTotalCost(c);},0); %>
                <% var liTotal = liRollupChildren.reduce(function(s,c){return s + rfpComputedTotalWithMarkup(c);},0); %>
                <!-- D-105: Line item container row — Item name + auto-rolled-up totals from approved sub-lines.
                     Falls back to direct values on the line item itself when no sub-lines exist (legacy data). -->
                <% var liSubCount = children.length; var liApprovedSubs = apprChildren.length; %>
                <% var liDisplayTotal = liHasSubs ? liTotal : (Number(item.total_with_markup) || 0); %>
                <% var liDisplayUnit = liHasSubs ? (liQty > 0 ? liTotal / liQty : 0) : (Number(item.final_unit_cost) || 0); %>
                <% var liDisplayBaseUnit = liHasSubs ? (liQty > 0 ? liTotalCost / liQty : 0) : (Number(item.unit_cost) || 0); %>
                <% var liMarkup = liHasSubs ? rfpPercentSummary(apprChildren, 'markup_pct', DEFAULT_RFP_MARKUP_PCT) : (item.markup_pct == null ? '—' : formatPercentValue(numberOrDefault(item.markup_pct, 0))); %>
                <% var liGr = liHasSubs ? rfpPercentSummary(apprChildren, 'general_requirements_pct', DEFAULT_RFP_GENERAL_REQUIREMENTS_PCT) : (item.general_requirements_pct == null ? '—' : formatPercentValue(numberOrDefault(item.general_requirements_pct, 0))); %>
                <% var liApproved = liHasSubs ? (apprChildren.length === children.length ? true : false) : !!item.approved; %>
                <tr id="rfp-line-<%= item.id %>" class="rfp-li-row bg-recon-deeper/20 hover:bg-recon-cloud/20 border-t-2 border-recon-mist/40" style="cursor:pointer" data-rfp-line-total="<%= liDisplayTotal.toFixed(2) %>" data-rfp-line-approved="<%= liHasSubs ? (liApprovedSubs > 0 ? '1' : '0') : (item.approved ? '1' : '0') %>" data-rfp-line-search="<%= (item.description || '').toLowerCase() %>" onclick="toggleRfpLineEditor('<%= item.id %>');">
                  <td class="text-center" onclick="event.stopPropagation();">
                    <input form="rfp-bid-request-form" type="checkbox" name="item_ids" value="<%= item.id %>" class="h-4 w-4" data-rfp-bid-item>
                  </td>
                  <td>
                    <div class="flex items-start gap-1">
                      <span class="rfp-li-chevron text-recon-fog text-xs mt-1 select-none inline-block" style="transition:transform 0.15s; transform:rotate(0deg);">▸</span>
                      <form id="<%= itemFormId %>" action="/projects/rfps/items/<%= item.id %>" method="POST" onclick="event.stopPropagation();"></form>
                      <textarea form="<%= itemFormId %>" name="description" class="input text-xs py-0.5 font-medium w-full" placeholder="Item description" rows="1" data-autosize
                                data-rfp-autosave-item data-item-id="<%= item.id %>" data-field="description" data-original-value="<%= item.description || '' %>"><%= item.description %></textarea>
                    </div>
                  </td>
                  <td class="text-right"><span class="font-medium text-xs" data-rfp-parent-qty="<%= item.id %>"><%= liQty %></span></td>
                  <td class="text-right font-medium" data-rfp-parent-unit-cost="<%= item.id %>">$<%= (liHasSubs ? liDisplayBaseUnit : Number(item.unit_cost) || 0).toFixed(2) %></td>
                  <td class="text-right font-medium" data-rfp-parent-total-cost="<%= item.id %>">$<%= (liHasSubs ? liTotalCost : Number(item.total_cost) || 0).toFixed(2) %></td>
                  <td class="text-right text-xs" data-rfp-parent-markup="<%= item.id %>"><%= liMarkup %></td>
                  <td class="text-right text-xs" data-rfp-parent-gr="<%= item.id %>"><%= liGr %></td>
                  <td class="text-right font-medium" data-rfp-parent-total="<%= item.id %>">$<%= liDisplayTotal.toFixed(2) %></td>
                  <td class="text-right text-xs" data-rfp-parent-final-unit="<%= item.id %>">$<%= liDisplayUnit.toFixed(2) %></td>
                  <td class="text-center" onclick="event.stopPropagation();"><% if (liHasSubs) { %><span class="text-xs <%= liApproved ? 'text-green-600' : 'text-recon-fog' %>" data-rfp-parent-approved-icon="<%= item.id %>"><%= liApproved ? '✓' : '○' %></span><% } else { %><input form="<%= itemFormId %>" type="hidden" name="approved" value="0"><input form="<%= itemFormId %>" type="checkbox" name="approved" value="1" <%= item.approved ? 'checked' : '' %> data-rfp-autosave-item data-item-id="<%= item.id %>" data-field="approved" data-original-value="<%= item.approved ? '1' : '0' %>"><% } %></td>
                  <td class="text-right align-middle whitespace-nowrap">
                    <span class="inline-flex items-center justify-end gap-1 rounded bg-recon-deeper/40 px-2 py-1 text-xs text-recon-fog" title="Approved vendor / contractor lines" data-rfp-parent-line-count="<%= item.id %>">
                      <%= liApprovedSubs %>/<%= liSubCount %>
                    </span>
                    <form id="<%= itemDelFormId %>" action="/projects/rfps/items/<%= item.id %>/delete" method="POST" onclick="event.stopPropagation();" onsubmit="return confirm('Delete?')"></form>
                    <button type="submit" form="<%= itemDelFormId %>" class="ml-1 text-recon-fog hover:text-recon-red text-xs">&times;</button>
                  </td>
                </tr>
                <tr id="rfp-line-editor-<%= item.id %>" class="rfp-line-editor-modal hidden fixed inset-0 z-[80] bg-black/50">
                  <td colspan="11" class="block h-screen overflow-y-auto p-4 sm:p-6" onclick="closeRfpLineEditor('<%= item.id %>');">
                    <div class="mx-auto my-8 w-full max-w-6xl rounded-lg border border-recon-mist bg-white shadow-2xl" role="dialog" aria-modal="true" aria-labelledby="rfp-line-editor-title-<%= item.id %>" onclick="event.stopPropagation();">
                      <div class="flex flex-wrap items-center justify-between gap-3 border-b border-recon-mist px-4 py-3">
                        <div>
                          <div class="text-[10px] font-semibold uppercase tracking-wider text-recon-fog">Line item editor</div>
                          <div id="rfp-line-editor-title-<%= item.id %>" class="font-semibold text-sm">Vendor / contractor pricing</div>
                        </div>
                        <div class="flex items-center gap-2">
                          <span class="text-xs text-recon-fog"><%= liApprovedSubs %> of <%= liSubCount %> approved</span>
                          <button type="button" class="btn btn-secondary text-xs" onclick="saveRfpLineEditor('<%= item.id %>')">Save line item</button>
                          <button type="button" class="btn btn-secondary text-xs" onclick="event.stopPropagation();closeRfpLineEditor('<%= item.id %>')">Close</button>
                        </div>
                      </div>

                      <div class="grid gap-3 px-4 py-3 md:grid-cols-[minmax(0,1fr)_9rem]">
                        <label class="block">
                          <span class="text-[10px] font-semibold uppercase tracking-wider text-recon-fog">Main line item description</span>
                          <textarea form="<%= itemFormId %>" name="description" class="input mt-1 w-full text-sm" rows="2" data-autosize
                                    data-rfp-autosave-item data-item-id="<%= item.id %>" data-field="description" data-original-value="<%= item.description || '' %>"><%= item.description %></textarea>
                        </label>
                        <label class="block">
                          <span class="text-[10px] font-semibold uppercase tracking-wider text-recon-fog">Main qty</span>
                          <input form="<%= itemFormId %>" name="quantity" type="number" step="any" value="<%= item.quantity != null ? item.quantity : '' %>" class="input mt-1 w-full text-right"
                                 data-rfp-autosave-item data-item-id="<%= item.id %>" data-field="quantity" data-original-value="<%= item.quantity != null ? item.quantity : '' %>">
                        </label>
                      </div>

                      <div class="px-4 pb-4">
                        <div class="mb-2 flex items-center justify-between gap-3">
                          <div class="text-[10px] font-semibold uppercase tracking-wider text-recon-fog">Vendor / contractor lines</div>
                          <div class="text-xs text-recon-fog">Approved lines roll up to the main line item. Supplier/material lines also sync to the Materials page.</div>
                        </div>

                        <% if (children.length === 0) { %>
                          <div class="mb-3 rounded border border-dashed border-recon-mist bg-recon-cloud/10 p-3 text-sm text-recon-fog">No vendor or contractor pricing lines yet. Add one below.</div>
                        <% } %>

                        <div class="mb-3 grid gap-3 rounded border border-recon-mist bg-recon-deeper/30 p-3 sm:grid-cols-3" data-rfp-editor-summary="<%= item.id %>">
                          <div>
                            <div class="text-[10px] font-semibold uppercase tracking-wider text-recon-fog">Combined total cost</div>
                            <div class="text-lg font-semibold" data-rfp-editor-summary-total-cost>$0.00</div>
                          </div>
                          <div>
                            <div class="text-[10px] font-semibold uppercase tracking-wider text-recon-fog">Combined total w/ MU + GR</div>
                            <div class="text-lg font-semibold text-recon-red" data-rfp-editor-summary-total-with-markup>$0.00</div>
                          </div>
                          <div>
                            <div class="text-[10px] font-semibold uppercase tracking-wider text-recon-fog">Combined final unit</div>
                            <div class="text-lg font-semibold" data-rfp-editor-summary-final-unit>$0.00</div>
                          </div>
                        </div>

                        <div class="space-y-3">
                          <% children.forEach(function(sub){ %>
                            <% var subFid = 'rfp-sub-form-' + sub.id; var subDid = 'rfp-sub-del-' + sub.id; %>
                            <% var subDisplayTotalCost = rfpComputedTotalCost(sub); %>
                            <% var subDisplayTotalWithMarkup = rfpComputedTotalWithMarkup(sub); %>
                            <% var subDisplayFinalUnit = rfpComputedFinalUnit(sub); %>
                            <form id="<%= subFid %>" action="/projects/rfps/items/<%= sub.id %>" method="POST"></form>
                            <div class="rounded border border-recon-mist bg-recon-cloud/5 p-3" data-rfp-pricing-line data-parent-item-id="<%= item.id %>">
                              <div class="grid min-w-0 gap-3 lg:grid-cols-12 lg:items-end">
                                <label class="block min-w-0 lg:col-span-2">
                                  <span class="text-[10px] font-semibold uppercase tracking-wider text-recon-fog">Type</span>
                                  <select form="<%= subFid %>" name="scope_type" class="input mt-1 w-full text-xs"
                                          data-rfp-autosave-item data-item-id="<%= sub.id %>" data-field="scope_type"
                                          data-original-value="<%= sub.scope_type || 'contractor' %>">
                                    <option value="contractor" <%= (sub.scope_type || 'contractor') === 'contractor' ? 'selected' : '' %>>Contractor / Labor</option>
                                    <option value="supplier" <%= sub.scope_type === 'supplier' ? 'selected' : '' %>>Supplier / Material</option>
                                  </select>
                                </label>
                                <label class="block min-w-0 lg:col-span-2">
                                  <span class="text-[10px] font-semibold uppercase tracking-wider text-recon-fog">Company</span>
                                  <input form="<%= subFid %>" name="vendor" value="<%= sub.vendor || '' %>"
                                         class="input mt-1 w-full text-xs" placeholder="Vendor or contractor"
                                         list="rfp-line-entity-options" autocomplete="off"
                                         data-rfp-autosave-item data-item-id="<%= sub.id %>" data-field="vendor" data-original-value="<%= sub.vendor || '' %>">
                                </label>
                                <label class="block min-w-0 lg:col-span-4">
                                  <span class="text-[10px] font-semibold uppercase tracking-wider text-recon-fog">Scope / description</span>
                                  <textarea form="<%= subFid %>" name="description" class="input mt-1 w-full resize-y text-xs leading-snug" placeholder="Pricing line description" rows="2" data-autosize
                                            data-rfp-autosave-item data-item-id="<%= sub.id %>" data-field="description" data-original-value="<%= sub.description || '' %>"><%= sub.description %></textarea>
                                </label>
                                <label class="block min-w-0 sm:col-span-1 lg:col-span-1">
                                  <span class="text-[10px] font-semibold uppercase tracking-wider text-recon-fog">Qty</span>
                                  <input form="<%= subFid %>" name="quantity" type="number" step="any" value="<%= sub.quantity != null ? sub.quantity : '' %>" class="input mt-1 w-full text-right text-xs" data-rfp-live-calc data-rfp-autosave-item data-item-id="<%= sub.id %>" data-field="quantity" data-original-value="<%= sub.quantity != null ? sub.quantity : '' %>">
                                </label>
                                <label class="block min-w-0 sm:col-span-1 lg:col-span-1">
                                  <span class="text-[10px] font-semibold uppercase tracking-wider text-recon-fog">Unit cost</span>
                                  <input form="<%= subFid %>" name="contractor_cost" type="number" step="any" value="<%= sub.contractor_cost != null ? sub.contractor_cost : '' %>" class="input mt-1 w-full text-right text-xs" placeholder="$ Unit" data-rfp-live-calc data-rfp-autosave-item data-item-id="<%= sub.id %>" data-field="contractor_cost" data-original-value="<%= sub.contractor_cost != null ? sub.contractor_cost : '' %>">
                                </label>
                                <label class="block min-w-0 sm:col-span-1 lg:col-span-1">
                                  <span class="text-[10px] font-semibold uppercase tracking-wider text-recon-fog">MU%</span>
                                  <input form="<%= subFid %>" name="markup_pct" type="number" step="any" value="<%= sub.markup_pct != null ? sub.markup_pct : DEFAULT_RFP_MARKUP_PCT %>" class="input mt-1 w-full text-right text-xs" data-rfp-live-calc data-rfp-autosave-item data-item-id="<%= sub.id %>" data-field="markup_pct" data-original-value="<%= sub.markup_pct != null ? sub.markup_pct : DEFAULT_RFP_MARKUP_PCT %>">
                                </label>
                                <label class="block min-w-0 sm:col-span-1 lg:col-span-1">
                                  <span class="text-[10px] font-semibold uppercase tracking-wider text-recon-fog">GR%</span>
                                  <input form="<%= subFid %>" name="general_requirements_pct" type="number" step="any" value="<%= sub.general_requirements_pct != null ? sub.general_requirements_pct : DEFAULT_RFP_GENERAL_REQUIREMENTS_PCT %>" class="input mt-1 w-full text-right text-xs" data-rfp-live-calc data-rfp-autosave-item data-item-id="<%= sub.id %>" data-field="general_requirements_pct" data-original-value="<%= sub.general_requirements_pct != null ? sub.general_requirements_pct : DEFAULT_RFP_GENERAL_REQUIREMENTS_PCT %>">
                                </label>
                                <div class="min-w-0 lg:col-span-12">
                                  <div class="mt-1 flex flex-wrap items-center justify-end gap-x-5 gap-y-3 border-t border-recon-mist pt-3">
                                    <div class="min-w-[7rem] text-right">
                                      <span class="text-[10px] font-semibold uppercase tracking-wider text-recon-fog">Total cost</span>
                                      <div class="font-semibold" data-rfp-live-total-cost>$<%= subDisplayTotalCost.toFixed(2) %></div>
                                    </div>
                                    <div class="min-w-[7rem] text-right">
                                      <span class="text-[10px] font-semibold uppercase tracking-wider text-recon-fog">Total w/ MU + GR</span>
                                      <div class="font-semibold" data-rfp-live-total-with-markup>$<%= subDisplayTotalWithMarkup.toFixed(2) %></div>
                                    </div>
                                    <div class="min-w-[8rem] text-right">
                                      <span class="text-[10px] font-semibold uppercase tracking-wider text-recon-fog">Final unit w/ MU + GR</span>
                                      <div class="font-semibold" data-rfp-live-final-unit>$<%= subDisplayFinalUnit.toFixed(2) %></div>
                                    </div>
                                    <label class="flex items-center gap-2">
                                      <input form="<%= subFid %>" type="hidden" name="approved" value="0">
                                      <input form="<%= subFid %>" type="checkbox" name="approved" value="1" <%= sub.approved ? 'checked' : '' %> data-rfp-live-calc data-rfp-autosave-item data-item-id="<%= sub.id %>" data-field="approved" data-original-value="<%= sub.approved ? '1' : '0' %>">
                                      <span class="text-xs">Approved</span>
                                    </label>
                                    <div class="flex items-center justify-end gap-2">
                                      <button type="submit" form="<%= subFid %>" class="btn btn-secondary text-xs">Save</button>
                                      <form id="<%= subDid %>" action="/projects/rfps/items/<%= sub.id %>/delete" method="POST" onsubmit="return confirm('Delete this vendor/contractor line?')"></form>
                                      <button type="submit" form="<%= subDid %>" class="text-recon-fog hover:text-recon-red text-sm">&times;</button>
                                    </div>
                                  </div>
                                </div>
                              </div>
                            </div>
                          <% }); %>
                        </div>

                        <div id="add-sub-<%= item.id %>" class="mt-4 rounded border border-recon-mist bg-white p-3">
                          <div class="mb-2 text-[10px] font-semibold uppercase tracking-wider text-recon-fog">Add vendor / contractor line</div>
                          <form id="rfp-add-sub-form-<%= item.id %>" action="/projects/<%= job.id %>/rfps/<%= rfp.id %>/items" method="POST" class="rfp-line-form grid min-w-0 gap-3 text-xs lg:grid-cols-12 lg:items-end" data-rfp-pricing-line data-parent-item-id="<%= item.id %>" data-rfp-new-line onclick="event.stopPropagation();">
                            <label class="block min-w-0 lg:col-span-2">
                              <span class="text-[10px] font-semibold uppercase tracking-wider text-recon-fog">Type</span>
                              <select name="scope_type" class="input mt-1 w-full">
                                <option value="contractor">Contractor / Labor</option>
                                <option value="supplier">Supplier / Material</option>
                              </select>
                            </label>
                            <label class="block min-w-0 lg:col-span-2">
                              <span class="text-[10px] font-semibold uppercase tracking-wider text-recon-fog">Company</span>
                              <input name="vendor" class="input mt-1 w-full" placeholder="Vendor or contractor" autocomplete="off" list="rfp-line-entity-options">
                            </label>
                            <label class="block min-w-0 lg:col-span-4">
                              <span class="text-[10px] font-semibold uppercase tracking-wider text-recon-fog">Scope / description</span>
                              <textarea name="description" placeholder="Pricing line description" class="input mt-1 w-full resize-y leading-snug" rows="2" data-autosize required></textarea>
                            </label>
                            <label class="block min-w-0 lg:col-span-1">
                              <span class="text-[10px] font-semibold uppercase tracking-wider text-recon-fog">Qty</span>
                              <input name="quantity" data-compute-input data-rfp-live-calc type="number" step="any" placeholder="Qty" class="input mt-1 w-full text-right">
                            </label>
                            <label class="block min-w-0 lg:col-span-1">
                              <span class="text-[10px] font-semibold uppercase tracking-wider text-recon-fog">Unit cost</span>
                              <input name="contractor_cost" data-compute-input data-rfp-live-calc type="number" step="any" placeholder="$ Unit" class="input mt-1 w-full text-right">
                            </label>
                            <label class="block min-w-0 lg:col-span-1">
                              <span class="text-[10px] font-semibold uppercase tracking-wider text-recon-fog">MU%</span>
                              <input name="markup_pct" data-compute-input data-rfp-live-calc type="number" step="any" placeholder="MU%" value="<%= DEFAULT_RFP_MARKUP_PCT %>" class="input mt-1 w-full text-right">
                            </label>
                            <label class="block min-w-0 lg:col-span-1">
                              <span class="text-[10px] font-semibold uppercase tracking-wider text-recon-fog">GR%</span>
                              <input name="general_requirements_pct" data-compute-input data-rfp-live-calc type="number" step="any" placeholder="GR%" value="<%= DEFAULT_RFP_GENERAL_REQUIREMENTS_PCT %>" class="input mt-1 w-full text-right">
                            </label>
                            <div class="lg:col-span-12">
                              <div class="mt-1 flex flex-wrap items-center justify-end gap-x-5 gap-y-3 border-t border-recon-mist pt-3">
                                <label class="block min-w-[7rem] text-right">
                                  <span class="text-[10px] font-semibold uppercase tracking-wider text-recon-fog">Total cost</span>
                                  <input data-compute-output="total_cost" data-rfp-live-total-cost readonly value="0.00" class="input mt-1 w-full text-right text-xs" tabindex="-1">
                                </label>
                                <label class="block min-w-[7rem] text-right">
                                  <span class="text-[10px] font-semibold uppercase tracking-wider text-recon-fog">Total w/ MU + GR</span>
                                  <input data-compute-output="total_with_markup" data-rfp-live-total-with-markup readonly value="0.00" class="input mt-1 w-full text-right text-xs" tabindex="-1">
                                </label>
                                <label class="block min-w-[8rem] text-right">
                                  <span class="text-[10px] font-semibold uppercase tracking-wider text-recon-fog">Final unit w/ MU + GR</span>
                                  <input data-compute-output="final_unit_cost" data-rfp-live-final-unit readonly value="0.00" class="input mt-1 w-full text-right text-xs" tabindex="-1">
                                </label>
                              </div>
                            </div>
                            <div class="lg:col-span-12 flex justify-end">
                              <button type="submit" class="btn btn-primary text-xs">Add line</button>
                            </div>
                            <input name="parent_id" type="hidden" value="<%= item.id %>">
                            <input name="approved" type="hidden" value="1">
                          </form>
                        </div>
                      </div>
                    </div>
                  </td>
                </tr>
              <% }); %>
              <% if (items.length === 0) { %>
                <tr><td colspan="11" class="text-center text-recon-fog py-4">No line items yet. Click + Add item to add one.</td></tr>
              <% } %>
            </tbody>
            <tfoot>
              <tr class="font-semibold bg-recon-deeper/50">
                <td colspan="9" class="text-right">Grand Total (approved)</td>
                <td colspan="2" class="text-right text-recon-red" data-rfp-grand-total="<%= rfp.id %>">$<%= grandTotal.toFixed(2) %></td>
              </tr>
            </tfoot>
          </table>
        </div>
      </div>
    </td></tr>
    <% }); %>
  </tbody></table>
  </div>
  <% } %>
</div>

<!-- D-105: SortableJS drag-drop + auto-total calculator + rename-on-dblclick -->
<style>
  .rfp-action-bar {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
    padding: .85rem 1rem;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    background: #fff;
    box-shadow: 0 1px 2px rgba(15, 23, 42, .04);
  }
  .rfp-action-group,
  .rfp-bid-request-tools,
  .rfp-action-buttons {
    display: flex;
    align-items: center;
    gap: .5rem;
    flex-wrap: wrap;
  }
  .rfp-action-label {
    display: block;
    color: #8a8f98;
    font-size: .66rem;
    font-weight: 700;
    letter-spacing: .06em;
    line-height: 1;
    text-transform: uppercase;
    white-space: nowrap;
  }
  .rfp-bid-recipient {
    display: grid;
    gap: .35rem;
    min-width: min(24rem, 100%);
  }
  .rfp-bid-recipient .input {
    width: 100%;
    min-height: 2.35rem;
  }
  .rfp-selected-count {
    color: #8a8f98;
    font-size: .78rem;
    font-weight: 600;
    white-space: nowrap;
  }
  #rfp-bid-request-submit:disabled {
    opacity: .55;
    cursor: not-allowed;
  }
  .rfp-items-table {
    width: 100% !important;
    min-width: 96rem;
    table-layout: auto;
  }
  .rfp-items-table thead,
  .rfp-items-table tbody,
  .rfp-items-table tfoot {
    display: block;
  }
  .rfp-items-table thead tr,
  .rfp-items-table tbody tr.rfp-li-row,
  .rfp-items-table tfoot tr {
    display: grid;
    grid-template-columns: 3.5rem minmax(24rem, 2fr) 5.5rem 9.5rem 10.5rem 6rem 5.5rem 11rem 8.5rem 3.5rem 5rem;
    align-items: center;
  }
  .rfp-items-table thead tr > th,
  .rfp-items-table tbody tr.rfp-li-row > td,
  .rfp-items-table tfoot tr > td {
    display: block;
  }
  .rfp-items-table tbody tr.rfp-line-editor-modal {
    display: block;
  }
  .rfp-items-table tbody tr.rfp-line-editor-modal.hidden {
    display: none !important;
  }
  .rfp-items-table th,
  .rfp-items-table td {
    padding-left: .75rem;
    padding-right: .75rem;
  }
  .rfp-items-table th,
  .rfp-items-table td {
    vertical-align: middle;
    min-width: 0;
  }
  .rfp-items-table th {
    white-space: normal;
    line-height: 1.15;
  }
  .rfp-items-table td:nth-child(n+3):not(:nth-child(10)),
  .rfp-items-table th:nth-child(n+3):not(:nth-child(10)) {
    text-align: right;
    white-space: nowrap;
  }
  .rfp-items-table td:nth-child(10),
  .rfp-items-table th:nth-child(10) {
    text-align: center;
  }
  .rfp-items-table td:nth-child(2) textarea {
    width: 100%;
    min-width: 0;
  }
  .rfp-items-table tfoot td:first-child {
    grid-column: 1 / 10;
  }
  .rfp-items-table tfoot td:last-child {
    grid-column: 10 / 12;
  }
  /* D-120: field-sizing ensures textareas start at rows="1" even inside hidden containers */
  .rfp-items-table textarea.input { field-sizing: content; min-height: 1.5rem; }
  .rfp-line-editor-modal label { min-width: 0; }
  .rfp-line-editor-modal .input { max-width: 100%; }
  @media (max-width: 860px) {
    .rfp-action-bar {
      align-items: stretch;
      flex-direction: column;
    }
    .rfp-action-group,
    .rfp-bid-request-tools {
      align-items: stretch;
    }
    .rfp-bid-request-tools .btn,
    .rfp-bid-recipient {
      width: 100%;
    }
  }
</style>
<script>
(function(){
  function updateBidRequestSelectionCount() {
    var selected = document.querySelectorAll('[data-rfp-bid-item]:checked').length;
    var count = document.getElementById('rfp-bid-request-count');
    var submit = document.getElementById('rfp-bid-request-submit');
    if (count) count.textContent = selected + ' selected';
    if (submit) submit.disabled = selected === 0;
  }
  document.querySelectorAll('[data-rfp-bid-item]').forEach(function(el) {
    el.addEventListener('change', updateBidRequestSelectionCount);
  });
  var bidForm = document.getElementById('rfp-bid-request-form');
  if (bidForm) {
    bidForm.addEventListener('submit', function(e) {
      if (!document.querySelector('[data-rfp-bid-item]:checked')) {
        e.preventDefault();
        alert('Select at least one line item for the bid request PDF.');
      }
    });
  }
  updateBidRequestSelectionCount();

  // Rename RFP tab on double-click
  document.addEventListener('dblclick', function(e) {
    var target = e.target.closest('.rfp-rename-trigger');
    if (!target) return;
    e.stopPropagation();
    var span = target;
    var form = span.nextElementSibling;
    var inp = span.parentElement && span.parentElement.querySelector('.rename-input');
    if (!inp) return;
    inp.value = span.textContent.trim();
    inp.dataset.originalValue = inp.value;
    span.style.display = 'none';
    inp.style.display = 'inline';
    var pencil = span.parentElement && span.parentElement.querySelector('button[title="Edit category name"]');
    if (pencil) pencil.style.display = 'none';
    inp.focus();
  });
(function(){
  // Drag-drop reorder
  if (typeof Sortable !== 'undefined') {
    var tbodies = document.querySelectorAll('.rfp-items-table tbody');
    tbodies.forEach(function(tbody){
      new Sortable(tbody, {
        animation: 150,
        draggable: '.rfp-li-row',
        handle: '.rfp-li-row',
        filter: '.rfp-line-editor-modal, input, textarea, select, button, a, form',
        preventOnFilter: false,
        onEnd: function(evt) {
          var ids = [];
          tbody.querySelectorAll('.rfp-li-row').forEach(function(tr){
            var form = tr.querySelector('form[id^=rfp-li-form-]');
            if (form) ids.push(form.action.split('/').pop());
          });
          if (ids.length) {
            var rfpId = tbody.closest('.rfp-items-table')?.getAttribute('data-rfp-id') || '';
            var xhr = new XMLHttpRequest();
            xhr.open('POST', '/projects/rfps/items/reorder', true);
            xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');
            var body = ids.map(function(id) {
              return 'item_ids=' + encodeURIComponent(id);
            }).join('&') + '&rfp_id=' + encodeURIComponent(rfpId);
            xhr.send(body);
          }
        }
      });
    });
  }
  var forms = document.querySelectorAll('.rfp-line-form');
  forms.forEach(function(form){
    var inputs = form.querySelectorAll('[data-compute-input]');
    var outputs = {};
    form.querySelectorAll('[data-compute-output]').forEach(function(el){
      outputs[el.getAttribute('data-compute-output')] = el;
    });
    function recalc(){
      var qty = parseFloat(form.querySelector('[name="quantity"]')?.value) || 0;
      var cCost = parseFloat(form.querySelector('[name="contractor_cost"]')?.value) || 0;
      var vCost = parseFloat(form.querySelector('[name="vendor_cost"]')?.value) || 0;
      var markupRaw = parseFloat(form.querySelector('[name="markup_pct"]')?.value);
      var markup = isFinite(markupRaw) ? markupRaw : <%= DEFAULT_RFP_MARKUP_PCT %>;
      var grRaw = parseFloat(form.querySelector('[name="general_requirements_pct"]')?.value);
      var gr = isFinite(grRaw) ? grRaw : <%= DEFAULT_RFP_GENERAL_REQUIREMENTS_PCT %>;
      var unit = cCost + vCost;
      var total = unit * qty;
      // D-140: markup + GR are ADDITIVE percentages applied once, not compounding
      var withMarkup = total * (1 + (markup + gr) / 100);
      var finalUnit = qty > 0 ? withMarkup / qty : 0;
      if (outputs.unit_cost) outputs.unit_cost.value = unit.toFixed(2);
      if (outputs.total_cost) outputs.total_cost.value = total.toFixed(2);
      if (outputs.total_with_markup) outputs.total_with_markup.value = withMarkup.toFixed(2);
      if (outputs.final_unit_cost) outputs.final_unit_cost.value = finalUnit.toFixed(2);
    }
    inputs.forEach(function(el){ el.addEventListener('input', recalc); });
    recalc();
  });

  function applyRfpFilters() {
    var searchEl = document.getElementById('rfp-filter-search');
    var statusEl = document.getElementById('rfp-filter-status');
    var approvedEl = document.getElementById('rfp-filter-approved-only');
    var q = (searchEl && searchEl.value || '').trim().toLowerCase();
    var status = (statusEl && statusEl.value || '').trim();
    var approvedOnly = !!(approvedEl && approvedEl.checked);

    document.querySelectorAll('[data-rfp-category-row]').forEach(function(row) {
      var rfpId = row.getAttribute('data-rfp-id');
      var itemsRow = document.querySelector('[data-rfp-items-row="' + rfpId + '"]');
      var rowStatus = row.getAttribute('data-rfp-status') || '';
      var searchHaystack = row.getAttribute('data-rfp-search') || '';
      var categoryName = row.getAttribute('data-rfp-category-name') || '';
      var approvedCount = parseInt(row.getAttribute('data-rfp-approved-count') || '0', 10) || 0;
      var categoryMatch = !q || searchHaystack.indexOf(q) !== -1;
      var statusMatch = !status || rowStatus === status;
      var approvedMatch = !approvedOnly || (rowStatus === 'awarded' && approvedCount > 0);
      var showCategory = categoryMatch && statusMatch && approvedMatch;
      row.classList.toggle('hidden', !showCategory);
      if (itemsRow) itemsRow.classList.toggle('hidden', itemsRow.classList.contains('hidden') || !showCategory);

      if (!itemsRow) return;
      itemsRow.querySelectorAll('.rfp-li-row').forEach(function(lineRow) {
        var lineSearch = lineRow.getAttribute('data-rfp-line-search') || '';
        var lineApproved = lineRow.getAttribute('data-rfp-line-approved') === '1';
        var searchMatch = !q || categoryName.indexOf(q) !== -1 || lineSearch.indexOf(q) !== -1;
        var lineMatch = (!approvedOnly || lineApproved) && searchMatch;
        lineRow.classList.toggle('hidden', !lineMatch);
      });
    });
  }

  window.applyRfpFilters = applyRfpFilters;
  var filterSearch = document.getElementById('rfp-filter-search');
  var filterStatus = document.getElementById('rfp-filter-status');
  var filterApprovedOnly = document.getElementById('rfp-filter-approved-only');
  var filterClear = document.getElementById('rfp-filter-clear');
  if (filterSearch) filterSearch.addEventListener('input', applyRfpFilters);
  if (filterStatus) filterStatus.addEventListener('change', applyRfpFilters);
  if (filterApprovedOnly) filterApprovedOnly.addEventListener('change', applyRfpFilters);
  if (filterClear) {
    filterClear.addEventListener('click', function() {
      if (filterSearch) filterSearch.value = '';
      if (filterStatus) filterStatus.value = '';
      if (filterApprovedOnly) filterApprovedOnly.checked = false;
      applyRfpFilters();
    });
  }

  function expandRfp(rfpId) {
    if (!rfpId) return null;
    var section = document.getElementById('rfp-items-' + rfpId);
    var icon = document.getElementById('rfp-chev-' + rfpId);
    if (section) section.classList.remove('hidden');
    if (icon) icon.textContent = '▼';
    return document.getElementById('rfp-row-' + rfpId) || section;
  }

  // D-141: BuildingConnected bid instructions — collapsible per category,
  // remembered across page reloads (this page reloads a lot from other
  // actions, so an in-memory-only toggle would re-expand constantly).
  function bidInstructionsKey(rfpId) { return 'rfp-bid-instructions-collapsed-' + rfpId; }

  function setBidInstructionsCollapsed(rfpId, collapsed) {
    var body = document.getElementById('bid-instructions-body-' + rfpId);
    var chevron = document.getElementById('bid-instructions-chevron-' + rfpId);
    if (body) body.classList.toggle('hidden', collapsed);
    if (chevron) chevron.style.transform = collapsed ? 'rotate(-90deg)' : 'rotate(0deg)';
  }

  function toggleBidInstructions(rfpId) {
    var body = document.getElementById('bid-instructions-body-' + rfpId);
    if (!body) return;
    var collapsed = !body.classList.contains('hidden');
    setBidInstructionsCollapsed(rfpId, collapsed);
    try { localStorage.setItem(bidInstructionsKey(rfpId), collapsed ? '1' : '0'); } catch (e) {}
  }
  window.toggleBidInstructions = toggleBidInstructions;

  document.querySelectorAll('[id^="bid-instructions-body-"]').forEach(function(body) {
    var rfpId = body.id.replace('bid-instructions-body-', '');
    var collapsed = false;
    try { collapsed = localStorage.getItem(bidInstructionsKey(rfpId)) === '1'; } catch (e) {}
    if (collapsed) setBidInstructionsCollapsed(rfpId, true);
  });

  function closeRfpLineEditor(itemId) {
    if (!itemId) return null;
    if (typeof window.updateRfpEditorSummary === 'function') window.updateRfpEditorSummary(itemId);
    var row = document.getElementById('rfp-line-' + itemId);
    var editor = document.getElementById('rfp-line-editor-' + itemId);
    if (editor) {
      editor.classList.add('hidden');
      editor.style.display = 'none';
    }
    document.body.classList.remove('overflow-hidden');
    if (row) row.classList.remove('bg-recon-cloud/20');
    var chevron = row && row.querySelector('.rfp-li-chevron');
    if (chevron) chevron.style.transform = 'rotate(0deg)';
    return row;
  }

  function openRfpLineEditor(itemId) {
    if (!itemId) return null;
    var row = document.getElementById('rfp-line-' + itemId);
    var editor = document.getElementById('rfp-line-editor-' + itemId);
    if (!row || !editor) return row;
    document.querySelectorAll('.rfp-line-editor-modal').forEach(function(other) {
      if (other !== editor) {
        other.classList.add('hidden');
        other.style.display = 'none';
        var otherId = other.id.replace('rfp-line-editor-', '');
        var otherRow = document.getElementById('rfp-line-' + otherId);
        if (otherRow) {
          otherRow.classList.remove('bg-recon-cloud/20');
          var otherChevron = otherRow.querySelector('.rfp-li-chevron');
          if (otherChevron) otherChevron.style.transform = 'rotate(0deg)';
        }
      }
    });
    editor.classList.remove('hidden');
    editor.style.display = 'block';
    document.body.classList.add('overflow-hidden');
    row.classList.add('bg-recon-cloud/20');
    var chevron = row.querySelector('.rfp-li-chevron');
    if (chevron) chevron.style.transform = 'rotate(90deg)';
    return row;
  }

  function rfpAddLineFormHasData(form) {
    if (!form) return false;
    var fields = ['vendor', 'description', 'quantity', 'contractor_cost'];
    return fields.some(function(name) {
      var el = form.querySelector('[name="' + name + '"]');
      return el && String(el.value || '').trim() !== '';
    });
  }

  function saveRfpLineEditor(itemId) {
    var addForm = document.getElementById('rfp-add-sub-form-' + itemId);
    if (rfpAddLineFormHasData(addForm)) {
      addForm.requestSubmit();
      return;
    }
    if (typeof window.saveRfpEditorFields === 'function') {
      window.saveRfpEditorFields(itemId);
    }
  }

  window.closeRfpLineEditor = closeRfpLineEditor;
  window.openRfpLineEditor = openRfpLineEditor;
  window.saveRfpLineEditor = saveRfpLineEditor;
  window.toggleRfpLineEditor = function(itemId) {
    var editor = document.getElementById('rfp-line-editor-' + itemId);
    if (!editor) return null;
    if (editor.classList.contains('hidden')) return openRfpLineEditor(itemId);
    return closeRfpLineEditor(itemId);
  };
  document.addEventListener('keydown', function(e) {
    if (e.key !== 'Escape') return;
    var openEditor = document.querySelector('.rfp-line-editor-modal:not(.hidden)');
    if (!openEditor) return;
    closeRfpLineEditor(openEditor.id.replace('rfp-line-editor-', ''));
  });

  (function restoreRfpPosition(){
    var params = new URLSearchParams(window.location.search);
    var rfpId = params.get('open_rfp');
    var itemId = params.get('open_item');
    var showSubForm = params.get('show_sub_form');
    if (!rfpId && !itemId && !showSubForm) return;

    var target = expandRfp(rfpId);
    if (itemId) {
      var itemRow = document.getElementById('rfp-line-' + itemId);
      if (itemRow) target = itemRow;
    }
    if (showSubForm) {
      var subForm = document.getElementById('add-sub-' + showSubForm);
      if (subForm) {
        target = subForm;
      }
    }
    if (target && target.scrollIntoView) {
      setTimeout(function(){
        target.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }, 60);
    }
  })();
  })();
})();
</script>

<div id="rfp-autosave-msg" style="display:none;position:fixed;top:16px;right:16px;z-index:9999;padding:10px 18px;border-radius:6px;font-size:13px;font-weight:500;box-shadow:0 2px 8px rgba(0,0,0,0.15);transition:opacity 0.3s;"></div>

<script>
(function(){
  var timers = new WeakMap();

  function fieldValue(el) {
    if (el.type === 'checkbox') return el.checked ? '1' : '0';
    return el.value;
  }

  function autosaveUrl(el) {
    if (el.hasAttribute('data-rfp-autosave-category')) {
      return '/projects/' + encodeURIComponent(el.dataset.jobId) + '/rfps/' + encodeURIComponent(el.dataset.rfpId) + '/autosave';
    }
    return '/projects/rfps/items/' + encodeURIComponent(el.dataset.itemId) + '/autosave';
  }

  function showAutosaveStatus(text, type) {
    var status = document.getElementById('rfp-autosave-status');
    if (status) {
      status.textContent = text;
      status.className = 'text-xs px-2 ' + (type === 'error' ? 'text-recon-red' : type === 'warning' ? 'text-amber-700' : 'text-recon-fog');
    }
  }

  function showAutosaveToast(text, type) {
    var el = document.getElementById('rfp-autosave-msg');
    if (!el) return;
    var bg = type === 'error' ? '#dc2626' : type === 'warning' ? '#d97706' : '#059669';
    el.style.background = bg;
    el.style.color = '#fff';
    el.textContent = text;
    el.style.display = 'block';
    setTimeout(function() {
      el.style.opacity = '0';
      setTimeout(function() { el.style.display = 'none'; el.style.opacity = '1'; }, 300);
    }, 3000);
  }

  function markConflict(el, data) {
    el.classList.add('border-recon-red');
    el.title = 'Changed by another user. Current value: ' + (data.currentValue == null ? '' : data.currentValue);
    showAutosaveStatus('Conflict - refresh before replacing', 'warning');
    showAutosaveToast('This field changed elsewhere. Refresh before overwriting it.', 'warning');
  }

  function clearFieldState(el) {
    el.classList.remove('border-recon-red');
    el.title = '';
  }

  function restoreRenameInput(el) {
    if (!el.classList.contains('rename-input')) return;
    var wrapper = el.closest('.flex');
    var label = wrapper && wrapper.querySelector('.rfp-rename-trigger');
    var pencil = wrapper && wrapper.querySelector('button[title="Edit category name"]');
    if (label) label.style.display = '';
    if (pencil) pencil.style.display = '';
    el.style.display = 'none';
  }

  function moneyText(value) {
    var num = Number(value);
    return '$' + (isFinite(num) ? num : 0).toFixed(2);
  }

  function moneyPlain(value) {
    var num = Number(value);
    return (isFinite(num) ? num : 0).toFixed(2);
  }

  function setMoneyOutput(el, value) {
    if (!el) return;
    if (el.tagName === 'INPUT') el.value = moneyPlain(value);
    else el.textContent = moneyText(value);
  }

  function setPlainOutput(el, value) {
    if (!el) return;
    el.textContent = value == null || value === '' ? '—' : String(value);
  }

  function syncRfpItemField(itemId, field, saved, sourceEl) {
    if (!itemId || !field) return;
    var value = saved == null ? '' : String(saved);
    document.querySelectorAll('[data-rfp-autosave-item][data-item-id="' + itemId + '"][data-field="' + field + '"]').forEach(function(peer) {
      if (peer !== sourceEl) {
        if (peer.type === 'checkbox') peer.checked = value === '1' || value === 'true';
        else peer.value = value;
      }
      peer.dataset.originalValue = value;
      clearFieldState(peer);
      if (peer.hasAttribute('data-autosize') && typeof autosize === 'function') autosize(peer);
    });
    if (field === 'description') {
      var parentRow = document.getElementById('rfp-line-' + itemId);
      if (parentRow) {
        parentRow.setAttribute('data-rfp-line-search', value.toLowerCase());
        var categoryRow = parentRow.closest('[data-rfp-items-row]');
        var rfpId = categoryRow && categoryRow.getAttribute('data-rfp-items-row');
        var summaryRow = rfpId && document.querySelector('[data-rfp-category-row][data-rfp-id="' + rfpId + '"]');
        if (summaryRow) {
          var categoryName = summaryRow.getAttribute('data-rfp-category-name') || '';
          var lineText = Array.prototype.map.call(categoryRow.querySelectorAll('.rfp-li-row'), function(row) {
            return row.getAttribute('data-rfp-line-search') || '';
          }).join(' ');
          summaryRow.setAttribute('data-rfp-search', (categoryName + ' ' + lineText).toLowerCase());
        }
      }
      if (typeof window.applyRfpFilters === 'function') window.applyRfpFilters();
    }
  }

  function formatPercentValue(value) {
    var n = Number(value);
    if (!Number.isFinite(n)) return '';
    return Number.isInteger(n) ? String(n) : String(parseFloat(n.toFixed(4)));
  }

  function percentInput(scope, name, fallback) {
    return formatPercentValue(numberInput(scope, name, fallback));
  }

  function percentSummary(values) {
    var unique = [];
    values.forEach(function(value) {
      if (value !== '' && unique.indexOf(value) === -1) unique.push(value);
    });
    return unique.length ? unique.join(' / ') : '—';
  }

  function numberInput(scope, name, fallback) {
    var el = scope && scope.querySelector('[name="' + name + '"]');
    if (!el) return fallback || 0;
    var n = parseFloat(el.value);
    return Number.isFinite(n) ? n : (fallback || 0);
  }

  function rfpLiveLineHasData(line) {
    if (!line || !line.hasAttribute('data-rfp-new-line')) return true;
    return ['vendor', 'description', 'quantity', 'contractor_cost'].some(function(name) {
      var el = line.querySelector('[name="' + name + '"]');
      return el && String(el.value || '').trim() !== '';
    });
  }

  function computeRfpLiveLine(line) {
    var qty = numberInput(line, 'quantity', 0);
    var unit = numberInput(line, 'contractor_cost', 0) + numberInput(line, 'vendor_cost', 0);
    var markup = numberInput(line, 'markup_pct', 16);
    var gr = numberInput(line, 'general_requirements_pct', 4);
    var totalCost = qty * unit;
    var totalWithMarkup = totalCost * (1 + ((markup + gr) / 100));
    return {
      qty: qty,
      totalCost: totalCost,
      totalWithMarkup: totalWithMarkup,
      finalUnit: qty > 0 ? totalWithMarkup / qty : 0,
    };
  }

  function updateRfpEditorSummary(parentItemId) {
    var summary = document.querySelector('[data-rfp-editor-summary="' + parentItemId + '"]');
    if (!summary) return;
    var parentRow = document.getElementById('rfp-line-' + parentItemId);
    var totalCost = 0;
    var totalWithMarkup = 0;
    var qty = 0;
    var approvedTotalCost = 0;
    var approvedTotalWithMarkup = 0;
    var approvedQty = 0;
    var approvedMarkupValues = [];
    var approvedGrValues = [];
    var approvedCount = 0;
    var lineCount = 0;
    document.querySelectorAll('[data-rfp-pricing-line][data-parent-item-id="' + parentItemId + '"]').forEach(function(line) {
      if (!rfpLiveLineHasData(line)) return;
      var isNewLine = line.hasAttribute('data-rfp-new-line');
      if (!isNewLine) lineCount += 1;
      var checkbox = line.querySelector('input[type="checkbox"][data-field="approved"]');
      var approved = checkbox ? checkbox.checked : true;
      var computed = computeRfpLiveLine(line);
      setMoneyOutput(line.querySelector('[data-rfp-live-total-cost]'), computed.totalCost);
      setMoneyOutput(line.querySelector('[data-rfp-live-total-with-markup]'), computed.totalWithMarkup);
      setMoneyOutput(line.querySelector('[data-rfp-live-final-unit]'), computed.finalUnit);
      totalCost += computed.totalCost;
      totalWithMarkup += computed.totalWithMarkup;
      qty = Math.max(qty, computed.qty || 0);
      if (approved) {
        if (!isNewLine) {
          approvedCount += 1;
          approvedTotalCost += computed.totalCost;
          approvedTotalWithMarkup += computed.totalWithMarkup;
          approvedQty = Math.max(approvedQty, computed.qty || 0);
          approvedMarkupValues.push(percentInput(line, 'markup_pct', 16));
          approvedGrValues.push(percentInput(line, 'general_requirements_pct', 4));
        }
      }
    });
    setMoneyOutput(summary.querySelector('[data-rfp-editor-summary-total-cost]'), totalCost);
    setMoneyOutput(summary.querySelector('[data-rfp-editor-summary-total-with-markup]'), totalWithMarkup);
    setMoneyOutput(summary.querySelector('[data-rfp-editor-summary-final-unit]'), qty > 0 ? totalWithMarkup / qty : 0);
    if (parentRow) {
      parentRow.setAttribute('data-rfp-line-total', moneyPlain(approvedTotalWithMarkup));
      parentRow.setAttribute('data-rfp-line-approved', approvedCount > 0 ? '1' : '0');
      setPlainOutput(parentRow.querySelector('[data-rfp-parent-qty="' + parentItemId + '"]'), approvedQty || 0);
      setMoneyOutput(parentRow.querySelector('[data-rfp-parent-unit-cost="' + parentItemId + '"]'), approvedQty > 0 ? approvedTotalCost / approvedQty : 0);
      setMoneyOutput(parentRow.querySelector('[data-rfp-parent-total-cost="' + parentItemId + '"]'), approvedTotalCost);
      setPlainOutput(parentRow.querySelector('[data-rfp-parent-markup="' + parentItemId + '"]'), percentSummary(approvedMarkupValues));
      setPlainOutput(parentRow.querySelector('[data-rfp-parent-gr="' + parentItemId + '"]'), percentSummary(approvedGrValues));
      setMoneyOutput(parentRow.querySelector('[data-rfp-parent-total="' + parentItemId + '"]'), approvedTotalWithMarkup);
      setMoneyOutput(parentRow.querySelector('[data-rfp-parent-final-unit="' + parentItemId + '"]'), approvedQty > 0 ? approvedTotalWithMarkup / approvedQty : 0);
      var approvedIcon = parentRow.querySelector('[data-rfp-parent-approved-icon="' + parentItemId + '"]');
      if (approvedIcon) {
        var allApproved = lineCount > 0 && approvedCount === lineCount;
        approvedIcon.textContent = allApproved ? '✓' : '○';
        approvedIcon.classList.toggle('text-green-600', allApproved);
        approvedIcon.classList.toggle('text-recon-fog', !allApproved);
      }
      var lineBadge = parentRow.querySelector('[data-rfp-parent-line-count="' + parentItemId + '"]');
      if (lineBadge) lineBadge.textContent = approvedCount + '/' + lineCount;
      var table = parentRow.closest('.rfp-items-table');
      if (table) {
        var firstApproved = table.querySelector('input[type="checkbox"][data-field="approved"]') || parentRow;
        refreshApprovedTotalsFor(firstApproved);
      }
    }
  }

  window.updateRfpEditorSummary = updateRfpEditorSummary;

  function updateRfpLiveCalculatorFrom(el) {
    var line = el && el.closest('[data-rfp-pricing-line]');
    if (!line) return;
    var parentItemId = line.getAttribute('data-parent-item-id');
    if (parentItemId) updateRfpEditorSummary(parentItemId);
  }

  function refreshApprovedTotalsFor(el) {
    var table = el.closest('.rfp-items-table');
    if (!table) return;
    var rfpId = table.getAttribute('data-rfp-id');
    var total = 0;
    var approvedCount = 0;
    table.querySelectorAll('.rfp-li-row').forEach(function(row) {
      var rowTotal = parseFloat(row.getAttribute('data-rfp-line-total')) || 0;
      var checkbox = row.querySelector('input[type="checkbox"][data-field="approved"]');
      if (checkbox) {
        row.setAttribute('data-rfp-line-approved', checkbox.checked ? '1' : '0');
        if (checkbox.checked) {
          total += rowTotal;
          approvedCount += 1;
        }
      } else {
        if (row.getAttribute('data-rfp-line-approved') === '1') {
          approvedCount += 1;
          total += rowTotal;
        }
      }
    });
    var summary = document.querySelector('[data-rfp-summary-total="' + rfpId + '"]');
    var grand = document.querySelector('[data-rfp-grand-total="' + rfpId + '"]');
    var categoryRow = document.querySelector('[data-rfp-category-row][data-rfp-id="' + rfpId + '"]');
    if (categoryRow) categoryRow.setAttribute('data-rfp-approved-count', String(approvedCount));
    if (summary) summary.textContent = moneyText(total);
    if (grand) grand.textContent = moneyText(total);
    if (typeof window.applyRfpFilters === 'function') window.applyRfpFilters();
  }

  function applySuccessfulSave(el, data) {
    var saved = fieldValue(el);
    if (data && data.rfp && el.dataset.field === 'contractor_name') {
      saved = data.rfp.contractor_name || '';
      var wrapper = el.closest('.flex');
      var label = wrapper && wrapper.querySelector('.rfp-rename-trigger');
      var pencil = wrapper && wrapper.querySelector('button[title="Edit category name"]');
      if (label) {
        label.textContent = saved;
        label.style.display = '';
      }
      if (pencil) pencil.style.display = '';
      el.style.display = 'none';
      el.value = saved;
    }
    if (data && data.rfp && el.dataset.field === 'status') {
      saved = data.rfp.status || saved;
      var categoryRow = document.querySelector('[data-rfp-category-row][data-rfp-id="' + el.dataset.rfpId + '"]');
      if (categoryRow) categoryRow.setAttribute('data-rfp-status', saved || 'pending');
      if (typeof window.applyRfpFilters === 'function') window.applyRfpFilters();
    }
    if (data && data.item && Object.prototype.hasOwnProperty.call(data.item, el.dataset.field)) {
      saved = data.item[el.dataset.field];
      if (el.type === 'checkbox') saved = data.item[el.dataset.field] ? '1' : '0';
      syncRfpItemField(el.dataset.itemId, el.dataset.field, saved, el);
    }
    if (!(data && data.item && Object.prototype.hasOwnProperty.call(data.item, el.dataset.field))) {
      el.dataset.originalValue = saved == null ? '' : String(saved);
    }
    clearFieldState(el);
    if (el.dataset.field === 'approved') refreshApprovedTotalsFor(el);
    updateRfpLiveCalculatorFrom(el);
    showAutosaveStatus('Saved just now', 'success');
  }

  function saveField(el) {
    var value = fieldValue(el);
    if (value === (el.dataset.originalValue || '')) {
      restoreRenameInput(el);
      return Promise.resolve();
    }
    showAutosaveStatus('Saving...', 'success');
    return fetch(autosaveUrl(el), {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        field: el.dataset.field,
        value: value,
        originalValue: el.dataset.originalValue || ''
      })
    }).then(function(r) {
      return r.json().then(function(data) {
        if (!r.ok) {
          if (r.status === 409 && data && data.conflict) markConflict(el, data);
          else {
            showAutosaveStatus('Autosave failed', 'error');
            showAutosaveToast(data && data.error ? data.error : 'Autosave failed.', 'error');
          }
          throw new Error(data && data.error ? data.error : 'Autosave failed.');
        }
        applySuccessfulSave(el, data);
        return data;
      });
    }).catch(function(err) {
      if (!el.classList.contains('border-recon-red')) {
        showAutosaveStatus('Autosave failed', 'error');
      }
      throw err;
    });
  }

  function queueSave(el) {
    if (timers.has(el)) clearTimeout(timers.get(el));
    timers.set(el, setTimeout(function(){ saveField(el).catch(function(){}); }, 650));
  }

  function associatedFormData(form) {
    var data = new FormData(form);
    document.querySelectorAll('[form="' + form.id + '"]').forEach(function(el) {
      if (!el.name || el.disabled) return;
      if ((el.type === 'checkbox' || el.type === 'radio') && !el.checked) return;
      data.append(el.name, el.value);
    });
    return data;
  }

  window.saveRfpEditorFields = function(itemId) {
    var editor = document.getElementById('rfp-line-editor-' + itemId);
    if (!editor) return;
    var saves = [];
    editor.querySelectorAll('[data-rfp-autosave-item]').forEach(function(el) {
      if (timers.has(el)) {
        clearTimeout(timers.get(el));
        timers.delete(el);
      }
      if (fieldValue(el) !== (el.dataset.originalValue || '')) saves.push(saveField(el));
    });
    if (!saves.length) {
      showAutosaveStatus('Saved just now', 'success');
      showAutosaveToast('Line item is already saved.', 'success');
      return;
    }
    Promise.allSettled(saves).then(function(results) {
      var failed = results.some(function(r) { return r.status === 'rejected'; });
      if (!failed) showAutosaveToast('Line item saved.', 'success');
    });
  };

  document.querySelectorAll('[data-rfp-autosave-item], [data-rfp-autosave-category]').forEach(function(el) {
    var eventName = (el.tagName === 'SELECT' || el.type === 'checkbox') ? 'change' : 'input';
    el.addEventListener(eventName, function() {
      updateRfpLiveCalculatorFrom(el);
      if (el.tagName === 'SELECT' || el.type === 'checkbox') saveField(el).catch(function(){});
      else queueSave(el);
    });
    el.addEventListener('blur', function() {
      if (timers.has(el)) clearTimeout(timers.get(el));
      saveField(el).catch(function(){});
    });
    el.addEventListener('keydown', function(e) {
      if (e.key === 'Enter' && el.classList.contains('rename-input')) {
        e.preventDefault();
        el.blur();
      }
    });
  });

  document.querySelectorAll('[data-rfp-live-calc]').forEach(function(el) {
    el.addEventListener('input', function() { updateRfpLiveCalculatorFrom(el); });
    el.addEventListener('change', function() { updateRfpLiveCalculatorFrom(el); });
  });

  document.querySelectorAll('[data-rfp-editor-summary]').forEach(function(summary) {
    updateRfpEditorSummary(summary.getAttribute('data-rfp-editor-summary'));
  });

  document.querySelectorAll('form[id^="rfp-sub-form-"]').forEach(function(form) {
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      fetch(form.action, {
        method: 'POST',
        body: associatedFormData(form),
        headers: { 'X-Requested-With': 'fetch' }
      }).then(function(r) {
        if (!r.ok) throw new Error('Save failed.');
        document.querySelectorAll('[form="' + form.id + '"][data-rfp-autosave-item]').forEach(function(el) {
          el.dataset.originalValue = fieldValue(el);
          clearFieldState(el);
        });
        var line = form.closest('.rfp-line-editor-modal')?.querySelector('[data-rfp-pricing-line] [form="' + form.id + '"]')?.closest('[data-rfp-pricing-line]');
        var parentItemId = line ? line.getAttribute('data-parent-item-id') : null;
        if (!parentItemId) {
          var anyAssociated = document.querySelector('[form="' + form.id + '"][data-rfp-autosave-item]');
          line = anyAssociated && anyAssociated.closest('[data-rfp-pricing-line]');
          parentItemId = line ? line.getAttribute('data-parent-item-id') : null;
        }
        if (parentItemId) updateRfpEditorSummary(parentItemId);
        showAutosaveStatus('Saved just now', 'success');
        showAutosaveToast('Pricing line saved.', 'success');
      }).catch(function() {
        showAutosaveStatus('Save failed', 'error');
        showAutosaveToast('Pricing line save failed.', 'error');
      });
    });
  });

  // "Add line" does a real full-page POST/redirect (unlike the AJAX sub-line
  // forms above). If a description/qty edit elsewhere in this same editor is
  // still queued or mid-flight when that navigation fires, the browser cancels
  // it and the edit is lost — the field appears to "revert" after reload.
  // Flush any pending autosaves for this editor before letting the native
  // submit proceed.
  document.querySelectorAll('form[id^="rfp-add-sub-form-"]').forEach(function(form) {
    form.addEventListener('submit', function(e) {
      var itemId = form.getAttribute('data-parent-item-id');
      var editor = itemId && document.getElementById('rfp-line-editor-' + itemId);
      if (!editor) return;
      var pending = [];
      editor.querySelectorAll('[data-rfp-autosave-item]').forEach(function(el) {
        if (form.contains(el)) return;
        if (timers.has(el)) { clearTimeout(timers.get(el)); timers.delete(el); }
        if (fieldValue(el) !== (el.dataset.originalValue || '')) pending.push(saveField(el).catch(function(){}));
      });
      if (!pending.length) return;
      e.preventDefault();
      showAutosaveStatus('Saving...', 'success');
      Promise.allSettled(pending).then(function() {
        form.submit();
      });
    });
  });
})();
</script>

<%- include('../layouts/footer') %>

<!-- RFP autocomplete data (rendered server-side) -->
<script>
window.RFP_SOURCES = [
<% (vendors || []).forEach(function(v, i){ %>
  <%= i > 0 ? ',' : '' %>{name:<%= JSON.stringify(v.name) %>,label:'(Vendor)',type:'vendor'}
<% }); %>
<% (contractors || []).forEach(function(c, i){ %>
  <%= i > 0 || ((vendors || []).length > 0) ? ',' : '' %>{name:<%= JSON.stringify(c.name) %>,label:<%= JSON.stringify('(Contractor' + (c.trade ? ', ' + c.trade : '') + ')') %>,type:'contractor'}
<% }); %>
];
</script>

<script>
// RFP autocomplete — search using server-rendered data, fallback to API
(function(){
  var sources = window.RFP_SOURCES || [];

  function setupAutocomplete(inputId) {
    var input = document.getElementById(inputId);
    setupAutocompleteFromElement(input);
  }

  function setupAutocompleteFromElement(input) {
    if (!input) return;

    var dropdown = document.createElement('div');
    dropdown.className = 'rfp-autocomplete-dropdown';
    dropdown.style.cssText = 'position:absolute;z-index:9999;background:#fff;border:1px solid #d0d0d0;border-radius:6px;max-height:240px;overflow-y:auto;box-shadow:0 4px 12px rgba(0,0,0,.12);display:none;width:100%;font-size:.82rem;';
    input.parentNode.style.position = 'relative';
    input.parentNode.appendChild(dropdown);

    input.addEventListener('input', function(){
      var q = this.value.toLowerCase().trim();
      dropdown.innerHTML = '';
      if (q.length < 1) { showAllResults(); return; }

      var matches = sources.filter(function(s){ return s.name.toLowerCase().indexOf(q) !== -1; }).slice(0, 10);
      if (matches.length === 0) { dropdown.style.display = 'none'; return; }

      renderResults(matches);
    });

    input.addEventListener('focus', function(){
      showAllResults();
    });

    function showAllResults() {
      var all = sources.slice(0, 10);
      if (all.length === 0) { dropdown.style.display = 'none'; return; }
      renderResults(all);
    }

    function renderResults(items) {
      items.forEach(function(m) {
        var item = document.createElement('div');
        item.style.cssText = 'padding:.5rem .75rem;cursor:pointer;border-bottom:1px solid #f0f0f0;display:flex;justify-content:space-between;align-items:center;';
        var name = document.createElement('span');
        name.textContent = m.name;
        var label = document.createElement('span');
        label.style.cssText = 'font-size:.75rem;color:#888';
        label.textContent = m.label;
        item.appendChild(name);
        item.appendChild(label);
        item.addEventListener('mouseenter', function(){ this.style.background = '#f5f5f5'; });
        item.addEventListener('mouseleave', function(){ this.style.background = ''; });
        item.addEventListener('click', function(){
          input.value = m.name;
          dropdown.style.display = 'none';
          input.dispatchEvent(new Event('change'));
        });
        dropdown.appendChild(item);
      });
      dropdown.style.display = 'block';
    }

    input.addEventListener('blur', function(){
      setTimeout(function(){ dropdown.style.display = 'none'; }, 200);
    });

    input.addEventListener('focus', function(){
      if (dropdown.children.length) dropdown.style.display = 'block';
    });
  }

  setupAutocomplete('vendor-search-rfp');
  document.querySelectorAll('.rfp-vendor-autocomplete').forEach(function(el) {
    setupAutocompleteFromElement(el);
  });

  // F-007 bonus: persist expand state of parent rows in localStorage
  document.querySelectorAll('[data-toggle-parent]').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var rfpId = this.getAttribute('data-rfp-id');
      var parentId = this.getAttribute('data-parent-id');
      if (!rfpId || !parentId) return;
      var key = 'rfp-expand-' + rfpId;
      var expanded = {};
      try { expanded = JSON.parse(localStorage.getItem(key)) || {}; } catch(e) {}
      var children = document.getElementById('children-' + parentId);
      if (children) {
        var isHidden = children.classList.contains('hidden');
        if (isHidden) {
          expanded[parentId] = true;
        } else {
          delete expanded[parentId];
        }
        localStorage.setItem(key, JSON.stringify(expanded));
      }
    });
  });

  // Restore expand state from localStorage on page load
  (function() {
    var expandBtns = document.querySelectorAll('[data-toggle-parent]');
    if (!expandBtns.length) return;
    var rfpId = expandBtns[0].getAttribute('data-rfp-id');
    if (!rfpId) return;
    var key = 'rfp-expand-' + rfpId;
    var expanded = {};
    try { expanded = JSON.parse(localStorage.getItem(key)) || {}; } catch(e) {}
    Object.keys(expanded).forEach(function(pid) {
      var btn = document.querySelector('[data-toggle-parent][data-parent-id="' + pid + '"]');
      var children = document.getElementById('children-' + pid);
      if (btn && children) {
        children.classList.remove('hidden');
        var icon = btn.querySelector('.chevron-icon');
        if (icon) icon.textContent = '▼';
      }
    });
  })();
})();
</script>
