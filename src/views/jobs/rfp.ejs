<%- include('../layouts/header', { title: 'RFP — ' + (job.title || job.name), currentUser: currentUser, flash: flash, activeNav: activeNav }) %>

<div class="max-w-7xl mx-auto px-4 py-6">
  <div class="mb-4 flex items-center justify-between">
    <a href="/projects/<%= job.id %>" class="text-sm text-recon-fog hover:text-recon-red">&larr; Back to <%= job.title || job.name %></a>
    <button onclick="document.getElementById('rfp-new-form').classList.toggle('hidden')"
            class="btn btn-primary text-sm">+ New RFP</button>
  </div>

  <div class="mb-6">
    <h1 class="page-h1">RFP / Bid Comparison</h1>
    <p class="text-sm text-recon-fog mt-1">Project: <a href="/projects/<%= job.id %>" class="text-recon-red hover:underline"><%= job.title || job.name %></a></p>
  </div>


  <!-- New RFP "Tab" / scope area — user-defined names like "Cabinet", "Painting", "1st floor"
       per D-078 spec (matches Michael's Excel template). Contractor/vendor bids go INSIDE
       each tab as line items (see line-item form below). -->
  <div id="rfp-new-form" class="hidden card p-4 mb-6 bg-recon-deeper border-recon-mist">
    <h3 class="text-sm font-semibold mb-3">New RFP Tab</h3>
    <p class="text-xs text-recon-fog mb-3">Add a scope area (e.g. "Cabinet", "Painting", "1st floor"). Click into it to add line items per contractor/vendor.</p>
    <form action="/projects/<%= job.id %>/rfps" method="POST" class="flex gap-3 items-end flex-wrap">
      <div>
        <label class="block text-xs text-recon-fog mb-1">Category / Tab name</label>
        <input name="contractor_name" required class="input" placeholder="Pick from list or type custom" style="min-width:240px" maxlength="80" autocomplete="off" list="rfp-tab-presets">
        <datalist id="rfp-tab-presets">
          <option value="Cabinets">
          <option value="Concrete">
          <option value="Countertops">
          <option value="Demolition">
          <option value="Doors">
          <option value="Drywall">
          <option value="Electrical">
          <option value="Flooring">
          <option value="Framing">
          <option value="General">
          <option value="HVAC">
          <option value="Insulation">
          <option value="Landscaping">
          <option value="Painting">
          <option value="Plumbing">
          <option value="Roofing">
          <option value="Site Work">
          <option value="Tile">
          <option value="Trim / Finish">
          <option value="Windows">
        </datalist>
        <p class="text-xs text-recon-fog mt-1">Type any custom name (e.g. "1st floor", "Activities bldg") — picker is just a suggestion list.</p>
      </div>
      <button type="submit" class="btn btn-primary text-sm">Add Tab</button>
    </form>
  </div>

  <!-- Shared datalist for line-item vendor/contractor selection (used inside each RFP tab below) -->
  <datalist id="rfp-line-entity-options">
    <% (contractors || []).forEach(function(c) { %>
      <option value="<%= c.name %>" data-type="contractor"><%= c.name %> — Contractor<% if (c.trade) { %> (<%= c.trade %>)<% } %></option>
    <% }); %>
    <% (vendors || []).forEach(function(v) { %>
      <option value="<%= v.name %>" data-type="vendor"><%= v.name %> — Vendor</option>
    <% }); %>
  </datalist>

  <!-- RFP list -->
  <% if (!rfps || rfps.length === 0) { %>
    <div class="card p-12 text-center text-recon-fog text-sm">
      No RFPs yet. Click <strong>+ New RFP</strong> to add a contractor bid.
    </div>
  <% } else { %>
    <% 
    // Calculate RFP-level totals for summary cards.
    // For parent/sub-line groups, count approved sub-lines once and never also
    // count the parent row. Standalone legacy rows still count when approved.
    function approvedRfpTotal(items) {
      var childrenByParent = {};
      (items || []).forEach(function(i) {
        if (i.parent_line_item_id) {
          (childrenByParent[i.parent_line_item_id] = childrenByParent[i.parent_line_item_id] || []).push(i);
        }
      });
      return (items || []).reduce(function(sum, i) {
        if (i.parent_line_item_id) return sum;
        var children = childrenByParent[i.id] || [];
        if (children.length > 0) {
          return sum + children.reduce(function(childSum, c) {
            return childSum + (c.approved ? Number(c.total_with_markup || 0) : 0);
          }, 0);
        }
        return sum + (i.approved ? Number(i.total_with_markup || 0) : 0);
      }, 0);
    }
    var rfpTotals = {};
    rfps.forEach(function(r) { 
      var items = (rfpItemsMap && rfpItemsMap[r.id]) || [];
      rfpTotals[r.id] = approvedRfpTotal(items);
    });
    %>

    <!-- D-104: RFP summary table (FORGE format — single card, table layout) -->
    <div class="card overflow-hidden mb-6">
      <div class="px-5 py-3 border-b border-recon-mist">
        <h3 class="font-semibold text-sm">RFP / Bid Summary</h3>
      </div>
      <table class="data">
        <thead>
          <tr>
            <th>Category</th>
            <th>Status</th>
            <th class="text-right">Items</th>
            <th class="text-right">Approved Total</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% rfps.forEach(function(rfp){ %>
            <tr class="cursor-pointer hover:bg-recon-cloud/20" onclick="var el=document.getElementById('rfp-items-<%= rfp.id %>');var icon=document.getElementById('rfp-chev-<%= rfp.id %>');el.classList.toggle('hidden');if(icon){icon.textContent=el.classList.contains('hidden')?'▶':'▼';}">
              <td>
                <div class="flex items-center gap-1">
                  <button type="button" id="rfp-chev-<%= rfp.id %>"
                          class="text-recon-fog hover:text-recon-red text-lg leading-none px-1.5 py-1 select-none"
                          style="min-width:1.75rem;"
                          onclick="event.stopPropagation();var el=document.getElementById('rfp-items-<%= rfp.id %>');el.classList.toggle('hidden');this.textContent=el.classList.contains('hidden')?'▶':'▼';"
                          aria-label="Toggle line items">▶</button>
                  <span class="font-semibold text-sm cursor-pointer hover:text-recon-red flex-1 rfp-rename-trigger"
                        onclick="var el=document.getElementById('rfp-items-<%= rfp.id %>');var icon=document.getElementById('rfp-chev-<%= rfp.id %>');el.classList.toggle('hidden');if(icon){icon.textContent=el.classList.contains('hidden')?'▶':'▼';}"
                        title="Click to expand/collapse line items">
                    <%= rfp.contractor_name %>
                  </span>
                  <form action="/projects/<%= job.id %>/rfps/<%= rfp.id %>" method="POST" class="flex items-center gap-1 ml-1"
                        onsubmit="this.querySelector('input.rename-input').style.display='none';this.querySelector('.rename-save').style.display='none';this.querySelector('input').removeAttribute('disabled');">
                    <input name="contractor_name" class="input text-xs py-0.5 px-1 w-32 rename-input" style="display:none"
                           list="rfp-tab-presets" autocomplete="off"
                           onblur="var f=this.parentElement;var s=f&&f.previousElementSibling;if(s){s.style.display='';}this.style.display='none';this.nextElementSibling.style.display='none';">
                    <button type="submit" style="display:none" class="btn btn-primary text-xs py-0.5 px-1.5 rename-save">Save</button>
                  </form>
                </div>
              </td>
              <td>
                <form action="/projects/<%= job.id %>/rfps/<%= rfp.id %>" method="POST" onclick="event.stopPropagation()">
                  <select name="status" onchange="this.form.submit()" class="text-xs border rounded px-1 py-0.5">
                    <option value="pending" <%= rfp.status === 'pending' ? 'selected' : '' %>>Pending</option>
                    <option value="submitted" <%= rfp.status === 'submitted' ? 'selected' : '' %>>Submitted</option>
                    <option value="awarded" <%= rfp.status === 'awarded' ? 'selected' : '' %>>Awarded</option>
                    <option value="declined" <%= rfp.status === 'declined' ? 'selected' : '' %>>Declined</option>
                  </select>
                </form>
              </td>
              <td class="text-right"><%= (rfpItemsMap && rfpItemsMap[rfp.id] ? rfpItemsMap[rfp.id].length : 0) %></td>
              <td class="text-right font-semibold <%= rfp.status === 'awarded' ? 'text-green-700' : '' %>">$<%= rfpTotals[rfp.id].toFixed(2) %></td>
              <td class="text-right">
                <form action="/projects/<%= job.id %>/rfps/<%= rfp.id %>/delete" method="POST" onclick="event.stopPropagation()"
                      onsubmit="return confirm('Delete this RFP and all its items?')" class="inline">
                  <button class="text-recon-fog hover:text-recon-red text-xs">&times;</button>
                </form>
              </td>
            </tr>
            <tr id="rfp-items-<%= rfp.id %>" class="hidden">
              <td colspan="5" class="p-0">

    <!-- D-104: Line-item content for each RFP (inside summary table rows) -->
      <div>
        <div class="px-5 py-2 border-b border-recon-mist bg-recon-deeper/10 flex items-center justify-between">
          <span class="text-xs font-medium text-recon-fog">Line items</span>
          <button onclick="document.getElementById('rfp-item-form-<%= rfp.id %>').classList.toggle('hidden')"
                  class="text-sm text-recon-red hover:underline">+ Add item</button>
        </div>

        <!-- Add item form — line item is just an Item name (e.g. Demo, Install, Supply).
             Costs / qty / totals auto-compute from sub-line items added under each item. -->
        <div id="rfp-item-form-<%= rfp.id %>" class="hidden p-3 bg-recon-deeper/30 border-b border-recon-mist">
          <form action="/projects/<%= job.id %>/rfps/<%= rfp.id %>/items" method="POST" class="flex gap-2 items-end text-xs">
            <div class="flex-1">
              <label class="block text-xs text-recon-fog mb-1">Item</label>
              <textarea name="description" placeholder="e.g. Demo, Install, Supply, Demo kitchen" class="input w-full" required maxlength="500" rows="1" data-autosize></textarea>
            </div>
            <input name="parent_id" type="hidden" value="">
            <button type="submit" class="btn btn-primary text-xs">Add Item</button>
          </form>
          <p class="text-xs text-recon-fog mt-2">Click into the item below to add sub-line items per contractor/vendor — costs, qty, markup, and totals roll up automatically from the sub-lines.</p>
        </div>

        <!-- Line items table -->
        <%
        var items = (rfpItemsMap && rfpItemsMap[rfp.id] ? rfpItemsMap[rfp.id].filter(function(i) { return !i.parent_line_item_id; }) : []);
        var subItems = {};
        if (rfpItemsMap && rfpItemsMap[rfp.id]) {
          rfpItemsMap[rfp.id].filter(function(i) { return i.parent_line_item_id; }).forEach(function(s) {
            (subItems[s.parent_line_item_id] = subItems[s.parent_line_item_id] || []).push(s);
          });
        }
        var allItems = (rfpItemsMap && rfpItemsMap[rfp.id]) || [];
        var grandTotal = approvedRfpTotal(allItems);
        var grandTotalAll = allItems.reduce(function(s, i) { return s + Number(i.total_with_markup || 0); }, 0);
        %>
        <div class="overflow-x-auto">
          <table class="data text-xs rfp-items-table table-fixed" data-rfp-id="<%= rfp.id %>">
            <colgroup>
              <col class="w-[28%]">
              <col class="w-[8%]">
              <col class="w-[12%]">
              <col class="w-[10%]">
              <col class="w-[8%]">
              <col class="w-[8%]">
              <col class="w-[10%]">
              <col class="w-[8%]">
              <col class="w-10">
              <col class="w-[6%]">
            </colgroup>
            <thead>
              <tr>
                <th class="w-[28%]">Description</th>
                <th class="text-right">Qty</th>
                <th class="text-right">Unit Cost</th>
                <th class="text-right">Total Cost</th>
                <th class="text-right">Markup</th>
                <th class="text-right">GR %</th>
                <th class="text-right">Total w/ Markup</th>
                <th class="text-right">Final Unit</th>
                <th class="text-center">✓</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              <% items.forEach(function(item){ %>
                <% var itemFormId = 'rfp-li-form-' + item.id; var itemDelFormId = 'rfp-li-del-' + item.id; var children = subItems[item.id] || []; %>
                <% var apprChildren = children.filter(function(s){return s.approved;}); %>
                <% var liQty = apprChildren.reduce(function(s,c){return s + Number(c.quantity||0);}, 0) || (children.length > 0 ? children.reduce(function(s,c){return s + Number(c.quantity||0);}, 0) : (Number(item.quantity)||0)); %>
                <% var liUnit = apprChildren.reduce(function(s,c){return s + (Number(c.contractor_cost||0)+Number(c.vendor_cost||0));},0); %>
                <% var liTotalCost = (apprChildren.length > 0 ? apprChildren.reduce(function(s,c){return s + (Number(c.total_cost||0));},0) : children.reduce(function(s,c){return s + (Number(c.total_cost||0));},0)); %>
                <% var liTotal = apprChildren.length > 0 ? apprChildren.reduce(function(s,c){return s + (Number(c.total_with_markup||0));},0) : children.reduce(function(s,c){return s + (Number(c.total_with_markup||0));},0); %>
                <!-- D-105: Line item container row — Item name + auto-rolled-up totals from approved sub-lines.
                     Falls back to direct values on the line item itself when no sub-lines exist (legacy data). -->
                <% var liSubCount = children.length; var liApprovedSubs = apprChildren.length; %>
                <% var liHasSubs = children.length > 0; %>
                <% var liDisplayTotal = liTotal || (Number(item.total_with_markup) || 0); %>
                <% var liDisplayUnit = liHasSubs
                     ? (liQty > 0 ? (liTotal || Number(item.total_with_markup) || 0) / liQty : 0)
                     : (Number(item.final_unit_cost) || 0); %>
                <% var liMarkup = liHasSubs ? (children.some(function(s){return Number(s.markup_pct||20) !== Number(children[0].markup_pct||20);}) ? 'mixed' : (Number(children[0].markup_pct||20))) : (Number(item.markup_pct) || '—'); %>
                <% var liGr = liHasSubs ? (children.some(function(s){return Number(s.general_requirements_pct||6) !== Number(children[0].general_requirements_pct||6);}) ? 'mixed' : (Number(children[0].general_requirements_pct||6))) : (Number(item.general_requirements_pct) || '—'); %>
                <% var liApproved = liHasSubs ? (apprChildren.length === children.length ? true : false) : !!item.approved; %>
                <tr class="bg-recon-deeper/20 hover:bg-recon-cloud/20" style="cursor:pointer" onclick="var n=this.nextElementSibling;while(n&&n.classList.contains('rfp-sub-row')){n.style.display=n.style.display==='none'?'':'none';n=n.nextElementSibling;}">
                  <td><form id="<%= itemFormId %>" action="/projects/rfps/items/<%= item.id %>" method="POST" onclick="event.stopPropagation();"></form><textarea form="<%= itemFormId %>" name="description" class="input text-xs py-0.5 font-medium w-full" placeholder="Item description" rows="1" data-autosize><%= item.description %></textarea></td>
                  <td class="text-right"><% if (liHasSubs) { %><span class="font-medium text-xs"><%= liQty %></span><% } else { %><input form="<%= itemFormId %>" name="quantity" type="number" step="any" value="<%= item.quantity != null ? item.quantity : '' %>" class="input text-xs py-0.5 w-16 text-right"><% } %></td>
                  <td class="text-right font-medium">$<%= (liHasSubs ? liUnit : Number(item.unit_cost) || 0).toFixed(2) %></td>
                  <td class="text-right font-medium">$<%= (liHasSubs ? liTotalCost : Number(item.total_cost) || 0).toFixed(2) %></td>
                  <td class="text-right text-xs"><%= liMarkup %></td>
                  <td class="text-right text-xs"><%= liGr %></td>
                  <td class="text-right font-medium">$<%= liDisplayTotal.toFixed(2) %></td>
                  <td class="text-right text-xs">$<%= liDisplayUnit.toFixed(2) %></td>
                  <td class="text-center"><% if (liHasSubs) { %><span class="text-xs <%= liApproved ? 'text-green-600' : 'text-recon-fog' %>"><%= liApproved ? '✓' : '○' %></span><% } else { %><input form="<%= itemFormId %>" type="hidden" name="approved" value="0"><input form="<%= itemFormId %>" type="checkbox" name="approved" value="1" <%= item.approved ? 'checked' : '' %>><% } %></td>
                  <td class="text-right flex gap-1 items-center">
                    <span class="text-xs text-recon-fog mr-1" title="Approved sub-lines"><%= liApprovedSubs %>/<%= liSubCount %></span>
                    <button type="submit" form="<%= itemFormId %>" class="text-green-600 hover:text-green-800 text-xs font-bold" title="Save">&#10003;</button>
                    <form id="<%= itemDelFormId %>" action="/projects/rfps/items/<%= item.id %>/delete" method="POST" onclick="event.stopPropagation();" onsubmit="return confirm('Delete?')"></form>
                    <button type="submit" form="<%= itemDelFormId %>" class="text-recon-fog hover:text-recon-red text-xs">&times;</button>
                  </td>
                </tr>
                <!-- D-105: Sub-line items under this line item (initially hidden, toggled by clicking parent) -->
                <!-- D-105b: Add sub-line row + inline form (parent_id pre-filled) -->
                <tr class="rfp-sub-row bg-recon-deeper/5">
                  <td colspan="10" class="pl-4 py-1.5">
                    <button type="button" onclick="document.getElementById('add-sub-<%= item.id %>').classList.toggle('hidden'); event.stopPropagation();" class="text-xs text-recon-red hover:underline">+ Add sub-line under "<%= item.description || 'item' %>"</button>
                    <div id="add-sub-<%= item.id %>" class="hidden mt-2 p-2 bg-recon-cloud/10 border border-recon-mist rounded">
                      <form action="/projects/<%= job.id %>/rfps/<%= rfp.id %>/items" method="POST" class="rfp-line-form grid grid-cols-2 md:grid-cols-6 gap-2 text-xs" onclick="event.stopPropagation();">
                        <input name="vendor" class="input w-full" placeholder="Vendor or contractor" autocomplete="off" list="rfp-line-entity-options">
                        <textarea name="description" placeholder="Sub-line description" class="input w-full" rows="1" data-autosize required></textarea>
                        <input name="quantity" data-compute-input type="number" step="any" placeholder="Qty" class="input w-16">
                        <input name="contractor_cost" data-compute-input type="number" step="any" placeholder="$ Unit cost" class="input w-20">
                        <div class="flex gap-1 items-center">
                          <input name="markup_pct" data-compute-input type="number" step="any" placeholder="MU%" value="20" class="input w-14">
                          <input name="general_requirements_pct" data-compute-input type="number" step="any" placeholder="GR%" value="6" class="input w-14">
                          <button type="submit" class="btn btn-primary text-xs ml-1">Add sub</button>
                        </div>
                        <input name="parent_id" type="hidden" value="<%= item.id %>">
                      </form>
                    </div>
                  </td>
                </tr>
                <% children.forEach(function(sub){ %>
                  <% var subFid = 'rfp-sub-form-' + sub.id; var subDid = 'rfp-sub-del-' + sub.id; %>
                  <tr class="rfp-sub-row">
                    <td class="pl-6 text-recon-fog text-xs">
                      <form id="<%= subFid %>" action="/projects/rfps/items/<%= sub.id %>" method="POST"></form>
                      <div class="flex flex-col gap-1">
                        <input form="<%= subFid %>" name="vendor" value="<%= sub.vendor || '' %>"
                               class="input text-xs py-0.5 w-full" placeholder="Vendor or contractor"
                               list="rfp-line-entity-options" autocomplete="off">
                        <textarea form="<%= subFid %>" name="description" class="input text-xs py-0.5 w-full" placeholder="Sub-line description" rows="1" data-autosize><%= sub.description %></textarea>
                      </div>
                    </td>
                    <td class="text-right"><input form="<%= subFid %>" name="quantity" type="number" step="any" value="<%= sub.quantity != null ? sub.quantity : '' %>" class="input text-xs py-0.5 w-16 text-right"></td>
                    <td class="text-right">
                      <input form="<%= subFid %>" name="contractor_cost" type="number" step="any" value="<%= sub.contractor_cost != null ? sub.contractor_cost : '' %>" class="input text-xs py-0.5 w-20 text-right" placeholder="$ Unit cost">
                    </td>
                    <td class="text-right"><%= sub.total_cost != null ? '$' + Number(sub.total_cost).toFixed(2) : '-' %></td>
                    <td class="text-right"><input form="<%= subFid %>" name="markup_pct" type="number" step="any" value="<%= sub.markup_pct != null ? sub.markup_pct : '20' %>" class="input text-xs py-0.5 w-14 text-right"></td>
                    <td class="text-right"><input form="<%= subFid %>" name="general_requirements_pct" type="number" step="any" value="<%= sub.general_requirements_pct != null ? sub.general_requirements_pct : '6' %>" class="input text-xs py-0.5 w-14 text-right"></td>
                    <td class="text-right font-medium"><%= sub.total_with_markup != null ? '$' + Number(sub.total_with_markup).toFixed(2) : '-' %></td>
                    <td class="text-right font-medium"><%= sub.final_unit_cost != null ? '$' + Number(sub.final_unit_cost).toFixed(2) : '-' %></td>
                    <td class="text-center"><input form="<%= subFid %>" type="hidden" name="approved" value="0"><input form="<%= subFid %>" type="checkbox" name="approved" value="1" <%= sub.approved ? 'checked' : '' %>></td>
                    <td class="text-right flex gap-1">
                      <button type="submit" form="<%= subFid %>" class="text-green-600 hover:text-green-800 text-xs font-bold" title="Save">&#10003;</button>
                      <form id="<%= subDid %>" action="/projects/rfps/items/<%= sub.id %>/delete" method="POST" onsubmit="return confirm('Delete?')"></form>
                      <button type="submit" form="<%= subDid %>" class="text-recon-fog hover:text-recon-red text-xs">&times;</button>
                    </td>
                  </tr>
                <% }); %>
              <% }); %>
              <% if (items.length === 0) { %>
                <tr><td colspan="10" class="text-center text-recon-fog py-4">No line items yet. Click + Add item to add one.</td></tr>
              <% } %>
            </tbody>
            <tfoot>
              <tr class="font-semibold bg-recon-deeper/50">
                <td colspan="8" class="text-right">Grand Total (approved)</td>
                <td class="text-right text-recon-red">$<%= grandTotal.toFixed(2) %></td>
                <td></td>
              </tr>
            </tfoot>
          </table>
        </div>
      </div>
    </td></tr>
    <% }); %>
  </tbody></table>
  </div>
  <% } %>
</div>

<!-- D-105: SortableJS drag-drop + auto-total calculator + rename-on-dblclick -->
<style>
  /* D-120: field-sizing ensures textareas start at rows="1" even inside hidden containers */
  .rfp-items-table textarea.input { field-sizing: content; min-height: 1.5rem; }
</style>
<script>
(function(){
  // Rename RFP tab on double-click
  document.addEventListener('dblclick', function(e) {
    var target = e.target.closest('.rfp-rename-trigger');
    if (!target) return;
    e.stopPropagation();
    var span = target;
    var form = span.nextElementSibling;
    if (!form || !form.querySelector) return;
    var inp = form.querySelector('.rename-input');
    var btn = form.querySelector('.rename-save');
    if (!inp) return;
    inp.value = span.textContent.trim();
    span.style.display = 'none';
    inp.style.display = 'inline';
    btn.style.display = 'inline-block';
    inp.focus();
  });
(function(){
  // Drag-drop reorder
  if (typeof Sortable !== 'undefined') {
    var tbodies = document.querySelectorAll('.rfp-items-table tbody');
    tbodies.forEach(function(tbody){
      new Sortable(tbody, {
        animation: 150,
        handle: 'tr',
        onEnd: function(evt) {
          var ids = [];
          tbody.querySelectorAll('tr').forEach(function(tr){
            var form = tr.querySelector('form[id^=rfp-li-form-]');
            if (form) ids.push(form.action.split('/').pop());
          });
          if (ids.length) {
            var rfpId = tbody.closest('.rfp-items-table')?.getAttribute('data-rfp-id') || '';
            var xhr = new XMLHttpRequest();
            xhr.open('POST', '/projects/rfps/items/reorder', true);
            xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');
            var body = ids.map(function(id) {
              return 'item_ids=' + encodeURIComponent(id);
            }).join('&') + '&rfp_id=' + encodeURIComponent(rfpId);
            xhr.send(body);
          }
        }
      });
    });
  }
  var forms = document.querySelectorAll('.rfp-line-form');
  forms.forEach(function(form){
    var inputs = form.querySelectorAll('[data-compute-input]');
    var outputs = {};
    form.querySelectorAll('[data-compute-output]').forEach(function(el){
      outputs[el.getAttribute('data-compute-output')] = el;
    });
    function recalc(){
      var qty = parseFloat(form.querySelector('[name="quantity"]')?.value) || 0;
      var cCost = parseFloat(form.querySelector('[name="contractor_cost"]')?.value) || 0;
      var vCost = parseFloat(form.querySelector('[name="vendor_cost"]')?.value) || 0;
      var markup = parseFloat(form.querySelector('[name="markup_pct"]')?.value) || 20;
      var unit = cCost + vCost;
      var total = unit * qty;
      var withMarkup = total * (1 + markup / 100) * 1.06;
      var finalUnit = qty > 0 ? withMarkup / qty : 0;
      if (outputs.unit_cost) outputs.unit_cost.value = unit.toFixed(2);
      if (outputs.total_cost) outputs.total_cost.value = total.toFixed(2);
      if (outputs.total_with_markup) outputs.total_with_markup.value = withMarkup.toFixed(2);
      if (outputs.final_unit_cost) outputs.final_unit_cost.value = finalUnit.toFixed(2);
    }
    inputs.forEach(function(el){ el.addEventListener('input', recalc); });
    recalc();
  });
})();
})();
</script>

