<%
// D-007 Project members list partial.
// Inputs: members[] (with user_name, user_email, role), job, users[] (avail users).
var roles = [
  { value: 'superintendent', label: 'Superintendent', hint: 'Operations only. No billing or cost visibility.' },
  { value: 'pre_construction', label: 'Pre-construction', hint: 'Can view RFPs, project files, and operations data. No billing.' },
  { value: 'accountant', label: 'Accountant', hint: 'Billing and cost visibility only.' },
  { value: 'admin', label: 'Admin', hint: 'Full project access.' },
];
var roleLabels = { superintendent: 'Superintendent', pre_construction: 'Pre-construction', accountant: 'Accountant', admin: 'Admin' };
var roleBadges = { superintendent: 'scheduled', pre_construction: 'estimating', accountant: 'info', admin: 'accepted' };
var canManage = typeof projectAccess === 'undefined' || projectAccess.canManageMembers;
var memberForm = typeof memberForm !== 'undefined' ? memberForm : {};
var memberError = typeof memberError !== 'undefined' ? memberError : null;
var selectedUserId = memberForm.user_id ? String(memberForm.user_id) : '';
var selectedRole = memberForm.role || 'superintendent';
%>
<div class="card overflow-hidden" id="members-section">
  <div class="px-5 py-3 border-b border-recon-mist flex items-center justify-between">
    <h3 class="font-semibold">Project members (<%= members.length %>)</h3>
    <% if (canManage) { %>
    <button type="button"
            data-toggle-member-form
            class="text-sm text-recon-red hover:underline">+ Add member</button>
    <% } %>
  </div>

  <% if (canManage) { %>
  <div id="mem-form" class="<%= memberError ? '' : 'hidden ' %>p-5 border-b border-recon-mist bg-recon-cloud">
    <% if (memberError) { %>
      <div class="mb-3 rounded border border-red-200 bg-red-50 px-3 py-2 text-sm text-red-800">
        <%= memberError %>
      </div>
    <% } %>
    <form method="post"
          action="/projects/<%= job.id %>/members"
          hx-post="/projects/<%= job.id %>/members"
          hx-target="#members-section"
          hx-swap="outerHTML"
          class="grid grid-cols-1 md:grid-cols-3 gap-3">
      <div>
        <label class="label">User</label>
        <select name="user_id" required class="input">
          <option value="">— select user —</option>
          <% (typeof users !== 'undefined' ? users : []).forEach(function(u){ %>
            <option value="<%= u.id %>" <%= String(u.id) === selectedUserId ? 'selected' : '' %>><%= u.name %></option>
          <% }); %>
        </select>
      </div>
      <div>
        <label class="label">Role</label>
        <select name="role" class="input">
          <% roles.forEach(function(r){ %>
            <option value="<%= r.value %>" <%= r.value === selectedRole ? 'selected' : '' %> title="<%= r.hint %>"><%= r.label %></option>
          <% }); %>
        </select>
        <p class="text-[.7rem] text-recon-fog mt-1">Project manager already has full access. Add roles only for extra project team visibility.</p>
      </div>
      <div class="flex items-end">
        <button type="submit" class="btn btn-primary w-full">Add</button>
      </div>
    </form>
  </div>
  <% } %>

  <% if (members.length === 0) { %>
    <div class="p-8 text-center text-recon-fog text-sm">No members yet.</div>
  <% } else { %>
    <ul class="divide-y divide-recon-mist">
      <% members.forEach(function(m){ %>
        <li class="px-5 py-3 flex items-center justify-between">
          <div>
            <p class="font-medium text-recon-charcoal"><%= m.user_name %></p>
            <% if (m.user_email) { %><p class="text-xs text-recon-fog"><%= m.user_email %></p><% } %>
          </div>
          <div class="flex items-center gap-3">
            <span class="badge badge-<%= roleBadges[m.role] || 'draft' %>"><%= roleLabels[m.role] || m.role %></span>
            <% if (canManage) { %>
            <form method="post"
                  action="/projects/<%= job.id %>/members/<%= m.id %>/delete"
                  hx-delete="/projects/<%= job.id %>/members/<%= m.id %>"
                  hx-target="#members-section" hx-swap="outerHTML"
                  hx-confirm="Remove <%= m.user_name %> from this project?"
                  class="inline m-0">
              <button type="submit" class="text-xs text-red-700 hover:underline">Remove</button>
            </form>
            <% } %>
          </div>
        </li>
      <% }); %>
    </ul>
  <% } %>
</div>

<script>
(function(){
  var section = document.getElementById('members-section');
  if (!section) return;
  var toggle = section.querySelector('[data-toggle-member-form]');
  var form = section.querySelector('#mem-form');
  if (!toggle || !form) return;
  toggle.addEventListener('click', function(){
    form.classList.toggle('hidden');
  });
})();
</script>
