<%# D-024b: Schedule of Values — HTMX add/edit rows, inline percent-complete sliders, Generate draw button. %>

<section id="sov-section" class="card mb-6">
  <header class="px-5 py-3 border-b border-recon-mist flex flex-wrap items-baseline justify-between gap-2">
    <div>
      <h3 class="font-semibold">Schedule of Values</h3>
      <p class="text-xs text-recon-fog mt-0.5"><%= sovItems.length %> item<%= sovItems.length === 1 ? '' : 's' %> — total scheduled <strong class="text-recon-charcoal">$<%= sovTotalScheduled %></strong></p>
    </div>
    <% if (sovItems.length > 0) { %>
      <form action="/projects/<%= jobId %>/draws/generate" method="post">
        <button type="submit" class="btn btn-primary text-sm">Generate draw</button>
      </form>
    <% } %>
  </header>

  <!-- Add SOV item form (collapsible) -->
  <details class="border-b border-recon-mist">
    <summary class="px-5 py-2 cursor-pointer text-xs font-medium text-recon-fog hover:text-recon-red">+ Add SOV item</summary>
    <div class="px-5 py-3 bg-recon-cloud">
      <form action="/projects/<%= jobId %>/sov-items" method="post" class="flex flex-wrap items-end gap-3">
        <div class="min-w-[80px]">
          <label class="text-xs text-recon-fog block mb-1">Code</label>
          <input type="text" name="code" class="input text-sm" placeholder="e.g. 01.1" style="min-width:60px">
        </div>
        <div class="flex-1 min-w-[160px]">
          <label class="text-xs text-recon-fog block mb-1">Description</label>
          <textarea name="description" rows="1" class="input text-sm" required placeholder="e.g. Site work">
        </div>
        <div class="min-w-[110px]">
          <label class="text-xs text-recon-fog block mb-1">Scheduled value</label>
          <div class="flex">
            <span class="text-sm text-recon-fog mr-1 pt-2">$</span>
            <input type="number" step="0.01" min="0" name="scheduled_value" class="input text-sm text-right" required placeholder="0.00" style="min-width:80px">
          </div>
        </div>
        <div class="min-w-[80px]">
          <label class="text-xs text-recon-fog block mb-1">% complete</label>
          <input type="number" step="0.01" min="0" max="100" name="percent_complete" class="input text-sm text-right" value="0" style="min-width:60px">
        </div>
        <div class="min-w-[80px]">
          <label class="text-xs text-recon-fog block mb-1">Retainage %</label>
          <input type="number" step="0.01" min="0" max="100" name="retainage_rate" class="input text-sm text-right" value="0" style="min-width:60px">
        </div>
        <button type="submit" class="btn btn-primary text-sm" style="margin-bottom:1px">Add</button>
      </form>
    </div>
  </details>

  <% if (sovItems.length === 0) { %>
    <div class="p-6 text-center text-recon-fog text-sm italic">No SOV items yet. Add your first line item above.</div>
  <% } else { %>
    <table class="data">
      <thead>
        <tr>
          <th class="text-xs">Code</th>
          <th>Description</th>
          <th class="text-right">Scheduled</th>
          <th class="text-right">%</th>
          <th class="text-right">Previous billed</th>
          <th class="text-right">Current billed</th>
          <th class="text-right">Retainage</th>
          <th class="text-right">Total billed</th>
          <th class="text-right">Remaining</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% sovItems.forEach(function(item, idx){ %>
          <tr>
            <td class="font-mono text-xs"><%= item.code || '—' %></td>
            <td><%= item.description %></td>
            <td class="text-right">$<%= sovFmt(item.scheduled_value) %></td>
            <td class="text-right">
              <form action="/projects/<%= jobId %>/sov-items/<%= item.id %>/update" method="post" class="inline sov-inline-form">
                <input type="hidden" name="field" value="percent_complete">
                <input type="number" step="0.01" min="0" max="100" name="value" value="<%= item.percent_complete %>" class="input text-right text-xs" style="width:55px;padding:2px 4px;">
                <button type="submit" class="text-xs text-recon-fog hover:text-recon-red" title="Save">💾</button>
              </form>
            </td>
            <td class="text-right">$<%= sovFmt(item.previous_billed) %></td>
            <td class="text-right">
              <form action="/projects/<%= jobId %>/sov-items/<%= item.id %>/update" method="post" class="inline sov-inline-form">
                <input type="hidden" name="field" value="current_billed">
                <input type="number" step="0.01" min="0" name="value" value="<%= item.current_billed %>" class="input text-right text-xs" style="width:80px;padding:2px 4px;">
                <button type="submit" class="text-xs text-recon-fog hover:text-recon-red" title="Save">💾</button>
              </form>
            </td>
            <td class="text-right">
              <form action="/projects/<%= jobId %>/sov-items/<%= item.id %>/update" method="post" class="inline sov-inline-form">
                <input type="hidden" name="field" value="retainage_rate">
                <input type="number" step="0.01" min="0" max="100" name="value" value="<%= item.retainage_rate %>" class="input text-right text-xs" style="width:55px;padding:2px 4px;">
                <button type="submit" class="text-xs text-recon-fog hover:text-recon-red" title="Save">💾</button>
              </form>
            </td>
            <td class="text-right font-medium">$<%= sovFmt(Number(item.previous_billed) + Number(item.current_billed)) %></td>
            <td class="text-right <%= (Number(item.scheduled_value) - Number(item.previous_billed) - Number(item.current_billed)) > 0 ? 'text-green-700 font-medium' : 'text-recon-fog' %>">
              $<%= sovFmt(Math.max(0, Number(item.scheduled_value) - Number(item.previous_billed) - Number(item.current_billed))) %>
            </td>
            <td class="text-right">
              <form action="/projects/<%= jobId %>/sov-items/<%= item.id %>/delete" method="post" class="inline" onsubmit="return confirm('Delete this SOV item?')">
                <button type="submit" class="text-xs text-recon-fog hover:text-recon-red">&#10005;</button>
              </form>
            </td>
          </tr>
        <% }); %>
      </tbody>
      <tfoot class="bg-recon-cloud">
        <tr>
          <td class="text-right text-sm font-medium" colspan="2">Totals</td>
          <td class="text-right font-bold">$<%= sovFmt(sovTotalScheduled) %></td>
          <td></td>
          <td class="text-right">$<%= sovFmt(sovTotalPrev) %></td>
          <td class="text-right">$<%= sovFmt(sovTotalCurrent) %></td>
          <td></td>
          <td class="text-right font-bold text-recon-red">$<%= sovFmt(Number(sovTotalPrev) + Number(sovTotalCurrent)) %></td>
          <td class="text-right font-bold text-green-700">$<%= sovFmt(Math.max(0, sovTotalScheduled - sovTotalPrev - sovTotalCurrent)) %></td>
          <td></td>
        </tr>
      </tfoot>
    </table>
  <% } %>
</section>
