<%- include('layouts/header', { title: title || 'Error', currentUser: typeof currentUser !== 'undefined' ? currentUser : null, flash: typeof flash !== 'undefined' ? flash : {} }) %>

<div class="min-h-[60vh] flex items-center justify-center px-4">
  <div class="card p-8 max-w-md text-center">
    <div class="text-5xl font-bold text-recon-red mb-2"><%= code %></div>
    <p class="text-recon-charcoal mb-6"><%= message %></p>
    <% if (typeof actionLink !== 'undefined' && actionLink) { %>
      <a href="<%= actionLink %>" class="btn btn-primary mb-3"><%= typeof actionLabel !== 'undefined' ? actionLabel : 'Go back' %></a>
    <% } else { %>
      <a href="/" class="btn btn-primary">Back to dashboard</a>
    <% } %>
    <% if (code === 500) { %>
      <form action="/report-error" method="post" class="mt-4">
        <input type="hidden" name="code" value="<%= code %>">
        <input type="hidden" name="message" value="<%= message %>">
        <input type="hidden" name="url" value="<%= typeof currentUrl !== 'undefined' ? currentUrl : '' %>">
        <input type="hidden" name="error_detail" value="<%= typeof errorDetail !== 'undefined' ? errorDetail : '' %>">
        <input type="hidden" name="user_email" value="<%= typeof currentUser !== 'undefined' && currentUser ? currentUser.email : '' %>">
        <input type="hidden" name="error_ctx" value="<%= typeof errorCtx !== 'undefined' ? JSON.stringify(errorCtx) : '{}' %>">
        <button type="submit" class="btn btn-ghost text-sm text-recon-red">📧 Report this error to support</button>
      </form>
    <% } %>
  </div>
</div>

<%- include('layouts/footer') %>
