<%- include('../layouts/header', { title: title, currentUser: currentUser, flash: flash, activeNav: activeNav }) %>

<%
const primaryReports = [
  {
    name: 'AR Aging',
    href: '/accounting/ar-aging',
    pdf: '/accounting/ar-aging.pdf',
    type: 'Receivable',
    cadence: 'Current',
    description: 'Customer invoice balances by age and due date.'
  },
  {
    name: 'AP Aging',
    href: '/accounting/ap-aging',
    pdf: '/accounting/ap-aging.pdf',
    type: 'Payable',
    cadence: 'Current',
    description: 'Open vendor bills by age and due date.'
  }
];
const financialReports = [
  {
    name: 'Chart of accounts',
    href: '/accounting/accounts',
    pdf: '/accounting/accounts.pdf',
    type: 'Setup',
    cadence: 'As needed',
    description: 'Account list used for posting and reports.'
  },
  {
    name: 'Journal entries',
    href: '/accounting/journal',
    pdf: '/accounting/journal.pdf',
    type: 'Ledger',
    cadence: 'As posted',
    description: 'Posted accounting activity from invoices, bills, and payments.'
  },
  {
    name: 'Trial balance',
    href: '/accounting/reports/trial-balance',
    pdf: '/accounting/reports/trial-balance.pdf',
    type: 'Report',
    cadence: 'Current',
    description: 'Debit and credit balances from posted journal lines.'
  },
  {
    name: 'Profit & loss',
    href: '/accounting/reports/profit-loss',
    pdf: '/accounting/reports/profit-loss.pdf',
    type: 'Report',
    cadence: 'Current',
    description: 'Revenue, expenses, and net income.'
  },
  {
    name: 'Balance sheet',
    href: '/accounting/reports/balance-sheet',
    pdf: '/accounting/reports/balance-sheet.pdf',
    type: 'Report',
    cadence: 'Current',
    description: 'Assets, liabilities, equity, and balance check.'
  }
];
const importTools = [
  {
    name: 'Bank transactions',
    href: '/accounting/bank-transactions',
    pdf: '',
    type: 'Review',
    cadence: 'Manual import',
    description: 'Review bank activity and assign chart accounts before posting.'
  },
  {
    name: 'Payroll',
    href: '/accounting/payroll',
    pdf: '',
    type: 'Admin only',
    cadence: 'QuickBooks source',
    description: 'Review payroll roster, payroll runs, and labor-cost allocation status.'
  }
];
const allReports = primaryReports.concat(financialReports);
%>

<style>
  .accounting-table {
    table-layout: fixed;
    min-width: 64rem;
  }
  .accounting-table .acct-name-col { width: 17%; }
  .accounting-table .acct-type-col { width: 13%; }
  .accounting-table .acct-description-col { width: 45%; }
  .accounting-table .acct-updated-col { width: 12%; }
  .accounting-table .acct-actions-col { width: 13%; }
  .accounting-actions {
    display: inline-flex;
    align-items: center;
    justify-content: flex-end;
    gap: .55rem;
    width: 100%;
    white-space: nowrap;
  }
  .accounting-actions .btn {
    min-width: 3.75rem;
    text-align: center;
  }
  .accounting-actions .acct-pdf-link {
    display: inline-block;
    min-width: 2rem;
    text-align: center;
    color: #1a1a1a;
    font-size: .78rem;
    font-weight: 600;
  }
  .accounting-actions .acct-pdf-link:hover { color: #c0202b; }
</style>

<div class="ops-shell">
  <div class="ops-header">
    <div class="ops-title-block">
      <h1 class="page-h1">Accounting</h1>
      <p class="page-sub mt-1">Aging, ledgers, and financial reports.</p>
    </div>
  </div>

  <div class="ops-summary">
    <div class="ops-summary-item">
      <div class="ops-summary-label">Reports</div>
      <div class="ops-summary-value"><%= allReports.length + importTools.length %></div>
      <div class="ops-summary-meta">views available</div>
    </div>
    <div class="ops-summary-item">
      <div class="ops-summary-label">Banking</div>
      <div class="ops-summary-value">1</div>
      <div class="ops-summary-meta">review workspace</div>
    </div>
    <div class="ops-summary-item">
      <div class="ops-summary-label">Ledger</div>
      <div class="ops-summary-value">1</div>
      <div class="ops-summary-meta">journal register</div>
    </div>
    <div class="ops-summary-item">
      <div class="ops-summary-label">Exports</div>
      <div class="ops-summary-value">PDF</div>
      <div class="ops-summary-meta">print-ready</div>
    </div>
  </div>

  <div class="ops-panel ops-table mb-4">
    <div class="ops-panel-head">
      <div class="ops-panel-title">Import controls</div>
      <div class="text-xs text-recon-fog"><%= importTools.length %> tool</div>
    </div>
    <div class="ops-panel-body">
      <table class="data accounting-table">
        <colgroup>
          <col class="acct-name-col">
          <col class="acct-type-col">
          <col class="acct-description-col">
          <col class="acct-updated-col">
          <col class="acct-actions-col">
        </colgroup>
        <thead>
          <tr>
            <th>Tool</th>
            <th>Type</th>
            <th>Description</th>
            <th>Status</th>
            <th class="text-right">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% importTools.forEach(function(r){ %>
            <tr class="row-link" data-href="<%= r.href %>">
              <td class="font-semibold"><%= r.name %></td>
              <td><span class="badge badge-draft"><%= r.type %></span></td>
              <td class="text-recon-fog"><%= r.description %></td>
              <td><%= r.cadence %></td>
              <td class="text-right">
                <span class="accounting-actions">
                  <a href="<%= r.href %>" class="btn btn-secondary text-xs">Open</a>
                </span>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="ops-panel ops-table mb-4">
    <div class="ops-panel-head">
      <div class="ops-panel-title">Aging</div>
      <div class="text-xs text-recon-fog"><%= primaryReports.length %> views</div>
    </div>
    <div class="ops-panel-body">
      <table class="data accounting-table">
        <colgroup>
          <col class="acct-name-col">
          <col class="acct-type-col">
          <col class="acct-description-col">
          <col class="acct-updated-col">
          <col class="acct-actions-col">
        </colgroup>
        <thead>
          <tr>
            <th>View</th>
            <th>Type</th>
            <th>Description</th>
            <th>Updated</th>
            <th class="text-right">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% primaryReports.forEach(function(r){ %>
            <tr class="row-link" data-href="<%= r.href %>">
              <td class="font-semibold"><%= r.name %></td>
              <td><span class="badge badge-draft"><%= r.type %></span></td>
              <td class="text-recon-fog"><%= r.description %></td>
              <td><%= r.cadence %></td>
              <td class="text-right">
                <span class="accounting-actions">
                  <a href="<%= r.href %>" class="btn btn-secondary text-xs">Open</a>
                  <a href="<%= r.pdf %>" class="acct-pdf-link">PDF</a>
                </span>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="ops-panel ops-table">
    <div class="ops-panel-head">
      <div class="ops-panel-title">Reports and ledger</div>
      <div class="text-xs text-recon-fog"><%= financialReports.length %> items</div>
    </div>
    <div class="ops-panel-body">
      <table class="data accounting-table">
        <colgroup>
          <col class="acct-name-col">
          <col class="acct-type-col">
          <col class="acct-description-col">
          <col class="acct-updated-col">
          <col class="acct-actions-col">
        </colgroup>
        <thead>
          <tr>
            <th>Report</th>
            <th>Type</th>
            <th>Description</th>
            <th>Updated</th>
            <th class="text-right">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% financialReports.forEach(function(r){ %>
            <tr class="row-link" data-href="<%= r.href %>">
              <td class="font-semibold"><%= r.name %></td>
              <td><span class="badge badge-draft"><%= r.type %></span></td>
              <td class="text-recon-fog"><%= r.description %></td>
              <td><%= r.cadence %></td>
              <td class="text-right">
                <span class="accounting-actions">
                  <a href="<%= r.href %>" class="btn btn-secondary text-xs">Open</a>
                  <a href="<%= r.pdf %>" class="acct-pdf-link">PDF</a>
                </span>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<%- include('../layouts/footer') %>
