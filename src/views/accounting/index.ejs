<%- include('../layouts/header', { title: title, currentUser: currentUser, flash: flash, activeNav: activeNav }) %>

<div class="max-w-7xl mx-auto px-4 py-6">
  <h1 class="page-h1 mb-2">Accounting</h1>
  <p class="page-sub mb-6">Financial cockpit — aging, reports, and journal entries.</p>

  <!-- Aging cards -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
    <a href="/accounting/ar-aging" class="card p-6 hover:shadow-md transition block border-l-4 border-recon-red">
      <div class="text-2xl font-bold text-recon-red mb-1">AR Aging</div>
      <p class="text-sm text-recon-fog">Accounts receivable by age — who owes you money and how overdue.</p>
    </a>
    <a href="/accounting/ap-aging" class="card p-6 hover:shadow-md transition block border-l-4 border-amber-500">
      <div class="text-2xl font-bold text-amber-600 mb-1">AP Aging</div>
      <p class="text-sm text-recon-fog">Accounts payable by age — who you owe and when it's due.</p>
    </a>
  </div>

  <!-- Reports + tools grid -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
    <a href="/accounting/accounts" class="card p-6 hover:shadow-md transition block">
      <div class="text-lg font-bold text-recon-red mb-1">Chart of accounts</div>
      <p class="text-sm text-recon-fog">View and print/export the account list.</p>
    </a>
    <a href="/accounting/journal" class="card p-6 hover:shadow-md transition block">
      <div class="text-lg font-bold text-recon-red mb-1">Journal entries</div>
      <p class="text-sm text-recon-fog">Browse posted entries and export journal detail.</p>
    </a>
    <a href="/accounting/reports/trial-balance" class="card p-6 hover:shadow-md transition block">
      <div class="text-lg font-bold text-recon-red mb-1">Trial balance</div>
      <p class="text-sm text-recon-fog">Debit and credit report from posted journal lines.</p>
    </a>
    <a href="/accounting/reports/profit-loss" class="card p-6 hover:shadow-md transition block">
      <div class="text-lg font-bold text-recon-red mb-1">Profit &amp; loss</div>
      <p class="text-sm text-recon-fog">Revenue, expenses, and net income.</p>
    </a>
    <a href="/accounting/reports/balance-sheet" class="card p-6 hover:shadow-md transition block">
      <div class="text-lg font-bold text-recon-red mb-1">Balance sheet</div>
      <p class="text-sm text-recon-fog">Assets, liabilities, equity, and balance check.</p>
    </a>
  </div>
</div>

<%- include('../layouts/footer') %>
