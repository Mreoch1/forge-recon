<%- include('../layouts/header', { title: title, currentUser: currentUser, flash: flash, activeNav: activeNav }) %>

<div class="ops-shell">
  <div class="ops-header">
    <div class="ops-title-block">
      <a href="/accounting" class="text-sm text-recon-fog hover:text-recon-red">&larr; Accounting</a>
      <h1 class="page-h1 mt-3">QuickBooks import staging</h1>
      <p class="page-sub mt-1">Review exports and staged rows before anything touches live Forge records.</p>
    </div>
    <div class="flex gap-2 flex-wrap">
      <% if (qbConnected) { %>
        <form action="/accounting/quickbooks/sync" method="post" class="m-0 inline">
          <input type="hidden" name="entity" value="customers">
          <button class="btn btn-secondary text-sm" title="Pull customers from QuickBooks">Sync Customers</button>
        </form>
        <form action="/accounting/quickbooks/sync" method="post" class="m-0 inline">
          <input type="hidden" name="entity" value="invoices">
          <button class="btn btn-secondary text-sm" title="Pull invoices from QuickBooks">Sync Invoices</button>
        </form>
        <form action="/accounting/quickbooks/sync" method="post" class="m-0 inline">
          <input type="hidden" name="entity" value="bills">
          <button class="btn btn-secondary text-sm" title="Pull bills from QuickBooks">Sync Bills</button>
        </form>
        <form action="/accounting/quickbooks/disconnect" method="post" class="m-0 inline"
              onsubmit="return confirm('Disconnect QuickBooks?');">
          <button class="btn btn-ghost text-sm text-recon-red">Disconnect</button>
        </form>
        <span class="inline-flex items-center gap-1 text-xs text-green-700 bg-green-50 px-2 py-1 rounded">
          ✓ Connected
        </span>
      <% } else { %>
        <a href="/accounting/quickbooks/connect" class="btn btn-primary text-sm">Connect to QuickBooks</a>
        <span class="inline-flex items-center gap-1 text-xs text-recon-fog px-2 py-1 rounded">
          Not connected
        </span>
      <% } %>
    </div>
  </div>

  <div class="ops-summary">
    <div class="ops-summary-item">
      <div class="ops-summary-label">Reviewed exports</div>
      <div class="ops-summary-value"><%= exportCards.length %></div>
      <div class="ops-summary-meta">discovery files</div>
    </div>
    <div class="ops-summary-item">
      <div class="ops-summary-label">Staged batches</div>
      <div class="ops-summary-value"><%= staging.ready ? staging.batchCount : '0' %></div>
      <div class="ops-summary-meta"><%= staging.ready ? 'database ready' : 'setup pending' %></div>
    </div>
    <div class="ops-summary-item">
      <div class="ops-summary-label">Staged rows</div>
      <div class="ops-summary-value"><%= staging.ready ? staging.rowCount : '0' %></div>
      <div class="ops-summary-meta">not applied</div>
    </div>
    <div class="ops-summary-item">
      <div class="ops-summary-label">Guardrail</div>
      <div class="ops-summary-value">Review</div>
      <div class="ops-summary-meta">before import</div>
    </div>
  </div>

  <% if (!staging.ready) { %>
    <div class="card border border-yellow-200 bg-yellow-50 text-yellow-900 p-4 mb-4">
      QuickBooks staging tables are not available yet. Deploy the latest migration before loading imports.
      <% if (staging.error) { %><span class="block text-xs mt-1">Database said: <%= staging.error %></span><% } %>
    </div>
  <% } %>

  <div class="ops-panel ops-table mb-4">
    <div class="ops-panel-head">
      <div class="ops-panel-title">QuickBooks files reviewed</div>
      <div class="text-xs text-recon-fog"><%= summary.generated_at ? 'Summary generated ' + String(summary.generated_at).slice(0, 10) : 'Discovery summary' %></div>
    </div>
    <div class="ops-panel-body">
      <table class="data">
        <thead>
          <tr>
            <th>Export</th>
            <th>Source file</th>
            <th class="text-right">Rows / records</th>
            <th class="text-right">Amount</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          <% exportCards.forEach(function(card){ %>
            <tr>
              <td class="font-semibold"><%= card.label %></td>
              <td class="text-recon-fog"><%= card.source %></td>
              <td class="text-right font-mono"><%= card.count %></td>
              <td class="text-right font-mono"><%= card.amount || '-' %></td>
              <td><span class="badge badge-draft"><%= card.status %></span></td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="ops-panel ops-table mb-4">
    <div class="ops-panel-head">
      <div class="ops-panel-title">Import order</div>
      <div class="text-xs text-recon-fog"><%= (summary.import_sequence || []).length %> steps</div>
    </div>
    <div class="ops-panel-body">
      <table class="data">
        <thead>
          <tr>
            <th class="w-20">Step</th>
            <th>Source</th>
            <th>Why it comes here</th>
          </tr>
        </thead>
        <tbody>
          <% (summary.import_sequence || []).forEach(function(step, idx){ %>
            <tr>
              <td class="font-mono"><%= idx + 1 %></td>
              <td class="font-semibold"><%= String(step).replace(/_/g, ' ') %></td>
              <td class="text-recon-fog">
                <% if (step === 'chart_of_accounts') { %>Accounts need to exist before invoices, bills, and journal entries can post.<% } %>
                <% if (step === 'customers') { %>Customers must be cleaned up before A/R invoices or projects are matched.<% } %>
                <% if (step === 'vendors') { %>Vendors and contractors need one reviewed company record before A/P is loaded.<% } %>
                <% if (step === 'opening_ar') { %>A/R should reconcile to QuickBooks before historical invoices are trusted.<% } %>
                <% if (step === 'opening_ap') { %>A/P should reconcile to QuickBooks before bill detail is applied.<% } %>
                <% if (step === 'projects_and_open_work') { %>Projects and active work connect customer balances back to operations.<% } %>
                <% if (step === 'products_services') { %>Line-item labels and income/cost mappings get reviewed after account setup.<% } %>
                <% if (step === 'historical_transactions') { %>History comes last so current balances stay the control totals.<% } %>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="ops-panel ops-table">
    <div class="ops-panel-head">
      <div class="ops-panel-title">Staged batches</div>
      <div class="text-xs text-recon-fog">No live records are changed from this table</div>
    </div>
    <div class="ops-panel-body">
      <% if (!staging.ready || staging.batches.length === 0) { %>
        <div class="empty-state">No QuickBooks batches have been staged yet.</div>
      <% } else { %>
        <table class="data">
          <thead>
            <tr>
              <th>File</th>
              <th>Type</th>
              <th>Status</th>
              <th class="text-right">Rows</th>
              <th class="text-right">Total</th>
              <th>Imported</th>
            </tr>
          </thead>
          <tbody>
            <% staging.batches.forEach(function(batch){ %>
              <tr>
                <td class="font-semibold"><%= batch.original_filename %></td>
                <td><%= String(batch.source_type).replace(/_/g, ' ') %></td>
                <td><span class="badge badge-draft"><%= batch.status %></span></td>
                <td class="text-right font-mono"><%= batch.row_count || 0 %></td>
                <td class="text-right font-mono"><%= batch.total_amount == null ? '-' : money(batch.total_amount) %></td>
                <td class="text-recon-fog"><%= batch.imported_at ? String(batch.imported_at).slice(0, 10) : '-' %></td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      <% } %>
    </div>
  </div>
</div>

<%- include('../layouts/footer') %>
