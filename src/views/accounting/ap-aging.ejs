<%- include('../layouts/header', { title: title, currentUser: currentUser, flash: flash, activeNav: activeNav }) %>

<div class="ops-shell">
  <div class="mb-4">
    <a href="/accounting" class="text-sm text-recon-fog hover:text-recon-red">&larr; Accounting</a>
  </div>

  <div class="flex items-center justify-between gap-3 mb-6 flex-wrap">
    <h1 class="page-h1">AP Aging</h1>
    <div class="flex gap-2 no-print">
      <button type="button" class="btn btn-secondary text-sm" onclick="window.print()">Print</button>
      <a href="/accounting/ap-aging.pdf" class="btn btn-secondary text-sm">PDF</a>
    </div>
  </div>

  <!-- Bucket summary — clickable to filter -->
  <div class="grid grid-cols-2 md:grid-cols-5 gap-3 mb-8" id="bucket-filters">
    <% ['Current','1-30','31-60','61-90','90+'].forEach(function(b){ %>
      <a href="#" data-bucket="<%= b %>"
         class="card p-4 text-center block hover:shadow-md transition-shadow cursor-pointer <%= b === '90+' ? 'border-red-200' : '' %>">
        <div class="text-xs uppercase tracking-wide text-recon-fog"><%= b %></div>
        <div class="text-xl font-bold mt-1 <%= b === '90+' ? 'text-recon-red' : '' %>">$<%= fmt(buckets[b] || 0) %></div>
      </a>
    <% }); %>
  </div>

  <!-- Aging table -->
  <div class="card overflow-hidden">
    <div class="px-5 py-3 border-b border-recon-mist flex items-center justify-between">
      <h3 class="font-semibold"><span id="row-count"><%= rows.length %></span> open item<%= rows.length === 1 ? '' : 's' %></h3>
      <div id="active-filter" class="hidden flex items-center gap-2">
        <span class="text-xs text-recon-fog">Filtered: <span id="filter-label"></span></span>
        <button id="clear-filter" class="text-xs text-recon-red hover:underline">Clear</button>
      </div>
    </div>
    <% if (rows.length === 0) { %>
      <div class="p-6 text-center text-recon-fog text-sm">No outstanding payables. Everything is current!</div>
    <% } else { %>
      <div class="overflow-x-auto">
        <table class="data" id="ap-table">
          <thead>
            <tr>
              <th data-sort="vendor" class="cursor-pointer hover:text-recon-red select-none">Vendor <span class="sort-arrow"></span></th>
              <th data-sort="source" class="cursor-pointer hover:text-recon-red select-none">Source <span class="sort-arrow"></span></th>
              <th data-sort="ref" class="cursor-pointer hover:text-recon-red select-none">Reference <span class="sort-arrow"></span></th>
              <th data-sort="dueDate" class="cursor-pointer hover:text-recon-red select-none">Due <span class="sort-arrow"></span></th>
              <th data-sort="ageDays" class="text-right cursor-pointer hover:text-recon-red select-none">Age (days) <span class="sort-arrow"></span></th>
              <th data-sort="total" class="text-right cursor-pointer hover:text-recon-red select-none">Total <span class="sort-arrow"></span></th>
              <th data-sort="balance" class="text-right cursor-pointer hover:text-recon-red select-none">Balance <span class="sort-arrow"></span></th>
              <th data-sort="bucket" class="cursor-pointer hover:text-recon-red select-none">Bucket <span class="sort-arrow"></span></th>
            </tr>
          </thead>
          <tbody id="ap-body">
            <% rows.forEach(function(r){ %>
              <tr data-bucket="<%= r.bucket %>">
                <td><%= r.vendor %></td>
                <td><span class="badge badge-info"><%= r.source %></span></td>
                <td class="font-mono text-xs">
                  <% if (r.source === 'Bill') { %>
                    <a href="/bills/<%= r.id %>" class="hover:text-recon-red"><%= r.ref %></a>
                  <% } else { %>
                    <%= r.ref %>
                  <% } %>
                </td>
                <td class="text-xs"><%= r.dueDate %></td>
                <td class="text-right"><%= r.ageDays %></td>
                <td class="text-right">$<%= fmt(r.total) %></td>
                <td class="text-right font-semibold <%= r.balance > 0 ? 'text-recon-red' : '' %>">$<%= fmt(r.balance) %></td>
                <td><span class="badge <%= r.bucket === '90+' ? 'badge-danger' : 'badge-info' %>"><%= r.bucket %></span></td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</div>

<script>
(function(){
  var rows = Array.from(document.querySelectorAll('#ap-body tr'));
  var filterLabel = document.getElementById('filter-label');
  var activeFilter = document.getElementById('active-filter');
  var rowCount = document.getElementById('row-count');
  var currentBucket = null;
  var sortKey = null;
  var sortDir = 1;

  document.querySelectorAll('[data-bucket]').forEach(function(el){
    el.addEventListener('click', function(e){
      e.preventDefault();
      var bucket = el.dataset.bucket;
      currentBucket = (currentBucket === bucket) ? null : bucket;
      applyFilter();
    });
  });

  document.getElementById('clear-filter').addEventListener('click', function(){
    currentBucket = null;
    applyFilter();
  });

  function applyFilter() {
    var visible = 0;
    rows.forEach(function(row){
      var match = !currentBucket || row.dataset.bucket === currentBucket;
      row.style.display = match ? '' : 'none';
      if (match) visible++;
    });
    rowCount.textContent = visible;
    if (currentBucket) {
      filterLabel.textContent = currentBucket;
      activeFilter.classList.remove('hidden');
    } else {
      activeFilter.classList.add('hidden');
    }
    document.querySelectorAll('[data-bucket]').forEach(function(card){
      card.classList.toggle('ring-2', card.dataset.bucket === currentBucket);
      card.classList.toggle('ring-recon-red', card.dataset.bucket === currentBucket);
    });
  }

  document.querySelectorAll('[data-sort]').forEach(function(th){
    th.addEventListener('click', function(){
      var key = th.dataset.sort;
      sortKey = (sortKey === key) ? sortKey : key;
      sortDir = (sortKey === key) ? sortDir * -1 : 1;
      sortKey = key;
      sortTable(key, sortDir);
      document.querySelectorAll('[data-sort]').forEach(function(h){
        var arrow = h.querySelector('.sort-arrow');
        if (arrow) arrow.textContent = '';
      });
      var arrow = th.querySelector('.sort-arrow');
      if (arrow) arrow.textContent = sortDir === 1 ? ' ▲' : ' ▼';
    });
  });

  function sortTable(key, dir) {
    var tbody = document.getElementById('ap-body');
    var colIndex = { vendor:0, source:1, ref:2, dueDate:3, ageDays:4, total:5, balance:6, bucket:7 };
    var idx = colIndex[key] || 0;
    var sorted = rows.slice().sort(function(a, b){
      var va = a.querySelector('td:nth-child(' + (idx + 1) + ')').textContent.trim();
      var vb = b.querySelector('td:nth-child(' + (idx + 1) + ')').textContent.trim();
      if (['ageDays', 'total', 'balance'].includes(key)) {
        va = parseFloat(va.replace(/[$,]/g, '')) || 0;
        vb = parseFloat(vb.replace(/[$,]/g, '')) || 0;
        return (va - vb) * dir;
      }
      return va.localeCompare(vb) * dir;
    });
    sorted.forEach(function(row){ tbody.appendChild(row); });
    applyFilter();
  }
})();
</script>

<%- include('../layouts/footer') %>
