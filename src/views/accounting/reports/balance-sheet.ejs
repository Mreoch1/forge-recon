<%- include('../../layouts/header', { title: title, currentUser: currentUser, flash: flash, activeNav: activeNav }) %>
<div class="document-shell">
  <div class="mb-4"><a href="/accounting" class="text-sm text-recon-fog hover:text-recon-red">&larr; Accounting</a></div>
  <div class="flex items-center justify-between gap-3 mb-6 flex-wrap">
    <div>
      <h1 class="page-h1">Balance sheet</h1>
      <p class="page-sub mt-1"><%= range ? range.label : 'Current range' %></p>
    </div>
    <div class="flex gap-2 no-print">
      <button type="button" class="btn btn-secondary text-sm" onclick="window.print()">Print</button>
      <a href="/accounting/reports/balance-sheet.pdf<%= range ? '?range=' + encodeURIComponent(range.value) : '' %>" class="btn btn-secondary text-sm">PDF</a>
    </div>
  </div>
  <form method="get" class="card p-4 mb-6 no-print">
    <div class="flex flex-wrap items-end gap-3">
      <div>
        <label class="form-label" for="range">Date range</label>
        <select id="range" name="range" class="input min-w-[180px]">
          <% rangeOptions.forEach(function(option){ %>
            <option value="<%= option.value %>" <%= range && option.value === range.value ? 'selected' : '' %>><%= option.label %></option>
          <% }); %>
        </select>
      </div>
      <button type="submit" class="btn btn-secondary text-sm">Apply</button>
    </div>
  </form>
  <% if ((!assets || assets.length === 0) && (!liabilities || liabilities.length === 0) && (!equity || equity.length === 0)) { %>
    <div class="card p-8 text-center"><p class="text-recon-fog">No account balances yet.</p></div>
  <% } else { %>
    <div class="card p-6 mb-4">
      <h3 class="font-semibold text-blue-700 mb-2">Assets</h3>
      <table class="w-full"><tbody>
        <% assets.forEach(function(a) { %>
          <tr><td><%= a.name %></td><td class="text-right font-mono">$<%= fmt(a.amount) %></td></tr>
        <% }); %>
        <tr class="font-semibold border-t"><td>Total Assets</td><td class="text-right font-mono">$<%= fmt(totalAssets) %></td></tr>
      </tbody></table>
    </div>
    <div class="card p-6 mb-4">
      <h3 class="font-semibold text-amber-700 mb-2">Liabilities</h3>
      <table class="w-full"><tbody>
        <% liabilities.forEach(function(l) { %>
          <tr><td><%= l.name %></td><td class="text-right font-mono">$<%= fmt(l.amount) %></td></tr>
        <% }); %>
        <tr class="font-semibold border-t"><td>Total Liabilities</td><td class="text-right font-mono">$<%= fmt(totalLiabilities) %></td></tr>
      </tbody></table>
    </div>
    <div class="card p-6 mb-6">
      <h3 class="font-semibold text-purple-700 mb-2">Equity</h3>
      <table class="w-full"><tbody>
        <% equity.forEach(function(e) { %>
          <tr><td><%= e.name %></td><td class="text-right font-mono">$<%= fmt(e.amount) %></td></tr>
        <% }); %>
        <tr><td>Net Income (current period)</td><td class="text-right font-mono">$<%= fmt(netIncome) %></td></tr>
        <tr class="font-semibold border-t"><td>Total Equity</td><td class="text-right font-mono">$<%= fmt(totalEquity) %></td></tr>
      </tbody></table>
    </div>
    <div class="card p-4 <%= balanced ? 'bg-green-50 border-green-200' : 'bg-red-50 border-red-200' %>">
      <p class="text-center <%= balanced ? 'text-green-700' : 'text-red-700' %> font-semibold">
        <%= balanced ? 'Balanced: Assets = Liabilities + Equity' : 'Unbalanced: Assets do not equal Liabilities + Equity' %>
      </p>
      <p class="text-center text-sm text-recon-fog mt-1">
        Assets $<%= fmt(totalAssets) %> = Liabilities $<%= fmt(totalLiabilities) %> + Equity $<%= fmt(totalEquity) %>
      </p>
    </div>
  <% } %>
</div>
<%- include('../../layouts/footer') %>
