<%- include('../../layouts/header', { title: title, currentUser: currentUser, flash: flash, activeNav: activeNav }) %>
<div class="max-w-4xl mx-auto px-4 py-6">
  <div class="mb-4"><a href="/accounting" class="text-sm text-recon-fog hover:text-recon-red">&larr; Accounting</a></div>
  <h1 class="page-h1 mb-6">Profit &amp; loss</h1>
  <% if (!revenueRows || revenueRows.length === 0) { %>
    <div class="card p-8 text-center"><p class="text-recon-fog">No revenue or expense entries yet.</p></div>
  <% } else { %>
    <div class="card p-6 mb-4">
      <h3 class="font-semibold text-green-700 mb-2">Revenue</h3>
      <table class="w-full"><tbody>
        <% revenueRows.forEach(function(r) { %>
          <tr><td><%= r.name %></td><td class="text-right font-mono">$<%= fmt(r.amount) %></td></tr>
        <% }); %>
        <tr class="font-semibold border-t"><td>Total Revenue</td><td class="text-right font-mono">$<%= fmt(totalRevenue) %></td></tr>
      </tbody></table>
    </div>
    <div class="card p-6 mb-4">
      <h3 class="font-semibold text-red-700 mb-2">Expenses</h3>
      <table class="w-full"><tbody>
        <% expenseRows.forEach(function(r) { %>
          <tr><td><%= r.name %></td><td class="text-right font-mono">$<%= fmt(r.amount) %></td></tr>
        <% }); %>
        <tr class="font-semibold border-t"><td>Total Expenses</td><td class="text-right font-mono">$<%= fmt(totalExpenses) %></td></tr>
      </tbody></table>
    </div>
    <div class="card p-6 <%= netIncome >= 0 ? 'bg-green-50 border-green-200' : 'bg-red-50 border-red-200' %>">
      <div class="flex justify-between items-center">
        <span class="text-xl font-bold <%= netIncome >= 0 ? 'text-green-700' : 'text-red-700' %>">Net Income</span>
        <span class="text-xl font-bold font-mono <%= netIncome >= 0 ? 'text-green-700' : 'text-red-700' %>">$<%= fmt(netIncome) %></span>
      </div>
    </div>
  <% } %>
</div>
<%- include('../../layouts/footer') %>
