<%- include('../layouts/header', { title: title, currentUser: currentUser, flash: flash, activeNav: activeNav }) %>
<%
const pageTotal = (bills || []).reduce(function(s, b){ return s + (Number(b.total) || 0); }, 0);
const pagePaid = (bills || []).reduce(function(s, b){ return s + (Number(b.amount_paid) || 0); }, 0);
const paidCount = (bills || []).filter(function(b){ return b.status === 'paid'; }).length;
%>
<div class="ops-shell">
  <div class="ops-header">
    <div class="ops-title-block"><h1 class="page-h1">Billing</h1><p class="page-sub"><%= total %> total</p></div>
    <div class="ops-actions"><a href="/bills/new" class="btn btn-primary">+ New bill</a></div>
  </div>
  <div class="ops-summary">
    <div class="ops-summary-item"><div class="ops-summary-label">Total</div><div class="ops-summary-value"><%= total %></div><div class="ops-summary-meta">bills</div></div>
    <div class="ops-summary-item"><div class="ops-summary-label">Paid</div><div class="ops-summary-value"><%= paidCount %></div><div class="ops-summary-meta">closed bills shown</div></div>
    <div class="ops-summary-item"><div class="ops-summary-label">Open balance</div><div class="ops-summary-value">$<%= (pageTotal - pagePaid).toFixed(2) %></div><div class="ops-summary-meta">$<%= pageTotal.toFixed(2) %> billed shown</div></div>
  </div>
  <form method="get" class="list-utility-bar">
    <input type="text" name="q" value="<%= q || '' %>" placeholder="Search bill #, vendor..." class="list-search">
    <select name="vendor_id" class="list-filter">
      <option value="">All vendors</option>
      <% vendors.forEach(function(v) { %>
        <option value="<%= v.id %>" <%= String(vendorId) === String(v.id) ? 'selected' : '' %>><%= v.name %></option>
      <% }); %>
    </select>
    <button class="btn btn-secondary">Filter</button>
    <% if (status || vendorId || q) { %><a href="/bills" class="list-clear">Clear</a><% } %>
  </form>
  <% if (!bills || bills.length === 0) { %>
    <div class="ops-panel">
      <div class="ops-panel-head"><div class="ops-panel-title">Accounts payable</div><div class="text-xs text-recon-fog">0 shown</div></div>
      <div class="ops-empty">
        No bills yet. Add a <a href="/vendors" class="text-recon-red underline">vendor</a> first, then use <a href="/bills/new" class="text-recon-red underline">+ New bill</a> to record what you owe.
        <% if (status || vendorId || q) { %><div class="mt-3"><a href="/bills" class="btn btn-ghost">Clear filter</a></div><% } %>
      </div>
    </div>
  <% } else { %>
    <div class="ops-panel ops-table">
      <div class="ops-panel-head"><div class="ops-panel-title">Accounts payable</div><div class="text-xs text-recon-fog"><%= bills.length %> shown</div></div>
      <div class="ops-panel-body">
      <table class="data">
        <thead>
          <tr>
            <th>Bill #</th><th>Vendor</th><th class="text-right">Total</th>
            <th class="text-right">Paid</th><th class="text-right">Balance</th>
            <th>Date</th><th>Due</th><th>Invoice</th>
          </tr>
        </thead>
        <tbody>
          <% bills.forEach(function(b) { %>
            <% const bal = (Number(b.total) || 0) - (Number(b.amount_paid) || 0); %>
            <tr class="row-link" data-href="/bills/<%= b.id %>">
              <td><%= b.bill_number || '#' + b.id %></td>
              <td><%= b.vendor_name || '-' %></td>
              <td class="text-right">$<%= Number(b.total).toFixed(2) %></td>
              <td class="text-right">$<%= (Number(b.amount_paid) || 0).toFixed(2) %></td>
              <td class="text-right <%= bal > 0 ? 'text-recon-red font-medium' : '' %>">$<%= bal.toFixed(2) %></td>
              <td><%= b.bill_date ? String(b.bill_date).slice(0,10) : '-' %></td>
              <td><%= b.due_date ? String(b.due_date).slice(0,10) : '-' %></td>
              <td><% if (b.attachment_file_id) { %><a href="/files/<%= b.attachment_file_id %>/view" target="_blank" rel="noopener" class="text-recon-red hover:underline" onclick="event.stopPropagation()">PDF</a><% } else { %>—<% } %></td>
            </tr>
          <% }); %>
        </tbody>
      </table>
      </div>
    </div>
    <div class="flex justify-between items-center mt-4 text-sm text-recon-fog">
      <span>Page <%= page %> of <%= totalPages %></span>
      <div class="flex gap-2">
        <% if (page > 1) { %><a href="/bills?page=<%= page - 1 %><%= status ? '&status=' + status : '' %><%= vendorId ? '&vendor_id=' + vendorId : '' %><%= q ? '&q=' + encodeURIComponent(q) : '' %>" class="btn btn-ghost text-xs">Previous</a><% } %>
        <% if (page < totalPages) { %><a href="/bills?page=<%= page + 1 %><%= status ? '&status=' + status : '' %><%= vendorId ? '&vendor_id=' + vendorId : '' %><%= q ? '&q=' + encodeURIComponent(q) : '' %>" class="btn btn-ghost text-xs">Next</a><% } %>
      </div>
    </div>
  <% } %>
</div>
<%- include('../layouts/footer') %>
