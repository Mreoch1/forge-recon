<%
// Bills form (v0.7). Expects: bill, vendors, expenseAccounts, errors, formAction, submitLabel.
const linesToRender = (bill.lines && bill.lines.length) ? bill.lines : [{
  account_id: '', description: '', quantity: 1, unit_price: 0, line_total: 0
}];
function fmt(n) { const num = Number(n); return isFinite(num) ? num.toFixed(2) : '0.00'; }
function woSearchLabel(w) {
  const description = String(w.description || '').replace(/\s+/g, ' ').trim();
  return [
    `WO-${w.display_number}`,
    w.customer_name,
    w.job_title && w.job_title !== w.customer_name ? w.job_title : '',
    w.unit_number ? `Unit ${w.unit_number}` : '',
    w.address,
    description ? description.slice(0, 80) : '',
    w.invoice_id ? `INV-${w.display_number}` : '',
    w.status ? `Status ${String(w.status).replace(/_/g, ' ')}` : '',
  ].filter(Boolean).join(' | ');
}
const selectedWorkOrder = (workOrders || []).find(w => String(w.id) === String(bill.work_order_id));
const workOrdersJson = JSON.stringify(workOrders || []).replace(/</g, '\\u003c').replace(/>/g, '\\u003e');
%>
<form action="<%= formAction %>" method="post" class="space-y-6">
  <div class="card p-5">
    <h3 class="text-sm font-semibold uppercase tracking-wide text-recon-fog mb-3">Header</h3>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <div>
        <label class="label" for="vendor-search">Vendor <span class="text-recon-red">*</span>
          <span class="ml-1 text-recon-fog cursor-help" title="Search your existing vendors. Add new vendors under Vendors first.">ⓘ</span>
        </label>
        <input type="text" id="vendor-search" list="vendor-list" placeholder="Search or select vendor..." class="input" autocomplete="off"
               value="<%= vendorName || '' %>">
        <datalist id="vendor-list">
          <% (vendors || []).forEach(function(v){ %>
            <option value="<%= v.name %>" data-id="<%= v.id %>"></option>
          <% }); %>
        </datalist>
        <input type="hidden" name="vendor_id" id="vendor-id" value="<%= bill.vendor_id || '' %>">
      </div>
      <div>
        <label class="label" for="bill_number">Bill #
          <span class="ml-1 text-recon-fog cursor-help" title="The vendor's invoice number. Helps match payments to their records.">ⓘ</span>
        </label>
        <input type="text" name="bill_number" id="bill_number" value="<%= bill.bill_number || '' %>" class="input">
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="label" for="bill_date">Bill date
            <span class="ml-1 text-recon-fog cursor-help" title="Date printed on the vendor's invoice.">ⓘ</span>
          </label>
          <input type="date" name="bill_date" id="bill_date" value="<%= bill.bill_date ? String(bill.bill_date).slice(0,10) : '' %>" class="input<%= errors.bill_date ? ' border-red-500' : '' %>">
          <% if (errors.bill_date) { %><p class="text-sm text-red-600 mt-1"><%= errors.bill_date %></p><% } %>
        </div>
        <div>
          <label class="label" for="due_date">Due date
            <span class="ml-1 text-recon-fog cursor-help" title="When the vendor expects payment. Drives the AP aging report.">ⓘ</span>
          </label>
          <input type="date" name="due_date" id="due_date" value="<%= bill.due_date ? String(bill.due_date).slice(0,10) : '' %>" class="input<%= errors.due_date ? ' border-red-500' : '' %>">
          <% if (errors.due_date) { %><p class="text-sm text-red-600 mt-1"><%= errors.due_date %></p><% } %>
        </div>
      </div>
    </div>
  </div>

  <!-- Project + WO links for propagation. Form posts project_id; bills.js maps it to the legacy DB column. -->
  <div class="card p-5">
    <div class="flex items-start justify-between gap-4 mb-4">
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wide text-recon-fog">Link to Forge work</h3>
        <p class="text-xs text-recon-fog mt-1">Search the details printed on the vendor invoice instead of looking up the WO in another tab.</p>
      </div>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <div class="md:col-span-2">
        <label class="label" for="work-order-search">Find work order</label>
        <div class="flex items-center gap-2">
          <input type="text" id="work-order-search" list="work-order-list" class="input text-sm"
                 value="<%= selectedWorkOrder ? woSearchLabel(selectedWorkOrder) : '' %>"
                 placeholder="Search WO #, customer/site, unit, description, or invoice..." autocomplete="off">
          <button type="button" id="clear-work-order" class="btn btn-secondary" title="Clear linked work order" aria-label="Clear linked work order">&times;</button>
        </div>
        <datalist id="work-order-list">
          <% (workOrders || []).forEach(function(w){ %>
            <option value="<%= woSearchLabel(w) %>"></option>
          <% }); %>
        </datalist>
        <input type="hidden" name="work_order_id" id="work_order_id" value="<%= bill.work_order_id || '' %>">
        <p id="work-order-hint" class="text-xs text-recon-fog mt-2">Start typing any detail, then choose the matching work order.</p>
      </div>
      <div>
        <label class="label" for="project_id">Project</label>
        <select name="project_id" id="project_id" class="input text-sm">
          <option value="">— None —</option>
          <% (projects || []).forEach(function(j){ %>
            <option value="<%= j.id %>" <%= String(bill.job_id) === String(j.id) ? 'selected' : '' %>><%= j.title %><%= j.status && !['open', 'active', 'pending', 'in_progress'].includes(j.status) ? ' (' + j.status.replace(/_/g, ' ') + ')' : '' %></option>
          <% }); %>
        </select>
      </div>
    </div>
    <div id="work-order-match" class="mt-4 pt-4 border-t border-recon-mist <%= selectedWorkOrder ? '' : 'hidden' %>">
      <div class="grid grid-cols-1 md:grid-cols-4 gap-3 text-sm">
        <div><div class="text-xs uppercase text-recon-fog">Work order</div><a id="matched-wo-link" class="font-semibold text-recon-red hover:underline" href="<%= selectedWorkOrder ? '/work-orders/' + selectedWorkOrder.id : '#' %>"><%= selectedWorkOrder ? 'WO-' + selectedWorkOrder.display_number : '' %></a></div>
        <div><div class="text-xs uppercase text-recon-fog">Customer / project</div><div id="matched-wo-customer" class="font-medium"><%= selectedWorkOrder ? ([selectedWorkOrder.customer_name, selectedWorkOrder.job_title].filter(Boolean).filter((v, i, a) => a.indexOf(v) === i).join(' · ') || '—') : '' %></div></div>
        <div><div class="text-xs uppercase text-recon-fog">Unit / area</div><div id="matched-wo-unit" class="font-medium"><%= selectedWorkOrder ? (selectedWorkOrder.unit_number || '—') : '' %></div></div>
        <div><div class="text-xs uppercase text-recon-fog">Forge invoice</div><div id="matched-wo-invoice"><% if (selectedWorkOrder && selectedWorkOrder.invoice_id) { %><a class="font-semibold text-recon-red hover:underline" href="/invoices/<%= selectedWorkOrder.invoice_id %>">INV-<%= selectedWorkOrder.display_number %></a><% } else if (selectedWorkOrder) { %>None yet<% } %></div></div>
      </div>
      <p id="matched-wo-description" class="text-xs text-recon-fog mt-3"><%= selectedWorkOrder ? (selectedWorkOrder.description || '') : '' %></p>
    </div>
    <p class="text-xs text-recon-fog mt-3">Selecting a work order also selects its project and updates the project financials, WO billing list, and linked estimate/invoice costs.</p>
  </div>

  <div class="card overflow-hidden">
    <div class="px-5 py-3 border-b border-recon-mist flex items-center justify-between">
      <h3 class="font-semibold">Line items</h3>
      <button type="button" data-add-line class="btn btn-secondary text-sm">+ Add line</button>
    </div>
    <% if (errors.lines) { %>
      <div class="px-5 py-2 text-sm text-red-600 bg-red-50 border-b border-red-200"><%= errors.lines %></div>
    <% } %>
    <div class="overflow-x-auto">
      <table class="data" data-line-items>
        <thead>
          <tr>
            <th title="Expense account this line posts to in the general ledger. Leave as Misc if unsure.">Account</th>
            <th title="What you bought, e.g. lumber, drywall, sub labor.">Description</th>
            <th class="text-right" title="How many units.">Qty</th>
            <th class="text-right" title="Cost per unit.">Unit $</th>
            <th class="text-right" title="Qty x Unit $ for this line.">Line $</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% linesToRender.forEach(function(li, idx) { %>
            <tr class="line-row">
              <td>
                <select name="lines[<%= idx %>][account_id]" class="input" data-field="account_id">
                  <option value="">— Misc —</option>
                  <% expenseAccounts.forEach(function(a) { %>
                    <option value="<%= a.id %>" <%= String(li.account_id) === String(a.id) ? 'selected' : '' %>><%= a.code %> — <%= a.name %></option>
                  <% }); %>
                </select>
              </td>
              <td>
                <textarea name="lines[<%= idx %>][description]" data-field="description"
                          data-autosize rows="1" class="input"
                          style="min-height: 2.25rem; resize: vertical;"
                          placeholder="Lumber, drywall..."><%= li.description || '' %></textarea>
              </td>
              <td class="text-right">
                <input type="number" step="0.01" min="0" name="lines[<%= idx %>][quantity]" data-field="quantity"
                       value="<%= li.quantity %>" class="input text-right" style="width: 4rem;"
                       onfocus="this.select()" inputmode="decimal">
              </td>
              <td class="text-right">
                <input type="number" step="0.01" min="0" name="lines[<%= idx %>][unit_price]" data-field="unit_price"
                       value="<%= li.unit_price %>" class="input text-right" style="width: 7rem;">
              </td>
              <td class="text-right font-medium" data-field="line_total"><%= fmt(li.line_total) %></td>
              <td>
                <button type="button" data-remove-line class="text-recon-fog hover:text-recon-red text-sm">remove</button>
              </td>
            </tr>
          <% }); %>

          <tr class="line-row hidden" data-template>
            <td>
              <select name="lines[__IDX__][account_id]" class="input" data-field="account_id">
                <option value="">— Misc —</option>
                <% expenseAccounts.forEach(function(a) { %>
                  <option value="<%= a.id %>"><%= a.code %> — <%= a.name %></option>
                <% }); %>
              </select>
            </td>
            <td><textarea name="lines[__IDX__][description]" data-field="description" data-autosize rows="1" class="input" style="min-height: 2.25rem; resize: vertical;" placeholder="Lumber, drywall..."></textarea></td>
            <td class="text-right"><input type="number" step="0.01" min="0" name="lines[__IDX__][quantity]" data-field="quantity" value="1" class="input text-right" style="width: 4rem;" onfocus="this.select()" inputmode="decimal"></td>
            <td class="text-right"><input type="number" step="0.01" min="0" name="lines[__IDX__][unit_price]" data-field="unit_price" value="0" class="input text-right" style="width: 7rem;"></td>
            <td class="text-right font-medium" data-field="line_total">0.00</td>
            <td><button type="button" data-remove-line class="text-recon-fog hover:text-recon-red text-sm">remove</button></td>
          </tr>
        </tbody>
        <tfoot class="bg-recon-cloud">
          <tr>
            <td colspan="4" class="text-right text-sm font-medium">Subtotal</td>
            <td class="text-right font-semibold">$<span data-totals="subtotal">0.00</span></td>
            <td></td>
          </tr>
          <tr>
            <td colspan="4" class="text-right text-sm font-medium">Total</td>
            <td class="text-right text-lg font-bold text-recon-red">$<span data-totals="total">0.00</span></td>
            <td></td>
          </tr>
        </tfoot>
      </table>
    </div>
  </div>

  <div class="card p-5">
    <label class="label" for="notes">Notes / memo
          <span class="ml-1 text-recon-fog cursor-help" title="Internal memo for this bill (PO number, approver, project reference). Not shown to the vendor.">ⓘ</span>
    </label>
    <textarea name="notes" id="notes" rows="3" class="input" data-autosize><%= bill.notes || '' %></textarea>
  </div>

  <div class="flex items-center gap-2 pt-2">
    <button type="submit" class="btn btn-primary"><%= submitLabel %></button>
    <a href="/bills" class="btn btn-ghost">Cancel</a>
  </div>
</form>

<script src="/js/line-items.js"></script>

<script>
// Vendor autocomplete (native datalist) — matches WO customer selector pattern
(function(){
  var vendors = <%- JSON.stringify(vendors || []) %>;
  var search = document.getElementById('vendor-search');
  var hidden = document.getElementById('vendor-id');

  function showVendor(id) {
    var v = vendors.find(function(x){ return x.id == id; });
    if (!v) return;
    hidden.value = v.id;
    search.value = v.name;
  }

  if (hidden.value) showVendor(hidden.value);

  search.addEventListener('change', function(){
    var selectedName = search.value;
    var match = vendors.find(function(v){ return v.name === selectedName; });
    if (match) { hidden.value = match.id; }
    else { hidden.value = ''; }
  });

  search.addEventListener('input', function(){
    var selectedName = search.value;
    var match = vendors.find(function(v){ return v.name === selectedName; });
    if (!match) { hidden.value = ''; }
  });
})();

// Match vendor paperwork to Forge by any detail visible on the bill. The hidden
// work_order_id remains the posted value; the richer search label is UI only.
(function(){
  var workOrders = <%- workOrdersJson %>;
  var search = document.getElementById('work-order-search');
  var hidden = document.getElementById('work_order_id');
  var project = document.getElementById('project_id');
  var clear = document.getElementById('clear-work-order');
  var matchPanel = document.getElementById('work-order-match');
  var hint = document.getElementById('work-order-hint');
  if (!search || !hidden) return;

  function labelFor(w) {
    var description = String(w.description || '').replace(/\s+/g, ' ').trim();
    return [
      'WO-' + w.display_number,
      w.customer_name,
      w.job_title && w.job_title !== w.customer_name ? w.job_title : '',
      w.unit_number ? 'Unit ' + w.unit_number : '',
      w.address,
      description ? description.slice(0, 80) : '',
      w.invoice_id ? 'INV-' + w.display_number : '',
      w.status ? 'Status ' + String(w.status).replace(/_/g, ' ') : ''
    ].filter(Boolean).join(' | ');
  }

  function findMatch(value) {
    var normalized = String(value || '').trim().toLowerCase();
    if (!normalized) return null;
    return workOrders.find(function(w) {
      return labelFor(w).toLowerCase() === normalized ||
        ('wo-' + String(w.display_number)).toLowerCase() === normalized ||
        String(w.display_number).toLowerCase() === normalized;
    }) || null;
  }

  function renderMatch(w) {
    if (!w) {
      hidden.value = '';
      matchPanel.classList.add('hidden');
      hint.textContent = search.value ? 'Choose a matching result to link this bill.' : 'Start typing any detail, then choose the matching work order.';
      return;
    }
    hidden.value = w.id;
    if (w.job_id && project) project.value = String(w.job_id);
    search.value = labelFor(w);
    document.getElementById('matched-wo-link').href = '/work-orders/' + w.id;
    document.getElementById('matched-wo-link').textContent = 'WO-' + w.display_number;
    document.getElementById('matched-wo-customer').textContent = [w.customer_name, w.job_title].filter(Boolean).filter(function(value, index, values) { return values.indexOf(value) === index; }).join(' · ') || '—';
    document.getElementById('matched-wo-unit').textContent = w.unit_number || '—';
    document.getElementById('matched-wo-description').textContent = w.description || '';
    var invoice = document.getElementById('matched-wo-invoice');
    invoice.textContent = '';
    if (w.invoice_id) {
      var link = document.createElement('a');
      link.href = '/invoices/' + w.invoice_id;
      link.className = 'font-semibold text-recon-red hover:underline';
      link.textContent = 'INV-' + w.display_number;
      invoice.appendChild(link);
    } else {
      invoice.textContent = 'None yet';
    }
    matchPanel.classList.remove('hidden');
    hint.textContent = 'Matched. Selecting another result will replace this link.';
  }

  function syncMatch() { renderMatch(findMatch(search.value)); }
  search.addEventListener('input', syncMatch);
  search.addEventListener('change', syncMatch);
  clear.addEventListener('click', function() {
    search.value = '';
    renderMatch(null);
    search.focus();
  });

  if (hidden.value) {
    renderMatch(workOrders.find(function(w) { return String(w.id) === String(hidden.value); }) || null);
  }
})();

// D-144: real-time totals — line $, subtotal, tax, total recompute as the user
// types qty / unit $ / tax_amount. Replaces the static server-rendered values.
(function(){
  var form = document.querySelector('form[data-line-items], form .table, form');
  if (!form) return;
  var taxInput = document.getElementById('tax_amount');
  var subEl    = document.querySelector('[data-totals="subtotal"]');
  var taxEl    = document.querySelector('[data-totals="tax_amount"]');
  var totEl    = document.querySelector('[data-totals="total"]');
  if (!subEl || !taxEl || !totEl) return;

  function fmt(n){ var x = Number(n); return isFinite(x) ? x.toFixed(2) : '0.00'; }

  function recalc(){
    var sub = 0;
    document.querySelectorAll('tr.line-row').forEach(function(row){
      if (row.classList.contains('hidden') || row.hasAttribute('data-template')) return;
      var q = parseFloat(row.querySelector('[data-field="quantity"]')?.value) || 0;
      var p = parseFloat(row.querySelector('[data-field="unit_price"]')?.value) || 0;
      var lt = Math.round(q * p * 100) / 100;
      var ltEl = row.querySelector('[data-field="line_total"]');
      if (ltEl) ltEl.textContent = fmt(lt);
      sub += lt;
    });
    var tax = parseFloat(taxInput && taxInput.value) || 0;
    if (tax < 0) tax = 0;
    var tot = Math.round((sub + tax) * 100) / 100;
    subEl.textContent = fmt(sub);
    taxEl.textContent = fmt(tax);
    totEl.textContent = fmt(tot);
  }

  // Delegate input events so new rows added after load are covered.
  document.addEventListener('input', function(e){
    if (!e.target) return;
    var f = e.target.getAttribute && e.target.getAttribute('data-field');
    if (f === 'quantity' || f === 'unit_price' || e.target.id === 'tax_amount') {
      recalc();
    }
  });
  // Initial calc on load + after Add line button.
  document.addEventListener('click', function(e){
    if (e.target && e.target.matches('[data-add-line], [data-remove-line]')) {
      setTimeout(recalc, 0);
    }
  });
  recalc();
})();
</script>
