<%- include('../layouts/header', { title: title, currentUser: currentUser, flash: flash, activeNav: activeNav }) %>

<%
function fmt(n) { const num = Number(n); return isFinite(num) ? num.toFixed(2) : '0.00'; }
const bal = (Number(bill.total) || 0) - (Number(bill.amount_paid) || 0);
%>

<div class="max-w-5xl mx-auto px-4 py-6">
  <div class="mb-4">
    <a href="/bills" class="text-sm text-recon-fog hover:text-recon-red">&larr; Bills</a>
  </div>

  <div class="flex items-baseline justify-between mb-6 flex-wrap gap-2">
    <div>
      <div class="flex items-center gap-3">
        <h1 class="page-h1"><%= bill.bill_number || '#' + bill.id %></h1>
        <span class="badge badge-<%= bill.status %>"><%= bill.status %></span>
      </div>
      <p class="page-sub">
        Vendor: <a href="/vendors/<%= bill.vendor_id %>" class="hover:text-recon-red"><%= bill.vendor_name || 'Vendor #' + bill.vendor_id %></a>
        <% if (bill.job_title) { %> &middot; Legacy job: <%= bill.job_title %><% } %>
      </p>
    </div>
    <div class="flex flex-wrap gap-2">
      <% if (bill.status === 'draft') { %>
        <a href="/bills/<%= bill.id %>/edit" class="btn btn-secondary">Edit</a>
        <form action="/bills/<%= bill.id %>/approve" method="post" class="m-0 inline">
          <button class="btn btn-primary">Approve</button>
        </form>
        <form action="/bills/<%= bill.id %>/void" method="post" class="m-0 inline">
          <button class="btn btn-danger">Void</button>
        </form>
      <% } else if (bill.status === 'approved') { %>
        <form action="/bills/<%= bill.id %>/pay" method="post" class="m-0 inline-flex items-center gap-2">
          <input type="number" step="0.01" min="0.01" name="amount"
                 value="<%= fmt(bal) %>" class="input text-right" style="width: 8rem;">
          <button class="btn btn-primary">Record payment</button>
        </form>
        <form action="/bills/<%= bill.id %>/void" method="post" class="m-0 inline">
          <button class="btn btn-danger">Void</button>
        </form>
      <% } else if (bill.status === 'void') { %>
        <form action="/bills/<%= bill.id %>/delete" method="post" class="m-0 inline"
              onsubmit="return confirm('Delete this voided bill?');">
          <button class="btn btn-danger">Delete</button>
        </form>
      <% } %>
    </div>
  </div>

  <% if (['approved', 'paid'].includes(bill.status)) { %>
    <div class="mb-6">
      <form action="/bills/<%= bill.id %>/pay" method="post" class="m-0 inline-flex items-center gap-2 bg-green-50 border border-green-200 rounded-lg px-4 py-3">
        <span class="text-sm text-green-800 font-medium">Make payment:</span>
        <input type="number" step="0.01" min="0.01" name="amount"
               value="<%= fmt(bal) %>" class="input max-w-[8rem]">
        <button class="btn btn-primary text-sm">Pay</button>
      </form>
    </div>
  <% } %>

  <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-6">
    <div class="card p-4">
      <div class="text-xs uppercase tracking-wide text-recon-fog">Subtotal</div>
      <div class="text-xl font-semibold mt-1">$<%= fmt(bill.subtotal) %></div>
    </div>
    <div class="card p-4">
      <div class="text-xs uppercase tracking-wide text-recon-fog">Tax</div>
      <div class="text-xl font-semibold mt-1">$<%= fmt(bill.tax_amount) %></div>
    </div>
    <div class="card p-4 bg-recon-charcoal text-white">
      <div class="text-xs uppercase tracking-wide text-recon-fog">Total</div>
      <div class="text-2xl font-bold mt-1 text-recon-red-light">$<%= fmt(bill.total) %></div>
    </div>
    <div class="card p-4 <%= bal === 0 ? 'bg-green-50' : '' %>">
      <div class="text-xs uppercase tracking-wide text-recon-fog">Balance</div>
      <div class="text-xl font-semibold mt-1 <%= bal > 0 ? 'text-recon-red' : 'text-green-700' %>">$<%= fmt(bal) %></div>
      <% if (bill.amount_paid && Number(bill.amount_paid) > 0) { %>
        <div class="text-xs text-recon-fog mt-1">Paid: $<%= fmt(bill.amount_paid) %></div>
      <% } %>
    </div>
  </div>

  <div class="card overflow-hidden mb-6">
    <div class="px-5 py-3 border-b border-recon-mist">
      <h3 class="font-semibold">Line items</h3>
    </div>
    <% if (!bill.lines || bill.lines.length === 0) { %>
      <div class="p-6 text-center text-recon-fog text-sm">No items.</div>
    <% } else { %>
      <table class="data">
        <thead>
          <tr>
            <th>Account</th>
            <th>Description</th>
            <th class="text-right">Qty</th>
            <th class="text-right">Unit $</th>
            <th class="text-right">Line $</th>
          </tr>
        </thead>
        <tbody>
          <% bill.lines.forEach(function(li) { %>
            <tr>
              <td><%= li.account_code ? li.account_code + ' — ' + li.account_name : '— Misc —' %></td>
              <td><%= li.description || '-' %></td>
              <td class="text-right"><%= li.quantity %></td>
              <td class="text-right">$<%= fmt(li.unit_price) %></td>
              <td class="text-right font-medium">$<%= fmt(li.line_total) %></td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    <% } %>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
    <div class="card p-5">
      <h3 class="text-sm font-semibold uppercase tracking-wide text-recon-fog mb-2">Dates & Details</h3>
      <dl class="space-y-1 text-sm">
        <div><dt class="text-recon-fog text-xs inline">Bill date:</dt> <dd class="inline"><%= bill.bill_date ? String(bill.bill_date).slice(0,10) : '—' %></dd></div>
        <div><dt class="text-recon-fog text-xs inline">Due date:</dt> <dd class="inline"><%= bill.due_date ? String(bill.due_date).slice(0,10) : '—' %></dd></div>
        <div><dt class="text-recon-fog text-xs inline">Created by:</dt> <dd class="inline"><%= bill.created_by_name || '—' %></dd></div>
        <% if (bill.approved_by_name) { %><div><dt class="text-recon-fog text-xs inline">Approved by:</dt> <dd class="inline"><%= bill.approved_by_name %></dd></div><% } %>
        <% if (bill.approved_at) { %><div><dt class="text-recon-fog text-xs inline">Approved at:</dt> <dd class="inline"><%= bill.approved_at %></dd></div><% } %>
        <% if (bill.paid_at) { %><div><dt class="text-recon-fog text-xs inline">Paid at:</dt> <dd class="inline"><%= bill.paid_at %></dd></div><% } %>
        <div><dt class="text-recon-fog text-xs inline">Created:</dt> <dd class="inline"><%= (bill.created_at || '—').slice(0,10) %></dd></div>
      </dl>
    </div>
    <% if (bill.notes) { %>
      <div class="card p-5">
        <h3 class="text-sm font-semibold uppercase tracking-wide text-recon-fog mb-2">Notes</h3>
        <p class="text-sm whitespace-pre-line"><%= bill.notes %></p>
      </div>
    <% } %>
  </div>

  <% if (bill.status === 'draft') { %>
    <div class="card p-5 border-red-200">
      <h3 class="font-semibold text-recon-red mb-2">Danger zone</h3>
      <form action="/bills/<%= bill.id %>/delete" method="post"
            onsubmit="return confirm('Delete this draft bill?');" class="m-0">
        <button type="submit" class="btn btn-danger">Delete bill</button>
      </form>
    </div>
  <% } %>
</div>

<%- include('../layouts/footer') %>
