<%- include('../layouts/header', { title: title, currentUser: currentUser, flash: flash, activeNav: activeNav }) %>
<div class="max-w-7xl mx-auto px-4 py-6">
  <h1 class="page-h1 mb-6">Files</h1>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    <% buckets.forEach(function(b){ %>
      <a href="<%= b.path %>" class="card p-6 hover:shadow-md transition block">
        <div class="text-2xl mb-2"><%= b.icon %></div>
        <h2 class="font-semibold text-recon-charcoal"><%= b.label %></h2>
        <p class="text-sm text-recon-fog mt-1">Browse files by <%= b.label.toLowerCase() %></p>
      </a>
    <% }); %>
  </div>
</div>
<%- include('../layouts/footer') %>
