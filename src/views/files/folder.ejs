<%- include('../layouts/header', { title: title, currentUser: currentUser, flash: flash, activeNav: activeNav }) %>
<div class="ops-shell">
  <% const contextQuery = folderContext ? '?context=' + encodeURIComponent(folderContext) : ''; %>
  <div class="flex items-baseline justify-between mb-4 flex-wrap gap-2">
    <div>
      <% const trail = Array.isArray(breadcrumb) && breadcrumb.length ? breadcrumb : [{ label: 'Files', href: '/files' }, { label: entityName || 'Folder', href: null }]; %>
      <nav class="mb-2 text-sm text-recon-fog flex flex-wrap items-center gap-1" aria-label="Folder path">
        <% trail.forEach(function(crumb, index){ %>
          <% const isLast = index === trail.length - 1; %>
          <% if (index > 0) { %><span class="text-recon-fog/70">/</span><% } %>
          <% if (!isLast && crumb.href) { %>
            <a href="<%= crumb.href %>" class="hover:text-recon-red"><%= crumb.label %></a>
          <% } else { %>
            <span class="<%= isLast ? 'text-recon-charcoal font-medium' : '' %>"><%= crumb.label %></span>
          <% } %>
        <% }); %>
      </nav>
      <h1 class="page-h1 mb-1"><%= entityName %></h1>
      <p class="page-sub">Files and folders</p>
      <% if (typeof oneDriveFolderUrl !== 'undefined' && oneDriveFolderUrl) { %>
        <a href="<%= oneDriveFolderUrl %>" target="_blank" rel="noopener" class="btn btn-secondary text-sm mt-3">Open OneDrive folder</a>
      <% } %>
    </div>
    <div class="flex flex-wrap gap-2">
      <% if (currentUser.role === 'admin' || currentUser.role === 'manager') { %>
        <form method="post" action="/files/folders/<%= folder.id %>/subfolder" class="inline-flex gap-1 items-center">
          <input type="text" name="name" placeholder="Subfolder name" class="input text-sm" style="width:140px;padding:.3rem .5rem;" required>
          <button type="submit" class="btn btn-secondary text-sm">+ Folder</button>
        </form>
      <% } %>
      <% if (currentUser.role === 'admin') { %>
        <form method="post" action="/files/folders/<%= folder.id %>/rename" class="inline-flex gap-1 items-center">
          <input type="text" name="name" value="<%= folder.name %>" class="input text-sm" style="width:120px;padding:.3rem .5rem;" required>
          <button type="submit" class="btn btn-ghost text-sm">Rename</button>
        </form>
        <form method="post" action="/files/folders/<%= folder.id %>/delete" class="inline" onsubmit="return confirm('Delete empty folder?')">
          <button type="submit" class="btn btn-danger text-sm">Delete</button>
        </form>
      <% } %>
    </div>
  </div>

  <% if (currentUser.role === 'admin' || currentUser.role === 'manager') { %>
    <div class="card p-4 mb-6">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
        <form method="post" action="/files/folders/<%= folder.id %>/upload" enctype="multipart/form-data" class="space-y-3" data-direct-folder-upload>
          <div>
            <h2 class="text-sm font-semibold text-recon-charcoal mb-1">Upload folder</h2>
            <p class="text-sm text-recon-fog">Preserves subfolders and uploads every file inside the selected folder.</p>
          </div>
          <input id="folder-upload-input" type="file" name="files" multiple webkitdirectory directory class="sr-only" required data-file-picker data-file-picker-label="folder-upload-label" data-file-picker-button="folder-upload-submit">
          <div class="flex flex-wrap gap-2 items-center">
            <label for="folder-upload-input" class="btn btn-secondary text-sm cursor-pointer">Choose folder</label>
            <button id="folder-upload-submit" type="submit" class="btn btn-primary text-sm disabled:opacity-50 disabled:cursor-not-allowed" disabled>Upload folder</button>
          </div>
          <p id="folder-upload-label" class="text-xs text-recon-fog">No folder selected.</p>
        </form>

        <form method="post" action="/files/folders/<%= folder.id %>/upload" enctype="multipart/form-data" class="space-y-3" data-direct-folder-upload>
          <div>
            <h2 class="text-sm font-semibold text-recon-charcoal mb-1">Upload files</h2>
            <p class="text-sm text-recon-fog">Adds selected files directly to this folder.</p>
          </div>
          <input id="file-upload-input" type="file" name="files" multiple class="sr-only" required data-file-picker data-file-picker-label="file-upload-label" data-file-picker-button="file-upload-submit">
          <div class="flex flex-wrap gap-2 items-center">
            <label for="file-upload-input" class="btn btn-secondary text-sm cursor-pointer">Choose files</label>
            <button id="file-upload-submit" type="submit" class="btn btn-primary text-sm disabled:opacity-50 disabled:cursor-not-allowed" disabled>Upload files</button>
          </div>
          <p id="file-upload-label" class="text-xs text-recon-fog">No files selected.</p>
        </form>

        <div class="space-y-3">
          <div>
            <h2 class="text-sm font-semibold text-recon-charcoal mb-1">Upload zipped folder</h2>
            <p class="text-sm text-recon-fog">Upload a .zip file to recreate its folder structure here.</p>
          </div>
          <input id="zip-file-input" type="file" accept=".zip" class="sr-only" data-zip-picker data-zip-label="zip-status-label">
          <div class="flex flex-wrap gap-2 items-center">
            <label for="zip-file-input" class="btn btn-secondary text-sm cursor-pointer">Choose .zip</label>
            <button id="zip-upload-btn" type="button" class="btn btn-primary text-sm disabled:opacity-50 disabled:cursor-not-allowed" disabled onclick="uploadZip()">Upload .zip</button>
          </div>
          <p id="zip-status-label" class="text-xs text-recon-fog">No .zip selected.</p>
          <div id="zip-progress-wrap" class="hidden space-y-2" aria-live="polite">
            <div class="h-2 rounded bg-recon-ash overflow-hidden">
              <div id="zip-progress-bar" class="h-full bg-recon-red transition-all duration-300" style="width:0%"></div>
            </div>
            <div class="flex flex-wrap gap-x-4 gap-y-1 text-xs text-recon-fog">
              <span id="zip-progress-percent">0%</span>
              <span id="zip-progress-elapsed">Elapsed 0:00</span>
              <span id="zip-progress-eta">Estimated time left: calculating...</span>
            </div>
            <p id="zip-progress-note" class="text-xs font-medium text-recon-charcoal">Keep this page open while the zip uploads and processes. Leaving this page will stop the upload.</p>
          </div>
        </div>
      </div>
    </div>
  <% } %>

  <% if (contents.subfolders.length === 0 && contents.files.length === 0) { %>
    <div class="card p-8 text-center text-recon-fog">This folder is empty. Use the buttons above to add files or subfolders.</div>
  <% } else { %>
    <% if (contents.subfolders.length > 0) { %>
      <h2 class="text-sm font-semibold uppercase tracking-wide text-recon-fog mb-2">Subfolders</h2>
      <div class="grid grid-cols-1 md:grid-cols-4 gap-3 mb-6">
        <% contents.subfolders.forEach(function(sf){ %>
          <a href="/files/folders/<%= sf.id %><%= contextQuery %>" class="card p-4 hover:shadow-md transition block">
            <div class="font-medium text-recon-charcoal">📁 <%= sf.name %></div>
          </a>
        <% }); %>
      </div>
    <% } %>

    <% if (contents.files.length > 0) { %>
      <h2 class="text-sm font-semibold uppercase tracking-wide text-recon-fog mb-2">Files</h2>
      <div class="card overflow-hidden">
        <table class="data">
          <thead><tr><th>Name</th><th>Type</th><th>Size</th><th>Uploaded</th><th></th></tr></thead>
          <tbody>
            <% contents.files.forEach(function(f){ %>
              <tr>
                <td class="font-medium"><a href="/files/<%= f.id %>/view<%= contextQuery %>" target="_blank" class="hover:text-recon-red"><%= f.original_filename %></a></td>
                <td class="text-sm text-recon-fog"><%= f.mime_type || '—' %></td>
                <td class="text-sm text-recon-fog"><%= f.size_bytes ? (f.size_bytes / 1024).toFixed(1) + ' KB' : '—' %></td>
                <td class="text-sm text-recon-fog"><%= (f.created_at || '').slice(0,10) %></td>
                <td class="text-right">
                  <% if (currentUser.role === 'admin' || f.uploaded_by_user_id === currentUser.id) { %>
                    <form method="post" action="/files/<%= f.id %>/delete" class="inline" onsubmit="return confirm('Delete <%= f.original_filename %>?')">
                      <button type="submit" class="text-xs text-recon-fog hover:text-recon-red">Delete</button>
                    </form>
                  <% } %>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    <% } %>
  <% } %>
</div>
<script src="/vendor/jszip/jszip.min.js"></script>
<script>
(function(){
  document.querySelectorAll('[data-file-picker]').forEach(function(input){
    var label = document.getElementById(input.getAttribute('data-file-picker-label'));
    var button = document.getElementById(input.getAttribute('data-file-picker-button'));
    input.addEventListener('change', function(){
      var count = input.files ? input.files.length : 0;
      if (button) button.disabled = count === 0;
      if (!label) return;
      if (count === 0) {
        label.textContent = input.name === 'archive' ? 'No .zip selected.' : input.webkitdirectory ? 'No folder selected.' : 'No files selected.';
        return;
      }
      if (input.webkitdirectory) {
        var first = input.files[0] && input.files[0].webkitRelativePath ? input.files[0].webkitRelativePath.split('/')[0] : 'Selected folder';
        label.textContent = first + ' selected - ' + count + ' file' + (count === 1 ? '' : 's') + '.';
      } else if (count === 1) {
        label.textContent = input.files[0].name + ' selected.';
      } else {
        label.textContent = count + ' files selected.';
      }
    });
  });
})();

// Regular file/folder upload: presigned URLs → direct-to-storage → metadata register
(function(){
  var forms = Array.prototype.slice.call(document.querySelectorAll('[data-direct-folder-upload]'));
  var maxFileSize = 500 * 1024 * 1024;
  var maxFiles = 250;

  function formatBytes(bytes) {
    if (!bytes) return '0 B';
    var units = ['B', 'KB', 'MB', 'GB'];
    var value = bytes;
    var unitIndex = 0;
    while (value >= 1024 && unitIndex < units.length - 1) {
      value = value / 1024;
      unitIndex += 1;
    }
    return value.toFixed(unitIndex === 0 ? 0 : 1) + ' ' + units[unitIndex];
  }

  async function readJson(response) {
    var data = await response.json().catch(function(){ return {}; });
    if (!response.ok || data.ok === false) {
      throw new Error(data.error || ('Upload failed with status ' + response.status));
    }
    return data;
  }

  async function registerUploadedFiles(files) {
    if (!files.length) return;
    var response = await fetch('/files/folders/' + currentFolderId + '/register-direct', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ files: files }),
    });
    await readJson(response);
  }

  function fileRelativePath(file) {
    return file.webkitRelativePath || file.name;
  }

  forms.forEach(function(form){
    var input = form.querySelector('input[type="file"]');
    var button = form.querySelector('button[type="submit"]');
    var labelId = input && input.getAttribute('data-file-picker-label');
    var label = labelId ? document.getElementById(labelId) : null;
    if (!input || !button || !label) return;

    form.addEventListener('submit', async function(event){
      var files = Array.prototype.slice.call(input.files || []);
      if (!files.length) return;
      event.preventDefault();

      var oversized = files.find(function(file){ return file.size > maxFileSize; });
      if (files.length > maxFiles) {
        label.textContent = 'Select ' + maxFiles + ' files or fewer per upload.';
        return;
      }
      if (oversized) {
        label.textContent = oversized.name + ' is too large. Each file must be 500 MB or smaller.';
        return;
      }

      button.disabled = true;
      input.disabled = true;
      var uploaded = [];
      try {
        for (var i = 0; i < files.length; i += 1) {
          var file = files[i];
          var relativePath = fileRelativePath(file);
          label.textContent = 'Preparing ' + (i + 1) + ' of ' + files.length + ': ' + relativePath;
          var params = new URLSearchParams({
            filename: file.name,
            relative_path: relativePath,
            content_type: file.type || 'application/octet-stream',
            size: String(file.size),
          });
          var urlData = await readJson(await fetch('/files/folders/' + currentFolderId + '/upload-url?' + params.toString()));

          label.textContent = 'Uploading ' + (i + 1) + ' of ' + files.length + ': ' + relativePath + ' (' + formatBytes(file.size) + ')';
          await uploadDirectFileToStorage(urlData, file, file.type || 'application/octet-stream');

          uploaded.push({
            storage_key: urlData.storageKey,
            original_filename: file.name,
            relative_path: relativePath,
            mime_type: file.type || 'application/octet-stream',
            size_bytes: file.size,
          });
        }

        label.textContent = 'Saving ' + uploaded.length + ' uploaded file' + (uploaded.length === 1 ? '' : 's') + '...';
        await registerUploadedFiles(uploaded);
        label.textContent = 'Upload complete. Refreshing...';
        window.location.reload();
      } catch (err) {
        if (uploaded.length) {
          try {
            label.textContent = 'Saving the ' + uploaded.length + ' file' + (uploaded.length === 1 ? '' : 's') + ' that finished before the error...';
            await registerUploadedFiles(uploaded);
          } catch (registerErr) {
            console.error(registerErr);
          }
        }
        label.textContent = err.message || 'Upload failed. Please try again.';
        button.disabled = false;
        input.disabled = false;
      }
    });
  });
})();

function sendZipUploadRequest(uploadUrl, options) {
  return new Promise(function(resolve, reject) {
    var xhr = new XMLHttpRequest();
    xhr.open('PUT', uploadUrl);
    Object.keys(options.headers || {}).forEach(function(name) {
      xhr.setRequestHeader(name, options.headers[name]);
    });
    xhr.upload.onprogress = function(event) {
      if (event.lengthComputable && typeof options.onProgress === 'function') {
        options.onProgress(event.loaded, event.total);
      }
    };
    xhr.onload = function() {
      resolve({
        ok: xhr.status >= 200 && xhr.status < 300,
        status: xhr.status,
        text: xhr.responseText || '',
      });
    };
    xhr.onerror = function() {
      reject(new Error('Upload failed because the network connection was interrupted.'));
    };
    xhr.send(options.body);
  });
}

async function uploadFileToSignedUrl(uploadUrl, file, contentType, onProgress) {
  var rawRes = await sendZipUploadRequest(uploadUrl, {
    headers: { 'Content-Type': contentType || 'application/octet-stream' },
    body: file,
    onProgress: onProgress,
  });
  if (rawRes.ok) return;

  var rawText = rawRes.text || '';
  if (rawRes.status !== 400) {
    throw new Error('Upload failed: ' + rawRes.status + (rawText ? ' - ' + rawText : ''));
  }

  var form = new FormData();
  var uploadName = file && file.name ? file.name : 'upload';
  form.append('cacheControl', '3600');
  form.append('file', file, uploadName);
  var formRes = await sendZipUploadRequest(uploadUrl, {
    body: form,
    onProgress: onProgress,
  });
  if (!formRes.ok) {
    var formText = formRes.text || '';
    throw new Error('Upload failed: ' + formRes.status + (formText ? ' - ' + formText : (rawText ? ' - ' + rawText : '')));
  }
}

async function uploadDirectFileToStorage(urlData, file, contentType, onProgress) {
  await uploadFileToSignedUrl(urlData.uploadUrl, file, contentType, onProgress);
}

function zipFormatBytes(bytes) {
  if (!bytes) return '0 B';
  var units = ['B', 'KB', 'MB', 'GB'];
  var value = bytes;
  var unitIndex = 0;
  while (value >= 1024 && unitIndex < units.length - 1) {
    value = value / 1024;
    unitIndex += 1;
  }
  return value.toFixed(unitIndex === 0 ? 0 : 1) + ' ' + units[unitIndex];
}

function zipGuessContentType(filename) {
  var ext = String(filename || '').split('.').pop().toLowerCase();
  var types = {
    jpg: 'image/jpeg',
    jpeg: 'image/jpeg',
    png: 'image/png',
    gif: 'image/gif',
    webp: 'image/webp',
    heic: 'image/heic',
    pdf: 'application/pdf',
    txt: 'text/plain',
    csv: 'text/csv',
    doc: 'application/msword',
    docx: 'application/vnd.openxmlformats-officedocument.wordprocessingml.document',
    xls: 'application/vnd.ms-excel',
    xlsx: 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet',
  };
  return types[ext] || 'application/octet-stream';
}

function isUsefulZipEntry(relPath, zipEntry) {
  if (!relPath || zipEntry.dir) return false;
  var parts = String(relPath).split('/').filter(Boolean);
  if (!parts.length) return false;
  return !parts.some(function(part) {
    return part === '__MACOSX' || part === '.DS_Store' || part.charAt(0) === '.';
  });
}

async function zipReadJson(response) {
  var data = await response.json().catch(function(){ return {}; });
  if (!response.ok || data.ok === false) {
    throw new Error(data.error || ('Upload failed with status ' + response.status));
  }
  return data;
}

async function registerZipUploadedFiles(files) {
  if (!files.length) return;
  var response = await fetch('/files/folders/' + currentFolderId + '/register-direct', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ files: files }),
  });
  await zipReadJson(response);
}

async function uploadZipExtractedInBrowser(file) {
  if (!window.JSZip) throw new Error('Zip tools are still loading. Please try again in a moment.');
  if (zipStatusLabel) zipStatusLabel.textContent = 'Reading ' + file.name + '...';
  if (zipProgressNote) zipProgressNote.textContent = 'Keep this page open while FORGE unpacks and uploads the zip. Leaving this page will stop the upload.';
  updateZipProgress(0, file.size, 'uploading');

  var zip = await window.JSZip.loadAsync(file);
  var entries = [];
  zip.forEach(function(relPath, zipEntry) {
    if (!isUsefulZipEntry(relPath, zipEntry)) return;
    entries.push({
      relPath: relPath,
      filename: relPath.split('/').filter(Boolean).pop(),
      size: zipEntry._data && Number(zipEntry._data.uncompressedSize || 0),
      zipEntry: zipEntry,
    });
  });

  if (!entries.length) throw new Error('No uploadable files were found in this zip.');

  var oversized = entries.find(function(entry) { return entry.size > 500 * 1024 * 1024; });
  if (oversized) {
    throw new Error(oversized.relPath + ' is too large. Files inside the zip must be 500 MB or smaller.');
  }

  var totalBytes = entries.reduce(function(sum, entry) { return sum + Math.max(0, entry.size || 0); }, 0) || file.size;
  var completedBytes = 0;
  var uploadedBatch = [];
  var batchSize = 100;

  for (var i = 0; i < entries.length; i += 1) {
    var entry = entries[i];
    if (zipStatusLabel) {
      zipStatusLabel.textContent = 'Uploading ' + (i + 1) + ' of ' + entries.length + ': ' + entry.relPath + ' (' + zipFormatBytes(entry.size) + ')';
    }
    var contentType = zipGuessContentType(entry.filename);
    var params = new URLSearchParams({
      filename: entry.filename,
      relative_path: entry.relPath,
      content_type: contentType,
      size: String(entry.size || 1),
    });
    var urlData = await zipReadJson(await fetch('/files/folders/' + currentFolderId + '/upload-url?' + params.toString()));
    var blob = await entry.zipEntry.async('blob');
    entry.size = blob.size || entry.size || 0;
    await uploadDirectFileToStorage(urlData, blob, contentType, function(loaded) {
      updateZipProgress(completedBytes + loaded, totalBytes, 'uploading');
    });
    completedBytes += entry.size;
    updateZipProgress(completedBytes, totalBytes, 'uploading');
    uploadedBatch.push({
      storage_key: urlData.storageKey,
      original_filename: entry.filename,
      relative_path: entry.relPath,
      mime_type: contentType,
      size_bytes: entry.size,
    });

    if (uploadedBatch.length >= batchSize) {
      if (zipStatusLabel) zipStatusLabel.textContent = 'Saving uploaded files...';
      await registerZipUploadedFiles(uploadedBatch);
      uploadedBatch = [];
    }
  }

  if (uploadedBatch.length) {
    if (zipStatusLabel) zipStatusLabel.textContent = 'Saving uploaded files...';
    await registerZipUploadedFiles(uploadedBatch);
  }
}

var zipFileInput = document.getElementById('zip-file-input');
var zipStatusLabel = document.getElementById('zip-status-label');
var zipUploadBtn = document.getElementById('zip-upload-btn');
var zipProgressWrap = document.getElementById('zip-progress-wrap');
var zipProgressBar = document.getElementById('zip-progress-bar');
var zipProgressPercent = document.getElementById('zip-progress-percent');
var zipProgressElapsed = document.getElementById('zip-progress-elapsed');
var zipProgressEta = document.getElementById('zip-progress-eta');
var zipProgressNote = document.getElementById('zip-progress-note');
var currentFolderId = '<%= folder.id %>';
var zipUploadStartedAt = null;
var zipTimer = null;
var zipIsBusy = false;
var zipLastProgress = { loaded: 0, total: 0, phase: 'idle' };

function formatZipDuration(seconds) {
  var totalSeconds = Math.max(0, Math.round(seconds || 0));
  var minutes = Math.floor(totalSeconds / 60);
  var remainingSeconds = totalSeconds % 60;
  if (minutes < 60) return minutes + ':' + String(remainingSeconds).padStart(2, '0');
  var hours = Math.floor(minutes / 60);
  return hours + ':' + String(minutes % 60).padStart(2, '0') + ':' + String(remainingSeconds).padStart(2, '0');
}

function setZipProgressVisible(visible) {
  if (zipProgressWrap) zipProgressWrap.classList.toggle('hidden', !visible);
}

function updateZipProgress(loaded, total, phase) {
  zipLastProgress = {
    loaded: Number(loaded || 0),
    total: Number(total || 0),
    phase: phase || zipLastProgress.phase || 'uploading',
  };
  var elapsedSeconds = zipUploadStartedAt ? (Date.now() - zipUploadStartedAt) / 1000 : 0;
  var percent = zipLastProgress.total > 0 ? Math.min(100, Math.max(0, (zipLastProgress.loaded / zipLastProgress.total) * 100)) : 0;
  if (zipProgressBar) zipProgressBar.style.width = (zipLastProgress.phase === 'processing' ? 100 : percent).toFixed(1) + '%';
  if (zipProgressPercent) {
    zipProgressPercent.textContent = zipLastProgress.phase === 'processing'
      ? 'Upload complete'
      : Math.round(percent) + '% uploaded';
  }
  if (zipProgressElapsed) zipProgressElapsed.textContent = 'Elapsed ' + formatZipDuration(elapsedSeconds);
  if (zipProgressEta) {
    if (zipLastProgress.phase === 'processing') {
      zipProgressEta.textContent = 'Processing folders and files...';
    } else if (percent > 2 && elapsedSeconds > 1) {
      var remainingSeconds = elapsedSeconds * ((100 - percent) / percent);
      zipProgressEta.textContent = 'Estimated time left: ' + formatZipDuration(remainingSeconds);
    } else {
      zipProgressEta.textContent = 'Estimated time left: calculating...';
    }
  }
}

function startZipProgressTimer() {
  stopZipProgressTimer();
  zipTimer = setInterval(function() {
    updateZipProgress(zipLastProgress.loaded, zipLastProgress.total, zipLastProgress.phase);
  }, 1000);
}

function stopZipProgressTimer() {
  if (zipTimer) clearInterval(zipTimer);
  zipTimer = null;
}

window.addEventListener('beforeunload', function(event) {
  if (!zipIsBusy) return;
  event.preventDefault();
  event.returnValue = 'A zip upload is still running. Leaving now may interrupt it.';
});

if (zipFileInput) {
  zipFileInput.addEventListener('change', function(){
    var hasFile = zipFileInput.files && zipFileInput.files.length > 0;
    if (zipUploadBtn) zipUploadBtn.disabled = !hasFile;
    if (zipStatusLabel) zipStatusLabel.textContent = hasFile ? zipFileInput.files[0].name + ' selected.' : 'No .zip selected.';
    setZipProgressVisible(false);
    updateZipProgress(0, 0, 'idle');
  });
}

async function uploadZip() {
  if (!zipFileInput || !zipFileInput.files || !zipFileInput.files[0]) return;
  var file = zipFileInput.files[0];
  if (zipUploadBtn) { zipUploadBtn.disabled = true; }
  zipIsBusy = true;
  zipUploadStartedAt = Date.now();
  setZipProgressVisible(true);
  updateZipProgress(0, file.size, 'preparing');
  startZipProgressTimer();
  if (zipStatusLabel) zipStatusLabel.textContent = 'Preparing ' + file.name + '...';
  if (zipProgressNote) zipProgressNote.textContent = 'Keep this page open while the zip uploads and processes. Leaving this page will stop the upload.';

  try {
    if (window.JSZip) {
      await uploadZipExtractedInBrowser(file);
      zipIsBusy = false;
      stopZipProgressTimer();
      if (zipStatusLabel) zipStatusLabel.textContent = 'Upload complete. Refreshing...';
      window.location.reload();
      return;
    }

    // Step 1: Get presigned upload URL
    if (zipStatusLabel) zipStatusLabel.textContent = 'Requesting upload URL...';
    var urlRes = await fetch('/files/folders/' + currentFolderId + '/upload-zip-url');
    if (!urlRes.ok) throw new Error('Failed to get upload URL');
    var urlData = await urlRes.json();
    if (!urlData.ok) throw new Error(urlData.error || 'Upload URL failed');

    // Step 2: Upload zip directly to Supabase Storage
    if (zipStatusLabel) zipStatusLabel.textContent = 'Uploading ' + file.name + ' (' + (file.size / 1024 / 1024).toFixed(1) + ' MB)...';
    await uploadFileToSignedUrl(urlData.uploadUrl, file, file.type || 'application/zip', function(loaded, total) {
      updateZipProgress(loaded, total || file.size, 'uploading');
    });

    // Step 3: Process the zip on the server
    if (zipStatusLabel) zipStatusLabel.textContent = 'Processing folders and files...';
    updateZipProgress(file.size, file.size, 'processing');
    if (zipProgressNote) zipProgressNote.textContent = 'Upload complete. FORGE is unpacking the zip now; large folders can take a few minutes.';
    var processRes = await fetch('/files/folders/' + currentFolderId + '/process-zip', {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: 'storage_key=' + encodeURIComponent(urlData.storageKey),
    });
    if (!processRes.ok) {
      var processText = await processRes.text().catch(function(){ return ''; });
      throw new Error('Zip uploaded, but processing failed: ' + processRes.status + (processText ? ' - ' + processText.replace(/<[^>]+>/g, ' ').replace(/\s+/g, ' ').trim().slice(0, 300) : ''));
    }
    // Fetch auto-follows the redirect. Reload to show new folders/files.
    zipIsBusy = false;
    stopZipProgressTimer();
    window.location.reload();
  } catch (e) {
    if (zipStatusLabel) zipStatusLabel.textContent = 'Error: ' + e.message;
    if (zipProgressNote) zipProgressNote.textContent = 'Upload stopped. You can try again when ready.';
    if (zipUploadBtn) zipUploadBtn.disabled = false;
    zipIsBusy = false;
    stopZipProgressTimer();
  }
}
</script>
