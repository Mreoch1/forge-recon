<%- include('../layouts/header', { title: 'Forgot password', currentUser: null, flash: typeof flash !== 'undefined' ? flash : {} }) %>

<div class="min-h-[80vh] flex items-center justify-center px-4">
  <div class="card w-full max-w-md p-8">
    <div class="flex flex-col items-center mb-6">
      <img src="/logos/recon.png" alt="Recon Construction" class="h-16 w-auto mb-2">
      <span class="forge-wordmark" style="font-size:1.5rem;font-weight:800;letter-spacing:.16em;background:linear-gradient(95deg,#e63946 0%,#ff6b75 35%,#ffffff 100%);-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;color:transparent;filter:drop-shadow(0 1px 0 rgba(0,0,0,.25));">FORGE</span>
      <p class="text-sm text-recon-fog mt-1">Reset your password</p>
    </div>

    <% if (typeof errors !== 'undefined' && errors.email) { %>
      <div class="mb-4 p-3 rounded bg-red-50 border border-red-200 text-red-800 text-sm"><%= errors.email %></div>
    <% } %>

    <form action="/forgot-password" method="post" class="space-y-4">
      <div>
        <label for="email" class="label">Email address</label>
        <input type="email" name="email" id="email" required
               class="input" autocomplete="email" autofocus>
      </div>
      <button type="submit" class="btn btn-primary w-full justify-center">
        Send reset link
      </button>
    </form>

    <p class="text-center text-xs text-recon-fog mt-4">
      <a href="/login" class="text-recon-red hover:underline">&larr; Back to sign in</a>
    </p>
  </div>
</div>

<%- include('../layouts/footer') %>
