<%- include('../layouts/header', { title: 'Forgot password', currentUser: null, flash: typeof flash !== 'undefined' ? flash : {} }) %>

<div class="min-h-[80vh] flex items-center justify-center px-4">
  <div class="card w-full max-w-md p-8">
    <div class="flex flex-col items-center mb-6">
      <img src="/logos/recon.png" alt="Recon Enterprises" class="h-16 w-auto mb-2">
      <span class="forge-wordmark" style="font-size:1.5rem;font-weight:800;letter-spacing:.16em;background-image:linear-gradient(105deg,transparent 0%,transparent 35%,rgba(255,255,255,0.5) 44%,rgba(255,255,255,0.95) 50%,rgba(255,255,255,0.5) 56%,transparent 65%,transparent 100%),linear-gradient(105deg,#6b1212 0%,#951818 15%,#b51e1e 28%,#c84444 42%,#b07878 55%,#888888 70%,#5a5a5a 86%,#3a3a3a 100%);background-size:250% 100%,100% 100%;background-position:100% center,0 0;background-repeat:no-repeat;background-clip:text;-webkit-background-clip:text;-webkit-text-fill-color:transparent;color:transparent;text-shadow:0 1px 2px rgba(0,0,0,0.2),0 2px 6px rgba(0,0,0,0.08);animation:forge-shine 4s linear infinite;">FORGE</span>
      <p class="text-sm text-recon-fog mt-1">Reset your password</p>
    </div>

    <% if (typeof errors !== 'undefined' && errors.email) { %>
      <div class="mb-4 p-3 rounded bg-red-50 border border-red-200 text-red-800 text-sm"><%= errors.email %></div>
    <% } %>

    <form action="/forgot-password" method="post" class="space-y-4">
      <div>
        <label for="email" class="label">Email address</label>
        <input type="email" name="email" id="email" required
               class="input" autocomplete="email" autofocus>
      </div>
      <button type="submit" class="btn btn-primary w-full justify-center">
        Send reset link
      </button>
    </form>

    <p class="text-center text-xs text-recon-fog mt-4">
      <a href="/login" class="text-recon-red hover:underline">&larr; Back to sign in</a>
    </p>
  </div>
</div>

<%- include('../layouts/footer') %>