<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
  <link rel="shortcut icon" href="/favicon.ico">
  <meta name="theme-color" content="#c0202b">
  <style>
    body { background: #f5f5f5; color: #1a1a1a; font-family: 'Inter', ui-sans-serif, system-ui, -apple-system, sans-serif; }
    .card { background: #ffffff; border-radius: .5rem; box-shadow: 0 1px 3px rgba(0,0,0,.06); border: 1px solid #e5e5e5; }
    .btn { display: inline-flex; align-items: center; padding: .5rem 1rem; border-radius: .375rem; font-weight: 500; cursor: pointer; border: none; font-size: .9rem; }
    .btn-primary { background: #c0202b; color: #ffffff; }
    .btn-primary:hover { background: #8a0e16; }
    .input { display: block; width: 100%; padding: .5rem .75rem; border-radius: .375rem; border: 1px solid #d0d0d0; font-size: .9rem; }
    .input:focus { border-color: #c0202b; outline: none; box-shadow: 0 0 0 3px rgba(192,32,43,.15); }
    .label { display: block; font-size: .85rem; font-weight: 500; margin-bottom: .25rem; }
  </style>
</head>
<body class="flex items-center justify-center min-h-screen p-4">
  <div class="card w-full max-w-md p-8 text-center">
    <div class="text-5xl mb-4">✉️</div>
    <h1 class="text-xl font-bold mb-2">Check your email</h1>
    <p class="text-gray-500 mb-6">
      We sent a verification link to <strong><%= email %></strong>.
      Click the link to activate your account.
    </p>
    <p class="text-sm text-gray-400">Didn't get it? Check spam or</p>
    <form action="/resend-verification" method="post" class="mt-2">
      <input type="hidden" name="email" value="<%= email %>">
      <button type="submit" class="btn btn-primary">Resend verification email</button>
    </form>
    <p class="text-center text-sm text-gray-500 mt-4">
      <a href="/login" class="text-[#c0202b] hover:underline">Back to sign in</a>
    </p>
  </div>
</body>
</html>
