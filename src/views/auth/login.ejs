<%- include('../layouts/header', { title: title, currentUser: typeof currentUser !== 'undefined' ? currentUser : null, flash: typeof flash !== 'undefined' ? flash : {} }) %>

<div class="min-h-[80vh] flex items-center justify-center px-4">
  <div class="card w-full max-w-md p-8">
    <div class="flex flex-col items-center mb-6">
      <img src="/logos/recon.png" alt="Recon Construction" class="h-20 w-auto mb-2">
      <span class="forge-wordmark" style="font-size:2rem;font-weight:800;letter-spacing:.16em;background-image:linear-gradient(105deg,transparent 0%,transparent 35%,rgba(255,255,255,0.5) 44%,rgba(255,255,255,0.95) 50%,rgba(255,255,255,0.5) 56%,transparent 65%,transparent 100%),linear-gradient(105deg,#6b1212 0%,#951818 15%,#b51e1e 28%,#c84444 42%,#b07878 55%,#888888 70%,#5a5a5a 86%,#3a3a3a 100%);background-size:250% 100%,100% 100%;background-position:100% center,0 0;background-repeat:no-repeat;background-clip:text;-webkit-background-clip:text;-webkit-text-fill-color:transparent;color:transparent;text-shadow:0 1px 2px rgba(0,0,0,0.2),0 2px 6px rgba(0,0,0,0.08);animation:forge-shine 4s linear infinite;">FORGE</span>
      <p class="text-sm text-recon-fog mt-1">by Recon Enterprises</p>
    </div>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="mb-4 p-3 rounded bg-red-50 border border-red-200 text-red-800 text-sm">
        <%= error %>
      </div>
    <% } %>

    <% if (typeof verified !== 'undefined' && verified) { %>
      <div class="mb-4 p-3 rounded bg-green-50 border border-green-200 text-green-800 text-sm">
        Email verified! You can now sign in.
      </div>
    <% } %>

    <% if (typeof alreadyVerified !== 'undefined' && alreadyVerified) { %>
      <div class="mb-4 p-3 rounded bg-blue-50 border border-blue-200 text-blue-800 text-sm">
        This email is already verified — sign in below.
      </div>
    <% } %>

    <form action="/login" method="post" class="space-y-4" autocomplete="on">
      <div>
        <label for="email" class="label">Email</label>
        <input type="email" name="email" id="email" required
               value="<%= typeof email !== 'undefined' ? email : '' %>"
               class="input" autocomplete="email" autofocus>
      </div>
      <div>
        <label for="password" class="label">Password</label>
        <input type="password" name="password" id="password" required
               class="input" autocomplete="current-password">
      </div>
      <button type="submit" class="btn btn-primary w-full justify-center">
        Sign in
      </button>
    </form>

    <p class="text-center text-xs text-recon-fog mt-4">
      <a href="/forgot-password" class="text-recon-red hover:underline">Forgot password?</a>
    </p>
    <p class="text-center text-xs text-recon-fog mt-2">
      <a href="/signup" class="text-recon-red hover:underline">Don't have an account? Sign up</a>
    </p>
    <p class="text-center text-xs text-recon-fog mt-2">
      In-house only.
    </p>
  </div>
</div>

<%- include('../layouts/footer') %>