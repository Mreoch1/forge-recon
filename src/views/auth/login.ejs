<%- include('../layouts/header', { title: title, currentUser: typeof currentUser !== 'undefined' ? currentUser : null, flash: typeof flash !== 'undefined' ? flash : {} }) %>

<div class="min-h-[80vh] flex items-center justify-center px-4">
  <div class="card w-full max-w-md p-8">
    <div class="flex flex-col items-center mb-6">
      <img src="/logos/recon.png" alt="Recon Construction" class="h-20 w-auto mb-2">
      <span class="forge-wordmark" style="font-size:2rem;font-weight:800;letter-spacing:.16em;background:linear-gradient(95deg,#e63946 0%,#ff6b75 35%,#ffffff 100%);-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;color:transparent;filter:drop-shadow(0 1px 0 rgba(0,0,0,.25));">FORGE</span>
      <p class="text-sm text-recon-fog mt-1">by Recon Enterprises</p>
    </div>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="mb-4 p-3 rounded bg-red-50 border border-red-200 text-red-800 text-sm">
        <%= error %>
      </div>
    <% } %>

    <form action="/login" method="post" class="space-y-4" autocomplete="on">
      <div>
        <label for="email" class="label">Email</label>
        <input type="email" name="email" id="email" required
               value="<%= typeof email !== 'undefined' ? email : '' %>"
               class="input" autocomplete="email" autofocus>
      </div>
      <div>
        <label for="password" class="label">Password</label>
        <input type="password" name="password" id="password" required
               class="input" autocomplete="current-password">
      </div>
      <button type="submit" class="btn btn-primary w-full justify-center">
        Sign in
      </button>
    </form>

    <p class="text-center text-xs text-recon-fog mt-4">
      <a href="/forgot-password" class="text-recon-red hover:underline">Forgot password?</a>
    </p>
    <p class="text-center text-xs text-recon-fog mt-2">
      In-house only.
    </p>
  </div>
</div>

<%- include('../layouts/footer') %>
