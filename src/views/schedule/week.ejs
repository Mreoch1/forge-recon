<%- include('../layouts/header', { title: title, currentUser: currentUser, flash: flash, activeNav: activeNav }) %>
<style>
  /* ── Schedule week view ── */
  .sc-layout { display: flex; flex-direction: column; height: calc(100vh - 3.5rem); }
  .sc-header { display: flex; align-items: center; gap: .75rem; padding: .75rem 1.25rem; border-bottom: 1px solid #e0e0e0; flex-shrink: 0; flex-wrap: wrap; }
  .sc-header h1 { font-size: 1rem; font-weight: 600; margin: 0; }
  .sc-header .sc-date-range { font-size: .82rem; color: #666; }
  .sc-header .sc-nav-btn { padding: .3rem .7rem; border: 1px solid #d0d0d0; border-radius: 4px; background: #fff; font-size: .78rem; cursor: pointer; }
  .sc-header .sc-nav-btn:hover { background: #f5f5f5; }
  .sc-header .sc-today-btn { padding: .3rem .7rem; border: 1px solid #1a1a1a; border-radius: 4px; background: #1a1a1a; color: #fff; font-size: .78rem; cursor: pointer; }
  .sc-header .sc-today-btn:hover { background: #333; }
  .sc-header select { font-size: .78rem; padding: .25rem .5rem; border: 1px solid #d0d0d0; border-radius: 4px; }

  /* Grid */
  .sc-grid-wrap { flex: 1; overflow-y: auto; position: relative; }
  .sc-grid { display: grid; grid-template-columns: 3.5rem repeat(7, 1fr); position: relative; min-height: 100%; }
  .sc-hour-gutter { grid-column: 1; border-right: 1px solid #e8e8e8; position: relative; }
  .sc-hour-label { position: absolute; right: .4rem; font-size: .65rem; color: #999; font-family: ui-monospace, monospace; transform: translateY(-50%); white-space: nowrap; }
  .sc-day-header { text-align: center; padding: .4rem 0; font-size: .72rem; font-weight: 600; color: #555; border-bottom: 1px solid #e0e0e0; position: sticky; top: 0; background: #fff; z-index: 2; }
  .sc-day-header .sc-day-num { display: block; font-size: 1.1rem; font-weight: 700; color: #1a1a1a; }
  .sc-day-header.is-today { background: #f0f4ff; }
  .sc-day-header.is-today .sc-day-num { color: #2563eb; }

  /* Hour row lines — visible calendar grid */
  .sc-hour-line { position: absolute; left: 0; right: 0; border-top: 1px solid #ececec; pointer-events: none; }
  .sc-hour-line.anchor-hour { border-top-color: #cfcfcf; border-top-width: 1.5px; }

  /* Day column separators */
  .sc-day-col { position: relative; min-height: 840px; border-right: 1px solid #e5e5e5; }
  .sc-day-col:last-child { border-right: none; }
  .sc-day-col.is-today { background: #fafbfe; }

  /* Now line */
  .sc-now-line { position: absolute; left: 0; right: 0; border-top: 1px solid #ef4444; z-index: 3; pointer-events: none; }
  .sc-now-dot { position: absolute; left: -3px; top: -3px; width: 7px; height: 7px; border-radius: 50%; background: #ef4444; }

  /* WO block — wrapper for hover card positioning */
  .sc-wo-wrap { position: absolute; left: 3px; right: 3px; z-index: 1; }
  .sc-wo-wrap:hover { z-index: 20; }
  .sc-wo-block { display: block; width: 100%; border-radius: 4px; padding: .25rem .4rem; font-size: .7rem; line-height: 1.3; overflow: hidden; cursor: pointer; border: 1px solid rgba(0,0,0,.08); transition: box-shadow .1s; box-sizing: border-box; height: 100%; position: relative; }
  .sc-wo-wrap[data-overlap-count] { left: 0; right: auto; }
  .sc-wo-wrap[data-overlap-count="2"] { width: calc(50% - 3px); }
  .sc-wo-wrap[data-overlap-count="2"][data-overlap-index="1"] { left: calc(50% + 3px); }
  .sc-wo-wrap[data-overlap-count="3"] { width: calc(33.33% - 4px); }
  .sc-wo-wrap[data-overlap-count="3"][data-overlap-index="1"] { left: calc(33.33% + 2px); }
  .sc-wo-wrap[data-overlap-count="3"][data-overlap-index="2"] { left: calc(66.66% + 4px); }
  .sc-wo-wrap[data-overlap-count="4"] { width: calc(25% - 4px); }
  .sc-wo-wrap[data-overlap-count="4"][data-overlap-index="1"] { left: calc(25% + 1px); }
  .sc-wo-wrap[data-overlap-count="4"][data-overlap-index="2"] { left: calc(50% + 2px); }
  .sc-wo-wrap[data-overlap-count="4"][data-overlap-index="3"] { left: calc(75% + 3px); }
  .sc-wo-block:hover { box-shadow: 0 2px 6px rgba(0,0,0,.15); }
  .sc-wo-block .sc-wo-num { font-family: ui-monospace, monospace; font-size: .62rem; opacity: .8; }
  .sc-wo-block .sc-wo-customer { font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .sc-wo-block .sc-wo-assignee { font-size: .62rem; opacity: .75; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

  /* Unassigned: grey hatched */
  .sc-wo-block.sc-unassigned { background: #f5f5f5 !important; border-color: #ddd; background-image: repeating-linear-gradient(45deg, transparent, transparent 4px, rgba(0,0,0,.03) 4px, rgba(0,0,0,.03) 8px) !important; }

  /* Conflict badge */
  .sc-conflict-badge { position: absolute; top: 2px; right: 2px; font-size: .65rem; z-index: 5; cursor: help; }
  .sc-conflict-tip { display: none; position: absolute; top: 0; right: 110%; background: #1a1a1a; color: #fff; font-size: .65rem; padding: .35rem .5rem; border-radius: 4px; white-space: nowrap; z-index: 10; pointer-events: none; }
  .sc-conflict-badge:hover .sc-conflict-tip { display: block; }

  /* Empty state */
  .sc-empty { text-align: center; padding: 3rem 1rem; color: #999; grid-column: 1 / -1; }

  /* Confirm card — from-to with editable time inputs */
  .sc-confirm-card { background: #fff; border: 2px dashed #c0202b; border-radius: 8px; padding: .75rem; width: 280px; z-index: 2000; box-shadow: 0 4px 16px rgba(0,0,0,.15); font-size: .78rem; line-height: 1.5; }
  .sc-confirm-card .scc-header { font-weight: 700; margin-bottom: .5rem; color: #1a1a1a; }
  .sc-confirm-card .scc-row { margin-bottom: .15rem; color: #444; }
  .sc-confirm-card .scc-label { color: #888; display: inline-block; width: 2.8rem; }
  .sc-confirm-card .scc-from-to-row { display: flex; align-items: center; gap: .5rem; margin-bottom: .35rem; }
  .sc-confirm-card .scc-from-to-row .scc-label { color: #888; width: 2.8rem; flex-shrink: 0; }
  .sc-confirm-card .scc-date-display { font-size: .78rem; color: #1a1a1a; }
  .sc-confirm-card .scc-time-input { font-size: .78rem; padding: .2rem .35rem; border: 1px solid #ccc; border-radius: 4px; width: 6rem; font-family: ui-monospace, monospace; }
  .sc-confirm-card .scc-time-input:focus { outline: none; border-color: #c0202b; box-shadow: 0 0 0 2px rgba(192,32,43,.15); }
  .sc-confirm-card .scc-conflicts { margin: .4rem 0; padding: .35rem; background: #fef3c7; border-radius: 4px; font-size: .7rem; color: #92400e; }
  .sc-confirm-card .scc-conflict { margin-bottom: .1rem; }
  .sc-confirm-card .scc-actions { display: flex; gap: .5rem; margin-top: .5rem; }
  .sc-confirm-card .scc-confirm { padding: .35rem 1rem; background: #c0202b; color: #fff; border: none; border-radius: 4px; font-size: .78rem; cursor: pointer; }
  .sc-confirm-card .scc-cancel { padding: .35rem 1rem; background: transparent; border: 1px solid #ccc; border-radius: 4px; font-size: .78rem; cursor: pointer; }
  .sc-confirm-card .scc-cancel:hover { background: #f5f5f5; }

  /* Grid lines for hours */
  .sc-day-col { background-clip: content-box; }

  /* ── Custom hover card ── */
  .wo-hover-card { display: none; position: absolute; left: 50%; bottom: calc(100% + 6px); transform: translateX(-50%); background: #1a1a1a; color: #fff; border-radius: 8px; padding: .6rem .75rem; min-width: 200px; box-shadow: 0 6px 20px rgba(0,0,0,.3); font-size: .75rem; line-height: 1.5; z-index: 100; pointer-events: none; white-space: nowrap; }
  .wo-hover-card::after { content: ''; position: absolute; top: 100%; left: 50%; transform: translateX(-50%); border: 5px solid transparent; border-top-color: #1a1a1a; }
  .sc-wo-wrap:hover .wo-hover-card { display: block; }
  .wo-hc-num { font-family: ui-monospace, monospace; font-size: .7rem; color: #e63946; font-weight: 700; }
  .wo-hc-customer { font-weight: 700; font-size: .85rem; color: #fff; }
  .wo-hc-job { color: #aaa; font-size: .72rem; }
  .wo-hc-row { margin-top: .15rem; font-size: .7rem; color: #ccc; }
  .wo-hc-row .wo-hc-label { color: #888; }
  .wo-hc-badge { display: inline-block; padding: .1rem .45rem; border-radius: 9999px; font-size: .6rem; font-weight: 600; margin-top: .2rem; text-transform: capitalize; }
  .wo-hc-badge-scheduled  { background: #ede9fe; color: #5b21b6; }
  .wo-hc-badge-in_progress { background: #fed7aa; color: #9a3412; }
  .wo-hc-badge-complete   { background: #d1fae5; color: #065f46; }
  .wo-hc-badge-cancelled  { background: #fee2e2; color: #991b1b; }
  .sc-view-toggle { display: flex; align-items: center; height: 28px; }
  .sc-view-toggle a { display: flex; align-items: center; height: 100%; padding: 0 .6rem; font-size: .82rem; color: #888; text-decoration: none; border-bottom: 2px solid transparent; }
  .sc-view-toggle a:hover { color: #555; }
  .sc-view-toggle a.active { color: #c0202b; border-bottom-color: #c0202b; }
  .sc-view-toggle .sc-toggle-sep { width: 1px; height: 16px; background: #d0d0d0; flex-shrink: 0; }
  /* Closures overlay */
  .sc-closure-overlay { position: absolute; left: 0; right: 0; top: 0; bottom: 0; background: repeating-linear-gradient(45deg, transparent, transparent 6px, rgba(0,0,0,.03) 6px, rgba(0,0,0,.03) 12px); background-color: #f0f0f0; z-index: 0; pointer-events: none; display: flex; align-items: center; justify-content: center; font-size: .7rem; color: #999; font-weight: 600; text-transform: uppercase; letter-spacing: .08em; }

  /* Initial chip */
  .sc-init-chip { position: absolute; top: 2px; right: 2px; width: 18px; height: 18px; border-radius: 50%; background: rgba(255,255,255,.3); color: #fff; font-size: .5rem; font-weight: 700; display: flex; align-items: center; justify-content: center; line-height: 1; pointer-events: none; }
  .sc-init-chip:hover { display: none; }
  .sc-wo-block { color: #fff; }
  .sc-wo-block.sc-unassigned { color: #555; }
  /* Unscheduled sidebar */
  .sc-layout { flex-direction: row; }
  .sc-sidebar { width: 220px; flex-shrink: 0; border-right: 1px solid #e0e0e0; display: flex; flex-direction: column; overflow-y: auto; background: #fafafa; }
  .sc-sb-header { display: flex; align-items: center; justify-content: space-between; padding: .6rem .75rem; border-bottom: 1px solid #e0e0e0; font-size: .72rem; text-transform: uppercase; letter-spacing: .12em; font-weight: 700; color: #555; }
  .sc-sb-count { background: #c0202b; color: #fff; border-radius: 9999px; padding: .05rem .45rem; font-size: .65rem; font-weight: 600; }
  .sc-sb-list { flex: 1; overflow-y: auto; padding: .35rem; }
  .sc-sb-pill { background: #fff; border-radius: 6px; padding: .4rem .5rem; margin-bottom: .35rem; cursor: grab; border: 1px solid #e5e5e5; transition: box-shadow .1s; }
  .sc-sb-pill:hover { box-shadow: 0 2px 6px rgba(0,0,0,.1); }
  .sc-sb-pill-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: .15rem; }
  .sc-sb-pill-num { font-family: ui-monospace, monospace; font-size: .68rem; font-weight: 700; }
  .sc-sb-chip { width: 16px; height: 16px; border-radius: 50%; background: #d0d0d0; color: #555; font-size: .45rem; font-weight: 700; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .sc-sb-pill-customer { font-size: .75rem; font-weight: 600; color: #1a1a1a; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .sc-sb-pill-job { font-size: .65rem; color: #888; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .sc-sb-pill-assignee { font-size: .62rem; color: #aaa; margin-top: .1rem; }
  .sc-sb-empty { padding: 1rem .75rem; font-size: .8rem; color: #10b981; text-align: center; }
  .sc-header-wrap { flex: 1; display: flex; flex-direction: column; min-width: 0; }
  @media (max-width: 768px) {
    .sc-layout { flex-direction: column; }
    .sc-sidebar { width: 100%; max-height: 120px; border-right: none; border-bottom: 1px solid #e0e0e0; }
    .sc-sb-list { display: flex; gap: .35rem; overflow-x: auto; padding: .35rem; }
    .sc-sb-pill { min-width: 160px; flex-shrink: 0; margin-bottom: 0; }
  }
</style>

<div class="sc-layout">
  <%- include('_unscheduled-lane') %>
  <div class="sc-header-wrap">
  <!-- Header chrome -->
  <div class="sc-header">
    <a href="/schedule?view=week&date=<%= prevDate %><%= assigneeFilter ? '&assignee=' + assigneeFilter : '' %>" class="sc-nav-btn">&larr;</a>
    <a href="/schedule?view=week&date=<%= nextDate %><%= assigneeFilter ? '&assignee=' + assigneeFilter : '' %>" class="sc-nav-btn">Next &rarr;</a>
    <a href="/schedule" class="sc-today-btn">Today</a>
    <h1>Schedule</h1>
    <span class="sc-date-range"><%= fmtDate(weekStart) %> – <%= fmtDate(weekEnd) %>, 2026</span>

    <div class="sc-view-toggle">
      <a href="/schedule?view=week&date=<%= rawDate %><%= assigneeFilter ? '&assignee=' + assigneeFilter : '' %>" class="active">Week</a>
      <span class="sc-toggle-sep"></span>
      <a href="/schedule?view=2week&date=<%= rawDate %><%= assigneeFilter ? '&assignee=' + assigneeFilter : '' %>">2 weeks</a>
      <span class="sc-toggle-sep"></span>
      <a href="/schedule?view=month&date=<%= rawDate %><%= assigneeFilter ? '&assignee=' + assigneeFilter : '' %>">Month</a>
    </div>

    <div style="flex:1"></div>

    <form method="get" action="/schedule" class="flex items-center gap-2">
      <input type="hidden" name="view" value="week">
      <input type="hidden" name="date" value="<%= weekStart %>">
      <select name="assignee" onchange="this.form.submit()">
        <option value="">All assignees</option>
        <% (users || []).forEach(function(u){ %>
          <option value="<%= u.id %>" <%= Number(assigneeFilter) === u.id ? 'selected' : '' %>><%= u.name %></option>
        <% }); %>
      </select>
      <a href="/work-orders/new" class="sc-nav-btn" style="font-weight:600;color:#1a1a1a;">+ New WO</a>
    </form>
  </div>

  <!-- Grid body -->
  <div class="sc-grid-wrap">
    <div class="sc-grid">
      <!-- Gutter (hour labels) -->
      <div class="sc-hour-gutter">
        <% hours.forEach(function(h){ %>
          <div class="sc-hour-label" style="top:<%= ((h - HOURS_START) / HOUR_COUNT * 100) %>%"><%= h %>:00</div>
          <div class="sc-hour-line<%= (h === 8 || h === 12 || h === 17) ? ' anchor-hour' : '' %>" style="top:<%= ((h - HOURS_START) / HOUR_COUNT * 100) %>%"></div>
        <% }); %>
      </div>

      <!-- Day columns -->
      <% days.forEach(function(day){ %>
        <div class="sc-day-col<%= day.isToday ? ' is-today' : '' %>" data-day-date="<%= day.date %>">
          <% var dayClosures = closures.filter(function(c){ return c.date_start <= day.date && (!c.date_end || c.date_end >= day.date); }); %>
          <% dayClosures.forEach(function(c){ %><div class="sc-closure-overlay"><%= c.name %></div><% }); %>
          <div class="sc-day-header<%= day.isToday ? ' is-today' : '' %>">
            <%= day.label %>
            <span class="sc-day-num"><%= day.num %></span>
          </div>

          <!-- Hour lines -->
          <% hours.forEach(function(h){ %>
            <div class="sc-hour-line<%= (h === 8 || h === 12 || h === 17) ? ' anchor-hour' : '' %>" style="top:<%= ((h - HOURS_START) / HOUR_COUNT * 100) %>%"></div>
          <% }); %>

          <!-- Now line (today only) -->
          <% if (day.isToday && nowOffset !== null) { %>
            <div class="sc-now-line" style="top:<%= nowOffset %>%"><div class="sc-now-dot"></div></div>
          <% } %>

          <!-- WO blocks -->
          <%
          var dayWos = wos.filter(function(w){ return w.scheduled_date === day.date; });
          if (dayWos.length > 0) {
            dayWos.forEach(function(wo){
              function fmtTime(t) {
                if (!t) return '—';
                var p = String(t).split(':');
                var h = parseInt(p[0], 10);
                if (isNaN(h)) return t;
                var ampm = h >= 12 ? 'PM' : 'AM';
                var h12 = h % 12 || 12;
                return h12 + ':' + (p[1] || '00') + ' ' + ampm;
              }
              var timeStr = wo.scheduled_time || '08:00';
              var endTimeStr = wo.scheduled_end_time || '';
              var parts = timeStr.split(':');
              var hour = parseInt(parts[0], 10);
              var min = parseInt(parts[1], 10);
              var startMin = (hour - HOURS_START) * 60 + min;
              var topPct = (startMin / TOTAL_MINUTES) * 100;
              var durHours = parseInt(process.env.WO_DEFAULT_DURATION_HOURS || '4', 10);
              // Use end_time if available, else default duration
              var heightPct;
              if (endTimeStr) {
                var ep = endTimeStr.split(':');
                var endMin = (parseInt(ep[0],10) - HOURS_START) * 60 + parseInt(ep[1],10);
                heightPct = Math.max((endMin - startMin) / TOTAL_MINUTES * 100, 3);
              } else {
                heightPct = (durHours * 60 / TOTAL_MINUTES) * 100;
              }
              var color = colorForStatus(wo, woConflicts);
              var hasConflict = !!woConflicts[wo.id];
              var isUnassigned = !wo.assigned_to_user_id && !wo.assigned_to;
          %>
            <div class="sc-wo-wrap" style="top:<%= topPct.toFixed(1) %>; height:<%= Math.max(heightPct, 3).toFixed(1) %>%"
               <% var o = woOverlaps[wo.id]; if (o && o.overlapCount > 1) { %>data-overlap-count="<%= o.overlapCount %>" data-overlap-index="<%= o.overlapIndex %>"<% } %>>
              <a href="/work-orders/<%= wo.id %>" class="sc-wo-block<%= isUnassigned ? ' sc-unassigned' : '' %>"
                 style="<%= color ? 'background:' + color : '' %>"
                 data-wo-id="<%= wo.id %>"
                 data-wo-display="<%= wo.display_number %>"
                 data-current-date="<%= wo.scheduled_date %>"
                 data-current-time="<%= wo.scheduled_time || '' %>"
                 data-end-time="<%= wo.scheduled_end_time || '' %>"
                 data-assignee-id="<%= wo.assigned_to_user_id || '' %>">
                <% if (hasConflict) { %>
                  <span class="sc-conflict-badge">
                    &#9888;
                    <span class="sc-conflict-tip">
                      <% woConflicts[wo.id].forEach(function(c){ %>
                        <%= 'WO-' + c.display_number %>: <%= c.overlap_minutes %>min overlap<br>
                      <% }); %>
                    </span>
                  </span>
                <% } %>
                <% var assigneeName = wo.assigned_user_name || wo.assigned_to || ''; %>
                <% if (assigneeName) { %><div class="sc-init-chip"><%= getInitials(assigneeName) %></div><% } %>
                <div class="sc-wo-num">WO-<%= wo.display_number %></div>
                <div class="sc-wo-customer"><%= (wo.customer_name || '').slice(0, 30) %></div>
                <div class="sc-wo-assignee"><%= assigneeName || 'Unassigned' %></div>
              </a>
              <div class="wo-hover-card">
                <div class="wo-hc-num">WO-<%= wo.display_number %></div>
                <div class="wo-hc-customer"><%= (wo.customer_name || '') %></div>
                <div class="wo-hc-job"><%= (wo.job_title || '') %></div>
                <div class="wo-hc-row"><span class="wo-hc-label">Time:</span> <%= fmtTime(wo.scheduled_time) %><% if (wo.scheduled_end_time) { %> – <%= fmtTime(wo.scheduled_end_time) %><% } %></div>
                <div class="wo-hc-row"><span class="wo-hc-label">Assignee:</span> <%= wo.assigned_user_name || wo.assigned_to || 'Unassigned' %></div>
                <span class="wo-hc-badge wo-hc-badge-<%= wo.status %>"><%= (wo.status || '').replace('_', ' ') %></span>
              </div>
            </div>
          <%
            });
          }
          %>
        </div>
      <% }); %>

      <!-- Empty state -->
      <% if (wos.length === 0) { %>
        <div class="sc-empty">No work scheduled this week.</div>
      <% } %>
    </div>
  </div>
</div>

<script src="/js/schedule-drag.js" defer></script>
</div>
<%- include('../layouts/footer') %>
