<div class="sc-sidebar" title="Work orders that don't have a date yet. Drag a pill onto the calendar to schedule it.">
  <div class="sc-sb-header">
    <span class="sc-sb-title">Unscheduled
      <span class="ml-1 text-recon-fog cursor-help" title="WOs without a scheduled date. Drag them onto the calendar to schedule. Drop a WO back here to unschedule it.">ⓘ</span>
    </span>
    <span class="sc-sb-count"><%= unscheduled.length %></span>
  </div>
  <% if (unscheduled.length === 0) { %>
    <div class="sc-sb-empty">&#10003; All work orders scheduled</div>
  <% } else { %>
    <div class="sc-sb-list">
      <% unscheduled.forEach(function(wo){
        var sColor = colorForStatus(wo, woConflicts);
        var sName = wo.assignee_display_name || wo.assigned_user_name || wo.assigned_to || '';
      %>
        <div class="sc-sb-pill" style="border-left:3px solid <%= sColor || '#9ca3af' %>"
             data-wo-id="<%= wo.id %>"
             data-wo-display="<%= wo.display_number %>"
             data-current-date=""
             data-current-time=""
             data-end-time=""
             data-assignee-id="<%= wo.assigned_to_user_id || '' %>"
             data-source="sidebar">
          <div class="sc-sb-pill-top">
            <span class="sc-sb-pill-num" style="color:<%= sColor || '#555' %>">WO-<%= wo.display_number %></span>
            <% if (sName) { %><span class="sc-sb-chip"><%= getInitials(sName) %></span><% } %>
          </div>
          <div class="sc-sb-pill-customer"><%= wo.customer_name || '' %></div>
          <div class="sc-sb-pill-job"><%= wo.job_title || '' %></div>
          <div class="sc-sb-pill-assignee"><%= sName || 'Unassigned' %></div>
        </div>
      <% }); %>
    </div>
  <% } %>
</div>
