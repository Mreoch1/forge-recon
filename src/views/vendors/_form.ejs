<%- include('../layouts/header', { title: title, currentUser: currentUser, flash: flash, activeNav: activeNav }) %>
<div class="max-w-2xl mx-auto px-4 py-6">
  <div class="mb-4"><a href="/vendors" class="text-sm text-recon-fog hover:text-recon-red">&larr; Vendors</a></div>
  <h1 class="page-h1 mb-6"><%= title %></h1>
  <div class="card p-6">
    <form action="<%= vendor.id ? '/vendors/' + vendor.id : '/vendors' %>" method="post" class="space-y-4">
      <div><label class="label">Name <span class="text-recon-red">*</span></label>
        <input type="text" name="name" value="<%= vendor.name || '' %>" class="input<%= errors.name ? ' border-red-500' : '' %>" required>
        <% if (errors.name) { %><p class="text-sm text-red-600 mt-1"><%= errors.name %></p><% } %></div>
      <div class="grid grid-cols-2 gap-4">
        <div><label class="label">Email</label><input type="email" name="email" value="<%= vendor.email || '' %>" class="input"></div>
        <div><label class="label">Phone</label><input type="text" name="phone" value="<%= vendor.phone || '' %>" class="input"></div>
      </div>
      <div><label class="label">Street</label><input type="text" name="address" value="<%= vendor.address || '' %>" class="input"></div>
      <div class="grid grid-cols-3 gap-4">
        <div><label class="label">City</label><input type="text" name="city" value="<%= vendor.city || '' %>" class="input"></div>
        <div><label class="label">State</label><input type="text" name="state" value="<%= vendor.state || '' %>" class="input" maxlength="2"></div>
        <div><label class="label">ZIP</label><input type="text" name="zip" value="<%= vendor.zip || '' %>" class="input" maxlength="10"></div>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div><label class="label">EIN / Tax ID</label><input type="text" name="ein" value="<%= vendor.ein || '' %>" class="input"></div>
        <div><label class="label">Default expense account</label>
          <select name="default_expense_account_id" class="input">
            <option value="">— Select —</option>
            <% (typeof accounts !== 'undefined' ? accounts : []).forEach(function(a) { %>
              <option value="<%= a.id %>" <%= String(vendor.default_expense_account_id) === String(a.id) ? 'selected' : '' %>><%= a.code %> — <%= a.name %></option>
            <% }); %>
          </select></div>
      </div>
      <div><label class="label">Notes</label><textarea name="notes" class="input" rows="3"><%= vendor.notes || '' %></textarea></div>
      <div class="flex gap-2 pt-4 border-t"><button type="submit" class="btn btn-primary">Save</button><a href="/vendors" class="btn btn-ghost">Cancel</a></div>
    </form>
  </div>
</div>
<%- include('../layouts/footer') %>