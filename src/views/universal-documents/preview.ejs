<%- include('../layouts/header', { title: title, currentUser: currentUser, flash: flash, activeNav: activeNav }) %>

<div class="document-shell">
  <div class="mb-4"><a href="/universal-documents" class="text-sm text-recon-fog hover:text-recon-red">&larr; Universal Documents</a></div>

  <div class="mb-4 flex flex-wrap items-start justify-between gap-3">
    <div>
      <h1 class="page-h1"><%= document.title %> <span class="badge"><%= statusLabel(document.status) %></span></h1>
      <p class="text-sm text-recon-fog">
        <% if (project) { %><a class="hover:text-recon-red" href="/projects/<%= project.id %>"><%= project.title %></a><% } else { %>No project<% } %>
        <% if (contractor) { %> · <a class="hover:text-recon-red" href="/contractors/<%= contractor.id %>"><%= contractor.name %></a><% } %>
        <% if (vendor) { %> · <a class="hover:text-recon-red" href="/vendors/<%= vendor.id %>"><%= vendor.name %></a><% } %>
      </p>
    </div>
    <div class="flex flex-wrap gap-2">
      <a href="/universal-documents/generated/<%= document.id %>/pdf" target="_blank" class="btn btn-secondary text-sm">PDF</a>
      <button type="button" class="btn btn-secondary text-sm" onclick="window.print()">Print</button>
    </div>
  </div>

  <div class="card p-5 mb-5">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 text-sm mb-5">
      <div><div class="label">Scope</div><%= document.scope_name || '-' %></div>
      <div><div class="label">Recipient</div><%= document.sent_to_email || '-' %></div>
      <div><div class="label">Created</div><%= formatDate(document.created_at) %></div>
    </div>
    <pre class="whitespace-pre-wrap font-sans text-sm leading-6"><%= document.body_snapshot %></pre>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-5">
    <form class="card p-4" method="post" action="/universal-documents/generated/<%= document.id %>/email">
      <h2 class="section-title mb-3">Send document</h2>
      <label class="block mb-3">
        <span class="label">Email</span>
        <input class="input" type="email" name="sent_to_email" value="<%= document.sent_to_email || '' %>" required>
      </label>
      <button class="btn btn-primary" type="submit">Send email</button>
    </form>

    <form class="card p-4" method="post" enctype="multipart/form-data" action="/universal-documents/generated/<%= document.id %>/upload-signed">
      <h2 class="section-title mb-3">Upload signed copy</h2>
      <input class="input mb-3" type="file" name="signed_file" required>
      <button class="btn btn-primary" type="submit">Upload signed document</button>
    </form>
  </div>

  <form class="card p-4 mb-5" method="post" action="/universal-documents/generated/<%= document.id %>/status">
    <h2 class="section-title mb-3">Status</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
      <select class="input" name="status">
        <% ['draft','generated','sent','viewed','signed','completed','expired','cancelled'].forEach(function(status) { %>
          <option value="<%= status %>" <%= document.status === status ? 'selected' : '' %>><%= statusLabel(status) %></option>
        <% }); %>
      </select>
      <input class="input md:col-span-2" name="note" placeholder="Optional note">
    </div>
    <button class="btn btn-secondary text-sm mt-3" type="submit">Update status</button>
  </form>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div class="card">
      <div class="section-header"><h2 class="section-title">Attachments</h2><span class="section-count"><%= attachments.length %></span></div>
      <table class="data text-sm"><tbody>
        <% if (!attachments.length) { %><tr><td class="text-recon-fog">No attachments yet.</td></tr><% } %>
        <% attachments.forEach(function(file) { %>
          <tr><td><%= file.filename %></td><td class="text-right text-recon-fog"><%= formatDate(file.created_at) %></td></tr>
        <% }); %>
      </tbody></table>
    </div>
    <div class="card">
      <div class="section-header"><h2 class="section-title">History</h2><span class="section-count"><%= events.length %></span></div>
      <table class="data text-sm"><tbody>
        <% if (!events.length) { %><tr><td class="text-recon-fog">No history yet.</td></tr><% } %>
        <% events.forEach(function(event) { %>
          <tr>
            <td><div class="font-semibold"><%= event.event_type %></div><div class="text-xs text-recon-fog"><%= event.note || '' %></div></td>
            <td class="text-right text-recon-fog"><%= formatDate(event.created_at) %></td>
          </tr>
        <% }); %>
      </tbody></table>
    </div>
  </div>
</div>

<%- include('../layouts/footer') %>
