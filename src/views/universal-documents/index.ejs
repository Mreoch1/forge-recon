<%- include('../layouts/header', { title: title, currentUser: currentUser, flash: flash, activeNav: activeNav }) %>

<div class="ops-shell">
  <div class="mb-5 flex flex-wrap items-start justify-between gap-3">
    <div>
      <h1 class="page-h1">Universal Documents</h1>
      <p class="text-recon-fog text-sm">Templates, generated documents, and pre-construction paperwork.</p>
    </div>
    <div class="flex flex-wrap gap-2">
      <a href="/universal-documents/templates/new" class="btn btn-secondary text-sm">New template</a>
      <a href="/universal-documents/generate" class="btn btn-primary text-sm">Generate document</a>
    </div>
  </div>

  <div class="kpi-strip mb-4">
    <div class="kpi"><div class="kpi-label">Templates</div><div class="kpi-value"><%= templates.length %></div><div class="kpi-sub">available</div></div>
    <div class="kpi"><div class="kpi-label">Recent docs</div><div class="kpi-value"><%= documents.length %></div><div class="kpi-sub">latest generated</div></div>
    <div class="kpi"><div class="kpi-label">Workflow</div><div class="kpi-value">Pre-con</div><div class="kpi-sub">project gate</div></div>
  </div>

  <div class="card mb-6">
    <div class="section-header">
      <h2 class="section-title">Templates</h2>
      <span class="section-count"><%= templates.length %> templates</span>
    </div>
    <table class="data">
      <thead>
        <tr>
          <th>Template</th>
          <th>Category</th>
          <th>Version</th>
          <th>Status</th>
          <th class="text-right">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% if (!templates.length) { %>
          <tr><td colspan="5" class="text-center text-recon-fog py-6">No templates yet.</td></tr>
        <% } %>
        <% templates.forEach(function(template) { %>
          <tr>
            <td>
              <div class="font-semibold"><%= template.title %></div>
              <% if (template.description) { %><div class="text-xs text-recon-fog"><%= template.description %></div><% } %>
            </td>
            <td><span class="badge"><%= template.category %></span></td>
            <td><%= template.version || '1.0' %></td>
            <td><span class="badge <%= template.is_active ? 'badge-green' : '' %>"><%= template.is_active ? 'Active' : 'Inactive' %></span></td>
            <td class="text-right"><a href="/universal-documents/templates/<%= template.id %>/edit" class="btn btn-secondary text-xs">Edit</a></td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>

  <div class="card">
    <div class="section-header">
      <h2 class="section-title">Recent Generated Documents</h2>
      <span class="section-count"><%= documents.length %> shown</span>
    </div>
    <table class="data">
      <thead>
        <tr>
          <th>Document</th>
          <th>Status</th>
          <th>Recipient</th>
          <th>Created</th>
          <th class="text-right">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% if (!documents.length) { %>
          <tr><td colspan="5" class="text-center text-recon-fog py-6">No documents generated yet.</td></tr>
        <% } %>
        <% documents.forEach(function(doc) { %>
          <tr>
            <td class="font-semibold"><%= doc.title %></td>
            <td><span class="badge"><%= statusLabel(doc.status) %></span></td>
            <td><%= doc.sent_to_email || '-' %></td>
            <td><%= formatDate(doc.created_at) %></td>
            <td class="text-right">
              <a href="/universal-documents/generated/<%= doc.id %>" class="btn btn-secondary text-xs">Open</a>
              <a href="/universal-documents/generated/<%= doc.id %>/pdf" class="btn btn-secondary text-xs" target="_blank">PDF</a>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>

<%- include('../layouts/footer') %>
