<%- include('../layouts/header', { title: title, currentUser: currentUser, flash: flash, activeNav: activeNav }) %>

<div class="ops-shell">
  <div class="mb-4"><a href="/projects/<%= project.id %>" class="text-sm text-recon-fog hover:text-recon-red">&larr; <%= project.title %></a></div>

  <div class="mb-5 flex flex-wrap items-start justify-between gap-3">
    <div>
      <h1 class="page-h1">Pre-Construction Documents</h1>
      <p class="text-recon-fog text-sm">Gate bid package, scope, drawing, and contact release until required docs are complete or waived.</p>
    </div>
    <a href="/universal-documents/generate?project_id=<%= project.id %>" class="btn btn-secondary text-sm">Generate custom document</a>
  </div>

  <form method="post" action="/universal-documents/preconstruction/projects/<%= project.id %>/requirements" class="card p-4 mb-5">
    <h2 class="section-title mb-3">Add requirement</h2>
    <div class="grid grid-cols-1 md:grid-cols-6 gap-3">
      <select class="input" name="document_type_id" required>
        <option value="">Document type</option>
        <% documentTypes.forEach(function(type) { %><option value="<%= type.id %>"><%= type.name %></option><% }); %>
      </select>
      <select class="input" name="contractor_id">
        <option value="">Contractor</option>
        <% contractors.forEach(function(contractor) { %><option value="<%= contractor.id %>"><%= contractor.name %></option><% }); %>
      </select>
      <select class="input" name="vendor_id">
        <option value="">Vendor</option>
        <% vendors.forEach(function(vendor) { %><option value="<%= vendor.id %>"><%= vendor.name %></option><% }); %>
      </select>
      <select class="input" name="project_rfp_id">
        <option value="">RFP / scope</option>
        <% rfps.filter(function(rfp){ return String(rfp.job_id) === String(project.id); }).forEach(function(rfp) { %>
          <option value="<%= rfp.id %>"><%= rfp.contractor_name || ('RFP #' + rfp.id) %></option>
        <% }); %>
      </select>
      <input class="input" name="scope_name" placeholder="Scope name">
      <input class="input" name="due_date" type="date">
      <input class="input md:col-span-5" name="notes" placeholder="Notes">
      <button class="btn btn-primary" type="submit">Add</button>
    </div>
  </form>

  <div class="card mb-5">
    <div class="section-header">
      <h2 class="section-title">Document Matrix</h2>
      <span class="section-count"><%= requirements.length %> requirements</span>
    </div>
    <table class="data text-sm">
      <thead>
        <tr>
          <th>Contractor / Vendor</th>
          <th>Scope</th>
          <th>Document</th>
          <th>Status</th>
          <th>Dates</th>
          <th class="text-right">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% if (!requirements.length) { %>
          <tr><td colspan="6" class="text-center text-recon-fog py-6">No pre-construction requirements yet.</td></tr>
        <% } %>
        <% requirements.forEach(function(req) { %>
          <tr>
            <td><%= req.contractors ? req.contractors.name : (req.vendors ? req.vendors.name : (req.scope_name || '-')) %></td>
            <td><%= req.scope_name || req.trade || '-' %></td>
            <td><%= req.preconstruction_document_types ? req.preconstruction_document_types.name : 'Document' %></td>
            <td><span class="badge"><%= statusLabel(req.status) %></span></td>
            <td class="text-xs text-recon-fog">
              <% if (req.due_date) { %>Due <%= formatDate(req.due_date) %><br><% } %>
              <% if (req.sent_at) { %>Sent <%= formatDate(req.sent_at) %><br><% } %>
              <% if (req.completed_at) { %>Complete <%= formatDate(req.completed_at) %><% } %>
            </td>
            <td class="text-right">
              <% if (!req.generated_document_id) { %>
                <form class="inline" method="post" action="/universal-documents/preconstruction/requirements/<%= req.id %>/generate"><button class="btn btn-secondary text-xs">Generate</button></form>
              <% } else { %>
                <a class="btn btn-secondary text-xs" href="/universal-documents/generated/<%= req.generated_document_id %>">View</a>
              <% } %>
              <form class="inline" method="post" action="/universal-documents/preconstruction/requirements/<%= req.id %>/complete"><button class="btn btn-secondary text-xs">Approve</button></form>
              <details class="inline-block relative text-left">
                <summary class="btn btn-secondary text-xs cursor-pointer">More</summary>
                <div class="absolute right-0 z-10 mt-1 w-72 rounded border bg-white p-3 shadow">
                  <form class="mb-2" method="post" enctype="multipart/form-data" action="/universal-documents/preconstruction/requirements/<%= req.id %>/upload">
                    <input class="input mb-2" type="file" name="requirement_file" required>
                    <button class="btn btn-primary text-xs">Upload</button>
                  </form>
                  <form class="mb-2" method="post" action="/universal-documents/preconstruction/requirements/<%= req.id %>/reject">
                    <input class="input mb-2" name="rejection_reason" placeholder="Revision reason" required>
                    <button class="btn btn-secondary text-xs">Reject</button>
                  </form>
                  <form method="post" action="/universal-documents/preconstruction/requirements/<%= req.id %>/waive">
                    <input class="input mb-2" name="waiver_reason" placeholder="Waiver reason" required>
                    <button class="btn btn-secondary text-xs">Waive</button>
                  </form>
                </div>
              </details>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>

  <form method="post" action="/universal-documents/preconstruction/projects/<%= project.id %>/release-scope" class="card p-4 mb-5">
    <h2 class="section-title mb-3">Scope release check</h2>
    <div class="grid grid-cols-1 md:grid-cols-4 gap-3">
      <select class="input" name="contractor_id">
        <option value="">Contractor</option>
        <% contractors.forEach(function(contractor) { %><option value="<%= contractor.id %>"><%= contractor.name %></option><% }); %>
      </select>
      <select class="input" name="vendor_id">
        <option value="">Vendor</option>
        <% vendors.forEach(function(vendor) { %><option value="<%= vendor.id %>"><%= vendor.name %></option><% }); %>
      </select>
      <select class="input" name="project_rfp_id">
        <option value="">RFP / scope</option>
        <% rfps.filter(function(rfp){ return String(rfp.job_id) === String(project.id); }).forEach(function(rfp) { %>
          <option value="<%= rfp.id %>"><%= rfp.contractor_name || ('RFP #' + rfp.id) %></option>
        <% }); %>
      </select>
      <button class="btn btn-primary" type="submit">Send scope</button>
    </div>
    <p class="text-xs text-recon-fog mt-2">FORGE will block release if required documents are not complete or waived.</p>
  </form>

  <div class="card">
    <div class="section-header"><h2 class="section-title">Release History</h2><span class="section-count"><%= releaseLogs.length %></span></div>
    <table class="data text-sm">
      <tbody>
        <% if (!releaseLogs.length) { %><tr><td class="text-recon-fog">No release checks yet.</td></tr><% } %>
        <% releaseLogs.forEach(function(log) { %>
          <tr>
            <td><span class="badge"><%= log.status %></span></td>
            <td><%= log.note || '-' %></td>
            <td class="text-right text-recon-fog"><%= formatDate(log.created_at) %></td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>

<%- include('../layouts/footer') %>
