<%- include('../layouts/header', { title: title, currentUser: currentUser, flash: flash, activeNav: activeNav }) %>

<div class="max-w-7xl mx-auto px-4 py-6">
  <div class="mb-4">
    <a href="/customers" class="text-sm text-recon-fog hover:text-recon-red">&larr; Customers</a>
  </div>

  <div class="flex items-baseline justify-between mb-6 flex-wrap gap-2">
    <div>
      <h1 class="page-h1"><%= customer.name %></h1>
      <p class="page-sub">Customer #<%= customer.id %> &middot; created <%= customer.created_at %></p>
    </div>
    <div class="flex gap-2">
      <a href="/customers/<%= customer.id %>/edit" class="btn btn-secondary">Edit</a>
      <a href="/work-orders/new?customer_id=<%= customer.id %>" class="btn btn-primary">+ Work order</a>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="lg:col-span-1">
      <div class="card p-5">
        <h3 class="text-sm font-semibold uppercase tracking-wide text-recon-fog mb-3">Contact</h3>
        <dl class="space-y-2 text-sm">
          <% if (customer.email) { %>
            <div><dt class="text-recon-fog text-xs">Email <span class="font-normal">(estimates)</span></dt><dd><a href="mailto:<%= customer.email %>" class="text-recon-charcoal hover:text-recon-red"><%= customer.email %></a></dd></div>
          <% } %>
          <% var custBillEmail = customer.billing_email || customer.email; %>
          <% if (custBillEmail) { %>
            <div><dt class="text-recon-fog text-xs">Billing email <span class="font-normal">(invoices)</span></dt><dd><a href="mailto:<%= custBillEmail %>" class="text-recon-charcoal hover:text-recon-red"><%= custBillEmail %></a><% if (!customer.billing_email) { %> <span class="text-xs text-recon-fog">(same as primary)</span><% } %></dd></div>
          <% } %>
          <% if (customer.phone) { %>
            <div><dt class="text-recon-fog text-xs">Phone</dt><dd><a href="tel:<%= customer.phone %>" class="text-recon-charcoal hover:text-recon-red"><%= customer.phone %></a></dd></div>
          <% } %>
          <% if (customer.contact_name) { %>
            <div><dt class="text-recon-fog text-xs">Contact person</dt><dd class="font-medium"><%= customer.contact_name %></dd></div>
          <% } %>
          <% if (customer.address || customer.city) { %>
            <div>
              <dt class="text-recon-fog text-xs">Address</dt>
              <dd>
                <% if (customer.address) { %><%= customer.address %><br><% } %>
                <%= [customer.city, customer.state, customer.zip].filter(Boolean).join(' ') %>
              </dd>
            </div>
          <% } %>
          <% if (!customer.email && !customer.phone && !customer.address && !customer.city) { %>
            <div class="text-recon-fog">No contact info on file. <a href="/customers/<%= customer.id %>/edit" class="text-recon-red underline">Add some</a>.</div>
          <% } %>
        </dl>
        <% if (customer.notes) { %>
          <h3 class="text-sm font-semibold uppercase tracking-wide text-recon-fog mt-5 mb-2">Notes</h3>
          <p class="text-sm whitespace-pre-line"><%= customer.notes %></p>
        <% } %>
      </div>
    </div>

    <div class="lg:col-span-2">
      <div class="card overflow-hidden">
        <div class="px-5 py-3 border-b border-recon-mist flex items-center justify-between flex-wrap gap-2">
          <h3 class="font-semibold">Work orders <% if (woTotal !== undefined) { %><span class="text-recon-fog font-normal text-sm">(<%= woTotal %> total)</span><% } %></h3>
          <a href="/work-orders/new?customer_id=<%= customer.id %>" class="text-sm text-recon-red hover:underline">+ Add work order</a>
        </div>

        <!-- D-071: search + status filter -->
        <form method="get" action="/customers/<%= customer.id %>" class="px-5 py-2 border-b border-recon-mist flex flex-wrap items-center gap-2">
          <input type="text" name="wo_q" value="<%= woQ || '' %>" placeholder="Search WOs..." class="input" style="flex:1;min-width:120px;padding:0.35rem 0.6rem;font-size:0.82rem;">
          <select name="wo_status" class="input" style="padding:0.35rem 0.6rem;font-size:0.82rem;">
            <option value="">All statuses</option>
            <option value="open" <%= woStatus === 'open' ? 'selected' : '' %>>Open</option>
            <option value="scheduled" <%= woStatus === 'scheduled' ? 'selected' : '' %>>Scheduled</option>
            <option value="in_progress" <%= woStatus === 'in_progress' ? 'selected' : '' %>>In Progress</option>
            <option value="on_hold" <%= woStatus === 'on_hold' ? 'selected' : '' %>>On Hold</option>
            <option value="closed" <%= woStatus === 'closed' ? 'selected' : '' %>>Closed</option>
            <option value="complete" <%= woStatus === 'complete' ? 'selected' : '' %>>Complete</option>
            <option value="cancelled" <%= woStatus === 'cancelled' ? 'selected' : '' %>>Cancelled</option>
          </select>
          <button class="btn btn-secondary" style="padding:0.35rem 0.8rem;font-size:0.82rem;">Filter</button>
          <% if (woQ || woStatus) { %>
            <a href="/customers/<%= customer.id %>" class="text-xs text-recon-fog hover:text-recon-red">Clear</a>
          <% } %>
        </form>

        <% if (workOrders.length === 0) { %>
          <div class="p-8 text-center text-recon-fog text-sm">
            <% if (woQ || woStatus) { %>
              No work orders match your search. <a href="/customers/<%= customer.id %>" class="text-recon-red underline">Clear filter</a>.
            <% } else { %>
              No work orders for this customer yet. <a href="/work-orders/new?customer_id=<%= customer.id %>" class="text-recon-red underline">Create a work order</a>.
            <% } %>
          </div>
        <% } else { %>
          <table class="data">
            <thead>
              <tr><th>WO</th><th>Description</th><th>Unit</th><th>Status</th><th>Scheduled</th><th>Created</th></tr>
            </thead>
            <tbody>
              <% workOrders.forEach(function(wo){ %>
                <tr>
                  <td class="font-medium"><a href="/work-orders/<%= wo.id %>" class="text-recon-red hover:underline">WO-<%= wo.display_number %></a></td>
                  <td><%= wo.description || '&mdash;' %></td>
                  <td><%= wo.unit_number || '&mdash;' %></td>
                  <td><span class="badge badge-<%= wo.status %>"><%= (wo.status || '').replace('_',' ') %></span></td>
                  <td><%= wo.scheduled_date ? String(wo.scheduled_date).slice(0,10) : '&mdash;' %><% if (wo.scheduled_time) { %> <span class="text-recon-fog"><%= String(wo.scheduled_time).slice(0,5) %></span><% } %></td>
                  <td><%= (wo.created_at || '').slice(0,10) %></td>
                </tr>
              <% }); %>
            </tbody>
          </table>

          <!-- D-071: pagination footer -->
          <% if (woPages > 1) { %>
            <div style="display:flex;align-items:center;justify-content:center;gap:0.5rem;padding:0.75rem 1rem;border-top:1px solid #e5e7eb;font-size:0.82rem;">
              <% if (woPage > 1) { %>
                <a href="?wo_page=<%= woPage - 1 %><%= woQ ? '&wo_q=' + encodeURIComponent(woQ) : '' %><%= woStatus ? '&wo_status=' + encodeURIComponent(woStatus) : '' %>" style="color:#c0202b;text-decoration:none;">&larr; Prev</a>
              <% } else { %>
                <span style="color:#9ca3af;">&larr; Prev</span>
              <% } %>
              <select onchange="if(this.value)window.location.href=this.value" style="font-size:0.82rem;padding:0.2rem 0.4rem;border-radius:4px;border:1px solid #d1d5db;">
                <% for (var p = 1; p <= woPages; p++) { %>
                  <option value="?wo_page=<%= p %><%= woQ ? '&wo_q=' + encodeURIComponent(woQ) : '' %><%= woStatus ? '&wo_status=' + encodeURIComponent(woStatus) : '' %>" <%= p === woPage ? 'selected' : '' %>>Page <%= p %> of <%= woPages %></option>
                <% } %>
              </select>
              <% if (woPage < woPages) { %>
                <a href="?wo_page=<%= woPage + 1 %><%= woQ ? '&wo_q=' + encodeURIComponent(woQ) : '' %><%= woStatus ? '&wo_status=' + encodeURIComponent(woStatus) : '' %>" style="color:#c0202b;text-decoration:none;">Next &rarr;</a>
              <% } else { %>
                <span style="color:#9ca3af;">Next &rarr;</span>
              <% } %>
            </div>
          <% } %>
        <% } %>
      </div>
    </div>
  </div>
</div>

<%- include("../layouts/footer") %>
