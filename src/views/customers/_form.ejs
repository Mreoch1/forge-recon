<%
// Shared form partial for new + edit. Expects: customer (object), errors (object), formAction (string), submitLabel (string).
%>
<form action="<%= formAction %>" method="post" class="space-y-4">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div class="md:col-span-2">
      <label class="label" for="name">Name <span class="text-recon-red">*</span>
        <span class="ml-1 text-recon-fog cursor-help" title="Customer or company name as it should appear on estimates, work orders, and invoices.">ⓘ</span>
      </label>
      <input type="text" name="name" id="name" required value="<%= customer.name || '' %>"
             class="input <%= errors.name ? 'border-red-500' : '' %>" autofocus>
      <% if (errors.name) { %><p class="text-sm text-red-600 mt-1"><%= errors.name %></p><% } %>
    </div>

    <div>
      <label class="label" for="contact_name">Contact person
        <span class="ml-1 text-recon-fog cursor-help" title="The manager or point of contact at this customer. Their email/phone should be the best way to reach them for approvals and scheduling.">ⓘ</span>
      </label>
      <input type="text" name="contact_name" id="contact_name" value="<%= customer.contact_name || '' %>" class="input" placeholder="e.g. Property manager or owner name">
    </div>

    <div>
      <label class="label" for="email">Primary email <span class="text-recon-fog text-xs font-normal">(estimates)</span>
        <span class="ml-1 text-recon-fog cursor-help" title="Where estimates and general communication are sent. Used as a fallback for billing if no billing email is set.">ⓘ</span>
      </label>
      <input type="email" name="email" id="email" value="<%= customer.email || '' %>"
             class="input <%= errors.email ? 'border-red-500' : '' %>">
      <% if (errors.email) { %><p class="text-sm text-red-600 mt-1"><%= errors.email %></p><% } %>
    </div>

    <div>
      <label class="label" for="billing_email">Billing email <span class="text-recon-fog text-xs font-normal">(invoices)</span>
        <span class="ml-1 text-recon-fog cursor-help" title="Where invoices and payment reminders are sent. Leave blank to use the primary email instead.">ⓘ</span>
      </label>
      <input type="email" name="billing_email" id="billing_email" value="<%= customer.billing_email || '' %>"
             class="input <%= errors.billing_email ? 'border-red-500' : '' %>"
             placeholder="Falls back to primary if blank">
      <% if (errors.billing_email) { %><p class="text-sm text-red-600 mt-1"><%= errors.billing_email %></p><% } %>
    </div>

    <div>
      <label class="label" for="phone">Phone
        <span class="ml-1 text-recon-fog cursor-help" title="Best contact number for scheduling and crew on-site coordination.">ⓘ</span>
      </label>
      <input type="text" name="phone" id="phone" value="<%= customer.phone || '' %>" class="input">
    </div>

    <div class="md:col-span-2">
      <label class="label" for="address">Address
        <span class="ml-1 text-recon-fog cursor-help" title="Service address — where the crew will go. Appears on the WO PDF.">ⓘ</span>
      </label>
      <input type="text" name="address" id="address" value="<%= customer.address || '' %>" class="input">
    </div>

    <div>
      <label class="label" for="city">City</label>
      <input type="text" name="city" id="city" value="<%= customer.city || '' %>" class="input">
    </div>

    <div class="grid grid-cols-2 gap-4">
      <div>
        <label class="label" for="state">State</label>
        <input type="text" name="state" id="state" value="<%= customer.state || '' %>" class="input" maxlength="2" placeholder="OH">
      </div>
      <div>
        <label class="label" for="zip">ZIP</label>
        <input type="text" name="zip" id="zip" value="<%= customer.zip || '' %>" class="input" maxlength="10">
      </div>
    </div>

    <div class="md:col-span-2">
      <label class="label" for="notes">Notes
        <span class="ml-1 text-recon-fog cursor-help" title="Internal notes about this customer (gate codes, preferences, billing quirks). NOT shown to the customer.">ⓘ</span>
      </label>
      <textarea name="notes" id="notes" rows="3" class="input" data-autosize><%= customer.notes || '' %></textarea>
    </div>
  </div>

  <div class="flex items-center gap-2 pt-4 border-t border-recon-mist">
    <button type="submit" class="btn btn-primary"><%= submitLabel %></button>
    <a href="<%= customer.id ? '/customers/' + customer.id : '/customers' %>" class="btn btn-ghost">Cancel</a>
  </div>
</form>

<script>
// Phone auto-format: (xxx) xxx-xxxx
document.addEventListener('input', function(e){
  if (e.target.id !== 'phone') return;
  var v = e.target.value.replace(/\D/g,'').slice(0,10);
  if (v.length > 6) v = '(' + v.slice(0,3) + ') ' + v.slice(3,6) + '-' + v.slice(6);
  else if (v.length > 3) v = '(' + v.slice(0,3) + ') ' + v.slice(3);
  else if (v.length) v = '(' + v;
  e.target.value = v;
});
</script>
