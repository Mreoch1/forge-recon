<%- include('../layouts/header', { title: title, currentUser: currentUser, flash: flash, activeNav: activeNav }) %>

<div class="max-w-3xl mx-auto px-4 py-6">
  <div class="mb-4">
    <a href="/customers/<%= customer.id %>" class="text-sm text-recon-fog hover:text-recon-red">&larr; <%= customer.name %></a>
  </div>
  <h1 class="page-h1 mb-6">Edit customer</h1>

  <div class="card p-6">
    <%- include('_form', { customer: customer, errors: errors, formAction: '/customers/' + customer.id, submitLabel: 'Save changes' }) %>
  </div>

  <div class="card p-6 mt-6 border-red-200">
    <h3 class="font-semibold text-recon-red mb-2">Danger zone</h3>
    <p class="text-sm text-recon-fog mb-3">Deleting a customer is permanent and only allowed if they have no jobs.</p>
    <form action="/customers/<%= customer.id %>/delete" method="post" onsubmit="return confirm('Delete <%= customer.name %>? This cannot be undone.');" class="m-0">
      <button type="submit" class="btn btn-danger" title="Permanently delete this customer. Only works if they have no work orders, estimates, or invoices.">Delete customer</button>
    </form>
  </div>
</div>

<%- include('../layouts/footer') %>
