<%- include('../layouts/header', { title: title, currentUser: currentUser, flash: flash, activeNav: activeNav }) %>

<%
function fmt(n) { const num = Number(n); return isFinite(num) ? num.toFixed(2) : '0.00'; }
const billToEmail = estimate.customer_billing_email || estimate.customer_email || '';
%>

<div class="max-w-5xl mx-auto px-4 py-6">
  <div class="mb-4">
    <a href="/estimates/<%= estimate.id %>" class="text-sm text-recon-fog hover:text-recon-red">&larr; <%= estimate.display_number %></a>
  </div>

  <div class="flex items-start justify-between gap-4 mb-6 flex-wrap">
    <div>
      <h1 class="page-h1">Create invoice</h1>
      <p class="page-sub">Approved scope from <%= estimate.display_number %> will transfer to a new draft invoice.</p>
    </div>
    <span class="badge badge-<%= estimate.status %>"><%= estimate.status %></span>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
    <div class="card p-5">
      <h3 class="text-sm font-semibold uppercase tracking-wide text-recon-fog mb-2">Customer</h3>
      <p class="font-semibold"><%= estimate.customer_name || 'Customer' %></p>
      <% if (billToEmail) { %><p class="text-sm text-recon-fog mt-1"><%= billToEmail %></p><% } %>
    </div>
    <div class="card p-5">
      <h3 class="text-sm font-semibold uppercase tracking-wide text-recon-fog mb-2">Work order</h3>
      <p class="font-semibold">WO-<%= estimate.wo_display_number %></p>
      <p class="text-sm text-recon-fog mt-1"><%= estimate.job_title || 'Customer work order' %></p>
    </div>
    <div class="card p-5">
      <h3 class="text-sm font-semibold uppercase tracking-wide text-recon-fog mb-2">Terms</h3>
      <p class="font-semibold"><%= estimate.payment_terms || 'Net 30' %></p>
      <p class="text-sm text-recon-fog mt-1">Copied to the invoice.</p>
    </div>
  </div>

  <form action="/estimates/<%= estimate.id %>/generate-invoice" method="post" class="space-y-6">
    <input type="hidden" name="invoice_review" value="1">
    <div class="card overflow-hidden">
      <div class="px-5 py-3 border-b border-recon-mist flex items-center justify-between gap-3">
        <h3 class="font-semibold">Approved scope items</h3>
        <span class="text-sm text-recon-fog"><%= approvedLines.length %> item(s)</span>
      </div>
      <div class="overflow-x-auto">
        <table class="data">
          <thead>
            <tr>
              <th>Description</th>
              <th class="text-right">Qty</th>
              <th>Unit</th>
              <th class="text-right">Unit $</th>
              <th class="text-right">Line $</th>
            </tr>
          </thead>
          <tbody>
            <% approvedLines.forEach(function(li) { %>
              <tr>
                <td>
                  <input type="hidden" name="selected_lines" value="<%= li.id %>">
                  <%= li.description %>
                </td>
                <td class="text-right"><%= li.quantity %></td>
                <td><%= li.unit %></td>
                <td class="text-right">$<%= fmt(li.unit_price) %></td>
                <td class="text-right font-medium">$<%= fmt(li.line_total) %></td>
              </tr>
            <% }); %>
          </tbody>
          <tfoot class="bg-recon-cloud">
            <tr>
              <td colspan="4" class="text-right text-sm font-medium">Subtotal</td>
              <td class="text-right font-semibold">$<%= fmt(totals.subtotal) %></td>
            </tr>
            <tr>
              <td colspan="4" class="text-right text-sm font-medium">Tax (<%= fmt(totals.taxRate) %>%)</td>
              <td class="text-right font-semibold">$<%= fmt(totals.taxAmount) %></td>
            </tr>
            <tr>
              <td colspan="4" class="text-right text-sm font-semibold uppercase">Invoice total</td>
              <td class="text-right text-lg font-bold text-recon-red">$<%= fmt(totals.total) %></td>
            </tr>
          </tfoot>
        </table>
      </div>
    </div>

    <div class="flex items-center justify-between gap-3 flex-wrap">
      <p class="text-sm text-recon-fog">Only these approved scope items will appear on the invoice.</p>
      <div class="flex items-center gap-2">
        <a href="/estimates/<%= estimate.id %>" class="btn btn-ghost">Back</a>
        <button type="submit" class="btn btn-primary">Create draft invoice</button>
      </div>
    </div>
  </form>
</div>

<%- include('../layouts/footer') %>
