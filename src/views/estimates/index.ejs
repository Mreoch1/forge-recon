<%- include('../layouts/header', { title: title, currentUser: currentUser, flash: flash, activeNav: activeNav }) %>

<%
function fmt(n) { const num = Number(n); return isFinite(num) ? num.toFixed(2) : '0.00'; }
function calcMargin(e) {
  const cost = Number(e.cost_total) || 0;
  const total = Number(e.total) || 0;
  if (cost <= 0 || total <= 0) return '—';
  const subtotal = Number(e.subtotal) || total;
  const profit = subtotal - cost;
  return ((profit / cost) * 100).toFixed(1) + '%';
}
const showPrices = (typeof canSeePrices === 'undefined') ? true : canSeePrices;
%>

<div class="max-w-7xl mx-auto px-4 py-6">
  <div class="flex items-baseline justify-between mb-2 flex-wrap gap-2">
    <div>
      <h1 class="page-h1">Estimates</h1>
      <p class="page-sub"><%= total %> total<% if (q) { %> &middot; "<%= q %>"<% } %><% if (status) { %> &middot; <%= status %><% } %></p>
    </div>
  </div>

  <form method="get" action="/estimates" class="list-utility-bar">
    <div class="flex items-center gap-1">
      <a href="/estimates?archived=0<%= q ? '&q='+encodeURIComponent(q) : '' %><%= status ? '&status='+encodeURIComponent(status) : '' %>"
         class="btn <%= archiveFilter === '0' ? 'btn-primary' : 'btn-ghost' %>">Active</a>
      <a href="/estimates?archived=1<%= q ? '&q='+encodeURIComponent(q) : '' %><%= status ? '&status='+encodeURIComponent(status) : '' %>"
         class="btn <%= archiveFilter === '1' ? 'btn-primary' : 'btn-ghost' %>">Archived</a>
      <a href="/estimates?archived=all<%= q ? '&q='+encodeURIComponent(q) : '' %><%= status ? '&status='+encodeURIComponent(status) : '' %>"
         class="btn <%= archiveFilter === 'all' ? 'btn-primary' : 'btn-ghost' %>">All</a>
    </div>
    <input type="text" name="q" value="<%= q %>" placeholder="Search number, job, customer..." class="list-search">
    <select name="status" class="list-filter">
      <option value="">All statuses</option>
      <% statuses.forEach(function(s){ %>
        <option value="<%= s %>" <%= status === s ? 'selected' : '' %>><%= s.replace('_',' ') %></option>
      <% }); %>
    </select>
    <button type="submit" class="btn btn-secondary">Filter</button>
    <% if (q || status) { %>
      <a href="/estimates" class="list-clear">Clear</a>
    <% } %>
    <a href="/estimates/new" class="btn btn-primary">+ New estimate</a>
  </form>

  <div class="card overflow-hidden">
    <% if (estimates.length === 0) { %>
      <div class="p-8 text-center text-recon-fog">
        <% if (q || status) { %>
          No estimates match. <a href="/estimates" class="text-recon-red underline">Clear</a>
        <% } else { %>
          No estimates yet. Use the <a href="/estimates/new" class="text-recon-red underline">+ New estimate</a> button above, or create one from a <a href="/work-orders" class="text-recon-red underline">work order</a>.
        <% } %>
      </div>
    <% } else { %>
      <table class="data">
        <thead>
          <tr>
            <th>Number</th>
            <th>Work order</th>
            <th>Customer</th>
            <th>Status</th>
            <th class="text-right">Total</th>
            <% if (showPrices) { %><th class="text-right">Margin</th><% } %>
            <th>Valid until</th>
            <th>Created</th>
            <% if (archiveFilter !== '0') { %><th></th><% } %>
          </tr>
        </thead>
        <tbody>
          <% estimates.forEach(function(e){
               const estStatusHint = e.status === 'draft' ? 'Not sent yet. Edit freely.'
                                   : e.status === 'sent' ? 'Emailed to customer, awaiting decision.'
                                   : e.status === 'accepted' ? 'Customer approved. Ready to convert to invoice.'
                                   : e.status === 'rejected' ? 'Customer declined. Read-only.'
                                   : e.status === 'converted' ? 'Invoice has been created from this estimate.'
                                   : e.status;
          %>
<tr class="row-link" data-href="/estimates/<%= e.id %>">
            <td class="font-medium">EST-<%= e.wo_display_number %></td>
              <td>WO-<%= e.wo_display_number %></td>
              <td><%= e.customer_name %></td>
              <td><span class="badge badge-<%= e.status %>" title="<%= estStatusHint %>"><%= e.status %></span></td>
              <td class="text-right">$<%= fmt(e.total) %></td>
              <% if (showPrices) { %><td class="text-right" style="color:<%= (Number(e.cost_total)||0) > 0 && (Number(e.subtotal)||0) > (Number(e.cost_total)||0) ? '#065f46' : '#991b1b' %>"><%= calcMargin(e) %></td><% } %>
              <td><%= (e.valid_until || '—').slice(0,10) %></td>
              <td><%= (e.created_at || '').slice(0,10) %></td>
              <% if (archiveFilter !== '0') { %>
                <td><% if (e.archived_at) { %><span class="badge badge-archived">archived</span><% } %></td>
              <% } %>
            </tr>
          <% }); %>
        </tbody>
      </table>
    <% } %>
  </div>

  <% if (totalPages > 1) { %>
    <div class="flex items-center justify-center gap-2 mt-4">
      <% for (let p = 1; p <= totalPages; p++) { %>
        <% const qs = ['page='+p]; if (q) qs.push('q='+encodeURIComponent(q)); if (status) qs.push('status='+encodeURIComponent(status)); %>
        <% if (p === page) { %><span class="btn btn-primary"><%= p %></span>
        <% } else { %><a href="/estimates?<%= qs.join('&') %>" class="btn btn-ghost"><%= p %></a><% } %>
      <% } %>
    </div>
  <% } %>
</div>

<%- include('../layouts/footer') %>
