<%- include('../layouts/header', { title: title, currentUser: currentUser, flash: flash, activeNav: activeNav }) %>

<%
function fmt(n) { const num = Number(n); return isFinite(num) ? num.toFixed(2) : '0.00'; }
const showCosts = (typeof canSeePrices === 'undefined') ? true : canSeePrices;
const costTotal = Number(estimate.cost_total) || 0;
const subtotal = Number(estimate.subtotal) || 0;
const markup = subtotal - costTotal;
const markupPct = costTotal > 0 ? ((markup / costTotal) * 100).toFixed(1) : '—';
const EST_STATUS_HINTS = {
  new: 'New — just created, not yet sent.',
  draft: 'Draft — not sent yet. Edit freely; only office can see it.',
  sent: 'Sent — emailed to the customer, awaiting response.',
  pending: 'Pending — estimate is out for approval.',
  approved: 'Approved — customer approved. Ready to convert to an invoice.',
  accepted: 'Accepted — customer approved. Ready to convert to an invoice.',
  rejected: 'Rejected — customer declined. Read-only history.',
  converted: 'Converted — an invoice has been created from this estimate.'
};
const estStatusHint = EST_STATUS_HINTS[estimate.status] || estimate.status;
const isAdmin = currentUser && currentUser.role === 'admin';
const customerLabel = estimate.customer_name || 'Customer';
%>

<div class="document-shell">
  <div class="mb-4">
    <a href="/estimates" class="text-sm text-recon-fog hover:text-recon-red">&larr; Estimates</a>
  </div>

  <div class="flex items-baseline justify-between mb-6 flex-wrap gap-2">
    <div>
      <div class="flex items-center gap-3">
        <h1 class="page-h1"><%= estimate.display_number %></h1>
        <span class="badge badge-<%= estimate.status %>" title="<%= estStatusHint %>"><%= estimate.status %></span>
        <% if (estimate.sent_at && estimate.status !== 'draft') { %>
          <div class="text-xs text-recon-fog mt-1">
            Sent <%= (estimate.sent_at || '').slice(0,10) %>
            <% if (estimate.sent_by_name) { %>by <%= estimate.sent_by_name %><% } %>
            <% if (estimate.sent_to_email) { %>to <%= estimate.sent_to_email %><% } %>
          </div>
        <% } %>
      </div>
      <p class="page-sub">
        <a href="/work-orders/<%= estimate.wo_id %>" class="hover:text-recon-red font-medium">&larr; WO-<%= estimate.wo_display_number %></a>
        &middot; Customer:
        <% if (isAdmin) { %>
          <a href="/customers/<%= estimate.customer_id %>" class="hover:text-recon-red"><%= customerLabel %></a>
        <% } else { %>
          <%= customerLabel %>
        <% } %>
        <% var unitNum = estimate.unit_number || estimate.wo_unit_number; if (unitNum) { %>
          &middot; Unit: <%= unitNum %>
        <% } %>
        <% if (estimate.customer_email) { %>
          &middot; Send estimate to: <a href="mailto:<%= estimate.customer_email %>" class="hover:text-recon-red"><%= estimate.customer_email %></a>
        <% } %>
      </p>
    </div>
    <%# R37e: Button row redesigned. Layout:
        LEFT  group — document actions (ghost outline, low visual weight): View PDF · Download
        RIGHT group — workflow actions in left-to-right order of escalation:
            Edit (secondary) → Create invoice (secondary skip-ahead OR primary when accepted) → Send/Accept (primary CTA)
        Only ONE primary button is visible at any status, so the user always sees a clear next step.
    %>
    <div class="document-actions">
      <!-- Document group: ghost outline, grouped together on the left -->
      <a href="/estimates/<%= estimate.id %>/pdf" class="btn btn-ghost" target="_blank" rel="noopener"
         title="Open the estimate PDF in a new tab.">View PDF</a>

      <% if (['new', 'draft', 'sent', 'pending', 'accepted', 'approved'].includes(estimate.status)) { %>
        <!-- Visual separator between document group and workflow group -->
        <span class="hidden md:inline text-recon-mist px-1" aria-hidden="true">|</span>

        <!-- Edit is always available pre-conversion, low-weight secondary -->
        <a href="/estimates/<%= estimate.id %>/edit" class="btn btn-secondary">Edit</a>

        <%# Create invoice — POSTs directly to /generate-invoice (skips the review/preview page).
            Creates the invoice immediately from approved lines and redirects to the invoice EDIT page. %>
        <% if (isAdmin && !invoice && estimate.lines.length > 0) { %>
          <button form="line-approvals-form"
                  formaction="/estimates/<%= estimate.id %>/generate-invoice"
                  formmethod="post"
                  class="btn <%= estimate.status === 'approved' || estimate.status === 'accepted' ? 'btn-primary' : 'btn-secondary' %>"
                  title="Create an invoice from the approved (checked) line items and open it for editing.">Create invoice</button>
        <% } %>

        <%# Workflow primary CTA: matches current status step. Only one primary at a time. %>
        <% if (estimate.status === 'new' || estimate.status === 'draft') { %>
          <%# R37l: manually mark-sent for cases where the estimate was emailed/printed/delivered outside FORGE. %>
          <form action="/estimates/<%= estimate.id %>/mark-sent" method="post" class="m-0 inline"
                onsubmit="return confirm('Mark <%= estimate.display_number %> as sent without firing the email?');">
            <button class="btn btn-secondary" title="Mark sent manually — no email is fired. Use when the customer was emailed/printed/delivered outside FORGE.">Mark sent</button>
          </form>
          <form action="/estimates/<%= estimate.id %>/send" method="post" class="m-0 inline">
            <button class="btn btn-primary" title="Email this estimate to the customer's primary email with the PDF attached.">Send email</button>
          </form>
        <% } else if (estimate.status === 'sent') { %>
          <form action="/estimates/<%= estimate.id %>/mark-pending" method="post" class="m-0 inline">
            <button class="btn btn-primary" title="Mark as pending — awaiting customer approval decision.">Mark pending</button>
          </form>
        <% } else if (estimate.status === 'pending') { %>
          <form action="/estimates/<%= estimate.id %>/approve" method="post" class="m-0 inline"
                onsubmit="return confirm('Approve <%= estimate.display_number %>? This marks it approved and ready for invoicing.');">
            <button class="btn btn-primary" title="Customer approved — mark approved so it can be converted to an invoice.">Approve</button>
          </form>
        <% } %>
      <% } %>
    </div>
  </div>

  <%- include('../partials/document-tabs', {
    documentTabs: {
      active: 'estimate',
      woId: estimate.wo_id,
      woDisplayNumber: estimate.wo_display_number,
      displayNumber: estimate.wo_display_number,
      woStatus: 'Field scope',
      estimateId: estimate.id,
      estimateStatus: estimate.status,
      invoiceId: isAdmin && invoice && invoice.id,
      invoiceStatus: invoice && invoice.status
    }
  }) %>

  <% if (showCosts && costTotal > 0) { %>
    <div class="card p-4 mb-6 bg-recon-cloud">
      <div class="flex flex-wrap items-center gap-6 text-sm">
        <span><span class="text-recon-fog">Cost:</span> <strong>$<%= fmt(costTotal) %></strong></span>
        <span><span class="text-recon-fog">Profit:</span> <strong class="<%= markup >= 0 ? 'text-green-700' : 'text-recon-red' %>">$<%= fmt(markup) %></strong></span>
        <span><span class="text-recon-fog">Markup:</span> <strong class="<%= markupPct !== '—' && parseFloat(markupPct) >= 0 ? 'text-green-700' : 'text-recon-red' %>"><%= markupPct %>%</strong></span>
      </div>
      <p class="text-xs text-recon-fog mt-1">Internal &mdash; not shown on customer PDFs.</p>
    </div>
  <% } %>

  <% if (showCosts && typeof actualCost !== 'undefined' && actualCost > 0) { %>
    <% var costVariance = actualCost - costTotal; %>
    <div class="card p-4 mb-6 bg-amber-50 border-amber-200">
      <div class="flex flex-wrap items-center gap-6 text-sm">
        <span><span class="text-recon-fog">Est. cost:</span> <strong>$<%= fmt(costTotal) %></strong></span>
        <span><span class="text-recon-fog">Actual cost:</span> <strong>$<%= fmt(actualCost) %></strong></span>
        <span><span class="text-recon-fog">Variance:</span> <strong class="<%= costVariance <= 0 ? 'text-green-700' : 'text-recon-red' %>"><%= costVariance >= 0 ? '+' : '' %>$<%= fmt(costVariance) %></strong></span>
      </div>
      <p class="text-xs text-recon-fog mt-1">From linked vendor bills &mdash; internal only.</p>
    </div>
  <% } %>

  <% if (isAdmin && invoice) { %>
    <div class="card p-4 mb-6 bg-green-50 border-green-200">
      <p class="text-sm">
        Invoice generated: <a href="/invoices/<%= invoice.id %>" class="font-medium text-recon-red hover:underline">INV-<%= estimate.wo_display_number %></a>
        <span class="badge badge-<%= invoice.status %>"><%= invoice.status %></span>
      </p>
    </div>
  <% } %>

  <div class="card overflow-hidden mb-6">
    <div class="px-5 py-3 border-b border-recon-mist flex items-center justify-between gap-3">
      <h3 class="font-semibold">Items</h3>
      <% if (!invoice && estimate.lines.length > 0 && ['new', 'draft', 'sent', 'pending'].includes(estimate.status)) { %>
        <button form="line-approvals-form" type="submit" class="btn btn-secondary text-sm">Save approvals</button>
      <% } %>
    </div>
    <% if (estimate.lines.length === 0) { %>
      <div class="p-6 text-center text-recon-fog text-sm">No items.</div>
    <% } else { %>
      <form id="line-approvals-form" action="/estimates/<%= estimate.id %>/line-approvals" method="post">
      <input type="hidden" name="approval_form" value="1">
      <table class="data">
        <thead>
          <tr>
            <th class="text-center">Approved</th>
            <th>Description</th>
            <th class="text-right">Qty</th>
            <th>Unit</th>
            <% if (showCosts) { %><th class="text-right text-recon-fog">Cost</th><% } %>
            <th class="text-right">Rate</th>
            <th class="text-right">Line $</th>
          </tr>
        </thead>
        <tbody>
          <% estimate.lines.forEach(function(li){ %>
            <tr>
              <td class="text-center">
                <input type="checkbox" name="approved_lines" value="<%= li.id %>" <%= li.selected === 0 || li.selected === false ? '' : 'checked' %> <%= invoice ? 'disabled' : '' %>>
              </td>
              <td><%= li.description %></td>
              <td class="text-right"><%= li.quantity %></td>
              <td><%= li.unit %></td>
              <% if (showCosts) { %><td class="text-right text-recon-fog">$<%= fmt(li.cost) %></td><% } %>
              <td class="text-right">$<%= fmt(li.unit_price) %></td>
              <td class="text-right font-medium">$<%= fmt(li.line_total) %></td>
            </tr>
          <% }); %>
        </tbody>
        <tfoot class="bg-recon-cloud">
          <%# Order: Subtotal → Cost (internal) → Tax → Total → Margin (internal). Cost + Margin only render when showCosts is true (manager/admin view). Customer-facing PDF/email is Subtotal → Tax → Total only. %>
          <tr>
            <td colspan="<%= showCosts ? 6 : 5 %>" class="text-right text-sm font-medium">Subtotal</td>
            <td class="text-right font-semibold">$<%= fmt(subtotal) %></td>
          </tr>
          <% if (showCosts) { %>
            <tr>
              <td colspan="6" class="text-right text-sm font-medium text-recon-fog">Cost <span class="text-xs">(internal)</span></td>
              <td class="text-right font-semibold text-recon-fog">$<%= fmt(costTotal) %></td>
            </tr>
          <% } %>
          <tr>
            <td colspan="<%= showCosts ? 6 : 5 %>" class="text-right text-sm font-medium">Tax (<%= fmt(estimate.tax_rate) %>%)</td>
            <td class="text-right font-semibold">$<%= fmt(estimate.tax_amount) %></td>
          </tr>
          <tr>
            <td colspan="<%= showCosts ? 6 : 5 %>" class="text-right text-sm font-semibold uppercase">Total</td>
            <td class="text-right text-lg font-bold text-recon-red">$<%= fmt(estimate.total) %></td>
          </tr>
          <% if (showCosts) { %>
            <tr>
              <td colspan="6" class="text-right text-sm font-medium text-recon-fog">Markup <span class="text-xs">(internal, <%= markupPct %>%)</span></td>
              <td class="text-right font-semibold <%= markup >= 0 ? 'text-green-700' : 'text-recon-red' %>">$<%= fmt(markup) %></td>
            </tr>
          <% } %>
        </tfoot>
      </table>
      </form>
    <% } %>
  </div>

  <%# R37g: Notes promoted out of the dates/notes 2-col grid into its own
      full-width prominent card right below the items table. Notes are the
      customer-visible terms/assumptions so they need to be obvious here
      AND in the email + PDF. %>
  <% if (estimate.notes) { %>
    <div class="card p-5 mb-6 border-l-4 border-recon-red">
      <h3 class="text-sm font-semibold uppercase tracking-wide text-recon-fog mb-2">Notes <span class="text-xs normal-case font-normal text-recon-fog">(visible on customer PDF + email)</span></h3>
      <p class="text-sm whitespace-pre-line"><%= estimate.notes %></p>
    </div>
  <% } %>

  <%# D-143: company default conditions & terms — same field that prints on every
      invoice (Admin → Settings → "Default invoice conditions & terms"). %>
  <% if (typeof defaultConditions !== 'undefined' && defaultConditions) { %>
    <div class="card p-5 mb-6">
      <h3 class="text-sm font-semibold uppercase tracking-wide text-recon-fog mb-2">Conditions &amp; terms <span class="text-xs normal-case font-normal text-recon-fog">(default — set in Admin → Settings)</span></h3>
      <p class="text-sm whitespace-pre-line"><%= defaultConditions %></p>
    </div>
  <% } %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
    <div class="card p-5">
      <h3 class="text-sm font-semibold uppercase tracking-wide text-recon-fog mb-2">Dates</h3>
      <dl class="space-y-1 text-sm">
        <div><dt class="text-recon-fog text-xs inline">Created:</dt> <dd class="inline"><%= (estimate.created_at || '—').slice(0,10) %></dd></div>
        <div><dt class="text-recon-fog text-xs inline">Terms:</dt> <dd class="inline"><%= estimate.payment_terms || 'Net 30' %></dd></div>
        <% if (estimate.po_number) { %>
          <div><dt class="text-recon-fog text-xs inline">PO #:</dt> <dd class="inline"><%= estimate.po_number %></dd></div>
        <% } %>
        <% if (estimate.valid_until) { %>
          <div><dt class="text-recon-fog text-xs inline">Valid until:</dt> <dd class="inline"><%= String(estimate.valid_until).slice(0,10) %></dd></div>
        <% } %>
        <% if (estimate.sent_at) { %>
          <div><dt class="text-recon-fog text-xs inline">Sent:</dt> <dd class="inline"><%= estimate.sent_at %></dd></div>
        <% } %>
        <% if (estimate.accepted_at) { %>
          <div><dt class="text-recon-fog text-xs inline">Accepted:</dt> <dd class="inline"><%= estimate.accepted_at %></dd></div>
          <%# D-124: badge if edited after acceptance %>
          <% if (estimate.updated_at && String(estimate.updated_at) > String(estimate.accepted_at)) { %>
            <div class="mt-1"><span class="inline-flex items-center gap-1 text-xs px-2 py-0.5 rounded-full bg-amber-100 text-amber-800">✎ Edited after acceptance · <%= String(estimate.updated_at).slice(0,10) %></span></div>
          <% } %>
        <% } %>
        <% if (estimate.archived_at) { %>
          <div><dt class="text-recon-fog text-xs inline">Archived:</dt> <dd class="inline"><%= estimate.archived_at %></dd></div>
        <% } %>
      </dl>
    </div>
  </div>

  <%- include('../partials/activity-panel', {
    activity: activity,
    activityTitle: 'Activity',
    activityNoteAction: '/estimates/' + estimate.id + '/activity-note'
  }) %>

  <details class="document-danger">
    <summary>Danger zone</summary>
    <div class="document-danger-body">

    <% if (estimate.status === 'sent' || estimate.status === 'pending') { %>
      <form action="/estimates/<%= estimate.id %>/reject" method="post"
            onsubmit="return confirm('Mark <%= estimate.display_number %> rejected?');">
        <button class="btn btn-danger" title="Customer declined — mark rejected. Estimate becomes read-only history.">Mark rejected</button>
      </form>
    <% } %>

    <% if (!estimate.archived_at) { %>
      <form action="/estimates/<%= estimate.id %>/archive" method="post"
            onsubmit="return confirm('Close <%= estimate.display_number %>?');">
        <button type="submit" class="btn btn-danger" title="Archive this estimate. Hides it from the main list but keeps history. Admins can unarchive later.">Close estimate</button>
      </form>
    <% } else if (currentUser && currentUser.role === 'admin') { %>
      <form action="/estimates/<%= estimate.id %>/unarchive" method="post"
            onsubmit="return confirm('Unarchive <%= estimate.display_number %>?');">
        <button type="submit" class="btn btn-ghost" title="Restore this estimate to the active list.">Unarchive</button>
      </form>
    <% } %>

    <% if ((estimate.status === 'new' || estimate.status === 'draft') && !invoice) { %>
      <form action="/estimates/<%= estimate.id %>/delete" method="post"
            onsubmit="return confirm('Delete <%= estimate.display_number %>?');">
        <button type="submit" class="btn btn-danger" title="Permanently delete this draft estimate. Only possible while in Draft status with no invoice.">Delete estimate</button>
      </form>
    <% } %>
    </div>
  </details>
</div>

<%- include('../layouts/footer') %>
