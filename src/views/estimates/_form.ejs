<%
// Shared form for new + edit. Expects: estimate, job, errors, trades, units, formAction, submitLabel.
// estimate.lines is array of { description, trade, quantity, unit, unit_price, line_total } objects.
// If estimate.lines is empty, render one empty row so the user has somewhere to start.
const linesToRender = (estimate.lines && estimate.lines.length) ? estimate.lines : [{
  description: '', trade: 'general', quantity: 1, unit: 'ea', unit_price: 0, line_total: 0
}];
function moneyFmt(n) { const num = Number(n); return isFinite(num) ? num.toFixed(2) : '0.00'; }
%>
<form action="<%= formAction %>" method="post" class="space-y-6">
  <input type="hidden" name="job_id" value="<%= job.id %>">

  <div class="card p-5">
    <h3 class="text-sm font-semibold uppercase tracking-wide text-recon-fog mb-3">Job</h3>
    <p class="font-medium"><%= job.title %></p>
    <p class="text-sm text-recon-fog">For <a href="/customers/<%= job.customer_id %>" class="hover:text-recon-red"><%= job.customer_name %></a></p>
  </div>

  <div class="card p-5">
    <h3 class="text-sm font-semibold uppercase tracking-wide text-recon-fog mb-3">Header</h3>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <div>
        <label class="label" for="valid_until">Valid until</label>
        <input type="date" name="valid_until" id="valid_until"
               value="<%= estimate.valid_until ? String(estimate.valid_until).slice(0,10) : '' %>"
               class="input <%= errors.valid_until ? 'border-red-500' : '' %>">
        <% if (errors.valid_until) { %><p class="text-sm text-red-600 mt-1"><%= errors.valid_until %></p><% } %>
      </div>
      <div>
        <label class="label" for="tax_rate">Tax rate (%)</label>
        <input type="number" step="0.001" min="0" name="tax_rate" id="tax_rate"
               value="<%= estimate.tax_rate || 0 %>"
               class="input" data-totals="tax_rate">
      </div>
      <% if (estimate.estimate_number) { %>
        <div>
          <label class="label">Number</label>
          <p class="input bg-recon-cloud text-recon-fog"><%= estimate.estimate_number %></p>
        </div>
      <% } %>
    </div>
  </div>

  <div class="card overflow-hidden">
    <div class="px-5 py-3 border-b border-recon-mist flex items-center justify-between">
      <h3 class="font-semibold">Line items</h3>
      <button type="button" data-add-line class="btn btn-secondary text-sm">+ Add line</button>
    </div>
    <% if (errors.lines) { %>
      <div class="px-5 py-2 text-sm text-red-600 bg-red-50 border-b border-red-200"><%= errors.lines %></div>
    <% } %>
    <div class="overflow-x-auto">
      <table class="data" data-line-items>
        <thead>
          <tr>
            <th>Trade</th>
            <th>Description</th>
            <th class="text-right">Qty</th>
            <th>Unit</th>
            <th class="text-right">Unit $</th>
            <th class="text-right">Line $</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% linesToRender.forEach(function(li, idx){ %>
            <tr class="line-row">
              <td>
                <select name="lines[<%= idx %>][trade]" data-field="trade" class="input">
                  <% trades.forEach(function(t){ %>
                    <option value="<%= t %>" <%= li.trade === t ? 'selected' : '' %>><%= t %></option>
                  <% }); %>
                </select>
              </td>
              <td>
                <input type="text" name="lines[<%= idx %>][description]" data-field="description"
                       value="<%= li.description || '' %>" required
                       class="input">
              </td>
              <td class="text-right">
                <input type="number" step="0.01" min="0" name="lines[<%= idx %>][quantity]" data-field="quantity"
                       value="<%= li.quantity %>" required
                       class="input text-right" style="width: 6rem;">
              </td>
              <td>
                <select name="lines[<%= idx %>][unit]" data-field="unit" class="input">
                  <% units.forEach(function(u){ %>
                    <option value="<%= u %>" <%= li.unit === u ? 'selected' : '' %>><%= u %></option>
                  <% }); %>
                </select>
              </td>
              <td class="text-right">
                <input type="number" step="0.01" min="0" name="lines[<%= idx %>][unit_price]" data-field="unit_price"
                       value="<%= li.unit_price %>" required
                       class="input text-right" style="width: 8rem;">
              </td>
              <td class="text-right font-medium" data-field="line_total"><%= moneyFmt(li.line_total) %></td>
              <td>
                <button type="button" data-remove-line class="text-recon-fog hover:text-recon-red text-sm">remove</button>
              </td>
            </tr>
          <% }); %>

          <!-- Hidden template row used by line-items.js when adding a new line. -->
          <tr class="line-row hidden" data-template>
            <td>
              <select name="lines[__IDX__][trade]" data-field="trade" class="input">
                <% trades.forEach(function(t){ %>
                  <option value="<%= t %>" <%= t === 'general' ? 'selected' : '' %>><%= t %></option>
                <% }); %>
              </select>
            </td>
            <td>
              <input type="text" name="lines[__IDX__][description]" data-field="description" class="input">
            </td>
            <td class="text-right">
              <input type="number" step="0.01" min="0" name="lines[__IDX__][quantity]" data-field="quantity" value="1" class="input text-right" style="width: 6rem;">
            </td>
            <td>
              <select name="lines[__IDX__][unit]" data-field="unit" class="input">
                <% units.forEach(function(u){ %>
                  <option value="<%= u %>" <%= u === 'ea' ? 'selected' : '' %>><%= u %></option>
                <% }); %>
              </select>
            </td>
            <td class="text-right">
              <input type="number" step="0.01" min="0" name="lines[__IDX__][unit_price]" data-field="unit_price" value="0" class="input text-right" style="width: 8rem;">
            </td>
            <td class="text-right font-medium" data-field="line_total">0.00</td>
            <td>
              <button type="button" data-remove-line class="text-recon-fog hover:text-recon-red text-sm">remove</button>
            </td>
          </tr>
        </tbody>
        <tfoot class="bg-recon-cloud">
          <tr>
            <td colspan="5" class="text-right text-sm font-medium">Subtotal</td>
            <td class="text-right font-semibold">$<span data-totals="subtotal">0.00</span></td>
            <td></td>
          </tr>
          <tr>
            <td colspan="5" class="text-right text-sm font-medium">Tax</td>
            <td class="text-right font-semibold">$<span data-totals="tax_amount">0.00</span></td>
            <td></td>
          </tr>
          <tr>
            <td colspan="5" class="text-right text-sm font-medium uppercase">Total</td>
            <td class="text-right text-lg font-bold text-recon-red">$<span data-totals="total">0.00</span></td>
            <td></td>
          </tr>
        </tfoot>
      </table>
    </div>
  </div>

  <div class="card p-5">
    <label class="label" for="notes">Notes / scope details (visible to customer on PDF)</label>
    <textarea name="notes" id="notes" rows="4" class="input"
              placeholder="Anything the customer should see on the estimate PDF."><%= estimate.notes || '' %></textarea>
  </div>

  <div class="flex items-center gap-2 pt-2">
    <button type="submit" class="btn btn-primary"><%= submitLabel %></button>
    <a href="<%= estimate.id ? '/estimates/' + estimate.id : '/jobs/' + job.id %>" class="btn btn-ghost">Cancel</a>
  </div>
</form>

<script src="/js/line-items.js"></script>
