<%
// Estimate form (v0.8 — D-112: labor + materials + markup columns).
// Expects: estimate, errors, units, formAction, submitLabel.
const linesToRender = (estimate.lines && estimate.lines.length) ? estimate.lines : [{
  description: '', quantity: 1, unit: 'ea', unit_price: 0, cost: 0, line_total: 0,
  labor_cost: 0, material_cost: 0, markup_pct: 25
}];
const termPresets = (typeof paymentTermsPresets !== 'undefined') ? paymentTermsPresets : ['Due on receipt', 'Net 15', 'Net 30', 'Net 45', 'Net 60'];
const currentTerms = estimate.payment_terms || 'Net 30';
const termsAreCustom = termPresets.indexOf(currentTerms) === -1;
function moneyFmt(n) { const num = Number(n); return isFinite(num) ? num.toFixed(2) : '0.00'; }
function numberInputValue(n) {
  const num = Number(n);
  return isFinite(num) && num !== 0 ? n : '';
}
%>
<form action="<%= formAction %>" method="post" class="space-y-6">
  <div class="card p-5">
    <h3 class="text-sm font-semibold uppercase tracking-wide text-recon-fog mb-3">Header</h3>
    <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
      <div>
        <label class="label" for="valid_until">Valid until
          <span class="ml-1 text-recon-fog cursor-help" title="Date this quote expires. After this date the office should re-quote before accepting.">ⓘ</span>
        </label>
        <input type="date" name="valid_until" id="valid_until"
               value="<%= estimate.valid_until ? String(estimate.valid_until).slice(0,10) : (estimate.id ? '' : new Date(Date.now() + 30 * 24 * 60 * 60 * 1000).toISOString().slice(0,10)) %>"
               class="input <%= errors.valid_until ? 'border-red-500' : '' %>">
        <% if (errors.valid_until) { %><p class="text-sm text-red-600 mt-1"><%= errors.valid_until %></p><% } %>
      </div>
      <div>
        <label class="label" for="payment_terms">Payment terms
          <span class="ml-1 text-recon-fog cursor-help" title="When the customer is expected to pay. Carries over to the invoice when this estimate is converted.">ⓘ</span>
        </label>
        <select name="payment_terms" id="payment_terms" class="input" data-payment-terms-select>
          <% termPresets.forEach(function(p){ %>
            <option value="<%= p %>" <%= currentTerms === p ? 'selected' : '' %>><%= p %></option>
          <% }); %>
          <option value="__custom" <%= termsAreCustom ? 'selected' : '' %>>Custom</option>
        </select>
        <input type="text" name="payment_terms_custom" value="<%= termsAreCustom ? currentTerms : '' %>"
               class="input mt-2 <%= termsAreCustom ? '' : 'hidden' %>" data-payment-terms-custom
               placeholder="Custom terms">
      </div>
      <div>
        <label class="label" for="tax_rate">Tax rate
          <span class="ml-1 text-recon-fog cursor-help" title="Michigan sales tax is 6%. Select 0 for tax-exempt customers.">ⓘ</span>
        </label>
        <select name="tax_rate" id="tax_rate" class="input" data-totals="tax_rate">
          <option value="0" <%= Number(estimate.tax_rate || 0) === 0 ? 'selected' : '' %>>0% (tax-exempt)</option>
          <option value="6" <%= Number(estimate.tax_rate || 0) === 6 ? 'selected' : '' %>>6% (Michigan)</option>
        </select>
      </div>
      <div>
        <label class="label">Number
          <span class="ml-1 text-recon-fog cursor-help" title="Auto-assigned estimate number. Used to identify this quote on PDFs and invoices.">ⓘ</span>
        </label>
        <p class="input bg-recon-cloud text-recon-fog"><%= estimate.display_number || '—' %></p>
      </div>
    </div>
  </div>

  <div class="card overflow-hidden">
    <div class="px-5 py-3 border-b border-recon-mist flex items-center justify-between">
      <h3 class="font-semibold">Items</h3>
      <button type="button" data-add-line class="btn btn-secondary text-sm">+ Add item</button>
    </div>
    <% if (errors.lines) { %>
      <div class="px-5 py-2 text-sm text-red-600 bg-red-50 border-b border-red-200"><%= errors.lines %></div>
    <% } %>
    <p class="px-5 py-2 text-xs text-recon-fog bg-recon-cloud">Approved items are ready to transfer to an invoice.</p>
    <div class="overflow-x-auto">
      <table class="data" data-line-items>
        <thead>
          <tr>
            <th class="text-center" title="Check to include this line when converting to an invoice.">Approved</th>
            <th title="Customer-visible description. Appears on the estimate and invoice PDF.">Description</th>
            <th class="text-right" title="How many units.">Qty</th>
            <th title="Unit of measure.">Unit</th>
            <th colspan="4" class="text-center text-2xs text-recon-fog uppercase tracking-wider border-l border-recon-mist" title="These columns are INTERNAL — not shown on customer PDFs.">INTERNAL</th>
            <th class="text-right" title="Price per unit charged to the customer.">Rate</th>
            <th class="text-right" title="Qty x Rate for this line.">Line $</th>
            <th></th>
          </tr>
          <tr>
            <th></th>
            <th></th>
            <th></th>
            <th></th>
            <th class="text-right text-recon-fog font-normal" title="Internal labor cost per unit.">Labor</th>
            <th class="text-right text-recon-fog font-normal" title="Internal materials cost per unit.">Materials</th>
            <th class="text-right text-recon-fog font-normal" title="Computed cost (labor + materials).">Cost</th>
            <th class="text-right text-recon-fog font-normal" title="Markup percentage applied to cost.">Markup %</th>
            <th></th>
            <th></th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% linesToRender.forEach(function(li, idx){ %>
            <tr class="line-row">
              <td class="text-center">
                <input type="hidden" name="lines[<%= idx %>][selected]" value="0">
                <input type="checkbox" name="lines[<%= idx %>][selected]" value="1" <%= li.selected === 0 || li.selected === false ? '' : 'checked' %>>
              </td>
              <td>
                <textarea name="lines[<%= idx %>][description]" data-field="description"
                          data-autosize rows="1"
                          class="input"
                          style="min-height: 2.25rem; resize: vertical;"
                ><%= li.description || '' %></textarea>
              </td>
              <td class="text-right">
                <input type="number" step="0.01" min="0" name="lines[<%= idx %>][quantity]" data-field="quantity"
                       value="<%= li.quantity %>" class="input text-right" style="width: 5rem; min-width: 4rem;"
                       onfocus="this.select()" inputmode="decimal">
              </td>
              <td>
                <select name="lines[<%= idx %>][unit]" data-field="unit" class="input" style="min-width: 5rem;">
                  <% units.forEach(function(u){ %>
                    <option value="<%= u %>" <%= li.unit === u ? 'selected' : '' %>><%= u %></option>
                  <% }); %>
                </select>
              </td>
              <td class="text-right">
                <input type="number" step="0.01" min="0" name="lines[<%= idx %>][labor_cost]" data-field="labor_cost"
                       value="<%= numberInputValue(li.labor_cost) %>" placeholder="0" class="input text-right" style="width: 6rem; min-width: 5rem;"
                       title="Internal labor cost per unit" onfocus="this.select()" inputmode="decimal">
              </td>
              <td class="text-right">
                <input type="number" step="0.01" min="0" name="lines[<%= idx %>][material_cost]" data-field="material_cost"
                       value="<%= numberInputValue(li.material_cost) %>" placeholder="0" class="input text-right" style="width: 6rem; min-width: 5rem;"
                       title="Internal materials cost per unit" onfocus="this.select()" inputmode="decimal">
              </td>
              <td class="text-right">
                <input type="number" step="0.01" min="0" name="lines[<%= idx %>][cost]" data-field="cost"
                       value="<%= moneyFmt(li.cost) %>" class="input text-right bg-recon-cloud text-recon-fog" style="width: 6rem; min-width: 5rem;"
                       readonly title="Computed cost (labor + materials)">
              </td>
              <td class="text-right">
                <input type="number" step="0.1" min="0" name="lines[<%= idx %>][markup_pct]" data-field="markup_pct"
                       value="<%= li.markup_pct !== undefined && li.markup_pct !== null ? li.markup_pct : 25 %>" class="input text-right" style="width: 5rem; min-width: 4.5rem;"
                       title="Markup percentage applied to cost" onfocus="this.select()" inputmode="decimal">
              </td>
              <td class="text-right">
                <input type="number" step="0.01" min="0" name="lines[<%= idx %>][unit_price]" data-field="unit_price"
                       value="<%= moneyFmt(li.unit_price) %>" class="input text-right bg-recon-cloud text-recon-fog" style="width: 7rem; min-width: 5.5rem;"
                       readonly title="Computed rate (cost x markup)">
              </td>
              <td class="text-right font-medium">
                <input type="number" step="0.01" min="0" name="lines[<%= idx %>][line_total]" data-field="line_total"
                       value="<%= moneyFmt(li.line_total) %>" class="input text-right bg-recon-cloud text-recon-fog font-medium" style="width: 7rem; min-width: 5.5rem;"
                       readonly title="Computed line total (rate x qty)">
              </td>
              <td>
                <button type="button" data-remove-line class="text-recon-fog hover:text-recon-red text-sm">remove</button>
              </td>
            </tr>
          <% }); %>

          <tr class="line-row hidden" data-template>
            <td class="text-center">
              <input type="hidden" name="lines[__IDX__][selected]" value="0">
              <input type="checkbox" name="lines[__IDX__][selected]" value="1" checked>
            </td>
            <td><textarea name="lines[__IDX__][description]" data-field="description" data-autosize rows="1" class="input" style="min-height: 2.25rem; resize: vertical;"></textarea></td>
            <td class="text-right"><input type="number" step="0.01" min="0" name="lines[__IDX__][quantity]" data-field="quantity" value="1" class="input text-right" style="width: 5rem; min-width: 4rem;" onfocus="this.select()" inputmode="decimal"></td>
            <td>
              <select name="lines[__IDX__][unit]" data-field="unit" class="input" style="min-width: 5rem;">
                <% units.forEach(function(u){ %>
                  <option value="<%= u %>" <%= u === 'ea' ? 'selected' : '' %>><%= u %></option>
                <% }); %>
              </select>
            </td>
            <td class="text-right"><input type="number" step="0.01" min="0" name="lines[__IDX__][labor_cost]" data-field="labor_cost" value="" placeholder="0" class="input text-right" style="width: 6rem; min-width: 5rem;" onfocus="this.select()" inputmode="decimal"></td>
            <td class="text-right"><input type="number" step="0.01" min="0" name="lines[__IDX__][material_cost]" data-field="material_cost" value="" placeholder="0" class="input text-right" style="width: 6rem; min-width: 5rem;" onfocus="this.select()" inputmode="decimal"></td>
            <td class="text-right"><input type="number" step="0.01" min="0" name="lines[__IDX__][cost]" data-field="cost" value="0.00" class="input text-right bg-recon-cloud text-recon-fog" style="width: 6rem; min-width: 5rem;" readonly></td>
            <td class="text-right"><input type="number" step="0.1" min="0" name="lines[__IDX__][markup_pct]" data-field="markup_pct" value="25" class="input text-right" style="width: 5rem; min-width: 4.5rem;" onfocus="this.select()" inputmode="decimal"></td>
            <td class="text-right"><input type="number" step="0.01" min="0" name="lines[__IDX__][unit_price]" data-field="unit_price" value="0.00" class="input text-right bg-recon-cloud text-recon-fog" style="width: 7rem; min-width: 5.5rem;" readonly></td>
            <td class="text-right"><input type="number" step="0.01" min="0" name="lines[__IDX__][line_total]" data-field="line_total" value="0.00" class="input text-right bg-recon-cloud text-recon-fog font-medium" style="width: 7rem; min-width: 5.5rem;" readonly></td>
            <td><button type="button" data-remove-line class="text-recon-fog hover:text-recon-red text-sm">remove</button></td>
          </tr>
        </tbody>
        <tfoot class="bg-recon-cloud">
          <tr>
            <td colspan="9" class="text-right text-sm font-medium">Subtotal</td>
            <td class="text-right font-semibold">$<span data-totals="subtotal">0.00</span></td>
            <td></td>
          </tr>
          <tr>
            <td colspan="9" class="text-right text-sm font-medium">Profit / ROI %</td>
            <td class="text-right font-semibold">
              $<span data-totals="profit">0.00</span>
              <span class="text-recon-fog">/</span>
              <span data-totals="roi">--</span>
            </td>
            <td></td>
          </tr>
          <tr>
            <td colspan="9" class="text-right text-sm font-medium">Tax</td>
            <td class="text-right font-semibold">$<span data-totals="tax_amount">0.00</span></td>
            <td></td>
          </tr>
          <tr>
            <td colspan="9" class="text-right text-sm font-medium uppercase">Total</td>
            <td class="text-right text-lg font-bold text-recon-red">$<span data-totals="total">0.00</span></td>
            <td></td>
          </tr>
        </tfoot>
      </table>
    </div>
  </div>

  <div class="card p-5">
    <label class="label" for="notes">Notes (visible on customer PDF)
      <span class="ml-1 text-recon-fog cursor-help" title="Customer-facing notes that print on the estimate PDF. Use for warranty terms, scheduling caveats, or assumptions.">ⓘ</span>
    </label>
    <textarea name="notes" id="notes" rows="3" data-autosize class="input"><%= estimate.notes || '' %></textarea>
  </div>

  <div class="flex items-center gap-2 pt-2">
    <button type="submit" class="btn btn-primary"><%= submitLabel %></button>
    <a href="/estimates/<%= estimate.id %>" class="btn btn-ghost">Cancel</a>
  </div>
</form>

<script src="/js/line-items.js"></script>
<script>
(function(){
  document.querySelectorAll('[data-payment-terms-select]').forEach(function(select){
    var custom = select.parentElement.querySelector('[data-payment-terms-custom]');
    if (!custom) return;
    function sync() { custom.classList.toggle('hidden', select.value !== '__custom'); }
    select.addEventListener('change', sync);
    sync();
  });

  // R37d — textarea autosize
  function fitTextarea(el){
    if (!el || el.tagName !== 'TEXTAREA') return;
    el.style.height = 'auto';
    el.style.height = (el.scrollHeight + 2) + 'px';
  }
  function bindAutosize(el){
    if (!el || el.dataset._autosizeBound === '1') return;
    el.dataset._autosizeBound = '1';
    fitTextarea(el);
    el.addEventListener('input', function(){ fitTextarea(el); });
  }
  document.querySelectorAll('textarea[data-autosize]').forEach(bindAutosize);
  var mo = new MutationObserver(function(mutations){
    mutations.forEach(function(m){
      m.addedNodes && m.addedNodes.forEach(function(node){
        if (!node.querySelectorAll) return;
        node.querySelectorAll && node.querySelectorAll('textarea[data-autosize]').forEach(bindAutosize);
      });
    });
  });
  mo.observe(document.body, { childList: true, subtree: true });

  // D-112: Auto-compute cost, unit_price, and line_total from labor + material + markup
  function recalcLine(idx) {
    var labor = parseFloat(document.querySelector('[name="lines[' + idx + '][labor_cost]"]')?.value) || 0;
    var material = parseFloat(document.querySelector('[name="lines[' + idx + '][material_cost]"]')?.value) || 0;
    var qty = parseFloat(document.querySelector('[name="lines[' + idx + '][quantity]"]')?.value) || 0;
    var markup = parseFloat(document.querySelector('[name="lines[' + idx + '][markup_pct]"]')?.value) || 25;
    var cost = labor + material;
    var unit_price = cost * (1 + markup / 100);
    var line_total = unit_price * qty;
    var costEl = document.querySelector('[name="lines[' + idx + '][cost]"]');
    if (costEl) costEl.value = cost.toFixed(2);
    var priceEl = document.querySelector('[name="lines[' + idx + '][unit_price]"]');
    if (priceEl) priceEl.value = unit_price.toFixed(2);
    var totalEl = document.querySelector('[name="lines[' + idx + '][line_total]"]');
    if (totalEl) totalEl.value = line_total.toFixed(2);
  }

  function wireRecalc(row) {
    var idxMatch = row.querySelector('[name^="lines["]')?.name?.match(/^lines\[(\d+)\]/);
    if (!idxMatch) return;
    var idx = idxMatch[1];
    row.querySelectorAll('[data-field="labor_cost"], [data-field="material_cost"], [data-field="quantity"], [data-field="markup_pct"]').forEach(function(el){
      el.addEventListener('input', function(){ recalcLine(idx); });
    });
    recalcLine(idx);
  }

  // Wire all existing rows and observe for new rows from line-items.js
  var table = document.querySelector('table[data-line-items]');
  if (table) {
    table.querySelectorAll('.line-row:not([data-template])').forEach(wireRecalc);
    var obs = new MutationObserver(function(mutations){
      mutations.forEach(function(m){
        m.addedNodes.forEach(function(node){
          if (node.nodeType === 1 && node.matches && node.matches('.line-row:not([data-template])')) {
            wireRecalc(node);
          }
          if (node.querySelectorAll) {
            node.querySelectorAll('.line-row:not([data-template])').forEach(wireRecalc);
          }
        });
      });
    });
    obs.observe(table.querySelector('tbody') || table, { childList: true, subtree: true });
  }
})();
</script>
