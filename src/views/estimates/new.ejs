<%- include('../layouts/header', { title: title, currentUser: currentUser, flash: flash, activeNav: activeNav }) %>

<div class="max-w-5xl mx-auto px-4 py-6">
  <div class="mb-4">
    <a href="/jobs/<%= job.id %>" class="text-sm text-recon-fog hover:text-recon-red">&larr; <%= job.title %></a>
  </div>
  <h1 class="page-h1 mb-6">New estimate</h1>

  <%- include('_form', {
    estimate: estimate, job: job, errors: errors,
    trades: trades, units: units,
    formAction: '/estimates', submitLabel: 'Create estimate'
  }) %>
</div>

<%- include('../layouts/footer') %>
