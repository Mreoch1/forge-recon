<%- include('../layouts/header', { title: title, currentUser: currentUser, flash: flash, activeNav: activeNav }) %>
<div class="ops-shell">
  <div class="ops-header"><div class="ops-title-block"><h1 class="page-h1">Contractors</h1><p class="page-sub"><%= total %> total<% if (q) { %> &middot; filter: "<%= q %>"<% } %></p></div>
    <div class="ops-actions"><a href="/contractors/new" class="btn btn-primary">+ New contractor</a></div>
  </div>
  <div class="ops-summary">
    <div class="ops-summary-item"><div class="ops-summary-label">Total</div><div class="ops-summary-value"><%= total %></div><div class="ops-summary-meta">contractors</div></div>
    <div class="ops-summary-item"><div class="ops-summary-label">Shown</div><div class="ops-summary-value"><%= contractors.length %></div><div class="ops-summary-meta">current page</div></div>
    <div class="ops-summary-item"><div class="ops-summary-label">Trades</div><div class="ops-summary-value"><%= Array.from(new Set(contractors.map(function(c){ return c.trade; }).filter(Boolean))).length %></div><div class="ops-summary-meta">shown on page</div></div>
    <div class="ops-summary-item"><div class="ops-summary-label">General</div><div class="ops-summary-value"><%= contractors.filter(function(c){ return c.trade === 'general'; }).length %></div><div class="ops-summary-meta">shown on page</div></div>
  </div>
  <form method="get" class="list-utility-bar"><input type="text" name="q" value="<%= q %>" placeholder="Search name, email, phone, trade..." class="list-search"><button class="btn btn-secondary">Search</button>
    <% if (q) { %><a href="/contractors" class="list-clear">Clear</a><% } %>
    </form>
  <% if (!contractors || contractors.length === 0) { %>
    <div class="ops-panel"><div class="ops-panel-head"><div class="ops-panel-title">Contractor directory</div><div class="text-xs text-recon-fog">0 shown</div></div><div class="ops-empty"><% if (q) { %>No contractors match "<%= q %>".<% } else { %>No contractors yet. <a href="/contractors/new" class="text-recon-red underline">Add your first contractor</a> to start tracking subs.<% } %>
      <% if (q) { %><div class="mt-3"><a href="/contractors" class="btn btn-ghost">Clear filter</a></div><% } %></div></div>
  <% } else { %>
    <div class="ops-panel ops-table"><div class="ops-panel-head"><div class="ops-panel-title">Contractor directory</div><div class="text-xs text-recon-fog"><%= contractors.length %> shown</div></div><div class="ops-panel-body"><table class="data"><thead><tr><th>Name</th><th>Trade</th><th>Email</th><th>Phone</th><th>Location</th></tr></thead><tbody>
      <% contractors.forEach(function(c) { %>
        <tr class="row-link" data-href="/contractors/<%= c.id %>"><td><%= c.name %></td>
          <td><% if (c.trade) { %><span class="badge badge-<%= c.trade %>"><%= c.trade %></span><% } else { %>-<% } %></td>
          <td><%= c.email || '-' %></td><td><%= c.phone || '-' %></td>
          <td><%= [c.city, c.state].filter(Boolean).join(', ') || '-' %></td></tr>
      <% }); %>
    </tbody></table></div></div>
    <div class="flex justify-between items-center mt-4 text-sm text-recon-fog">
      <span>Page <%= page %> of <%= totalPages %></span>
      <div class="flex gap-2">
        <% if (page > 1) { %><a href="/contractors?page=<%= page - 1 %><%= q ? '&q=' + q : '' %>" class="btn btn-ghost text-xs">Previous</a><% } %>
        <% if (page < totalPages) { %><a href="/contractors?page=<%= page + 1 %><%= q ? '&q=' + q : '' %>" class="btn btn-ghost text-xs">Next</a><% } %>
      </div></div>
  <% } %>
</div>
<%- include('../layouts/footer') %>
