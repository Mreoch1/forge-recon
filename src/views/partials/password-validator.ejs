<%# password-validator.ejs - Reusable live password requirements checklist. Usage: <%- include('../partials/password-validator', { fieldId: 'password', label: 'New password', confirmFieldId: 'confirm_password' }) %> %>
<div class="password-validator">
  <label for="<%= fieldId %>" class="label"><%= typeof label !== 'undefined' ? label : 'Password' %></label>
  <input type="password" name="<%= fieldId %>" id="<%= fieldId %>" class="input" required minlength="8" autocomplete="new-password">

  <ul class="mt-2 space-y-1 text-sm" id="<%= fieldId %>-rules">
    <li id="<%= fieldId %>-rule-length" class="text-recon-fog transition-colors duration-150">○ At least 8 characters</li>
    <li id="<%= fieldId %>-rule-upper" class="text-recon-fog transition-colors duration-150">○ At least one uppercase letter</li>
    <li id="<%= fieldId %>-rule-lower" class="text-recon-fog transition-colors duration-150">○ At least one lowercase letter</li>
    <li id="<%= fieldId %>-rule-number" class="text-recon-fog transition-colors duration-150">○ At least one number</li>
    <li id="<%= fieldId %>-rule-symbol" class="text-recon-fog transition-colors duration-150">○ At least one symbol</li>
    <% if (typeof confirmFieldId !== 'undefined' && confirmFieldId) { %>
      <li id="<%= fieldId %>-rule-match" class="text-recon-fog transition-colors duration-150">○ Passwords match</li>
    <% } %>
  </ul>
</div>

<script>
(function() {
  const pw = document.getElementById('<%= fieldId %>');
  if (!pw) return;
  const rules = {
    length: document.getElementById('<%= fieldId %>-rule-length'),
    upper: document.getElementById('<%= fieldId %>-rule-upper'),
    lower: document.getElementById('<%= fieldId %>-rule-lower'),
    number: document.getElementById('<%= fieldId %>-rule-number'),
    symbol: document.getElementById('<%= fieldId %>-rule-symbol'),
    match: document.getElementById('<%= fieldId %>-rule-match'),
  };

  const matchPw = typeof confirmFieldId !== 'undefined' && confirmFieldId
    ? document.getElementById(confirmFieldId)
    : null;

  function validate() {
    const v = pw.value;
    const tests = {
      length: v.length >= 8,
      upper: /[A-Z]/.test(v),
      lower: /[a-z]/.test(v),
      number: /\d/.test(v),
      symbol: /[^A-Za-z0-9]/.test(v),
      match: matchPw ? v === matchPw.value && v.length > 0 : true,
    };

    Object.keys(rules).forEach(function(key) {
      const el = rules[key];
      if (!el) return;
      if (tests[key]) {
        el.className = 'text-green-600 transition-colors duration-150';
        el.textContent = el.textContent.replace(/^○/, '●');
      } else {
        el.className = 'text-recon-fog transition-colors duration-150';
        el.textContent = el.textContent.replace(/^●/, '○');
      }
    });
  }

  pw.addEventListener('input', validate);
  if (matchPw) matchPw.addEventListener('input', validate);
})();
</script>
