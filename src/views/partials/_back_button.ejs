<%# D-073: Universal back button for authenticated pages %>
<% if (typeof showBackButton !== 'undefined' && showBackButton) { %>
<div class="page-back-shell">
  <a href="<%= backButtonFallback || '/' %>" class="inline-flex items-center gap-1 text-sm text-recon-fog hover:text-recon-red transition" onclick="if (document.referrer && document.referrer.startsWith(window.location.origin)) { history.back(); return false; } return true;">
    <span class="text-lg leading-none">&larr;</span> Back
  </a>
</div>
<% } %>
