<%
var tabs = typeof documentTabs !== 'undefined' && documentTabs ? documentTabs : {};
var activeTab = tabs.active || '';
var baseNumber = tabs.displayNumber || tabs.woDisplayNumber || '';
function tabClass(name, href) {
  return [
    'doc-tab',
    activeTab === name ? 'is-active' : '',
    href ? '' : 'is-disabled'
  ].filter(Boolean).join(' ');
}
%>
<style>
  .doc-tabs {
    display: flex;
    align-items: stretch;
    gap: 0;
    border: 1px solid #d8d8d8;
    border-radius: 8px;
    overflow: hidden;
    background: #fff;
    margin: 1rem 0 1.25rem;
  }
  .doc-tab {
    flex: 1 1 0;
    min-width: 0;
    padding: .75rem .9rem;
    border-right: 1px solid #e5e5e5;
    color: #555;
    background: #fff;
    text-decoration: none;
  }
  .doc-tab:last-child { border-right: 0; }
  .doc-tab:hover { background: #fafafa; color: #c0202b; }
  .doc-tab.is-active {
    background: #1a1a1a;
    color: #fff;
  }
  .doc-tab.is-disabled {
    color: #aaa;
    background: #f7f7f7;
    cursor: default;
    pointer-events: none;
  }
  .doc-tab-label {
    display: block;
    font-size: .65rem;
    font-weight: 700;
    letter-spacing: .12em;
    text-transform: uppercase;
  }
  .doc-tab-value {
    display: block;
    margin-top: .15rem;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: .9rem;
    font-weight: 700;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .doc-tab-meta {
    display: block;
    margin-top: .1rem;
    font-size: .72rem;
    opacity: .72;
  }
  html.dark .doc-tabs { background: var(--dark-surface) !important; border-color: var(--dark-border) !important; }
  html.dark .doc-tab { background: var(--dark-surface) !important; border-color: var(--dark-border) !important; color: var(--dark-text-muted) !important; }
  html.dark .doc-tab:hover { background: var(--dark-elevated) !important; color: var(--dark-text) !important; }
  html.dark .doc-tab.is-active { background: var(--dark-text) !important; color: var(--dark-bg) !important; }
  html.dark .doc-tab.is-disabled { background: var(--dark-elevated) !important; color: var(--dark-text-muted) !important; opacity: .7; }
  @media (max-width: 640px) {
    .doc-tabs { overflow-x: auto; }
    .doc-tab { flex: 0 0 11rem; }
  }
</style>
<nav class="doc-tabs" aria-label="Document workflow">
  <% const woHref = tabs.woId ? '/work-orders/' + tabs.woId : null; %>
  <% const estHref = tabs.estimateId ? '/estimates/' + tabs.estimateId : null; %>
  <% const invHref = tabs.invoiceId ? '/invoices/' + tabs.invoiceId : null; %>

  <a class="<%= tabClass('work_order', woHref) %>" href="<%= woHref || '#' %>" aria-current="<%= activeTab === 'work_order' ? 'page' : 'false' %>">
    <span class="doc-tab-label">Work order</span>
    <span class="doc-tab-value"><%= baseNumber ? 'WO-' + baseNumber : 'Not linked' %></span>
    <span class="doc-tab-meta"><%= tabs.woStatus || 'Field scope' %></span>
  </a>

  <a class="<%= tabClass('estimate', estHref) %>" href="<%= estHref || '#' %>" aria-current="<%= activeTab === 'estimate' ? 'page' : 'false' %>">
    <span class="doc-tab-label">Estimate</span>
    <span class="doc-tab-value"><%= baseNumber ? 'EST-' + baseNumber : 'Not created' %></span>
    <span class="doc-tab-meta"><%= estHref ? (tabs.estimateStatus || 'Open') : 'Not created yet' %></span>
  </a>

  <a class="<%= tabClass('invoice', invHref) %>" href="<%= invHref || '#' %>" aria-current="<%= activeTab === 'invoice' ? 'page' : 'false' %>">
    <span class="doc-tab-label">Invoice</span>
    <span class="doc-tab-value"><%= baseNumber ? 'INV-' + baseNumber : 'Not created' %></span>
    <span class="doc-tab-meta"><%= invHref ? (tabs.invoiceStatus || 'Open') : 'Not created yet' %></span>
  </a>
</nav>
