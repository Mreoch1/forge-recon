<!--
  emails/layout.ejs — Reusable branded HTML email wrapper.
  Inline CSS only (most email clients strip <style> tags).
  Usage (call from a route):
    res.render('emails/layout', { body: '<p>Email content here</p>' })
-->
<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>
<body style="margin:0;padding:0;background-color:#f5f5f5;font-family:Inter,'Segoe UI',system-ui,-apple-system,sans-serif;">
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background-color:#f5f5f5;">
    <tr>
      <td align="center" style="padding:32px 16px;">
        <table role="presentation" width="600" cellpadding="0" cellspacing="0" style="max-width:600px;width:100%;background-color:#ffffff;border-radius:8px;overflow:hidden;">
          <tr>
            <td style="padding:32px 32px 16px 32px;border-bottom:1px solid #eee;">
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
                <tr>
                  <td style="vertical-align:middle;text-align:left;">
                    <img src="<%= host %>/logos/recon-logo.jpg" alt="Recon Enterprises Inc." width="190" style="display:block;width:190px;max-width:190px;height:auto;border:0;outline:none;text-decoration:none;">
                    <span style="display:block;margin-top:8px;font-size:14px;line-height:1;font-weight:800;letter-spacing:.14em;color:#c0202b;mso-line-height-rule:exactly;">FORGE</span>
                  </td>
                  <td style="text-align:right;vertical-align:middle;">
                    <span style="display:inline-block;background-color:#c0202b;color:#ffffff;font-size:11px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;padding:7px 10px;border-radius:4px;">Secure Notice</span>
                  </td>
                </tr>
              </table>
            </td>
          </tr>
          <!-- Body -->
          <tr>
            <td style="padding:32px;font-size:15px;line-height:1.6;color:#1a1a1a;">
              <%# F8: raw render — `body` is the inner HTML passed by
                  services/email.js renderEmail(). It is built from
                  hard-coded HTML strings in email.js (verification,
                  password reset, estimate/invoice send), never from user
                  input. If you ever add a user-controlled value to body,
                  escape it at the call site. %>
              <%- body %>
            </td>
          </tr>
          <!-- Footer -->
          <tr>
            <td style="padding:16px 32px;border-top:1px solid #eee;font-size:12px;color:#888;text-align:center;">
              Recon Enterprises &middot; <a href="mailto:support@reconenterprises.net" style="color:#888;text-decoration:none;">support@reconenterprises.net</a>
              <br>If you didn't expect this email, you can ignore it.
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
