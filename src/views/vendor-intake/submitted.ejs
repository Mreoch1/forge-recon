<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Submitted - FORGE</title>
  <link rel="icon" href="/favicon.ico">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    body { margin:0; font-family:Inter,system-ui,sans-serif; background:#f5f5f5; color:#1a1a1a; }
    main { min-height:100vh; display:grid; place-items:center; padding:2rem 1rem; }
    .card { width:min(100%,620px); background:white; border:1px solid #e5e5e5; border-radius:10px; padding:2rem; box-shadow:0 18px 60px rgba(0,0,0,.08); }
    h1 { margin:.3rem 0 .5rem; font-size:1.8rem; }
    p { color:#666; line-height:1.5; }
    a.btn { display:inline-flex; margin-top:1rem; background:#c0202b; color:white; border-radius:6px; padding:.7rem 1rem; text-decoration:none; font-weight:700; }
    .link { word-break:break-all; background:#f7f7f7; border:1px solid #eee; border-radius:6px; padding:.75rem; font-size:.9rem; }
  </style>
</head>
<body>
  <main>
    <section class="card">
      <img src="/logos/recon-logo.jpg" alt="Recon Enterprises" style="width:54px;">
      <h1>Submitted</h1>
      <p>Thanks. Recon has received the intake for <strong><%= intake.company_name || 'your company' %></strong>. Keep this private link if you need to update your information later.</p>
      <div class="link"><%= publicUrl %></div>
      <a class="btn" href="/vendor-intake/<%= intake.access_token %>/company">Update information</a>
    </section>
  </main>
</body>
</html>
