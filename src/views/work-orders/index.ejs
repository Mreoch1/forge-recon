<%- include('../layouts/header', { title: title, currentUser: currentUser, flash: flash, activeNav: activeNav }) %>

<style>
  .wol-h1 { font-size: 1.45rem; font-weight: 700; letter-spacing: -.015em; color: #1a1a1a; }
  .wol-sub { color: #888; font-size: .82rem; }
  .wol-table { width: 100%; border-collapse: collapse; font-size: .88rem; }
  .wol-table thead th {
    text-align: left; font-size: .65rem; letter-spacing: .12em; text-transform: uppercase;
    color: #888; font-weight: 700; padding: .55rem .75rem;
    border-top: 2px solid #1a1a1a; border-bottom: 1px solid #cfcfcf;
    background: #fafafa;
  }
  .wol-table tbody td { padding: .65rem .75rem; border-bottom: 1px solid #f0f0f0; vertical-align: middle; }
  .wol-table tbody tr:hover td { background: #fafafa; }
  .wol-num { font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-weight: 600; font-size: .85rem; color: #1a1a1a; }
  .wol-customer { font-weight: 600; color: #1a1a1a; }
  .wol-job-title { font-size: .78rem; color: #666; margin-top: .1rem; }
  .wol-meta { font-family: ui-monospace, monospace; font-size: .8rem; color: #555; }
  .wol-dot { width: 6px; height: 6px; border-radius: 50%; display: inline-block; margin-right: .4rem; vertical-align: middle; }
  .wol-dot-live { background: #ea580c; box-shadow: 0 0 0 0 rgba(234,88,12,.5); animation: wol-pulse 2.4s infinite; }
  .wol-dot-sched { background: #b8b8b8; }
  .wol-dot-done { background: #10b981; }
  .wol-dot-cancel { background: #fca5a5; }
  @keyframes wol-pulse {
    0%   { box-shadow: 0 0 0 0 rgba(234,88,12,.5); }
    70%  { box-shadow: 0 0 0 5px rgba(234,88,12,0); }
    100% { box-shadow: 0 0 0 0 rgba(234,88,12,0); }
  }
  .wol-filter-row { display: flex; flex-wrap: wrap; align-items: center; gap: .55rem; padding-bottom: .85rem; }
  .wol-empty { padding: 2rem 1rem; text-align: center; color: #888; font-size: .85rem; }
</style>

<div class="max-w-7xl mx-auto px-4 py-5">
  <!-- R33: stack title and CTA on mobile -->
  <div class="flex flex-col md:flex-row md:items-baseline md:justify-between mb-2 gap-2">
    <div>
      <h1 class="wol-h1">Work orders</h1>
      <p class="wol-sub mt-1"><%= total %> total<% if (q) { %> &middot; "<%= q %>"<% } %><% if (status) { %> &middot; <%= status.replace('_',' ') %><% } %></p>
    </div>
    <div class="flex gap-2">
      <a href="/work-orders/new" class="btn btn-primary min-h-[44px]">+ New work order</a>
    </div>
  </div>

  <%
    var _users = (typeof users !== 'undefined') ? users : [];
    var _assigneeFilter = (typeof assigneeFilter !== 'undefined') ? assigneeFilter : '';
    var _statuses = (typeof statuses !== 'undefined') ? statuses : [];
  %>
  <form method="get" action="/work-orders" class="list-utility-bar" style="margin-bottom:.65rem">
    <input type="text" name="q" value="<%= q %>" placeholder="Search WO #, customer..." class="list-search">
    <select name="status" class="list-filter">
      <option value="">All statuses</option>
      <% _statuses.forEach(function(s){ %>
        <option value="<%= s %>" <%= status === s ? 'selected' : '' %>><%= s.replace('_',' ') %></option>
      <% }); %>
    </select>
    <% if (_users.length) { %>
      <select name="assignee" class="list-filter">
        <option value="">All assignees</option>
        <% _users.forEach(function(u){ %>
          <option value="<%= u.id %>" <%= String(_assigneeFilter) === String(u.id) ? 'selected' : '' %>><%= u.name %></option>
        <% }); %>
      </select>
    <% } %>
    <button type="submit" class="btn btn-secondary">Filter</button>
    <% if (q || status) { %><a href="/work-orders" class="list-clear">Clear</a><% } %>
  </form>
  <% if (workOrders.length === 0) { %>
    <div class="wol-empty">
      <% if (q || status) { %>
        No work orders match. <a href="/work-orders" class="text-recon-red underline">Clear filters</a>.
      <% } else { %>
        No work orders yet. Use the <a href="/work-orders/new" class="text-recon-red underline">+ New work order</a> button above, or convert an accepted <a href="/estimates" class="text-recon-red underline">estimate</a>.
      <% } %>
    </div>
  <% } else { %>
    <!-- R33: horizontal-scroll wrapper for narrow viewports -->
    <div class="overflow-x-auto -mx-4 px-4 md:mx-0 md:px-0" style="-webkit-overflow-scrolling: touch;">
    <table class="wol-table" style="min-width: 720px;">
      <thead>
        <tr>
          <th style="width:1.5rem;"></th>
          <th style="width:9rem;">Number</th>
          <th>Customer · Work order</th>
          <th style="width:7rem;">Status</th>
          <th style="width:7rem;">Scheduled</th>
          <th style="width:7rem;">Assigned</th>
          <th style="width:6rem;">Created</th>
        </tr>
      </thead>
      <tbody>
        <% workOrders.forEach(function(w){
             const dotClass = w.status === 'in_progress' ? 'wol-dot-live'
                            : w.status === 'complete'    ? 'wol-dot-done'
                            : w.status === 'cancelled'   ? 'wol-dot-cancel'
                            :                              'wol-dot-sched';
             const statusHint = w.status === 'scheduled' ? 'On the calendar but work has not started yet.'
                              : w.status === 'in_progress' ? 'Crew has started work on this WO.'
                              : w.status === 'complete' ? 'All work finished and signed off.'
                              : w.status === 'cancelled' ? 'WO will not be performed. Read-only.'
                              : w.status === 'on_hold' ? 'Paused for now. Resume by editing the WO.'
                              : w.status;
        %>
          <tr class="row-link" data-href="/work-orders/<%= w.id %>">
            <td><span class="wol-dot <%= dotClass %>"></span></td>
            <td><span class="wol-num">WO-<%= w.display_number %></span></td>
            <td>
              <span class="wol-customer"><%= w.customer_name %></span>
              <div class="wol-job-title"><%= w.job_title %></div>
            </td>
            <td><span class="badge badge-<%= w.status %>" title="<%= statusHint %>"><%= w.status.replace('_',' ') %></span></td>
            <td class="wol-meta"><%= (w.scheduled_date || '—').slice(0,10) %></td>
            <td class="wol-meta"><%= w.assigned_to || '—' %></td>
            <td class="wol-meta"><%= (w.created_at || '').slice(0,10) %></td>
          </tr>
        <% }); %>
      </tbody>
    </table>
    </div>
  <% } %>

  <% if (totalPages > 1) { %>
    <div class="flex items-center justify-center gap-2 mt-4">
      <% for (let p = 1; p <= totalPages; p++) { %>
        <% const qs = ['page='+p]; if (q) qs.push('q='+encodeURIComponent(q)); if (status) qs.push('status='+encodeURIComponent(status)); %>
        <% if (p === page) { %><span class="btn btn-primary"><%= p %></span>
        <% } else { %><a href="/work-orders?<%= qs.join('&') %>" class="btn btn-ghost"><%= p %></a><% } %>
      <% } %>
    </div>
  <% } %>
</div>

<%- include('../layouts/footer') %>
