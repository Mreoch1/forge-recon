<%
// Shared WO form (R34 — customer-centric, multi-assignee, optional project link).
// Expects: wo, customers, users, contractors, projects, errors, units, formAction, submitLabel
// customers: array of {id, name, email, phone, address, city, state, zip}
// projects: array of {id, title, customer_name, address, city, state}
// users: array of {id, name}
const selectedCustomerId = wo.customer_id || '';
const selectedAssignees = wo.assignee_ids || [];
const selectedContractors = wo.contractor_ids || [];
const selectedProjectId = wo.project_id || '';
%>
<form action="<%= formAction %>" method="post" class="space-y-6">
  <!-- Customer autocomplete -->
  <div class="card p-5">
    <h3 class="text-sm font-semibold uppercase tracking-wide text-recon-fog mb-3">Customer</h3>
    <div class="space-y-2">
      <div>
        <input type="text" id="customer-search" list="customer-list" placeholder="Search or select customer..." class="input"
               autocomplete="off" value="<%= customerName || '' %>">
        <datalist id="customer-list">
          <% (customers || []).forEach(function(c){ %>
            <option value="<%= c.picker_label || c.name %>" data-id="<%= c.id %>"></option>
          <% }); %>
        </datalist>
        <input type="hidden" name="customer_id" id="customer-id" value="<%= selectedCustomerId %>">
      </div>
      <div id="customer-card" class="<%= selectedCustomerId ? '' : 'hidden' %> p-3 bg-gray-50 rounded text-sm">
        <p class="font-medium" id="cust-name"><%= customerName || '' %></p>
        <p class="text-gray-500" id="cust-email"></p>
        <p class="text-gray-500" id="cust-phone"></p>
        <p class="text-gray-500" id="cust-address"></p>
      </div>
    </div>
  </div>

  <!-- Optional project link -->
  <div class="card p-5">
    <h3 class="text-sm font-semibold uppercase tracking-wide text-recon-fog mb-3">Project
      <span class="ml-1 text-recon-fog cursor-help" title="Optionally link this WO to a project. The customer is still set above.">ⓘ</span>
    </h3>
    <div class="space-y-2">
      <div>
        <select name="project_id" id="project-select" class="input">
          <option value="">-- None (standalone WO) --</option>
          <% (projects || []).forEach(function(p){ %>
            <option value="<%= p.id %>"
                    data-customer-id="<%= p.customer_id || '' %>"
                    data-customer-name="<%= p.customer_name || '' %>"
                    data-address="<%= (p.address || '') %>, <%= (p.city || '') %>, <%= (p.state || '') %>"
                    <%= (selectedProjectId == p.id) ? 'selected' : '' %>><%= p.picker_label || p.title %></option>
          <% }); %>
        </select>
      </div>
      <div id="project-card" class="<%= selectedProjectId ? '' : 'hidden' %> p-3 bg-gray-50 rounded text-sm">
        <p class="font-medium" id="proj-title"></p>
        <p class="text-gray-500" id="proj-customer"></p>
        <p class="text-gray-500" id="proj-address"></p>
      </div>
    </div>
  </div>

  <!-- Header: number, unit, date, time -->
  <div class="card p-5">
    <h3 class="text-sm font-semibold uppercase tracking-wide text-recon-fog mb-3">Schedule</h3>
    <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
      <div>
        <label class="label" for="display_number">WO Number
          <span class="ml-1 text-recon-fog cursor-help" title="Auto-generated if left blank. Format: 0001-0000 (year-sequence).">ⓘ</span>
        </label>
        <input type="text" name="display_number" id="display_number"
               value="<%= wo.display_number || '' %>"
               placeholder="<%= wo.suggested_display_number || '0001-0000' %>"
               class="input <%= errors.display_number ? 'border-red-500' : '' %>"
               pattern="\d{1,6}-\d{1,6}">
        <p class="text-xs text-recon-fog mt-1">Leave blank to auto-generate.</p>
      </div>
      <div>
        <label class="label" for="unit_number">Unit / Apt
          <span class="ml-1 text-recon-fog cursor-help" title="Apartment or suite number, e.g. Apt 101, Suite 200. Leave blank if not applicable.">ⓘ</span>
        </label>
        <input type="text" name="unit_number" id="unit_number" value="<%= wo.unit_number || '' %>"
               class="input" placeholder="Apt 101, Suite 200">
      </div>
      <div>
        <label class="label" for="scheduled_date">Date
          <span class="ml-1 text-recon-fog cursor-help" title="The day the crew should arrive on site.">ⓘ</span>
        </label>
        <input type="date" name="scheduled_date" id="scheduled_date"
               value="<%= wo.scheduled_date ? String(wo.scheduled_date).slice(0,10) : '' %>" class="input">
      </div>
      <div>
        <label class="label" for="scheduled_time">Time
          <span class="ml-1 text-recon-fog cursor-help" title="The time the crew should arrive on site.">ⓘ</span>
        </label>
        <select name="scheduled_time" id="scheduled_time" class="input">
          <option value="">-- Select time --</option>
          <% for (var h = 0; h < 24; h++) {
               for (var m = 0; m < 60; m += 30) {
                 var val = String(h).padStart(2,'0')+':'+String(m).padStart(2,'0');
                 var ampm = h < 12 ? 'AM' : 'PM';
                 var h12 = h % 12 || 12;
                 var label = h12 + ':' + String(m).padStart(2,'0') + ' ' + ampm;
          %>
            <option value="<%= val %>" <%= (wo.scheduled_time || val === '09:00') === val ? 'selected' : '' %>><%= label %></option>
          <% }} %>
        </select>
      </div>
    </div>
  </div>

  <!-- Status -->
  <div class="card p-5">
    <h3 class="text-sm font-semibold uppercase tracking-wide text-recon-fog mb-3">Status</h3>
    <div>
      <select name="status" class="input <%= errors.status ? 'border-red-500' : '' %>">
        <%
          var _validStatuses = ['open', 'scheduled', 'in_progress', 'closed', 'complete', 'cancelled'];
          var _statusLabels = {
            open: 'open',
            scheduled: 'scheduled',
            in_progress: 'in progress',
            closed: 'closed',
            complete: 'complete: no changes',
            cancelled: 'cancelled'
          };
          _validStatuses.forEach(function(s){
        %>
          <option value="<%= s %>" <%= (wo.status || 'open') === s ? 'selected' : '' %>><%= _statusLabels[s] || s.replace('_',' ')%></option>
        <% }); %>
      </select>
      <% if (errors.status) { %><p class="text-sm text-red-600 mt-1"><%= errors.status %></p><% } %>
    </div>
  </div>

  <!-- Multi-assignee -->
  <div class="card p-5">
    <h3 class="text-sm font-semibold uppercase tracking-wide text-recon-fog mb-3">Recon assignees
      <span class="ml-1 text-recon-fog cursor-help" title="Internal crew members who will receive an email with WO details + PDF when the WO is saved.">ⓘ</span>
    </h3>
    <div class="space-y-2">
      <div class="flex flex-wrap gap-2" id="assignee-chips">
        <% selectedAssignees.forEach(function(aid){ %>
          <% var u = users.find(function(uu){ return uu.id == aid; }); %>
          <% if (u) { %>
            <span class="inline-flex items-center gap-1 px-3 py-1 bg-blue-100 text-blue-800 rounded-full text-sm">
              <%= u.name %>
              <button type="button" class="remove-assignee text-blue-600 hover:text-blue-900 font-bold" data-id="<%= u.id %>">&times;</button>
              <input type="hidden" name="assignee_ids" value="<%= u.id %>">
            </span>
          <% } %>
        <% }); %>
      </div>
      <% if (!selectedAssignees || selectedAssignees.length === 0) { %>
        <p class="text-xs text-recon-fog">No assignees yet. Add crew members to send them email notifications + PDFs.</p>
      <% } %>
      <select id="assignee-select" class="input">
        <option value="">-- Add assignee --</option>
        <% users.forEach(function(u){ %>
          <option value="<%= u.id %>"><%= u.name %></option>
        <% }); %>
      </select>
    </div>
  </div>

  <div class="card p-5">
    <h3 class="text-sm font-semibold uppercase tracking-wide text-recon-fog mb-3">Contractor assignees
      <span class="ml-1 text-recon-fog cursor-help" title="Outside contractors assigned to this WO. Contractors with an email receive the WO details + PDF when assigned.">ⓘ</span>
    </h3>
    <div class="space-y-2">
      <div class="flex flex-wrap gap-2" id="contractor-chips">
        <% selectedContractors.forEach(function(cid){ %>
          <% var contractor = (contractors || []).find(function(cc){ return cc.id == cid; }); %>
          <% if (contractor) { %>
            <span class="inline-flex items-center gap-1 px-3 py-1 bg-amber-100 text-amber-900 rounded-full text-sm">
              <%= contractor.name %><% if (contractor.trade) { %> · <%= contractor.trade %><% } %>
              <button type="button" class="remove-contractor text-amber-700 hover:text-amber-950 font-bold" data-id="<%= contractor.id %>">&times;</button>
              <input type="hidden" name="contractor_ids" value="<%= contractor.id %>">
            </span>
          <% } %>
        <% }); %>
      </div>
      <% if (!selectedContractors || selectedContractors.length === 0) { %>
        <p class="text-xs text-recon-fog">No contractors assigned yet. Add a contractor if an outside trade is handling this WO.</p>
      <% } %>
      <select id="contractor-select" class="input">
        <option value="">-- Add contractor --</option>
        <% (contractors || []).forEach(function(contractor){ %>
          <option value="<%= contractor.id %>"><%= contractor.name %><%= contractor.trade ? ' · ' + contractor.trade : '' %></option>
        <% }); %>
      </select>
    </div>
  </div>

  <!-- Description -->
  <div class="card p-5">
    <label class="label" for="description">Description
      <span class="ml-1 text-recon-fog cursor-help" title="Customer-visible description of the work to be done. Appears on the WO PDF, the assignee email, and the WO show page.">ⓘ</span>
    </label>
    <textarea name="description" id="description" rows="5" class="input" data-autosize style="min-height:8rem;resize:vertical"
              placeholder="Full description with all the details about the work"><%= wo.description || '' %></textarea>
  </div>

  <div class="flex items-center gap-2 pt-2">
    <button type="submit" class="btn btn-primary"><%= submitLabel %></button>
    <a href="/work-orders" class="btn btn-ghost">Cancel</a>
  </div>
</form>

<script>
// Customer autocomplete (native datalist)
(function(){
  const customers = <%- JSON.stringify(customers || []) %>;
  const search = document.getElementById('customer-search');
  const hidden = document.getElementById('customer-id');
  const card = document.getElementById('customer-card');
  const cName = document.getElementById('cust-name');
  const cEmail = document.getElementById('cust-email');
  const cPhone = document.getElementById('cust-phone');
  const cAddr = document.getElementById('cust-address');

  function showCustomer(id) {
    var c = customers.find(function(x){ return x.id == id; });
    if (!c) return;
    hidden.value = c.id;
    search.value = c.picker_label || c.name;
    cName.textContent = c.name;
    cEmail.textContent = c.email || '';
    cPhone.textContent = c.phone || '';
    cAddr.textContent = [c.address, c.city, c.state].filter(Boolean).join(', ');
    card.classList.remove('hidden');
  }

  if (hidden.value) showCustomer(hidden.value);

  search.addEventListener('change', function(){
    var selectedName = search.value;
    var match = customers.find(function(c){ return (c.picker_label || c.name) === selectedName; });
    if (match) showCustomer(match.id);
  });

  search.addEventListener('input', function(){
    var selectedName = search.value;
    var match = customers.find(function(c){ return (c.picker_label || c.name) === selectedName; });
    if (!match) { hidden.value = ''; card.classList.add('hidden'); }
  });

  document.addEventListener('click', function(e){
    if (!search.contains(e.target)) { /* noop */}
  });
})();

// Project selector — shows project details on change (optional, independent of customer)
(function(){
  const select = document.getElementById('project-select');
  const card = document.getElementById('project-card');
  const title = document.getElementById('proj-title');
  const customer = document.getElementById('proj-customer');
  const addr = document.getElementById('proj-address');

  function showProject(opt) {
    if (!opt || !opt.value) {
      card.classList.add('hidden');
      return;
    }
    title.textContent = opt.textContent;
    customer.textContent = opt.dataset.customerName ? 'Customer: ' + opt.dataset.customerName : '';
    addr.textContent = opt.dataset.address || '';
    card.classList.remove('hidden');
  }

  var initial = select.options[select.selectedIndex];
  if (initial && initial.value) showProject(initial);

  select.addEventListener('change', function(){
    showProject(this.options[this.selectedIndex]);
  });
})();

// Multi-assignee chips
(function(){
  var select = document.getElementById('assignee-select');
  var chips = document.getElementById('assignee-chips');

  select.addEventListener('change', function(){
    var id = this.value;
    if (!id) return;
    var opt = this.options[this.selectedIndex];
    if (chips.querySelector('[value="' + id + '"]')) { this.value = ''; return; }
    var span = document.createElement('span');
    span.className = 'inline-flex items-center gap-1 px-3 py-1 bg-blue-100 text-blue-800 rounded-full text-sm';
    span.innerHTML = opt.text + ' <button type="button" class="remove-assignee text-blue-600 hover:text-blue-900 font-bold">&times;</button><input type="hidden" name="assignee_ids" value="' + id + '">';
    chips.appendChild(span);
    this.value = '';
  });

  chips.addEventListener('click', function(e){
    var btn = e.target.closest('.remove-assignee');
    if (btn) btn.closest('span').remove();
  });
})();

// Contractor assignment chips
(function(){
  var select = document.getElementById('contractor-select');
  var chips = document.getElementById('contractor-chips');
  if (!select || !chips) return;

  select.addEventListener('change', function(){
    var id = this.value;
    if (!id) return;
    var opt = this.options[this.selectedIndex];
    if (chips.querySelector('[value="' + id + '"]')) { this.value = ''; return; }
    var span = document.createElement('span');
    span.className = 'inline-flex items-center gap-1 px-3 py-1 bg-amber-100 text-amber-900 rounded-full text-sm';
    span.innerHTML = opt.text + ' <button type="button" class="remove-contractor text-amber-700 hover:text-amber-950 font-bold">&times;</button><input type="hidden" name="contractor_ids" value="' + id + '">';
    chips.appendChild(span);
    this.value = '';
  });

  chips.addEventListener('click', function(e){
    var btn = e.target.closest('.remove-contractor');
    if (btn) btn.closest('span').remove();
  });
})();
</script>
