<%
// Shared WO form (v0.7 — depriced). WOs are scope/dispatch, not money docs.
// Expects: wo, job, users, errors, units, formAction, submitLabel,
// isSubWO (boolean), parent (when isSubWO).
const linesToRender = (wo.lines && wo.lines.length) ? wo.lines : [{
  description: '', quantity: 1, unit: 'ea', completed: 0
}];
%>
<form action="<%= formAction %>" method="post" class="space-y-6">
  <% if (typeof job !== 'undefined' && job && job.id) { %>
    <input type="hidden" name="job_id" value="<%= job.id %>">
  <% } %>

  <% if (typeof job !== 'undefined' && job && job.id) { %>
    <div class="card p-5">
      <h3 class="text-sm font-semibold uppercase tracking-wide text-recon-fog mb-2">Job</h3>
      <p class="font-medium"><%= job.title %></p>
      <% if (typeof isSubWO !== 'undefined' && isSubWO && parent) { %>
        <p class="text-sm text-recon-fog">Sub-WO of <a href="/work-orders/<%= parent.id %>" class="hover:text-recon-red">WO-<%= parent.display_number %></a></p>
      <% } %>
    </div>
  <% } %>

  <div class="card p-5">
    <h3 class="text-sm font-semibold uppercase tracking-wide text-recon-fog mb-3">Header</h3>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <div>
        <label class="label" for="display_number">WO Number</label>
        <input type="text" name="display_number" id="display_number"
               value="<%= wo.display_number || '' %>"
               placeholder="<%= wo.suggested_display_number || '0001-0000' %>"
               class="input <%= errors.display_number ? 'border-red-500' : '' %>"
               pattern="\d{1,6}-\d{1,6}">
        <p class="text-xs text-recon-fog mt-1">Format: 0001-0000. Leave blank to auto-generate (<%= wo.suggested_display_number || '0001-0000' %>).</p>
        <% if (errors.display_number) { %><p class="text-sm text-red-600 mt-1"><%= errors.display_number %></p><% } %>
      </div>
      <div>
        <label class="label" for="scheduled_date">Scheduled date</label>
        <input type="date" name="scheduled_date" id="scheduled_date"
               value="<%= wo.scheduled_date ? String(wo.scheduled_date).slice(0,10) : '' %>" class="input">
      </div>
      <div>
        <label class="label" for="scheduled_time">Scheduled time</label>
        <input type="time" name="scheduled_time" id="scheduled_time"
               value="<%= wo.scheduled_time || '' %>" class="input">
      </div>
      <div class="md:col-span-2">
        <label class="label" for="assigned_to_user_id">Assigned employee</label>
        <select name="assigned_to_user_id" id="assigned_to_user_id" class="input">
          <option value="">-- unassigned --</option>
          <% users.forEach(function(u){ %>
            <option value="<%= u.id %>" <%= (wo.assigned_to_user_id == u.id) ? 'selected' : '' %>><%= u.name %></option>
          <% }); %>
        </select>
      </div>
      <div>
        <label class="label" for="assigned_to">Or external assignee</label>
        <input type="text" name="assigned_to" id="assigned_to" value="<%= wo.assigned_to || '' %>"
               class="input" placeholder="Sub-contractor, etc.">
      </div>
    </div>
  </div>

  <div class="card overflow-hidden">
    <div class="px-5 py-3 border-b border-recon-mist flex items-center justify-between">
      <h3 class="font-semibold">Items</h3>
      <button type="button" data-add-line class="btn btn-secondary text-sm">+ Add item</button>
    </div>
    <div class="overflow-x-auto">
      <table class="data" data-line-items>
        <thead>
          <tr>
            <th>Done</th>
            <th>Description</th>
            <th class="text-right">Qty</th>
            <th>Unit</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% linesToRender.forEach(function(li, idx){ %>
            <tr class="line-row">
              <td class="text-center">
                <input type="hidden" name="lines[<%= idx %>][completed]" value="0">
                <input type="checkbox" name="lines[<%= idx %>][completed]" value="1" <%= li.completed ? 'checked' : '' %>>
              </td>
              <td>
                <input type="text" name="lines[<%= idx %>][description]" data-field="description"
                       value="<%= li.description || '' %>" class="input">
              </td>
              <td class="text-right">
                <input type="number" step="0.01" min="0" name="lines[<%= idx %>][quantity]" data-field="quantity"
                       value="<%= li.quantity %>" class="input text-right" style="width: 5rem;">
              </td>
              <td>
                <select name="lines[<%= idx %>][unit]" data-field="unit" class="input">
                  <% units.forEach(function(u){ %>
                    <option value="<%= u %>" <%= li.unit === u ? 'selected' : '' %>><%= u %></option>
                  <% }); %>
                </select>
              </td>
              <td>
                <button type="button" data-remove-line class="text-recon-fog hover:text-recon-red text-sm">remove</button>
              </td>
            </tr>
          <% }); %>

          <tr class="line-row hidden" data-template>
            <td class="text-center">
              <input type="hidden" name="lines[__IDX__][completed]" value="0">
              <input type="checkbox" name="lines[__IDX__][completed]" value="1">
            </td>
            <td><input type="text" name="lines[__IDX__][description]" data-field="description" class="input"></td>
            <td class="text-right"><input type="number" step="0.01" min="0" name="lines[__IDX__][quantity]" data-field="quantity" value="1" class="input text-right" style="width: 5rem;"></td>
            <td>
              <select name="lines[__IDX__][unit]" data-field="unit" class="input">
                <% units.forEach(function(u){ %>
                  <option value="<%= u %>" <%= u === 'ea' ? 'selected' : '' %>><%= u %></option>
                <% }); %>
              </select>
            </td>
            <td><button type="button" data-remove-line class="text-recon-fog hover:text-recon-red text-sm">remove</button></td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  <div class="card p-5">
    <label class="label" for="notes">Notes</label>
    <textarea name="notes" id="notes" rows="3" class="input"
              placeholder="Crew instructions, materials, scope details..."><%= wo.notes || '' %></textarea>
  </div>

  <div class="flex items-center gap-2 pt-2">
    <button type="submit" class="btn btn-primary"><%= submitLabel %></button>
    <a href="<%= wo.id ? '/work-orders/' + wo.id : (job && job.id ? '/jobs/' + job.id : '/work-orders') %>" class="btn btn-ghost">Cancel</a>
  </div>
</form>

<script src="/js/line-items.js"></script>
