<%- include('../layouts/header', { title: title, currentUser: currentUser, flash: flash, activeNav: activeNav }) %>

<%
function fmt(n) { const num = Number(n); return isFinite(num) ? num.toFixed(2) : '0.00'; }
const subtotal = (wo.lines || []).reduce(function(s, li){ return s + (Number(li.line_total) || 0); }, 0);
const completedCount = (wo.lines || []).filter(function(li){ return li.completed; }).length;
const totalCount = (wo.lines || []).length;
%>

<div class="max-w-5xl mx-auto px-4 py-6">
  <div class="mb-4">
    <a href="/work-orders" class="text-sm text-recon-fog hover:text-recon-red">&larr; Work Orders</a>
  </div>

  <div class="flex items-baseline justify-between mb-6 flex-wrap gap-2">
    <div>
      <div class="flex items-center gap-3">
        <h1 class="page-h1"><%= wo.wo_number %></h1>
        <span class="badge badge-<%= wo.status %>"><%= wo.status.replace('_',' ') %></span>
      </div>
      <p class="page-sub">
        Job: <a href="/jobs/<%= wo.job_id %>" class="hover:text-recon-red"><%= wo.job_title %></a>
        &middot; Customer: <a href="/customers/<%= wo.customer_id %>" class="hover:text-recon-red"><%= wo.customer_name %></a>
        <% if (wo.estimate_number) { %>
          &middot; From: <a href="/estimates/<%= wo.estimate_id %>" class="hover:text-recon-red"><%= wo.estimate_number %></a>
        <% } %>
      </p>
    </div>
    <div class="flex flex-wrap gap-2">
      <a href="/work-orders/<%= wo.id %>/pdf" class="btn btn-secondary" target="_blank" rel="noopener">View PDF</a>
      <a href="/work-orders/<%= wo.id %>/pdf?download=1" class="btn btn-ghost">Download</a>

      <% if (wo.status === 'scheduled' || wo.status === 'in_progress') { %>
        <a href="/work-orders/<%= wo.id %>/edit" class="btn btn-secondary">Edit</a>
      <% } %>

      <% if (wo.status === 'scheduled') { %>
        <form action="/work-orders/<%= wo.id %>/start" method="post" class="m-0 inline">
          <button class="btn btn-primary">Start work</button>
        </form>
      <% } else if (wo.status === 'in_progress') { %>
        <form action="/work-orders/<%= wo.id %>/complete" method="post" class="m-0 inline">
          <button class="btn btn-primary">Mark complete</button>
        </form>
      <% } %>

      <% if (wo.status !== 'complete' && wo.status !== 'cancelled') { %>
        <form action="/work-orders/<%= wo.id %>/cancel" method="post" class="m-0 inline"
              onsubmit="return confirm('Cancel this work order?');">
          <button class="btn btn-ghost">Cancel WO</button>
        </form>
      <% } %>

      <% if (wo.status === 'complete' && !invoice) { %>
        <form action="/work-orders/<%= wo.id %>/generate-invoice" method="post" class="m-0 inline">
          <button class="btn btn-primary">Generate invoice</button>
        </form>
      <% } %>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-6">
    <div class="card p-4">
      <div class="text-xs uppercase tracking-wide text-recon-fog">Scheduled</div>
      <div class="text-lg font-semibold mt-1"><%= wo.scheduled_date ? String(wo.scheduled_date).slice(0,10) : '—' %></div>
    </div>
    <div class="card p-4">
      <div class="text-xs uppercase tracking-wide text-recon-fog">Assigned to</div>
      <div class="text-lg font-semibold mt-1"><%= wo.assigned_to || '—' %></div>
    </div>
    <div class="card p-4">
      <div class="text-xs uppercase tracking-wide text-recon-fog">Progress</div>
      <div class="text-lg font-semibold mt-1"><%= completedCount %> / <%= totalCount %> done</div>
    </div>
    <div class="card p-4">
      <div class="text-xs uppercase tracking-wide text-recon-fog">Total value</div>
      <div class="text-lg font-semibold mt-1 text-recon-red">$<%= fmt(subtotal) %></div>
    </div>
  </div>

  <% if (invoice) { %>
    <div class="card p-4 mb-6 bg-green-50 border-green-200">
      <p class="text-sm">
        Invoice generated: <a href="/invoices/<%= invoice.id %>" class="font-medium text-recon-red hover:underline"><%= invoice.invoice_number %></a>
        <span class="badge badge-<%= invoice.status %>"><%= invoice.status %></span>
      </p>
    </div>
  <% } %>

  <div class="card overflow-hidden mb-6">
    <div class="px-5 py-3 border-b border-recon-mist flex items-center justify-between">
      <h3 class="font-semibold">Line items</h3>
    </div>
    <% if (wo.lines.length === 0) { %>
      <div class="p-6 text-center text-recon-fog text-sm">No line items.</div>
    <% } else { %>
      <table class="data">
        <thead>
          <tr>
            <th>Done</th>
            <th>Trade</th>
            <th>Description</th>
            <th class="text-right">Qty</th>
            <th>Unit</th>
            <th class="text-right">Unit $</th>
            <th class="text-right">Line $</th>
          </tr>
        </thead>
        <tbody>
          <% wo.lines.forEach(function(li){ %>
            <tr>
              <td><%= li.completed ? '✅' : '⬜' %></td>
              <td><span class="badge badge-draft"><%= li.trade %></span></td>
              <td><%= li.description %></td>
              <td class="text-right"><%= li.quantity %></td>
              <td><%= li.unit %></td>
              <td class="text-right">$<%= fmt(li.unit_price) %></td>
              <td class="text-right font-medium">$<%= fmt(li.line_total) %></td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    <% } %>
  </div>

  <% if (wo.notes) { %>
    <div class="card p-5 mb-6">
      <h3 class="text-sm font-semibold uppercase tracking-wide text-recon-fog mb-2">Notes</h3>
      <p class="text-sm whitespace-pre-line"><%= wo.notes %></p>
    </div>
  <% } %>

  <% if (wo.status === 'scheduled' || wo.status === 'cancelled') { %>
    <div class="card p-5 border-red-200">
      <h3 class="font-semibold text-recon-red mb-2">Danger zone</h3>
      <p class="text-sm text-recon-fog mb-3">Deletion is permanent. Allowed only if no invoice references this work order.</p>
      <form action="/work-orders/<%= wo.id %>/delete" method="post"
            onsubmit="return confirm('Delete <%= wo.wo_number %>?');" class="m-0">
        <button type="submit" class="btn btn-danger">Delete</button>
      </form>
    </div>
  <% } %>
</div>

<%- include('../layouts/footer') %>
