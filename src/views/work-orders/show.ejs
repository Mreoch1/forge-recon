<%- include('../layouts/header', { title: title, currentUser: currentUser, flash: flash, activeNav: activeNav }) %>

<%
const completedCount = (wo.lines || []).filter(function(li){ return li.completed; }).length;
const totalCount = (wo.lines || []).length;
const pct = totalCount > 0 ? Math.round(completedCount * 100 / totalCount) : 0;
const live = wo.status === 'in_progress';
const WO_STATUS_HINTS = {
  scheduled: 'Scheduled — on the calendar but work has not started yet.',
  in_progress: 'In progress — crew has started work on this WO.',
  complete: 'Complete — all work finished and signed off.',
  cancelled: 'Cancelled — WO will not be performed. Read-only.',
  on_hold: 'On hold — paused for now. Resume by editing the WO.'
};
const woStatusHint = WO_STATUS_HINTS[wo.status] || wo.status;
function fmtDate(d) { return d ? String(d).slice(0,10) : '—'; }
function fmtTime(t) {
  if (!t) return '';
  const [hh, mm] = String(t).split(':');
  const h = parseInt(hh, 10);
  if (isNaN(h)) return t;
  const ampm = h >= 12 ? 'PM' : 'AM';
  const h12 = h % 12 || 12;
  return h12 + ':' + (mm || '00') + ' ' + ampm;
}
const addr = [wo.job_address, wo.job_city, wo.job_state].filter(Boolean).join(', ');
%>

<style>
  /* WO show v2 — single-pane operational workspace */
  .ws-back { font-size: .78rem; color: #999; }
  .ws-back:hover { color: #c0202b; }

  .ws-h1 { font-size: 1.55rem; font-weight: 700; letter-spacing: -.015em; color: #1a1a1a; }
  .ws-eyebrow { font-size: .68rem; letter-spacing: .14em; text-transform: uppercase; font-weight: 600; color: #999; }

  .ws-status-badge { padding: .15rem .55rem; border-radius: 3px; font-size: .72rem; font-weight: 600; letter-spacing: .03em; text-transform: uppercase; }

  /* Strip: schedule | assignee | estimate | invoice| cancel */
  .ws-strip {
    display: flex; flex-wrap: wrap; align-items: stretch;
    border-top: 2px solid #1a1a1a; border-bottom: 1px solid #cfcfcf;
    background: #fafafa;
    margin: 1rem 0 1.5rem;
  }
  .ws-strip-cell {
    padding: .65rem 1.1rem; border-right: 1px solid #e0e0e0; min-width: 8.5rem;
  }
  .ws-strip-cell:last-child { border-right: none; }
  .ws-strip-label { font-size: .65rem; letter-spacing: .12em; text-transform: uppercase; color: #888; font-weight: 600; }
  .ws-strip-value { font-size: .92rem; font-weight: 700; color: #1a1a1a; margin-top: .15rem; }
  .ws-strip-value-mono { font-family: ui-monospace, monospace; }
  .ws-strip-value a { color: #1a1a1a; }
  .ws-strip-value a:hover { color: #c0202b; }
  .ws-strip-meta { font-size: .72rem; color: #888; font-weight: 500; margin-top: .1rem; }

  /* Section heading rules */
  .ws-h-primary { font-size: 1.05rem; font-weight: 700; color: #1a1a1a; padding-bottom: .35rem; border-bottom: 2px solid #1a1a1a; margin-bottom: .25rem; display: flex; justify-content: space-between; align-items: baseline; }
  .ws-h-secondary { font-size: .82rem; font-weight: 700; color: #888; letter-spacing: .06em; text-transform: uppercase; padding-bottom: .25rem; border-bottom: 1px solid #e0e0e0; margin-bottom: .25rem; display: flex; justify-content: space-between; align-items: baseline; }

  /* Items table — flat, dividers only */
  .ws-items { width: 100%; border-collapse: collapse; font-size: .9rem; }
  .ws-items th { text-align: left; font-size: .65rem; letter-spacing: .12em; text-transform: uppercase; color: #999; font-weight: 600; padding: .55rem .75rem; border-bottom: 1px solid #e5e5e5; }
  .ws-items td { padding: .65rem .75rem; border-bottom: 1px solid #f0f0f0; vertical-align: top; }
  .ws-items tr:last-child td { border-bottom: none; }
  .ws-items tr:hover td { background: #fafafa; }
  .ws-items .done-cell { width: 1.6rem; }
  .ws-items .qty-cell { font-family: ui-monospace, monospace; font-size: .85rem; text-align: right; width: 4.5rem; }
  .ws-items .unit-cell { width: 4rem; color: #666; font-size: .8rem; }
  .ws-items .desc-cell { color: #1a1a1a; }
  .ws-items .desc-cell.done { color: #888; text-decoration: line-through; text-decoration-color: #ccc; }
  .ws-checkbox { display: inline-block; width: 14px; height: 14px; border: 1.5px solid #888; border-radius: 2px; vertical-align: middle; }
  .ws-checkbox.done { background: #10b981; border-color: #10b981; position: relative; }
  .ws-checkbox.done::after { content: ''; position: absolute; left: 3px; top: 0px; width: 4px; height: 8px; border: solid white; border-width: 0 2px 2px 0; transform: rotate(45deg); }

  /* Notes feed */
  .ws-note-row { padding: .6rem 0; border-bottom: 1px solid #f0f0f0; font-size: .82rem; }
  .ws-note-row:last-child { border-bottom: none; }
  .ws-note-meta { font-size: .68rem; color: #aaa; margin-bottom: .15rem; font-family: ui-monospace, monospace; }
  .ws-note-body { color: #1a1a1a; line-height: 1.4; white-space: pre-line; }

  /* Customer block */
  .ws-cust { font-size: .85rem; color: #1a1a1a; }
  .ws-cust-name { font-weight: 700; font-size: .95rem; margin-bottom: .15rem; }
  .ws-cust-line { color: #666; font-size: .8rem; }

  /* Status dot */
  .ws-dot { width: 7px; height: 7px; border-radius: 50%; display: inline-block; }
  .ws-dot-live { background: #ea580c; box-shadow: 0 0 0 0 rgba(234,88,12,.5); animation: ws-pulse 2.4s infinite; }
  .ws-dot-sched { background: #b8b8b8; }
  .ws-dot-done { background: #10b981; }
  @keyframes ws-pulse {
    0%   { box-shadow: 0 0 0 0 rgba(234,88,12,.5); }
    70%  { box-shadow: 0 0 0 6px rgba(234,88,12,0); }
    100% { box-shadow: 0 0 0 0 rgba(234,88,12,0); }
  }

  /* Empty states */
  .ws-empty { padding: 1rem 0; color: #aaa; font-size: .82rem; text-align: center; font-style: italic; }

  /* === RESPONSIVE === */
  @media (max-width: 900px) {
    .ws-grid { grid-template-columns: 1fr !important; gap: 2rem !important; }
    .ws-strip { flex-wrap: wrap; }
    .ws-strip-cell { min-width: 50%; flex: 1 1 50%; border-right: none; border-bottom: 1px solid #e0e0e0; }
    .ws-strip-cell:nth-last-child(-n+2) { border-bottom: none; }
  }
  @media (max-width: 600px) {
    .ws-h1 { font-size: 1.3rem; }
    .ws-strip-cell { min-width: 100%; flex: 1 1 100%; padding: .55rem .85rem; }
    .ws-strip-cell:nth-last-child(-n+2) { border-bottom: 1px solid #e0e0e0; }
    .ws-strip-cell:last-child { border-bottom: none; }
    .ws-items { font-size: .8rem; }
    .ws-items th, .ws-items td { padding: .5rem .55rem; }
    .ws-items .qty-cell { width: auto; }
    .ws-items .unit-cell { width: auto; }
    .ws-back { font-size: .72rem; }
  }
</style>

<div class="max-w-7xl mx-auto px-4 py-5">

  <!-- Back nav -->
  <div class="mb-2"><a href="/work-orders" class="ws-back">&larr; Work orders</a></div>

  <!-- Header: WO# / status / customer / job / actions — R33: stack on mobile, actions become a scroll strip -->
  <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-3">
    <div>
      <div class="flex items-center gap-3 flex-wrap">
        <span class="ws-dot <%= live ? 'ws-dot-live' : (wo.status === 'complete' ? 'ws-dot-done' : 'ws-dot-sched') %>"></span>
        <h1 class="ws-h1">WO-<%= wo.display_number %></h1>
        <span class="ws-status-badge badge-<%= wo.status %>" title="<%= woStatusHint %>"><%= wo.status.replace('_',' ') %></span>
      </div>
      <p class="text-sm text-recon-fog mt-1">
        <a href="/customers/<%= wo.customer_id %>" class="font-semibold text-recon-charcoal hover:text-recon-red"><%= wo.customer_name %></a>
        <% if (wo.unit_number) { %><span class="text-recon-fog">· Unit <%= wo.unit_number %></span><% } %>
        <% if (addr) { %><span class="text-recon-fog">· <%= addr %></span><% } %>
      </p>
    </div>

    <div class="flex flex-wrap gap-2 -mx-4 px-4 md:mx-0 md:px-0 overflow-x-auto md:overflow-visible md:flex-wrap" style="-webkit-overflow-scrolling: touch;">
      <a href="/work-orders/<%= wo.id %>/pdf" class="btn btn-secondary text-sm" target="_blank" rel="noopener"
         title="Open the WO PDF in a new tab. This is the version the crew and customer see.">PDF</a>
      <% if (wo.status === 'scheduled' || wo.status === 'in_progress') { %>
        <a href="/work-orders/<%= wo.id %>/edit" class="btn btn-secondary text-sm">Edit</a>
      <% } %>
      <% if (wo.status !== 'cancelled' && !estimate) { %>
        <form action="/work-orders/<%= wo.id %>/create-estimate" method="post" class="m-0 inline">
          <button class="btn btn-primary text-sm" title="Create a customer-facing estimate from this WO's line items. You can edit before sending.">Create estimate</button>
        </form>
      <% } %>
      <% if (wo.status !== 'complete' && wo.status !== 'cancelled') { %>
        <form action="/work-orders/<%= wo.id %>/cancel" method="post" class="m-0 inline"
              onsubmit="return confirm('Cancel this work order?');">
          <button class="btn btn-ghost text-sm" title="Cancel this WO. Keeps it in history but marks it as not performed.">Cancel</button>
        </form>
      <% } %>
    </div>
  </div>

  <!-- Operational strip: dense info bar with rule-line dividers, no card chrome -->
  <div class="ws-strip">
    <div class="ws-strip-cell">
      <div class="ws-strip-label">Scheduled</div>
      <div class="ws-strip-value ws-strip-value-mono"><%= fmtDate(wo.scheduled_date) %></div>
      <% if (wo.scheduled_time) { %>
        <div class="ws-strip-meta"><%= fmtTime(wo.scheduled_time) %></div>
      <% } %>
    </div>
    <div class="ws-strip-cell">
      <div class="ws-strip-label">Assignee</div>
      <div class="ws-strip-value"><%= wo.assigned_user_name || wo.assigned_to || '—' %></div>
    </div>
    <% if (estimate) { %>
      <div class="ws-strip-cell">
        <div class="ws-strip-label">Estimate</div>
        <div class="ws-strip-value">
          <a href="/estimates/<%= estimate.id %>" class="ws-strip-value-mono">EST-<%= wo.display_number %></a>
          <span class="badge badge-<%= estimate.status %>" style="font-size:.65rem;"><%= estimate.status %></span>
        </div>
      </div>
    <% } %>
    <% if (invoice) { %>
      <div class="ws-strip-cell">
        <div class="ws-strip-label">Invoice</div>
        <div class="ws-strip-value">
          <a href="/invoices/<%= invoice.id %>" class="ws-strip-value-mono">INV-<%= wo.display_number %></a>
          <span class="badge badge-<%= invoice.status %>" style="font-size:.65rem;"><%= invoice.status %></span>
        </div>
      </div>
    <% } %>
    <% if (wo.completed_date) { %>
      <div class="ws-strip-cell">
        <div class="ws-strip-label">Completed</div>
        <div class="ws-strip-value ws-strip-value-mono"><%= fmtDate(wo.completed_date) %></div>
      </div>
    <% } %>
  </div>

  <!-- Two-column layout: scope (left, wide) | context (right, narrow) -->
  <div class="grid gap-8 ws-grid" style="grid-template-columns: minmax(0,1.6fr) minmax(0,1fr);">

    <!-- LEFT: description + notes -->
    <div>

      <!-- Description (from create form) -->
      <h2 class="ws-h-primary">Description</h2>
      <% if (wo.description) { %>
        <div style="font-size:.85rem;line-height:1.5;color:#1a1a1a;white-space:pre-line;padding:.6rem 0"><%= wo.description %></div>
      <% } else { %>
        <p class="text-sm text-recon-fog">No description provided.</p>
      <% } %>

      <!-- Notes block — form + feed -->
      <h2 class="ws-h-secondary mt-8">Notes</h2>

      <!-- Add note form -->
      <form action="/work-orders/<%= wo.id %>/notes" method="post" class="mb-4">
        <textarea name="body" required minlength="2" maxlength="2000" rows="3"
                  class="input w-full text-sm" style="resize:vertical;"
                  placeholder="Add a note — what got done, blockers, photos uploaded, etc."></textarea>
        <div class="flex justify-end mt-1">
          <button type="submit" class="btn btn-sm btn-primary">Post note</button>
        </div>
      </form>

      <% if (wo.notes) { %>
        <div class="ws-note-row">
          <div class="ws-note-meta">Crew notes</div>
          <div class="ws-note-body"><%= wo.notes %></div>
        </div>
      <% } %>

      <% if (typeof notes !== 'undefined' && notes && notes.length) { %>
        <% notes.forEach(function(n){ %>
          <div class="ws-note-row">
            <div class="ws-note-meta">
              <%= (n.user_name || 'Unknown') %> · <%= (n.created_at || '').slice(0,16).replace('T',' ') %>
            </div>
            <div class="ws-note-body"><%= n.body %></div>
          </div>
        <% }); %>
      <% } %>

      <!-- Files removed per user request -->

      <!-- Photo gallery -->
      <h2 class="ws-h-secondary mt-8">Photos</h2>
      <form action="/work-orders/<%= wo.id %>/photos" method="post" enctype="multipart/form-data" class="mb-4">
        <div class="flex items-start gap-3">
          <input type="file" name="photos" multiple accept="image/jpeg,image/png,image/webp,image/heic"
                 class="text-sm flex-1" style="padding-top:.35rem;">
          <input type="text" name="caption" placeholder="Caption (optional)" class="input text-sm flex-1" maxlength="200">
          <button type="submit" class="btn btn-sm btn-primary whitespace-nowrap">Upload</button>
        </div>
      </form>
      <% if (typeof photos !== 'undefined' && photos && photos.length) { %>
        <div class="grid grid-cols-3 gap-2 mb-4">
          <% photos.forEach(function(p){ %>
            <div class="relative group">
              <a href="<%= p.url %>" target="_blank">
                <img src="<%= p.url %>"
                     class="w-full h-24 object-cover rounded border"
                     loading="lazy"
                     title="<%= (p.user_name || 'Unknown') %> · <%= (p.created_at || '').slice(0,16).replace('T',' ') %><%= p.caption ? ' — ' + p.caption : '' %>">
              </a>
              <% if (p.user_id === currentUser.id || currentUser.role !== 'worker') { %>
                <form method="post" action="/work-orders/<%= wo.id %>/photos/<%= p.id %>/delete"
                      class="absolute top-1 right-1 opacity-0 group-hover:opacity-100 transition-opacity"
                      onsubmit="return confirm('Delete this photo?');">
                  <button class="bg-red-600 text-white text-xs rounded-full w-5 h-5 flex items-center justify-center hover:bg-red-700">&times;</button>
                </form>
              <% } %>
            </div>
          <% }); %>
        </div>
      <% } else { %>
        <p class="text-sm text-recon-fog mb-4">No photos yet.</p>
      <% } %>
    </div>

    <!-- RIGHT: customer + documents + danger zone -->
    <div>

      <!-- Customer card -->
      <h2 class="ws-h-secondary">Customer</h2>
      <div class="ws-cust mb-6">
        <div class="ws-cust-name">
          <a href="/customers/<%= wo.customer_id %>" class="hover:text-recon-red"><%= wo.customer_name %></a>
        </div>
        <% if (wo.customer_phone) { %>
          <div class="ws-cust-line"><a href="tel:<%= wo.customer_phone %>" class="hover:text-recon-red"><%= wo.customer_phone %></a></div>
        <% } %>
        <% if (wo.customer_email) { %>
          <div class="ws-cust-line"><a href="mailto:<%= wo.customer_email %>" class="hover:text-recon-red"><%= wo.customer_email %></a>
            <span class="text-xs text-recon-fog">(estimates)</span></div>
        <% } %>
        <% var bEmail = wo.customer_billing_email || wo.customer_email; %>
        <% if (bEmail) { %>
          <div class="ws-cust-line"><a href="mailto:<%= bEmail %>" class="hover:text-recon-red"><%= bEmail %></a>
            <span class="text-xs text-recon-fog">(invoices)</span></div>
        <% } %>
        <% const custAddr = [wo.customer_address, wo.customer_city, wo.customer_state, wo.customer_zip].filter(Boolean).join(', '); %>
        <% if (custAddr) { %>
          <div class="ws-cust-line"><%= custAddr %></div>
        <% } %>
      </div>

      <!-- Documents quick links -->
      <% if (estimate || invoice) { %>
        <h2 class="ws-h-secondary">Documents</h2>
        <div class="mb-6 space-y-1">
          <% if (estimate) { %>
            <a href="/estimates/<%= estimate.id %>" class="block py-1 text-sm hover:text-recon-red">
              <span class="ws-sub-num">EST-<%= wo.display_number %></span>
              <span class="badge badge-<%= estimate.status %>" style="font-size:.62rem; margin-left:.3rem;"><%= estimate.status %></span>
            </a>
          <% } %>
          <% if (invoice) { %>
            <a href="/invoices/<%= invoice.id %>" class="block py-1 text-sm hover:text-recon-red">
              <span class="ws-sub-num">INV-<%= wo.display_number %></span>
              <span class="badge badge-<%= invoice.status %>" style="font-size:.62rem; margin-left:.3rem;"><%= invoice.status %></span>
            </a>
          <% } %>
        </div>
      <% } %>

      <!-- Danger zone (only when relevant) -->
      <% if (wo.status === 'scheduled' || wo.status === 'cancelled') { %>
        <h2 class="ws-h-secondary text-recon-red" style="border-color:#fca5a5;">Danger zone</h2>
        <p class="text-xs text-recon-fog mb-2">Allowed only when no estimate references this WO.</p>
        <form action="/work-orders/<%= wo.id %>/delete" method="post"
              onsubmit="return confirm('Delete WO-<%= wo.display_number %>?');" class="m-0">
          <button type="submit" class="btn btn-danger text-sm" title="Permanently delete this WO. Only works if no estimate or invoice references it.">Delete</button>
        </form>
      <% } %>
    </div>
  </div>
</div>

<%- include('../layouts/footer') %>
