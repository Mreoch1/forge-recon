<%# One-shot post-login password update prompt. Dismiss/update writes users.password_update_prompt_seen_at. %>
<% if (typeof showPasswordUpdatePrompt !== 'undefined' && showPasswordUpdatePrompt && typeof currentUser !== 'undefined' && currentUser) { %>
<div id="password-update-overlay" style="position:fixed;inset:0;z-index:10001;background:rgba(0,0,0,0.55);display:flex;align-items:center;justify-content:center;padding:20px">
  <div style="background:#fff;border-radius:12px;max-width:500px;width:100%;padding:28px;box-shadow:0 8px 40px rgba(0,0,0,0.28);border:1px solid #e5e5e5">
    <div style="margin-bottom:16px">
      <p style="margin:0 0 6px;color:#888;font-size:11px;font-weight:800;letter-spacing:.12em;text-transform:uppercase">Account security</p>
      <h2 style="margin:0;font-size:22px;font-weight:800;color:#1a1a1a">Update your password</h2>
    </div>
    <p style="font-size:14px;color:#333;line-height:1.5;margin:0 0 12px">
      For a clean handoff into FORGE, we recommend setting your own current password from Settings.
    </p>
    <p style="font-size:13px;color:#666;line-height:1.5;margin:0 0 18px">
      You will only see this reminder once.
    </p>
    <div style="display:flex;gap:10px;align-items:center;justify-content:flex-end;flex-wrap:wrap">
      <form action="/settings/password-prompt/dismiss" method="post" style="margin:0">
        <button type="submit" style="background:#fff;color:#1a1a1a;border:1px solid #d0d0d0;border-radius:8px;padding:11px 18px;font-size:14px;font-weight:600;cursor:pointer">Not now</button>
      </form>
      <form action="/settings/password-prompt/update" method="post" style="margin:0">
        <button type="submit" style="background:#c0202b;color:#fff;border:none;border-radius:8px;padding:12px 22px;font-size:14px;font-weight:700;cursor:pointer">Update password</button>
      </form>
    </div>
  </div>
</div>
<% } %>
