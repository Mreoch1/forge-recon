<%# D-029: One-shot email warning modal — shows on first page load if user hasn't acknowledged. %>
<% if (typeof currentUser !== 'undefined' && currentUser && !currentUser.acknowledged_live_email_warning_at) { %>
<div id="email-warning-overlay" style="position:fixed;inset:0;z-index:10000;background:rgba(0,0,0,0.6);display:flex;align-items:center;justify-content:center;padding:20px">
  <div style="background:#fff;border-radius:12px;max-width:480px;width:100%;padding:28px;box-shadow:0 8px 40px rgba(0,0,0,0.3);border:3px solid #c0202b">
    <div style="text-align:center;margin-bottom:16px">
      <div style="font-size:48px;margin-bottom:4px">⚠️</div>
      <h2 style="margin:0;font-size:20px;font-weight:700;color:#c0202b">LIVE EMAIL SYSTEM</h2>
    </div>
    <p style="font-size:14px;color:#333;line-height:1.5;margin:0 0 12px">
      FORGE is currently in beta but the <strong style="color:#c0202b">email system is LIVE</strong>.
      Any estimate, invoice, or notification you send <strong>WILL be delivered</strong> to real customer email addresses.
    </p>
    <p style="font-size:14px;color:#333;line-height:1.5;margin:0 0 16px">
      While testing, <strong>do not use real customer emails, names, or addresses</strong> — use clearly fake test data.
    </p>
    <div style="background:#fff5f5;border:1px solid #fecaca;border-radius:8px;padding:12px;margin-bottom:16px">
      <p style="font-size:12px;color:#b91c1c;margin:0">
        💬 Use the <strong>Feedback</strong> button (bottom-left) to report any issues.
      </p>
    </div>
    <form action="/account/ack-email-warning" method="post" style="text-align:center">
      <button type="submit" style="background:#c0202b;color:#fff;border:none;border-radius:8px;padding:12px 32px;font-size:14px;font-weight:600;cursor:pointer">I understand — don't show this again</button>
    </form>
  </div>
</div>
<script>
(function(){
  var overlay = document.getElementById('email-warning-overlay');
  if (overlay) {
    overlay.addEventListener('click', function(e) {
      if (e.target === overlay) return; // don't dismiss on backdrop click — must click button
    });
  }
})();
</script>
<% } %>
