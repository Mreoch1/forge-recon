<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' && title ? title + ' — FORGE' : 'FORGE' %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/htmx.org@2.0.3"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            recon: {
              red: '#c0202b',
              'red-dark': '#8a0e16',
              'red-light': '#e63946',
              charcoal: '#1a1a1a',
              steel: '#2d2d2d',
              ash: '#3d3d3d',
              fog: '#888888',
              mist: '#e5e5e5',
              cloud: '#f5f5f5'
            }
          },
          fontFamily: {
            sans: ['Inter', 'ui-sans-serif', 'system-ui', '-apple-system', 'Segoe UI', 'sans-serif']
          }
        }
      }
    }
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    body { background: #f5f5f5; color: #1a1a1a; font-family: 'Inter', ui-sans-serif, system-ui, -apple-system, sans-serif; }
    .forge-wordmark {
      background: linear-gradient(95deg, #e63946 0%, #ff6b75 35%, #ffffff 100%);
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
      color: transparent;
      filter: drop-shadow(0 1px 0 rgba(0,0,0,.25));
      transition: filter .2s;
    }
    .group:hover .forge-wordmark {
      filter: drop-shadow(0 0 6px rgba(230,57,70,.55)) drop-shadow(0 1px 0 rgba(0,0,0,.25));
    }
    .navlink { color: #d0d0d0; padding: .5rem .75rem; border-radius: .25rem; transition: all .15s; font-size: .9rem; }
    .navlink:hover { background: #3d3d3d; color: #ffffff; }
    .navlink.active { background: #c0202b; color: #ffffff; }
    .btn { display: inline-flex; align-items: center; padding: .5rem 1rem; border-radius: .375rem; font-weight: 500; transition: all .15s; cursor: pointer; border: none; font-size: .9rem; }
    .btn-primary { background: #c0202b; color: #ffffff; }
    .btn-primary:hover { background: #8a0e16; }
    .btn-secondary { background: #2d2d2d; color: #ffffff; }
    .btn-secondary:hover { background: #1a1a1a; }
    .btn-ghost { background: transparent; color: #1a1a1a; }
    .btn-ghost:hover { background: #e5e5e5; }
    .btn-danger { background: #ffffff; color: #c0202b; border: 1px solid #c0202b; }
    .btn-danger:hover { background: #c0202b; color: #ffffff; }
    .card { background: #ffffff; border-radius: .5rem; box-shadow: 0 1px 3px rgba(0,0,0,.06); border: 1px solid #e5e5e5; }
    .input, select.input, textarea.input { display: block; width: 100%; padding: .5rem .75rem; border-radius: .375rem; border: 1px solid #d0d0d0; background: #ffffff; font-size: .9rem; transition: all .15s; }
    .input:focus { border-color: #c0202b; outline: none; box-shadow: 0 0 0 3px rgba(192,32,43,.15); }
    .label { display: block; font-size: .85rem; font-weight: 500; color: #1a1a1a; margin-bottom: .25rem; }
    .badge { display: inline-flex; align-items: center; padding: .15rem .6rem; border-radius: 9999px; font-size: .75rem; font-weight: 500; }
    .badge-draft   { background: #e5e5e5; color: #1a1a1a; }
    .badge-sent    { background: #dbeafe; color: #1e40af; }
    .badge-accepted, .badge-paid, .badge-complete { background: #d1fae5; color: #065f46; }
    .badge-rejected, .badge-cancelled, .badge-void { background: #fee2e2; color: #991b1b; }
    .badge-overdue, .badge-expired { background: #fef3c7; color: #92400e; }
    .badge-scheduled, .badge-in_progress, .badge-estimating { background: #ede9fe; color: #5b21b6; }
    .badge-lead    { background: #f3f4f6; color: #374151; }
    table.data { width: 100%; border-collapse: collapse; }
    table.data th { text-align: left; font-size: .8rem; text-transform: uppercase; letter-spacing: .05em; color: #888; padding: .75rem 1rem; border-bottom: 1px solid #e5e5e5; background: #fafafa; }
    table.data td { padding: .75rem 1rem; border-bottom: 1px solid #f0f0f0; font-size: .9rem; }
    table.data tr:hover td { background: #fafafa; }
    .page-h1 { font-size: 1.5rem; font-weight: 700; color: #1a1a1a; }
    .page-sub { color: #888; font-size: .9rem; }
    .list-utility-bar { display: flex; align-items: center; gap: .5rem; margin-bottom: 1rem; min-height: 38px; flex-wrap: wrap; }
    .list-utility-bar .list-search { flex: 1; min-width: 140px; max-width: 260px; padding: .4rem .65rem; border-radius: .375rem; border: 1px solid #d0d0d0; background: #fff; font-size: .85rem; }
    .list-utility-bar .list-search:focus { border-color: #c0202b; outline: none; box-shadow: 0 0 0 3px rgba(192,32,43,.15); }
    .list-utility-bar .list-filter { padding: .4rem .65rem; border-radius: .375rem; border: 1px solid #d0d0d0; background: #fff; font-size: .85rem; min-width: 120px; color: #1a1a1a; }
    .list-utility-bar .btn { font-size: .85rem; padding: .4rem .75rem; }
    .list-utility-bar .list-clear { font-size: .8rem; color: #888; text-decoration: none; padding: .3rem .5rem; }
    .list-utility-bar .list-clear:hover { color: #c0202b; }
    tr.row-link { cursor: pointer; }
    tr.row-link:hover { background: #f0f0f0 !important; }
  </style>
</head>
<body class="min-h-screen flex flex-col">

<% if (typeof currentUser !== 'undefined' && currentUser) { %>
  <nav class="bg-recon-charcoal text-white shadow-md">
    <div class="max-w-7xl mx-auto px-4 flex items-center justify-between h-20">
      <div class="flex items-center gap-2">
        <a href="/" class="flex items-center gap-3 mr-4 group">
          <img src="/logos/recon.png" alt="Recon" class="h-14 w-auto">
          <span class="flex flex-col leading-none">
            <span class="forge-wordmark font-extrabold text-lg tracking-[.16em]">FORGE</span>
            <span class="text-[.55rem] uppercase tracking-[.18em] text-recon-fog mt-0.5">by Recon Enterprises</span>
          </span>
        </a>
        <!-- Desktop nav -->
        <div class="hidden md:flex items-center gap-1" id="desktop-nav">
          <a href="/" class="navlink<%= typeof activeNav !== 'undefined' && activeNav === 'dashboard' ? ' active' : '' %>">Dashboard</a>
          <a href="/schedule" class="navlink<%= typeof activeNav !== 'undefined' && activeNav === 'schedule' ? ' active' : '' %>">Schedule</a>
          <a href="/jobs" class="navlink<%= typeof activeNav !== 'undefined' && activeNav === 'jobs' ? ' active' : '' %>">Jobs</a>
          <a href="/customers" class="navlink<%= typeof activeNav !== 'undefined' && activeNav === 'customers' ? ' active' : '' %>">Customers</a>
          <a href="/estimates" class="navlink<%= typeof activeNav !== 'undefined' && activeNav === 'estimates' ? ' active' : '' %>">Estimates</a>
          <a href="/work-orders" class="navlink<%= typeof activeNav !== 'undefined' && activeNav === 'work-orders' ? ' active' : '' %>">Work Orders</a>
          <a href="/invoices" class="navlink<%= typeof activeNav !== 'undefined' && activeNav === 'invoices' ? ' active' : '' %>">Invoices</a>
          <!-- More dropdown -->
          <div class="relative" id="more-dropdown">
            <%
              var _activeNav = (typeof activeNav !== 'undefined') ? activeNav : '';
              var moreActive = _activeNav === 'vendors' || _activeNav === 'bills' || _activeNav === 'accounting' || _activeNav === 'admin';
            %>
            <button class="navlink more-toggle<%= moreActive ? ' active' : '' %>">More ▾</button>
            <div class="more-menu hidden absolute top-full right-0 mt-1 bg-recon-steel border border-recon-ash rounded-lg shadow-xl py-1 min-w-[160px] z-50">
              <a href="/vendors" class="block px-4 py-2 text-sm text-recon-mist hover:bg-recon-ash transition<%= typeof activeNav !== 'undefined' && activeNav === 'vendors' ? ' bg-recon-red text-white hover:bg-recon-red' : '' %>">Vendors</a>
              <a href="/bills" class="block px-4 py-2 text-sm text-recon-mist hover:bg-recon-ash transition<%= typeof activeNav !== 'undefined' && activeNav === 'bills' ? ' bg-recon-red text-white hover:bg-recon-red' : '' %>">Bills</a>
              <a href="/accounting" class="block px-4 py-2 text-sm text-recon-mist hover:bg-recon-ash transition<%= typeof activeNav !== 'undefined' && activeNav === 'accounting' ? ' bg-recon-red text-white hover:bg-recon-red' : '' %>">Accounting</a>
              <% if (currentUser.role === 'admin') { %>
                <div class="border-t border-recon-ash my-1"></div>
                <a href="/admin/users" class="block px-4 py-2 text-sm text-recon-mist hover:bg-recon-ash transition<%= typeof activeNav !== 'undefined' && activeNav === 'admin' ? ' bg-recon-red text-white hover:bg-recon-red' : '' %>">Admin</a>
              <% } %>
            </div>
          </div>
        </div>
        <!-- Mobile nav -->
        <div class="md:hidden flex items-center gap-1 flex-wrap" id="mobile-nav">
          <a href="/" class="navlink<%= typeof activeNav !== 'undefined' && activeNav === 'dashboard' ? ' active' : '' %>">Dashboard</a>
          <a href="/schedule" class="navlink<%= typeof activeNav !== 'undefined' && activeNav === 'schedule' ? ' active' : '' %>">Schedule</a>
          <a href="/jobs" class="navlink<%= typeof activeNav !== 'undefined' && activeNav === 'jobs' ? ' active' : '' %>">Jobs</a>
          <a href="/customers" class="navlink<%= typeof activeNav !== 'undefined' && activeNav === 'customers' ? ' active' : '' %>">Customers</a>
          <a href="/estimates" class="navlink<%= typeof activeNav !== 'undefined' && activeNav === 'estimates' ? ' active' : '' %>">Estimates</a>
          <a href="/invoices" class="navlink<%= typeof activeNav !== 'undefined' && activeNav === 'invoices' ? ' active' : '' %>">Invoices</a>
          <a href="/work-orders" class="navlink<%= typeof activeNav !== 'undefined' && activeNav === 'work-orders' ? ' active' : '' %>">Work Orders</a>
          <a href="/vendors" class="navlink<%= typeof activeNav !== 'undefined' && activeNav === 'vendors' ? ' active' : '' %>">Vendors</a>
          <a href="/bills" class="navlink<%= typeof activeNav !== 'undefined' && activeNav === 'bills' ? ' active' : '' %>">Bills</a>
          <a href="/accounting" class="navlink<%= typeof activeNav !== 'undefined' && activeNav === 'accounting' ? ' active' : '' %>">Accounting</a>
          <% if (currentUser.role === 'admin') { %>
            <a href="/admin/users" class="navlink<%= typeof activeNav !== 'undefined' && activeNav === 'admin' ? ' active' : '' %>">Admin</a>
          <% } %>
        </div>
      </div>
      <div class="flex items-center gap-3">
        <span class="text-sm text-recon-fog hidden sm:inline"><%= currentUser.name %></span>
        <span class="text-xs text-recon-fog hidden sm:inline">(<%= currentUser.role %>)</span>
        <form action="/logout" method="post" class="m-0 p-0">
          <button type="submit" class="text-sm text-recon-fog hover:text-white transition">Logout</button>
        </form>
      </div>
    </div>
  </nav>
<script>
(function(){
  var moreBtn = document.querySelector('.more-toggle');
  var moreMenu = document.querySelector('.more-menu');
  if (!moreBtn || !moreMenu) return;
  function toggle(e) {
    e.stopPropagation();
    var isOpen = !moreMenu.classList.contains('hidden');
    moreMenu.classList.toggle('hidden', isOpen);
  }
  moreBtn.addEventListener('click', toggle);
  document.addEventListener('click', function(e) {
    if (!moreMenu.classList.contains('hidden') && !moreBtn.contains(e.target) && !moreMenu.contains(e.target)) {
      moreMenu.classList.add('hidden');
    }
  });
  // Full-row click for list tables
  document.addEventListener('click', function(e) {
    var tr = e.target.closest('tr.row-link');
    if (!tr) return;
    var href = tr.getAttribute('data-href');
    if (href) window.location.href = href;
  });
})();
</script>
<% } %>

<% if (typeof flash !== 'undefined' && flash) { %>
  <% if (flash.success) { %>
    <div class="bg-green-50 border-b border-green-200 text-green-800 px-4 py-2 text-sm">
      <div class="max-w-7xl mx-auto"><%= flash.success %></div>
    </div>
  <% } %>
  <% if (flash.error) { %>
    <div class="bg-red-50 border-b border-red-200 text-red-800 px-4 py-2 text-sm">
      <div class="max-w-7xl mx-auto"><%= flash.error %></div>
    </div>
  <% } %>
  <% if (flash.info) { %>
    <div class="bg-blue-50 border-b border-blue-200 text-blue-800 px-4 py-2 text-sm">
      <div class="max-w-7xl mx-auto"><%= flash.info %></div>
    </div>
  <% } %>
<% } %>

<main class="flex-1">
