<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' && title ? title + ' — FORGE' : 'FORGE' %></title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
  <link rel="shortcut icon" href="/favicon.ico">
  <meta name="theme-color" content="#c0202b">
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/htmx.org@2.0.3"></script>
  <link rel="stylesheet" href="/css/dark.css">
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          colors: {
            recon: {
              red: '#c0202b',
              'red-dark': '#8a0e16',
              'red-light': '#e63946',
              charcoal: '#1a1a1a',
              steel: '#2d2d2d',
              ash: '#3d3d3d',
              fog: '#888888',
              mist: '#e5e5e5',
              cloud: '#f5f5f5'
            }
          },
          fontFamily: {
            sans: ['Inter', 'ui-sans-serif', 'system-ui', '-apple-system', 'Segoe UI', 'sans-serif']
          }
        }
      }
    }
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    body { background: #f5f5f5; color: #1a1a1a; font-family: 'Inter', ui-sans-serif, system-ui, -apple-system, sans-serif; }
        .forge-wordmark {
      font-family: 'Inter', system-ui, sans-serif;
      font-weight: 900;
      letter-spacing: 0.08em;
      background-image:
        linear-gradient(
          105deg,
          transparent 0%,
          transparent 35%,
          rgba(255, 255, 255, 0.5) 44%,
          rgba(255, 255, 255, 0.95) 50%,
          rgba(255, 255, 255, 0.5) 56%,
          transparent 65%,
          transparent 100%
        ),
        linear-gradient(
          105deg,
          #6b1212 0%,
          #951818 15%,
          #b51e1e 28%,
          #c84444 42%,
          #b07878 55%,
          #888888 70%,
          #5a5a5a 86%,
          #3a3a3a 100%
        );
      background-size: 250% 100%, 100% 100%;
      background-position: 100% center, 0 0;
      background-repeat: no-repeat;
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
      color: transparent;
      animation: forge-shine 4s linear infinite;
      text-shadow: 0 1px 2px rgba(0,0,0,0.2), 0 2px 6px rgba(0,0,0,0.08);
    }
    @keyframes forge-shine {
      0%   { background-position: 100% center, 0 0; }
      100% { background-position: -150% center, 0 0; }
    }
@media (prefers-reduced-motion: reduce) {
      .forge-wordmark { animation: none; background-position: 50% center, 0 0; }
    }
    .group:hover .forge-wordmark {
      filter: drop-shadow(0 0 6px rgba(230,57,70,.55)) drop-shadow(0 1px 0 rgba(0,0,0,.25));
    }
    .navlink { color: #d0d0d0; padding: .5rem .75rem; border-radius: .25rem; transition: all .15s; font-size: .9rem; }
    .navlink:hover { background: #3d3d3d; color: #ffffff; }
    .navlink.active { background: #c0202b; color: #ffffff; }
    .btn { display: inline-flex; align-items: center; justify-content: center; padding: .5rem 1rem; border-radius: .375rem; font-weight: 500; transition: all .15s; cursor: pointer; border: none; font-size: .9rem; }
    /* R33: bigger tap targets on phones */
    @media (max-width: 767px) {
      .btn { min-height: 44px; padding: .65rem 1rem; }
      .input, select.input, textarea.input { min-height: 44px; font-size: 1rem; } /* font-size 1rem prevents iOS auto-zoom */
    }
    .btn-primary { background: #c0202b; color: #ffffff; }
    .btn-primary:hover { background: #8a0e16; }
    .btn-secondary { background: #2d2d2d; color: #ffffff; }
    .btn-secondary:hover { background: #1a1a1a; }
    .btn-ghost { background: transparent; color: #1a1a1a; }
    .btn-ghost:hover { background: #e5e5e5; }
    .btn-danger { background: #ffffff; color: #c0202b; border: 1px solid #c0202b; }
    .btn-danger:hover { background: #c0202b; color: #ffffff; }
    .card { background: #ffffff; border-radius: .5rem; box-shadow: 0 1px 3px rgba(0,0,0,.06); border: 1px solid #e5e5e5; }
    .input, select.input, textarea.input { display: block; width: 100%; padding: .5rem .75rem; border-radius: .375rem; border: 1px solid #d0d0d0; background: #ffffff; font-size: .9rem; transition: all .15s; }
    .input:focus { border-color: #c0202b; outline: none; box-shadow: 0 0 0 3px rgba(192,32,43,.15); }
    .label { display: block; font-size: .85rem; font-weight: 500; color: #1a1a1a; margin-bottom: .25rem; }
    .badge { display: inline-flex; align-items: center; padding: .15rem .6rem; border-radius: 9999px; font-size: .75rem; font-weight: 500; }
    .badge-draft   { background: #e5e5e5; color: #1a1a1a; }
    .badge-sent    { background: #dbeafe; color: #1e40af; }
    .badge-accepted, .badge-paid, .badge-complete { background: #d1fae5; color: #065f46; }
    .badge-rejected, .badge-cancelled, .badge-void { background: #fee2e2; color: #991b1b; }
    .badge-overdue, .badge-expired { background: #fef3c7; color: #92400e; }
    .badge-scheduled, .badge-in_progress, .badge-estimating { background: #ede9fe; color: #5b21b6; }
    .badge-lead    { background: #f3f4f6; color: #374151; }
    .badge-archived { background: #6b7280; color: #ffffff; }
    /* R33: wrap any .data table in .card to get clean horizontal scroll on mobile. */
    .card.overflow-hidden { overflow-x: auto; -webkit-overflow-scrolling: touch; }
    @media (max-width: 767px) {
      table.data { min-width: 540px; }
    }
    table.data { width: 100%; border-collapse: collapse; }
    table.data th { text-align: left; font-size: .8rem; text-transform: uppercase; letter-spacing: .05em; color: #888; padding: .75rem 1rem; border-bottom: 1px solid #e5e5e5; background: #fafafa; }
    table.data td { padding: .75rem 1rem; border-bottom: 1px solid #f0f0f0; font-size: .9rem; }
    table.data tr:hover td { background: #fafafa; }
    .page-h1 { font-size: 1.5rem; font-weight: 700; color: #1a1a1a; }
    .page-sub { color: #888; font-size: .9rem; }
    .list-utility-bar { display: flex; align-items: center; gap: .5rem; margin-bottom: 1rem; min-height: 38px; flex-wrap: wrap; }
    .list-utility-bar .list-search { flex: 1 1 100%; min-width: 140px; max-width: 100%; padding: .55rem .75rem; border-radius: .375rem; border: 1px solid #d0d0d0; background: #fff; font-size: .9rem; min-height: 40px; }
    @media (min-width: 768px) {
      .list-utility-bar .list-search { flex: 1; max-width: 260px; padding: .4rem .65rem; font-size: .85rem; min-height: 0; }
    }
    .list-utility-bar .list-search:focus { border-color: #c0202b; outline: none; box-shadow: 0 0 0 3px rgba(192,32,43,.15); }
    .list-utility-bar .list-filter { padding: .4rem .65rem; border-radius: .375rem; border: 1px solid #d0d0d0; background: #fff; font-size: .85rem; min-width: 120px; color: #1a1a1a; }
    .list-utility-bar .btn { font-size: .85rem; padding: .4rem .75rem; }
    .list-utility-bar .list-clear { font-size: .8rem; color: #888; text-decoration: none; padding: .3rem .5rem; }
    .list-utility-bar .list-clear:hover { color: #c0202b; }
    tr.row-link { cursor: pointer; }
    tr.row-link:hover { background: #f0f0f0 !important; }

    /* R33 — mobile header / hamburger.
       Pure-CSS hamburger via a hidden checkbox + :checked sibling selector.
       The checkbox is the FIRST child of <nav>; #mobile-panel is a later
       sibling, so :checked ~ #mobile-panel reveals the panel. The label
       (.r33-hamburger) lives inside the toolbar and is wired via for=. */
    #r33-nav-toggle { display: none; }
    .r33-hamburger {
      display: inline-flex; align-items: center; justify-content: center;
      width: 44px; height: 44px; border-radius: 6px; cursor: pointer;
      color: #d0d0d0; transition: background .15s, color .15s;
    }
    .r33-hamburger:hover { background: #3d3d3d; color: #fff; }
    .r33-hamburger svg { width: 22px; height: 22px; }
    #mobile-panel { display: none; }
    #r33-nav-toggle:checked ~ #mobile-panel { display: block; }
    /* Hover-style hint to indicate active state on the label when panel is open */
    #r33-nav-toggle:checked ~ .max-w-7xl .r33-hamburger { background: #3d3d3d; color: #fff; }
    /* On md+ screens always hide the toggle UI even if state was checked */
    @media (min-width: 768px) {
      #r33-nav-toggle:checked ~ #mobile-panel { display: none; }
      .r33-hamburger { display: none; }
    }
    /* Bigger tap targets in the mobile panel */
    #mobile-panel .navlink { display: block; padding: .75rem .85rem; font-size: .95rem; min-height: 44px; }
  </style>
</head>
<body class="min-h-screen flex flex-col">

<% if (typeof currentUser !== 'undefined' && currentUser) { %>
  <nav class="bg-recon-charcoal text-white shadow-md">
    <!-- R33: hidden checkbox drives the mobile menu open/closed state -->
    <input type="checkbox" id="r33-nav-toggle" aria-hidden="true">
    <div class="max-w-7xl mx-auto px-3 md:px-4 flex items-center justify-between h-16 md:h-20 gap-2">
      <div class="flex items-center gap-2 min-w-0">
        <a href="/" class="flex items-center gap-2 md:gap-3 md:mr-4 group shrink-0">
          <img src="/logos/recon-logo.jpg" alt="Recon Enterprises Inc." class="h-10 md:h-14 w-auto">
          <span class="flex flex-col leading-none">
            <span class="forge-wordmark font-extrabold text-base md:text-lg tracking-[.16em]">FORGE</span>
            <span class="hidden sm:inline text-[.55rem] uppercase tracking-[.18em] text-recon-fog mt-0.5">by Recon Enterprises</span>
          </span>
        </a>
        <!-- Desktop nav (md+) -->
        <div class="hidden md:flex items-center gap-1" id="desktop-nav">
          <a href="/" class="navlink<%= typeof activeNav !== 'undefined' && activeNav === 'dashboard' ? ' active' : '' %>">Dashboard</a>
          <a href="/work-orders" class="navlink<%= typeof activeNav !== 'undefined' && activeNav === 'work-orders' ? ' active' : '' %>">Work Orders</a>
          <a href="/estimates" class="navlink<%= typeof activeNav !== 'undefined' && activeNav === 'estimates' ? ' active' : '' %>">Estimates</a>
          <a href="/invoices" class="navlink<%= typeof activeNav !== 'undefined' && activeNav === 'invoices' ? ' active' : '' %>">Invoices</a>
          <a href="/schedule" class="navlink<%= typeof activeNav !== 'undefined' && activeNav === 'schedule' ? ' active' : '' %>">Schedule</a>
          <!-- More dropdown -->
          <div class="relative" id="more-dropdown">
            <%
              var _activeNav = (typeof activeNav !== 'undefined') ? activeNav : '';
              var moreActive = _activeNav === 'vendors' || _activeNav === 'bills' || _activeNav === 'accounting' || _activeNav === 'customers' || _activeNav === 'projects';
            %>
            <button class="navlink more-toggle<%= moreActive ? ' active' : '' %>">More ▾</button>
            <div class="more-menu hidden absolute top-full right-0 mt-1 bg-recon-steel border border-recon-ash rounded-lg shadow-xl py-1 min-w-[160px] z-50">
              <a href="/customers" class="block px-4 py-2 text-sm text-recon-mist hover:bg-recon-ash transition<%= typeof activeNav !== 'undefined' && activeNav === 'customers' ? ' bg-recon-red text-white hover:bg-recon-red' : '' %>">Customers</a>
              <a href="/projects" class="block px-4 py-2 text-sm text-recon-mist hover:bg-recon-ash transition<%= typeof activeNav !== 'undefined' && activeNav === 'projects' ? ' bg-recon-red text-white hover:bg-recon-red' : '' %>">Projects</a>
              <a href="/vendors" class="block px-4 py-2 text-sm text-recon-mist hover:bg-recon-ash transition<%= typeof activeNav !== 'undefined' && activeNav === 'vendors' ? ' bg-recon-red text-white hover:bg-recon-red' : '' %>">Vendors</a>
              <a href="/bills" class="block px-4 py-2 text-sm text-recon-mist hover:bg-recon-ash transition<%= typeof activeNav !== 'undefined' && activeNav === 'bills' ? ' bg-recon-red text-white hover:bg-recon-red' : '' %>">Bills</a>
              <a href="/accounting" class="block px-4 py-2 text-sm text-recon-mist hover:bg-recon-ash transition<%= typeof activeNav !== 'undefined' && activeNav === 'accounting' ? ' bg-recon-red text-white hover:bg-recon-red' : '' %>">Accounting</a>
            </div>
          </div>
        </div>
      </div>
      <div class="flex items-center gap-2 md:gap-3 shrink-0">
        <span class="text-sm text-recon-fog hidden md:inline"><%= currentUser.name %></span>
        <a href="/settings" class="text-xs text-recon-fog hidden md:inline hover:text-white transition">(<%= currentUser.role %>)</a>
        <form action="/logout" method="post" class="m-0 p-0 hidden sm:block">
          <button type="submit" class="text-sm text-recon-fog hover:text-white transition">Logout</button>
        </form>
        <button id="theme-toggle" class="text-base text-recon-fog hover:text-white transition w-9 h-9 flex items-center justify-center rounded" title="Toggle dark mode">☀</button>
        <!-- R33: hamburger label (mobile only) — the actual toggle is the hidden checkbox above the toolbar -->
        <label for="r33-nav-toggle" class="r33-hamburger md:hidden" aria-label="Toggle menu">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
        </label>
      </div>
    </div>
    <!-- R33: mobile slide-down nav panel (md:hidden) -->
    <div id="mobile-panel" class="md:hidden bg-recon-steel border-t border-recon-ash">
      <div class="px-3 py-2 flex flex-col gap-1">
        <a href="/" class="navlink<%= typeof activeNav !== 'undefined' && activeNav === 'dashboard' ? ' active' : '' %>">Dashboard</a>
        <a href="/work-orders" class="navlink<%= typeof activeNav !== 'undefined' && activeNav === 'work-orders' ? ' active' : '' %>">Work Orders</a>
        <a href="/estimates" class="navlink<%= typeof activeNav !== 'undefined' && activeNav === 'estimates' ? ' active' : '' %>">Estimates</a>
        <a href="/invoices" class="navlink<%= typeof activeNav !== 'undefined' && activeNav === 'invoices' ? ' active' : '' %>">Invoices</a>
        <a href="/schedule" class="navlink<%= typeof activeNav !== 'undefined' && activeNav === 'schedule' ? ' active' : '' %>">Schedule</a>
        <a href="/customers" class="navlink<%= typeof activeNav !== 'undefined' && activeNav === 'customers' ? ' active' : '' %>">Customers</a>
        <a href="/projects" class="navlink<%= typeof activeNav !== 'undefined' && activeNav === 'projects' ? ' active' : '' %>">Projects</a>
        <a href="/vendors" class="navlink<%= typeof activeNav !== 'undefined' && activeNav === 'vendors' ? ' active' : '' %>">Vendors</a>
        <a href="/bills" class="navlink<%= typeof activeNav !== 'undefined' && activeNav === 'bills' ? ' active' : '' %>">Bills</a>
        <a href="/accounting" class="navlink<%= typeof activeNav !== 'undefined' && activeNav === 'accounting' ? ' active' : '' %>">Accounting</a>
        <div class="border-t border-recon-ash mt-1 pt-2 flex items-center justify-between text-xs text-recon-fog">
          <span><%= currentUser.name %> <span class="opacity-70">(<%= currentUser.role %>)</span></span>
          <form action="/logout" method="post" class="m-0 p-0">
            <button type="submit" class="text-recon-fog hover:text-white transition px-2 py-1">Logout</button>
          </form>
        </div>
      </div>
    </div>
  </nav>
<script>
// Theme toggle
(function(){
  const html = document.documentElement;
  const btn = document.getElementById('theme-toggle');
  const saved = localStorage.getItem('forge-theme');
  if (saved === 'dark') { html.classList.add('dark'); btn.textContent = '☾'; }
  btn.addEventListener('click', function(){
    html.classList.toggle('dark');
    const isDark = html.classList.contains('dark');
    btn.textContent = isDark ? '☾' : '☀';
    localStorage.setItem('forge-theme', isDark ? 'dark' : 'light');
  });
})();
(function(){
  var moreBtn = document.querySelector('.more-toggle');
  var moreMenu = document.querySelector('.more-menu');
  if (!moreBtn || !moreMenu) return;
  function toggle(e) {
    e.stopPropagation();
    var isOpen = !moreMenu.classList.contains('hidden');
    moreMenu.classList.toggle('hidden', isOpen);
  }
  moreBtn.addEventListener('click', toggle);
  document.addEventListener('click', function(e) {
    if (!moreMenu.classList.contains('hidden') && !moreBtn.contains(e.target) && !moreMenu.contains(e.target)) {
      moreMenu.classList.add('hidden');
    }
  });
  // Full-row click for list tables
  document.addEventListener('click', function(e) {
    var tr = e.target.closest('tr.row-link');
    if (!tr) return;
    var href = tr.getAttribute('data-href');
    if (href) window.location.href = href;
  });
})();
</script>
<% } %>

<% if (typeof flash !== 'undefined' && flash) { %>
  <% if (flash.success) { %>
    <div class="bg-green-50 border-b border-green-200 text-green-800 px-4 py-2 text-sm">
      <div class="max-w-7xl mx-auto"><%= flash.success %></div>
    </div>
  <% } %>
  <% if (flash.error) { %>
    <div class="bg-red-50 border-b border-red-200 text-red-800 px-4 py-2 text-sm">
      <div class="max-w-7xl mx-auto"><%= flash.error %></div>
    </div>
  <% } %>
  <% if (flash.info) { %>
    <div class="bg-blue-50 border-b border-blue-200 text-blue-800 px-4 py-2 text-sm">
      <div class="max-w-7xl mx-auto"><%= flash.info %></div>
    </div>
  <% } %>
<% } %>

<main class="flex-1">
