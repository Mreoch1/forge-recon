<%- include('../layouts/header', { title: title, currentUser: currentUser, flash: flash, activeNav: activeNav }) %>

<div class="max-w-3xl mx-auto px-4 py-6">
  <%
    const termPresets = ['Due on receipt', 'Net 15', 'Net 30', 'Net 45', 'Net 60'];
    const defaultTerms = settings.default_payment_terms || 'Net 30';
    const defaultIsCustom = termPresets.indexOf(defaultTerms) === -1;
  %>
  <div class="mb-4">
    <a href="/admin/users" class="text-sm text-recon-fog hover:text-recon-red">&larr; Admin</a>
  </div>
  <h1 class="page-h1 mb-6">Company settings</h1>

  <div class="card p-6">
    <form action="/admin/settings" method="post" class="space-y-6">
      <section>
        <h3 class="text-sm font-semibold uppercase tracking-wide text-recon-fog mb-3">Identity</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div class="md:col-span-2">
            <label class="label" for="company_name">Company name <span class="text-recon-red">*</span>
              <span class="ml-1 text-recon-fog cursor-help" title="Your company's legal name. Appears on every PDF (estimates, WOs, invoices) and outgoing email.">ⓘ</span>
            </label>
            <input type="text" name="company_name" id="company_name" required
                   value="<%= settings.company_name || '' %>"
                   class="input <%= errors.company_name ? 'border-red-500' : '' %>">
            <% if (errors.company_name) { %><p class="text-sm text-red-600 mt-1"><%= errors.company_name %></p><% } %>
          </div>
          <div>
            <label class="label" for="phone">Phone
              <span class="ml-1 text-recon-fog cursor-help" title="Main office phone number printed on customer-facing PDFs.">ⓘ</span>
            </label>
            <input type="text" name="phone" id="phone" value="<%= settings.phone || '' %>" class="input">
          </div>
          <div>
            <label class="label" for="email">Email
              <span class="ml-1 text-recon-fog cursor-help" title="Main office email shown on PDFs and used as the reply-to on outgoing notifications.">ⓘ</span>
            </label>
            <input type="email" name="email" id="email" value="<%= settings.email || '' %>" class="input">
          </div>
          <div>
            <label class="label" for="ein">EIN / tax ID
              <span class="ml-1 text-recon-fog cursor-help" title="Your federal tax ID. Used on invoices and W-9s.">ⓘ</span>
            </label>
            <input type="text" name="ein" id="ein" value="<%= settings.ein || '' %>" class="input">
          </div>
        </div>
      </section>

      <section>
        <h3 class="text-sm font-semibold uppercase tracking-wide text-recon-fog mb-3">Address</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div class="md:col-span-2">
            <label class="label" for="address">Street</label>
            <input type="text" name="address" id="address" value="<%= settings.address || '' %>" class="input">
          </div>
          <div>
            <label class="label" for="city">City</label>
            <input type="text" name="city" id="city" value="<%= settings.city || '' %>" class="input">
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="label" for="state">State</label>
              <input type="text" name="state" id="state" value="<%= settings.state || '' %>" class="input" maxlength="2">
            </div>
            <div>
              <label class="label" for="zip">ZIP</label>
              <input type="text" name="zip" id="zip" value="<%= settings.zip || '' %>" class="input" maxlength="10">
            </div>
          </div>
        </div>
      </section>

      <section>
        <h3 class="text-sm font-semibold uppercase tracking-wide text-recon-fog mb-3">Defaults &amp; numbering</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label class="label" for="default_tax_rate">Default tax rate (%)
              <span class="ml-1 text-recon-fog cursor-help" title="Sales tax rate pre-filled on new estimates and invoices. Can be overridden per document.">ⓘ</span>
            </label>
            <input type="number" step="0.001" min="0" name="default_tax_rate" id="default_tax_rate"
                   value="<%= settings.default_tax_rate || 0 %>" class="input">
          </div>
          <div>
            <label class="label" for="default_payment_terms">Default payment terms
              <span class="ml-1 text-recon-fog cursor-help" title="Default payment terms applied to new estimates and invoices. Can be overridden per document.">ⓘ</span>
            </label>
            <select name="default_payment_terms" id="default_payment_terms" class="input">
              <% termPresets.forEach(function(p){ %>
                <option value="<%= p %>" <%= defaultTerms === p ? 'selected' : '' %>><%= p %></option>
              <% }); %>
              <option value="__custom" <%= defaultIsCustom ? 'selected' : '' %>>Custom</option>
            </select>
            <input type="text" name="default_payment_terms_custom" id="default_payment_terms_custom"
                   value="<%= defaultIsCustom ? defaultTerms : '' %>" class="input mt-2 <%= defaultIsCustom ? '' : 'hidden' %>"
                   placeholder="Custom terms">
          </div>
        </div>
        <div class="md:col-span-2">
          <label class="label" for="default_conditions">Default invoice conditions &amp; terms
            <span class="ml-1 text-recon-fog cursor-help" title="Standard conditions printed on every invoice. Can be overridden per invoice.">ⓘ</span>
          </label>
          <textarea name="default_conditions" id="default_conditions" rows="4" class="input"><%= settings.default_conditions || '' %></textarea>
        </div>
        <p class="text-xs text-recon-fog mt-2">
          Next WO main number: <%= settings.next_wo_main_number || 1 %>
          (advances automatically when a new root WO is created)
        </p>
      </section>

      <div class="flex items-center gap-2 pt-4 border-t border-recon-mist">
        <button type="submit" class="btn btn-primary">Save settings</button>
        <a href="/admin/users" class="btn btn-ghost">Cancel</a>
      </div>
    </form>
  </div>
</div>

<script>
(function(){
  var select = document.getElementById('default_payment_terms');
  var custom = document.getElementById('default_payment_terms_custom');
  if (!select || !custom) return;
  function sync() { custom.classList.toggle('hidden', select.value !== '__custom'); }
  select.addEventListener('change', sync);
  sync();
})();
</script>

<%- include('../layouts/footer') %>
