<%- include('../layouts/header', { title, activeNav }) %>

<div class="max-w-6xl mx-auto px-4 py-6 space-y-6">

  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-white">Inbox</h1>
      <p class="text-sm text-recon-fog mt-1">Unified feed: feedback, error reports, and AI issues.</p>
    </div>
    <div class="flex items-center gap-2">
      <a href="/admin" class="text-sm text-recon-red-light hover:text-white transition">&larr; Admin</a>
      <a href="/admin/inbox?status=new" class="text-sm px-3 py-1 rounded <%= currentFilter === 'new' ? 'bg-recon-red text-white' : 'bg-recon-ash text-recon-fog hover:text-white' %> transition">New</a>
      <a href="/admin/inbox" class="text-sm px-3 py-1 rounded <%= currentFilter === 'all' ? 'bg-recon-red text-white' : 'bg-recon-ash text-recon-fog hover:text-white' %> transition">All</a>
    </div>
  </div>

  <% if (typeof error !== 'undefined' && error) { %>
    <div class="bg-red-900/50 border border-red-700 rounded-lg p-4 text-sm text-red-200">
      <%= error %>
    </div>
  <% } %>

  <!-- Feed -->
  <div class="bg-recon-steel rounded-lg border border-recon-ash overflow-hidden">
    <div class="px-6 py-4 border-b border-recon-ash flex items-center justify-between">
      <h2 class="text-lg font-semibold text-white">
        Items (<%= items.length %>)
      </h2>
      <span class="text-xs bg-recon-ash px-2 py-0.5 rounded text-recon-fog">
        Sorted newest first
      </span>
    </div>

    <% if (items && items.length) { %>
      <div class="divide-y divide-recon-ash">
        <% items.forEach(function(item) { %>
          <div class="px-6 py-4">
            <div class="flex items-start justify-between gap-4">
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 mb-1">
                  <!-- Source badge -->
                  <span class="text-xs font-medium px-1.5 py-0.5 rounded
                    <%= item.source === 'user_feedback' ? 'bg-blue-900/50 text-blue-300' : '' %>
                    <%= item.source === 'ai_chat_errors' ? 'bg-red-900/50 text-red-300' : '' %>
                  "><%= item.source === 'user_feedback' ? 'Feedback' : 'Error' %></span>
                  <!-- Status badge -->
                  <span class="text-xs px-1.5 py-0.5 rounded
                    <%= item.status === 'new' ? 'bg-green-900/50 text-green-300' : '' %>
                    <%= item.status === 'acked' ? 'bg-yellow-900/50 text-yellow-300' : '' %>
                    <%= item.status === 'fixed' ? 'bg-gray-700 text-recon-fog' : '' %>
                    <%= item.status === 'wontfix' ? 'bg-gray-700 text-recon-fog' : '' %>
                  "><%= item.status %></span>
                  <span class="text-xs text-recon-fog">
                    <%= new Date(item.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }) %>
                  </span>
                </div>
                <p class="text-sm font-medium text-white"><%= item.title %></p>
                <p class="text-sm text-recon-fog mt-1 line-clamp-2"><%= item.body %></p>
                <% if (item.pageUrl) { %>
                  <p class="text-xs text-recon-fog mt-1 truncate">Page: <%= item.pageUrl %></p>
                <% } %>
                <% if (item.userId) { %>
                  <p class="text-xs text-recon-fog">User #<%= item.userId %></p>
                <% } %>
              </div>
              <!-- Status actions -->
              <% if (item.source === 'user_feedback') { %>
                <div class="shrink-0">
                  <form method="POST" action="/admin/inbox/<%= item.source %>-<%= item.sourceId %>/status" class="flex gap-1">
                    <% if (item.status === 'new') { %>
                      <button name="status" value="acked" class="text-xs px-2 py-1 rounded bg-yellow-900/50 text-yellow-300 hover:bg-yellow-800/50 transition">ACK</button>
                    <% } %>
                    <% if (item.status !== 'fixed' && item.status !== 'wontfix') { %>
                      <button name="status" value="fixed" class="text-xs px-2 py-1 rounded bg-green-900/50 text-green-300 hover:bg-green-800/50 transition">Fixed</button>
                      <button name="status" value="wontfix" class="text-xs px-2 py-1 rounded bg-gray-700 text-recon-fog hover:bg-gray-600 transition">Won't fix</button>
                    <% } %>
                  </form>
                </div>
              <% } %>
            </div>
          </div>
        <% }); %>
      </div>
    <% } else { %>
      <div class="px-6 py-8 text-center text-recon-fog text-sm">
        No items found. Everything is clean.
      </div>
    <% } %>
  </div>

</div>

<%- include('../layouts/footer') %>
