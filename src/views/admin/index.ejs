<%- include('../layouts/header', { title: title, currentUser: currentUser, flash: flash, activeNav: activeNav }) %>
<div class="max-w-7xl mx-auto px-4 py-6">
  <h1 class="page-h1 mb-6">Admin panel</h1>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 mb-8">
    <a href="/admin/users" class="card p-5 hover:shadow-md transition block">
      <h2 class="font-semibold">Users</h2>
      <p class="text-sm text-recon-fog mt-1"><%= userCount %> active</p>
    </a>
    <a href="/admin/settings" class="card p-5 hover:shadow-md transition block">
      <h2 class="font-semibold">Company settings</h2>
      <p class="text-sm text-recon-fog mt-1">Business info, tax, payment terms</p>
    </a>
    <a href="/admin/ai-usage" class="card p-5 hover:shadow-md transition block">
      <h2 class="font-semibold">AI Usage</h2>
      <p class="text-sm text-recon-fog mt-1">Token usage and chat history</p>
    </a>
    <a href="/admin/announcements" class="card p-5 hover:shadow-md transition block">
      <h2 class="font-semibold">Announcements</h2>
      <p class="text-sm text-recon-fog mt-1">Change log banner for all users</p>
    </a>
    <a href="/admin/inbox" class="card p-5 hover:shadow-md transition block">
      <h2 class="font-semibold">Inbox</h2>
      <p class="text-sm text-recon-fog mt-1">Feedback, errors, and AI issues</p>
    </a>
  </div>

  <div class="card p-5">
    <h2 class="font-semibold mb-3">Holidays & Closures</h2>
    <p class="text-sm text-recon-fog mb-3">Showing <%= holidayCount %> holidays · <%= customCount %> custom</p>

    <div class="flex flex-wrap gap-3 items-end">
      <div>
        <select id="closure-select" class="list-filter" style="min-width:220px" onchange="document.getElementById('closure-id').value=this.value">
          <option value="">-- Select closure --</option>
          <% closures.forEach(function(c){ %>
            <option value="<%= c.id %>"><%= c.name %> &middot; <%= (c.date_start || '').slice(0,10) %><% if (c.date_end) { %> &ndash; <%= (c.date_end || '').slice(0,10) %><% } %> (<%= c.type %>)</option>
          <% }); %>
        </select>
      </div>
      <form method="post" action="/admin/closures/delete" class="inline" onsubmit="return confirm('Delete selected closure?')">
        <input type="hidden" name="closure_id" id="closure-id" value="">
        <button type="submit" class="btn btn-danger text-sm">Remove</button>
      </form>
    </div>

    <details class="mt-4">
      <summary class="text-sm font-medium text-recon-red cursor-pointer">+ Add new closure</summary>
      <form method="post" action="/admin/closures/create" class="mt-3 flex flex-wrap gap-3 items-end">
        <div>
          <label class="text-xs text-recon-fog block mb-1">Name</label>
          <input type="text" name="name" class="input text-sm" style="width:180px" required>
        </div>
        <div>
          <label class="text-xs text-recon-fog block mb-1">Start date</label>
          <input type="date" name="date_start" class="input text-sm" required>
        </div>
        <div>
          <label class="text-xs text-recon-fog block mb-1">End date</label>
          <input type="date" name="date_end" class="input text-sm">
        </div>
        <div>
          <label class="text-xs text-recon-fog block mb-1">Type</label>
          <select name="type" class="list-filter">
            <option value="holiday">Holiday</option>
            <option value="closure">Closure</option>
            <option value="company_event">Company event</option>
          </select>
        </div>
        <div>
          <label class="text-xs text-recon-fog block mb-1">Notes</label>
          <input type="text" name="notes" class="input text-sm" style="width:200px">
        </div>
        <button type="submit" class="btn btn-primary text-sm">Add</button>
      </form>
    </details>
  </div>
</div>
<%- include('../layouts/footer') %>
