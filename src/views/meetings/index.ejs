<%- include('../layouts/header', { title: title, currentUser: currentUser, flash: flash, activeNav: activeNav }) %>
<div class="ops-shell">
  <div class="flex items-baseline justify-between mb-4 flex-wrap gap-2">
    <div>
      <a href="/projects/<%= job.id %>" class="text-sm text-recon-fog hover:text-recon-red">&larr; <%= job.title %></a>
      <h1 class="page-h1 mt-1">Schedule</h1>
    </div>
    <div class="flex gap-2">
      <a href="/projects/<%= job.id %>/schedule/new" class="btn btn-primary text-sm">+ New meeting</a>
    </div>
  </div>

  <!-- Upcoming meetings -->
  <h2 class="text-sm font-semibold uppercase tracking-wide text-recon-fog mb-2">Upcoming</h2>
  <% if (upcoming.length === 0) { %>
    <div class="card p-8 text-center text-recon-fog text-sm italic mb-6">No upcoming meetings.</div>
  <% } else { %>
    <div class="space-y-3 mb-8">
      <% upcoming.forEach(function(m){ %>
        <div class="card p-4">
          <div class="flex items-start justify-between gap-4">
            <div class="min-w-0 flex-1">
              <div class="flex items-center gap-2 flex-wrap">
                <h3 class="font-semibold m-0"><%= m.title %></h3>
                <span class="badge badge-<%= m.start_time > new Date().toISOString() ? 'scheduled' : 'draft' %>"><%= m.start_time > new Date().toISOString() ? 'Upcoming' : 'Now' %></span>
              </div>
              <div class="text-xs text-recon-fog mt-1 space-y-0.5">
                <div>📅 <%= formatDateTime(m.start_time) %> · <%= m.duration_minutes %> min</div>
                <% if (m.location) { %><div>📍 <%= m.location %></div><% } %>
                <% if (m.meeting_link) { %><div>🔗 <a href="<%= m.meeting_link %>" target="_blank" class="text-recon-red hover:underline"><%= m.meeting_link %></a></div><% } %>
                <% if (m.description) { %><div class="mt-1 text-recon-charcoal whitespace-pre-line"><%= m.description %></div><% } %>
              </div>
            </div>
            <div class="flex flex-col items-end gap-1 text-xs flex-shrink-0">
              <% if (m.attendees && m.attendees.length) { %>
                <div class="text-recon-fog mb-1">
                  <% var counts = { accept: 0, decline: 0, maybe: 0, pending: 0 }; %>
                  <% m.attendees.forEach(function(a){ counts[a.response] = (counts[a.response] || 0) + 1; }); %>
                  <span title="Accepted">✅ <%= counts.accept || 0 %></span>
                  <span title="Maybe">❓ <%= counts.maybe || 0 %></span>
                  <span title="Declined">❌ <%= counts.decline || 0 %></span>
                  <span title="Pending">⏳ <%= counts.pending || 0 %></span>
                </div>
              <% } %>
              <% if (currentUser.role === 'admin' || currentUser.role === 'manager') { %>
                <details class="text-xs">
                  <summary class="cursor-pointer text-recon-fog hover:text-recon-red">Manage</summary>
                  <div class="mt-1 space-y-1 bg-white border border-recon-mist rounded p-2 shadow-sm">
                    <form method="post" action="/meetings/<%= m.id %>/send-invites" class="inline">
                      <button type="submit" class="block w-full text-left text-recon-charcoal hover:text-recon-red py-0.5">Re-send invites</button>
                    </form>
                    <form method="post" action="/meetings/<%= m.id %>/send-reminder" class="inline">
                      <button type="submit" class="block w-full text-left text-recon-charcoal hover:text-recon-red py-0.5">Send reminder</button>
                    </form>
                    <form method="post" action="/meetings/<%= m.id %>/delete" class="inline" onsubmit="return confirm('Delete this meeting?')">
                      <button type="submit" class="block w-full text-left text-recon-red py-0.5">Delete</button>
                    </form>
                  </div>
                </details>
              <% } %>
            </div>
          </div>
          <% if (m.attendees && m.attendees.length) { %>
            <div class="mt-3 pt-2 border-t border-recon-mist text-xs text-recon-fog">
              <% m.attendees.forEach(function(a){ %>
                <span class="inline-flex items-center gap-1 mr-3 mb-1">
                  <%= a.users?.name || '—' %>
                  <% if (a.response === 'accept') { %><span class="text-green-600" title="Accepted">✅</span>
                  <% } else if (a.response === 'decline') { %><span class="text-red-600" title="Declined">❌</span>
                  <% } else if (a.response === 'maybe') { %><span class="text-yellow-600" title="Maybe">❓</span>
                  <% } else { %><span class="text-gray-400" title="Pending">⏳</span><% } %>
                </span>
              <% }); %>
            </div>
          <% } %>
        </div>
      <% }); %>
    </div>
  <% } %>

  <!-- Past meetings -->
  <% if (past.length > 0) { %>
    <details class="mb-6">
      <summary class="cursor-pointer text-sm font-medium text-recon-fog mb-2 hover:text-recon-red">Past meetings (<%= past.length %>)</summary>
      <div class="space-y-2 mt-3">
        <% past.forEach(function(m){ %>
          <div class="card p-3 flex items-center justify-between">
            <div>
              <p class="font-medium text-sm m-0"><%= m.title %></p>
              <p class="text-xs text-recon-fog mt-0.5">📅 <%= formatDateTime(m.start_time) %></p>
            </div>
            <div class="flex gap-2 text-xs">
              <% if (m.attendees && m.attendees.length) { %>
                <span class="text-recon-fog">✅ <%= (m.attendees.filter(function(a){ return a.response === 'accept'; }).length) %> · ❓ <%= (m.attendees.filter(function(a){ return a.response === 'maybe'; }).length) %> · ❌ <%= (m.attendees.filter(function(a){ return a.response === 'decline'; }).length) %></span>
              <% } %>
              <% if (currentUser.role === 'admin' || currentUser.role === 'manager') { %>
                <form method="post" action="/meetings/<%= m.id %>/delete" class="inline" onsubmit="return confirm('Delete?')">
                  <button type="submit" class="text-recon-red hover:underline">Delete</button>
                </form>
              <% } %>
            </div>
          </div>
        <% }); %>
      </div>
    </details>
  <% } %>
</div>
<%- include('../layouts/footer') %>
