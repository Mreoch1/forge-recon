<%- include('../layouts/header', { title: 'Dashboard', currentUser: currentUser, flash: flash, activeNav: 'dashboard' }) %>

<%
function fmt(n) { const num = Number(n); return isFinite(num) ? num.toFixed(2) : '0.00'; }
function pathFor(act) {
  if (act.type === 'estimate')   return '/estimates/'    + act.id;
  if (act.type === 'work_order') return '/work-orders/'  + act.id;
  if (act.type === 'invoice')    return '/invoices/'     + act.id;
  return '#';
}
function typeLabel(t) {
  if (t === 'work_order') return 'Work Order';
  if (t === 'invoice')    return 'Invoice';
  if (t === 'estimate')   return 'Estimate';
  return t;
}
%>

<div class="max-w-7xl mx-auto px-4 py-6">
  <!-- R33: stack the title and action row vertically on mobile -->
  <div class="flex flex-col md:flex-row md:items-baseline md:justify-between mb-6 gap-3">
    <div>
      <h1 class="page-h1">Dashboard</h1>
      <p class="page-sub">Welcome back, <%= currentUser.name %>.</p>
    </div>
    <div class="flex flex-wrap gap-2 items-center">
      <%# D-093: classic-view lock — return path to FORGE mode posts default_landing=chat
          so the user is taken back out of "classic" lock. Otherwise the root route
          would just bounce them back here on next login. %>
      <form method="post" action="/account/landing-mode" style="margin:0;">
        <input type="hidden" name="mode" value="chat">
        <input type="hidden" name="redirect_to" value="/forge">
        <button type="submit" class="text-xs text-recon-fog hover:text-recon-red mr-2 bg-transparent border-0 p-0 cursor-pointer">
          ← back to FORGE mode
        </button>
      </form>
      <a href="/customers/new" class="btn btn-secondary">+ Customer</a>
      <a href="/work-orders/new" class="btn btn-primary">+ Work order</a>
    </div>
  </div>

  <!-- D-095: KPI summary table — single card, 2-col layout, no floating cards -->
  <div class="card overflow-hidden mb-6">
    <div class="px-5 py-3 border-b border-recon-mist">
      <h3 class="font-semibold text-sm">Pipeline Summary</h3>
    </div>
    <div class="divide-y divide-recon-mist">
      <table class="data">
        <tbody>
          <tr><td class="text-sm text-recon-charcoal">Open Estimates</td><td class="text-right font-semibold"><a href="/estimates?status=sent" class="text-recon-red hover:underline"><%= openEstimates %></a> <span class="text-xs text-recon-fog font-normal">draft + sent</span></td></tr>
          <tr><td class="text-sm text-recon-charcoal">Active Work Orders</td><td class="text-right font-semibold"><a href="/work-orders?status=scheduled" class="text-recon-red hover:underline"><%= scheduledWOs %></a> <span class="text-xs text-recon-fog font-normal">scheduled + in progress</span></td></tr>
          <tr><td class="text-sm text-recon-charcoal">Unpaid Invoices</td><td class="text-right font-semibold"><a href="/invoices?status=sent" class="text-recon-red hover:underline"><%= unpaidInvoices %></a> <span class="text-xs text-recon-fog font-normal">sent + overdue</span></td></tr>
          <tr><td class="text-sm text-recon-charcoal">A/R Balance</td><td class="text-right font-semibold<% if (overdueCount > 0) { %> text-recon-red<% } %>">$<%= fmt(arBalance) %><% if (overdueCount > 0) { %> <span class="text-xs text-red-600 font-normal">(<%= overdueCount %> overdue $<%= fmt(overdueBalance) %>)</span><% } else { %> <span class="text-xs text-recon-fog font-normal">none overdue</span><% } %></td></tr>
          <tr><td class="text-sm text-recon-charcoal">Revenue this month</td><td class="text-right font-semibold">$<%= fmt(revenueThisMonth) %></td></tr>
          <tr><td class="text-sm text-recon-charcoal">Revenue year-to-date</td><td class="text-right font-semibold">$<%= fmt(revenueYTD) %></td></tr>
          <tr><td class="text-sm text-recon-charcoal">Customers / Work orders</td><td class="text-right"><span class="font-semibold"><%= customerCount %></span> <span class="text-xs text-recon-fog">customers</span> / <span class="font-semibold"><%= workOrderCount %></span> <span class="text-xs text-recon-fog">work orders</span></td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Recent activity -->
  <div class="card overflow-hidden">
    <div class="px-5 py-3 border-b border-recon-mist flex items-center justify-between">
      <h3 class="font-semibold">Recent activity</h3>
      <span class="text-xs text-recon-fog">last 10</span>
    </div>
    <% if (activity.length === 0) { %>
      <div class="p-8 text-center text-recon-fog text-sm">
        Nothing yet. <a href="/customers/new" class="text-recon-red underline">Add a customer</a> to get started.
      </div>
    <% } else { %>
      <ul class="divide-y divide-recon-mist">
        <% activity.forEach(function(act){ %>
          <li class="px-5 py-3 hover:bg-recon-cloud transition">
            <a href="<%= pathFor(act) %>" class="flex items-center justify-between gap-3">
              <div class="flex items-center gap-3 flex-1 min-w-0">
                <span class="badge badge-<%= act.status %> shrink-0"><%= act.status.replace('_',' ') %></span>
                <div class="min-w-0">
                  <p class="text-sm font-medium text-recon-charcoal truncate">
                    <span class="text-xs text-recon-fog uppercase tracking-wide mr-2"><%= typeLabel(act.type) %></span>
                    <%= act.number %>
                    <% if (act.total != null) { %>
                      <span class="text-recon-fog font-normal">— $<%= fmt(act.total) %></span>
                    <% } %>
                  </p>
                  <p class="text-xs text-recon-fog truncate">
                    <%= act.customer_name %><% if (act.job_title) { %> &middot; <%= act.job_title %><% } %>
                  </p>
                </div>
              </div>
              <span class="text-xs text-recon-fog shrink-0"><%= (act.created_at || '').slice(0,16) %></span>
            </a>
          </li>
        <% }); %>
      </ul>
    <% } %>
  </div>
</div>

<%- include('../layouts/footer') %>
