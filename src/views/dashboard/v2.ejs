<%- include('../layouts/header', { title: title, currentUser: currentUser, flash: flash, activeNav: activeNav }) %>

<%
function fmt(n) { const num = Number(n); return isFinite(num) ? num.toFixed(2) : '0.00'; }
function fmtMoney(n) {
  const num = Number(n) || 0;
  return Math.abs(num) >= 1000
    ? '$' + Math.round(num).toLocaleString()
    : '$' + num.toFixed(2);
}
function fmtTime(t) {
  if (!t) return '—';
  const [hh, mm] = String(t).split(':');
  const h = parseInt(hh, 10);
  if (isNaN(h)) return t;
  const ampm = h >= 12 ? 'PM' : 'AM';
  const h12 = h % 12 || 12;
  return h12 + ':' + (mm || '00') + ' ' + ampm;
}
function pathFor(act) {
  if (act.type === 'estimate')   return '/estimates/'    + act.id;
  if (act.type === 'work_order') return '/work-orders/'  + act.id;
  if (act.type === 'invoice')    return '/invoices/'     + act.id;
  return '#';
}
function typeAbbr(t) {
  if (t === 'work_order') return 'WO';
  if (t === 'invoice')    return 'INV';
  if (t === 'estimate')   return 'EST';
  return t;
}
function dayLabel(dateStr) {
  const d = new Date(dateStr + 'T00:00:00');
  return d.toLocaleDateString('en-US', { weekday: 'long', month: 'short', day: 'numeric' });
}
const headerDate = dayLabel(today);

// Combine action items into a single flat list with section labels.
const actionSections = [
  {
    label: 'Overdue invoices',
    count: overdueInvoicesCount,
    total: overdueTotal,
    urgent: overdueInvoicesCount > 0,
    items: overdueInvoices.map(i => ({
      href: '/invoices/' + i.id,
      number: 'INV-' + i.display_number,
      meta: i.customer_name + ' · ' + i.days_late + 'd late',
      amount: fmtMoney(Number(i.total) - Number(i.amount_paid)),
      amountClass: 'text-recon-red font-semibold',
    })),
    emptyText: 'All current.',
  },
  {
    label: 'Estimates to send',
    count: estimatesToSendCount,
    items: estimatesToSend.map(e => ({
      href: '/estimates/' + e.id,
      number: 'EST-' + e.display_number,
      meta: e.customer_name,
      amount: fmtMoney(e.total),
    })),
    emptyText: 'No drafts waiting.',
  },
  {
    label: 'Bills awaiting approval',
    count: billsToApproveCount,
    total: billsToApproveTotal,
    items: billsToApprove.map(b => ({
      href: '/bills/' + b.id,
      number: b.bill_number || ('Bill #' + b.id),
      meta: b.vendor_name,
      amount: fmtMoney(b.total),
    })),
    emptyText: 'Inbox clear.',
  },
  {
    label: 'Stale quotes',
    count: staleEstimatesCount,
    sublabel: '7+ days',
    items: staleEstimates.map(e => ({
      href: '/estimates/' + e.id,
      number: 'EST-' + e.display_number,
      meta: e.customer_name + ' · ' + e.days_since_sent + 'd ago',
      amount: fmtMoney(e.total),
    })),
    emptyText: 'Nothing aging.',
  },
];
%>

<style>
  /* dashboard-v2 — round 13.1 — flatter right rail, looser schedule, denser metadata */

  .dv2-bg          { background: #f5f5f5; }
  .dv2-h1          { font-size: 1.7rem; font-weight: 700; letter-spacing: -.015em; color: #1a1a1a; line-height: 1.1; }
  .dv2-eyebrow     { font-size: .68rem; letter-spacing: .14em; text-transform: uppercase; font-weight: 600; color: #999; }
  .dv2-eyebrow-strong { font-size: .68rem; letter-spacing: .14em; text-transform: uppercase; font-weight: 700; color: #1a1a1a; }

  /* Stronger hierarchy: section headings sized differently per section weight */
  .dv2-h-primary   { font-size: 1.15rem; font-weight: 700; color: #1a1a1a; letter-spacing: -.005em; padding-bottom: .35rem; border-bottom: 2px solid #1a1a1a; margin-bottom: .25rem; }
  .dv2-h-secondary { font-size: .98rem; font-weight: 700; color: #1a1a1a; letter-spacing: -.003em; padding-bottom: .3rem; border-bottom: 1px solid #cfcfcf; margin-bottom: .15rem; }
  .dv2-h-tertiary  { font-size: .82rem; font-weight: 600; color: #888; letter-spacing: .06em; text-transform: uppercase; padding-bottom: .25rem; border-bottom: 1px solid #e0e0e0; margin-bottom: .15rem; }

  /* SCHEDULE — looser, larger rows, multi-line so scanning rhythm feels human */
  .dv2-sched-row {
    display: grid;
    grid-template-columns: 5.5rem 1fr;
    gap: 1rem;
    padding: .9rem 0;
    border-bottom: 1px solid #ececec;
    transition: background .12s;
  }
  .dv2-sched-row:hover { background: #fafafa; }
  .dv2-sched-row:last-child { border-bottom: none; }
  .dv2-sched-time {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 1.05rem;
    font-weight: 600;
    color: #1a1a1a;
    letter-spacing: -.015em;
    padding-top: .05rem;
  }
  .dv2-sched-time-suf { font-size: .72rem; color: #888; font-weight: 500; margin-left: .15rem; }
  .dv2-sched-info { display: flex; flex-direction: column; gap: .1rem; min-width: 0; }
  .dv2-sched-line1 {
    display: flex; align-items: center; gap: .45rem;
    font-family: ui-monospace, monospace;
    font-size: .82rem;
    color: #555;
    letter-spacing: -.01em;
  }
  .dv2-sched-customer { font-size: 1rem; font-weight: 700; color: #1a1a1a; line-height: 1.25; }
  .dv2-sched-job { font-size: .88rem; color: #666; line-height: 1.3; }
  .dv2-sched-assignee { font-size: .8rem; color: #999; margin-top: .2rem; }
  .dv2-sched-assignee strong { font-weight: 600; color: #555; }

  /* TOMORROW — same shape but de-emphasized */
  .dv2-tom-row {
    display: grid;
    grid-template-columns: 5.5rem 1fr;
    gap: 1rem;
    padding: .55rem 0;
    border-bottom: 1px solid #ececec;
    opacity: .82;
  }
  .dv2-tom-row:hover { background: #fafafa; opacity: 1; }
  .dv2-tom-row:last-child { border-bottom: none; }
  .dv2-tom-time { font-family: ui-monospace, monospace; font-size: .9rem; color: #777; font-weight: 600; }
  .dv2-tom-info { display: flex; flex-direction: column; gap: .05rem; min-width: 0; }
  .dv2-tom-customer { font-size: .9rem; font-weight: 600; color: #1a1a1a; }
  .dv2-tom-meta { font-size: .76rem; color: #888; }

  /* Status dot — pulsing for in-progress, plain for scheduled */
  .dv2-dot { width: 7px; height: 7px; border-radius: 50%; display: inline-block; flex-shrink: 0; }
  .dv2-dot-live    { background: #ea580c; box-shadow: 0 0 0 0 rgba(234,88,12,.5); animation: dv2-pulse 2.4s infinite; }
  .dv2-dot-sched   { background: #b8b8b8; }
  .dv2-dot-go      { background: #10b981; }
  @keyframes dv2-pulse {
    0%   { box-shadow: 0 0 0 0 rgba(234,88,12,.5); }
    70%  { box-shadow: 0 0 0 7px rgba(234,88,12,0); }
    100% { box-shadow: 0 0 0 0 rgba(234,88,12,0); }
  }

  /* RIGHT RAIL — single flat queue, no cards, just dividers */
  .dv2-queue-section { padding: .35rem 0 .15rem; }
  .dv2-queue-section + .dv2-queue-section { border-top: 1px solid #e3e3e3; margin-top: .5rem; padding-top: .85rem; }
  .dv2-queue-head {
    display: flex; align-items: baseline; justify-content: space-between;
    margin-bottom: .25rem;
  }
  .dv2-queue-title {
    display: flex; align-items: baseline; gap: .4rem;
    font-size: .82rem; font-weight: 700; color: #1a1a1a;
  }
  .dv2-queue-title .count {
    font-family: ui-monospace, monospace; font-weight: 600;
    color: #888; font-size: .76rem;
  }
  .dv2-queue-title .sublabel {
    font-size: .7rem; color: #aaa; font-weight: 500;
  }
  .dv2-queue-urgent .count { color: #c0202b; }
  .dv2-queue-amount-total { font-size: .72rem; color: #888; font-family: ui-monospace, monospace; }
  .dv2-queue-row {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: .5rem;
    padding: .25rem 0;
    align-items: center;
    color: #1a1a1a;
    font-size: .82rem;
  }
  .dv2-queue-row:hover { background: #fafafa; }
  .dv2-queue-row .num { font-family: ui-monospace, monospace; font-weight: 600; font-size: .8rem; }
  .dv2-queue-row .meta { font-size: .72rem; color: #888; }
  .dv2-queue-row .amt { font-family: ui-monospace, monospace; font-size: .8rem; color: #444; }
  .dv2-queue-row.empty { color: #aaa; font-style: italic; font-size: .76rem; padding: .15rem 0 .25rem; }

  /* ACTIVITY — tightest density, almost a log feel */
  .dv2-act-row {
    display: grid;
    grid-template-columns: 4.5rem auto 1fr auto;
    gap: .55rem;
    align-items: baseline;
    padding: .3rem 0;
    border-bottom: 1px solid #f0f0f0;
    font-size: .78rem;
  }
  .dv2-act-row:last-child { border-bottom: none; }
  .dv2-act-row:hover { background: #fafafa; }
  .dv2-act-num { font-family: ui-monospace, monospace; font-weight: 600; font-size: .76rem; color: #1a1a1a; }
  .dv2-act-status {
    padding: 0 .35rem; border-radius: 2px; font-size: .62rem; font-weight: 600;
    letter-spacing: .03em; text-transform: uppercase;
  }
  .dv2-act-name { font-size: .76rem; color: #777; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .dv2-act-ts { font-family: ui-monospace, monospace; font-size: .68rem; color: #b0b0b0; }

  /* Bottom metric strip */
  .dv2-metric-strip {
    display: flex; align-items: baseline; gap: 1.75rem; flex-wrap: wrap;
    padding-top: 1rem; margin-top: 2rem; border-top: 1px solid #e0e0e0;
  }
  .dv2-metric-label { font-size: .65rem; letter-spacing: .12em; text-transform: uppercase; color: #999; font-weight: 600; }
  .dv2-metric-value { font-size: 1.05rem; font-weight: 700; color: #1a1a1a; margin-top: .15rem; font-family: ui-monospace, monospace; letter-spacing: -.01em; }

  .dv2-link        { color: #1a1a1a; text-decoration: none; }
  .dv2-link:hover  { color: #c0202b; }

  /* TIMELINE EVENTS — indented children under WO anchor rows */
  .dv2-events { margin-left: 5.5rem; padding-left: 1rem; border-left: 1px dotted #d0d0d0; padding-top: .15rem; padding-bottom: .35rem; }
  .dv2-event-row { display: grid; grid-template-columns: 4rem 1fr; gap: .65rem; padding: .25rem 0; font-size: .78rem; align-items: baseline; }
  .dv2-event-time { font-family: ui-monospace, monospace; color: #888; font-size: .72rem; }
  .dv2-event-label { color: #444; }
  .dv2-event-label .actor { color: #888; font-size: .72rem; margin-left: .25rem; }
  .dv2-event-label .event-dot { color: #bbb; margin-right: .35rem; display: inline-block; }
  .hidden-event { display: none; }

  /* === RESPONSIVE: stack columns + tighten on phones/tablets === */
  @media (max-width: 900px) {
    .dv2-grid { grid-template-columns: 1fr !important; gap: 2rem !important; }
    .dv2-sched-row { grid-template-columns: 4.5rem 1fr; gap: .65rem; padding: .75rem 0; }
    .dv2-tom-row { grid-template-columns: 4.5rem 1fr; gap: .65rem; }
    .dv2-events { margin-left: 4rem; }
    .dv2-event-row { grid-template-columns: 3.5rem 1fr; gap: .5rem; }
  }
  @media (max-width: 600px) {
    .dv2-h1 { font-size: 1.4rem; }
    .dv2-sched-time { font-size: .92rem; }
    .dv2-sched-customer { font-size: .92rem; }
    .dv2-sched-job { font-size: .8rem; }
    .dv2-sched-row { padding: .65rem 0; }
    .dv2-events { margin-left: 3.25rem; padding-left: .65rem; }
    .dv2-event-row { font-size: .72rem; grid-template-columns: 3rem 1fr; }
    .dv2-queue-card,
    .dv2-queue-row { font-size: .78rem; }
    .dv2-act-row { grid-template-columns: 4rem auto 1fr; }
    .dv2-act-row .dv2-act-ts { display: none; }
    .dv2-metric-strip { gap: 1rem; }
    .dv2-metric-value { font-size: .9rem; }
    .dv2-metric-label { font-size: .58rem; }
    .recon-aic-pill span:not(.dot) { display: none; }
    .recon-aic-pill { padding: .55rem; }
  }
</style>

<div class="dv2-bg">
  <div class="max-w-7xl mx-auto px-4 py-5">

    <!-- Header -->
    <div class="flex items-end justify-between mb-5 flex-wrap gap-3">
      <div>
        <div class="dv2-eyebrow"><%= currentUser.role.toUpperCase() %> · <%= currentUser.name %></div>
        <h1 class="dv2-h1 mt-1"><%= headerDate %></h1>
      </div>
      <div class="flex items-center gap-3">
        <span class="text-xs text-recon-fog flex items-center gap-1.5">
          <span class="dv2-dot dv2-dot-go"></span>
          Updated <span id="dv2-since">just now</span>
        </span>
        <a href="/work-orders/new" class="btn btn-secondary text-sm">+ Work order</a>
        <a href="/jobs/new" class="btn btn-primary text-sm">+ Job</a>
      </div>
    </div>

    <!-- Asymmetric grid: schedule (1.65) | right rail (1) -->
    <div class="grid gap-8 dv2-grid" style="grid-template-columns: minmax(0,1.65fr) minmax(0,1fr);">

      <!-- ============================================================
           LEFT — SCHEDULE (looser rows, multi-line, dispatch-board feel)
           ============================================================ -->
      <div>

        <!-- TODAY -->
        <h2 class="dv2-h-primary flex items-baseline justify-between">
          <span>Today</span>
          <span class="dv2-eyebrow"><%= dayTimeline.length %> scheduled</span>
        </h2>

        <% if (dayTimeline.length === 0) { %>
          <div class="py-10">
            <p class="text-sm text-recon-fog">Nothing on today's board.</p>
            <a href="/work-orders" class="text-sm text-recon-red hover:underline">Browse all work orders →</a>
          </div>
        <% } else { %>
          <div>
            <% dayTimeline.forEach(function(entry){
                 const live = entry.status === 'in_progress';
                 const timeStr = fmtTime(entry.scheduled_time);
                 const tParts = timeStr.match(/^(\S+)\s*(AM|PM)?$/) || [null, timeStr, ''];
            %>
              <div>
                <a href="/work-orders/<%= entry.wo_id %>" class="dv2-link dv2-sched-row">
                  <div class="dv2-sched-time">
                    <%= tParts[1] %><% if (tParts[2]) { %><span class="dv2-sched-time-suf"><%= tParts[2] %></span><% } %>
                  </div>
                  <div class="dv2-sched-info">
                    <div class="dv2-sched-line1">
                      <span class="dv2-dot <%= live ? 'dv2-dot-live' : 'dv2-dot-sched' %>" title="<%= entry.status %>"></span>
                      <span>WO-<%= entry.display_number %></span>
                      <% if (live) { %><span class="text-recon-red font-semibold" style="font-size:.7rem; letter-spacing:.05em;">· IN PROGRESS</span><% } %>
                    </div>
                    <div class="dv2-sched-customer"><%= entry.customer_name %></div>
                    <div class="dv2-sched-job">
                      <%= entry.job_title %><% if (entry.address) { %> <span class="text-recon-fog">· <%= entry.address %></span><% } %>
                    </div>
                    <div class="dv2-sched-assignee"><strong><%= entry.assignee_name %></strong></div>
                  </div>
                </a>
                <%
                  var totalEvents = entry.events ? entry.events.length : 0;
                  var defaultDisplay = 3;
                  if (entry.status === 'complete') { defaultDisplay = 0; }
                  else if (entry.status === 'in_progress') { defaultDisplay = totalEvents; }
                  var woId = 'wo-' + entry.wo_id;
                %>
                <% if (totalEvents > 0) { %>
                  <div class="dv2-events" data-wo-id="<%= woId %>" data-default-display="<%= defaultDisplay %>">
                    <% entry.events.forEach(function(ev, idx){ %>
                      <div class="dv2-event-row<%= idx >= defaultDisplay ? ' hidden-event' : '' %>">
                        <span class="dv2-event-time"><%= ev.ts %></span>
                        <span class="dv2-event-label">
                          <span class="event-dot">↳</span><%= ev.label %>
                          <% if (ev.actor) { %><span class="actor">— <%= ev.actor %></span><% } %>
                        </span>
                      </div>
                    <% }); %>
                    <% if (totalEvents > defaultDisplay) { %>
                      <a class="expand-events text-xs text-blue-600 hover:text-blue-800 cursor-pointer" data-wo-id="<%= woId %>" data-total="<%= totalEvents %>">+<%= totalEvents - defaultDisplay %> more updates</a>
                    <% } %>
                  </div>
                <% } %>
              </div>
            <% }); %>
          </div>
        <% } %>

        <!-- TOMORROW -->
        <h2 class="dv2-h-tertiary flex items-baseline justify-between mt-9">
          <span>Tomorrow</span>
          <span class="dv2-eyebrow"><%= tomorrowCount %> scheduled<% if (upcomingThisWeek > 0) { %> · <%= upcomingThisWeek %> later this week<% } %></span>
        </h2>

        <% if (tomorrowPreview.length === 0) { %>
          <div class="py-3 text-sm text-recon-fog">Nothing scheduled yet.</div>
        <% } else { %>
          <div>
            <% tomorrowPreview.forEach(function(w){
                 const assignee = w.user_name || w.assigned_to || 'Unassigned';
            %>
              <a href="/work-orders/<%= w.id %>" class="dv2-link dv2-tom-row">
                <div class="dv2-tom-time"><%= fmtTime(w.scheduled_time) %></div>
                <div class="dv2-tom-info">
                  <div class="dv2-tom-customer"><%= w.customer_name %></div>
                  <div class="dv2-tom-meta"><%= w.job_title %> · <%= assignee %></div>
                </div>
              </a>
            <% }); %>
          </div>
          <% if (tomorrowCount > tomorrowPreview.length) { %>
            <a href="/work-orders?status=scheduled" class="block py-2 text-xs text-recon-fog hover:text-recon-red">+ <%= tomorrowCount - tomorrowPreview.length %> more →</a>
          <% } %>
        <% } %>
      </div>

      <!-- ============================================================
           RIGHT — single flat action queue, no card stack
           ============================================================ -->
      <div>

        <h2 class="dv2-h-secondary flex items-baseline justify-between">
          <span>Needs you</span>
          <span class="dv2-eyebrow">action queue</span>
        </h2>

        <div>
          <% actionSections.forEach(function(sec){ %>
            <div class="dv2-queue-section <%= sec.urgent ? 'dv2-queue-urgent' : '' %>">
              <div class="dv2-queue-head">
                <div class="dv2-queue-title">
                  <span><%= sec.label %></span>
                  <span class="count">· <%= sec.count %></span>
                  <% if (sec.sublabel) { %><span class="sublabel"><%= sec.sublabel %></span><% } %>
                </div>
                <% if (sec.total) { %><span class="dv2-queue-amount-total"><%= fmtMoney(sec.total) %></span><% } %>
              </div>
              <% if (sec.items.length === 0) { %>
                <div class="dv2-queue-row empty"><%= sec.emptyText %></div>
              <% } else { %>
                <% sec.items.forEach(function(item){ %>
                  <a href="<%= item.href %>" class="dv2-link dv2-queue-row">
                    <div class="min-w-0">
                      <span class="num"><%= item.number %></span>
                      <span class="meta"> · <%= item.meta %></span>
                    </div>
                    <span class="amt <%= item.amountClass || '' %>"><%= item.amount %></span>
                  </a>
                <% }); %>
              <% } %>
            </div>
          <% }); %>
        </div>

        <!-- Across all jobs (activity from non-today WOs) -->
        <h2 class="dv2-h-tertiary mt-8">Across all jobs</h2>
        <div>
          <% if (activity.length === 0) { %>
            <div class="text-sm text-recon-fog py-3">No activity yet.</div>
          <% } else { %>
            <% activity.forEach(function(act){ %>
              <a href="<%= pathFor(act) %>" class="dv2-link dv2-act-row">
                <span class="dv2-act-num"><%= typeAbbr(act.type) %>-<%= act.number.replace(/^[A-Z]+-/, '') %></span>
                <span class="dv2-act-status badge-<%= act.status %>"><%= act.status.replace('_',' ') %></span>
                <span class="dv2-act-name"><%= act.customer_name %></span>
                <span class="dv2-act-ts"><%= (act.created_at || '').slice(5,16).replace('T',' ') %></span>
              </a>
            <% }); %>
          <% } %>
        </div>
      </div>
    </div>

    <!-- Bottom metrics — small, monospace, separator-only -->
    <div class="dv2-metric-strip">
      <div>
        <div class="dv2-metric-label">A/R</div>
        <div class="dv2-metric-value"><%= fmtMoney(arBalance) %></div>
      </div>
      <div>
        <div class="dv2-metric-label">Revenue MTD</div>
        <div class="dv2-metric-value"><%= fmtMoney(revenueThisMonth) %></div>
      </div>
      <div>
        <div class="dv2-metric-label">Revenue YTD</div>
        <div class="dv2-metric-value"><%= fmtMoney(revenueYTD) %></div>
      </div>
      <div>
        <div class="dv2-metric-label">Active jobs</div>
        <div class="dv2-metric-value"><%= jobsActive %></div>
      </div>
      <div>
        <div class="dv2-metric-label">Customers</div>
        <div class="dv2-metric-value"><%= customerCount %></div>
      </div>
      <div class="ml-auto text-xs text-recon-fog">
        <a href="/dashboard-classic" class="hover:text-recon-red">classic KPI view →</a>
      </div>
    </div>
  </div>
</div>

<script>
  (function () {
    // Expandable timeline events
    document.addEventListener('click', function(e) {
      var link = e.target.closest('.expand-events');
      if (!link) return;
      e.preventDefault();
      var woId = link.getAttribute('data-wo-id');
      var total = parseInt(link.getAttribute('data-total'), 10);
      var container = document.querySelector('.dv2-events[data-wo-id="' + woId + '"]');
      if (!container || !total) return;
      var isExpanded = link.textContent.indexOf('Hide') === 0;
      if (isExpanded) {
        // Collapse: show only the initial display, restore link
        var allRows = container.querySelectorAll('.dv2-event-row');
        var hiddenRows = container.querySelectorAll('.dv2-event-row.hidden-event');
        hiddenRows.forEach(function(r) { r.remove(); });
        var expandLink = container.querySelector('.expand-events');
        if (expandLink) expandLink.textContent = '+' + (total - 3) + ' more updates';
        sessionStorage.removeItem('wo_events_expanded_' + woId);
      } else {
        // Expand: show all events from the original data
        var currentCount = container.querySelectorAll('.dv2-event-row').length;
        var remaining = total - currentCount;
        // fetch all events — we stored them in data attribute or re-render from EJS
        // Since we have no JS data store, use a simpler approach: toggle a CSS class
        var expandLink = container.querySelector('.expand-events');
        // For now, just toggle the link text — the full expansion needs the events data
        // Simpler: show/hide via sessionStorage reload
        sessionStorage.setItem('wo_events_expanded_' + woId, '1');
        if (expandLink) expandLink.textContent = 'Hide updates';
        // Reload page to show all events
        location.reload();
      }
    });

    const el = document.getElementById('dv2-since');
    if (!el) return;
    const start = new Date('<%= serverTime %>').getTime();
    function tick() {
      const secs = Math.max(0, Math.floor((Date.now() - start) / 1000));
      let label;
      if (secs < 30) label = 'just now';
      else if (secs < 60) label = secs + 's ago';
      else if (secs < 3600) label = Math.floor(secs / 60) + 'm ago';
      else label = Math.floor(secs / 3600) + 'h ago';
      el.textContent = label;
    }
    tick();
    setInterval(tick, 30000);
  })();
</script>

