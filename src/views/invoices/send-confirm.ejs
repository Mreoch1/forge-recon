<%- include('../layouts/header', { title: title, currentUser: currentUser, flash: flash, activeNav: activeNav }) %>

<%
function fmt(n) { const num = Number(n); return isFinite(num) ? num.toFixed(2) : '0.00'; }
const toValue = form && form.to_email ? form.to_email : '';
const ccValue = form && form.cc_emails ? form.cc_emails : '';
const balance = (Number(invoice.total) || 0) - (Number(invoice.amount_paid) || 0);
%>

<div class="document-shell">
  <div class="mb-4">
    <a href="/invoices/<%= invoice.id %>" class="text-sm text-recon-fog hover:text-recon-red">&larr; <%= invoice.display_number %></a>
  </div>

  <div class="flex items-baseline justify-between mb-6 flex-wrap gap-2">
    <div>
      <h1 class="page-h1">Confirm invoice email</h1>
      <p class="page-sub">Review the recipient list before sending <%= invoice.display_number %>.</p>
    </div>
    <div class="document-actions">
      <a href="/invoices/<%= invoice.id %>" class="btn btn-secondary">Cancel</a>
    </div>
  </div>

  <div class="card p-0 overflow-hidden">
    <div class="p-5 border-b border-recon-border">
      <div class="grid gap-4 md:grid-cols-4">
        <div>
          <div class="text-xs uppercase tracking-wide text-recon-fog font-semibold">Invoice</div>
          <div class="font-semibold"><%= invoice.display_number %></div>
        </div>
        <div>
          <div class="text-xs uppercase tracking-wide text-recon-fog font-semibold">Customer</div>
          <div class="font-semibold"><%= invoice.customer_name || 'Customer' %></div>
        </div>
        <div>
          <div class="text-xs uppercase tracking-wide text-recon-fog font-semibold">Total</div>
          <div class="font-semibold">$<%= fmt(invoice.total) %></div>
        </div>
        <div>
          <div class="text-xs uppercase tracking-wide text-recon-fog font-semibold">Balance due</div>
          <div class="font-semibold">$<%= fmt(balance) %></div>
        </div>
      </div>
    </div>

    <form action="/invoices/<%= invoice.id %>/send" method="post" class="p-5 space-y-5">
      <div>
        <label for="to_email" class="label">To</label>
        <input id="to_email" name="to_email" type="email" class="input" value="<%= toValue %>" placeholder="customer@example.com" required>
        <% if (errors && errors.to_email) { %>
          <div class="text-sm text-recon-red mt-1"><%= errors.to_email %></div>
        <% } %>
      </div>

      <div>
        <label for="cc_emails" class="label">Additional recipients</label>
        <textarea id="cc_emails" name="cc_emails" class="input min-h-[96px]" placeholder="email@company.com, another@company.com"><%= ccValue %></textarea>
        <% if (errors && errors.cc_emails) { %>
          <div class="text-sm text-recon-red mt-1"><%= errors.cc_emails %></div>
        <% } %>
        <p class="text-sm text-recon-fog mt-2">Separate additional email addresses with commas or new lines.</p>
      </div>

      <div class="card p-4 text-sm text-recon-fog">
        FORGE will attach the invoice PDF and mark this invoice sent after the email is delivered or saved to the mail outbox.
      </div>

      <div class="flex justify-end gap-2">
        <a href="/invoices/<%= invoice.id %>" class="btn btn-secondary">Cancel</a>
        <button class="btn btn-primary">Confirm send</button>
      </div>
    </form>
  </div>
</div>

<%- include('../layouts/footer') %>
