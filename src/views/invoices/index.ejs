<%- include('../layouts/header', { title: title, currentUser: currentUser, flash: flash, activeNav: activeNav }) %>

<%
function fmt(n) { const num = Number(n); return isFinite(num) ? num.toFixed(2) : '0.00'; }
function isOverdue(inv) {
  if (inv.status !== 'sent') return false;
  if (!inv.due_date) return false;
  return new Date(String(inv.due_date).slice(0,10)) < new Date();
}
const pageTotal = invoices.reduce(function(s, i){ return s + (Number(i.total) || 0); }, 0);
const pageBalance = invoices.reduce(function(s, i){ return s + ((Number(i.total) || 0) - (Number(i.amount_paid) || 0)); }, 0);
const sentCount = invoices.filter(function(i){ return i.status === 'sent' || i.status === 'draft'; }).length;
const paidCount = invoices.filter(function(i){ return i.status === 'paid' || i.status === 'billing_complete'; }).length;
const isAdmin = currentUser && currentUser.role === 'admin';
const manualStatuses = ['draft', 'sent', 'overdue', 'billing_complete'];
%>

<div class="ops-shell">
  <div class="ops-header">
    <div class="ops-title-block">
      <h1 class="page-h1">Invoices</h1>
      <p class="page-sub"><%= total %> total<% if (q) { %> &middot; "<%= q %>"<% } %><% if (status) { %> &middot; <%= status %><% } %></p>
    </div>
  </div>

  <div class="ops-summary">
    <div class="ops-summary-item"><div class="ops-summary-label">Total</div><div class="ops-summary-value"><%= total %></div><div class="ops-summary-meta">invoices</div></div>
    <div class="ops-summary-item"><div class="ops-summary-label">Open / draft</div><div class="ops-summary-value"><%= sentCount %></div><div class="ops-summary-meta">shown on page</div></div>
    <div class="ops-summary-item"><div class="ops-summary-label">Paid</div><div class="ops-summary-value"><%= paidCount %></div><div class="ops-summary-meta">shown on page</div></div>
    <div class="ops-summary-item"><div class="ops-summary-label">Balance</div><div class="ops-summary-value">$<%= fmt(pageBalance) %></div><div class="ops-summary-meta">$<%= fmt(pageTotal) %> invoiced shown</div></div>
  </div>

  <form method="get" action="/invoices" class="list-utility-bar">
    <input type="text" name="q" value="<%= q %>" placeholder="Search number, job, customer..." class="list-search">
    <select name="status" class="list-filter">
      <option value="">All statuses</option>
      <% statuses.forEach(function(s){ %>
        <option value="<%= s %>" <%= status === s ? 'selected' : '' %>><%= s.replace('_',' ') %></option>
      <% }); %>
    </select>
    <button type="submit" class="btn btn-secondary">Filter</button>
    <% if (q || status) { %>
      <a href="/invoices" class="list-clear">Clear</a>
    <% } %>
  </form>

  <form id="batch-form" action="/invoices/batch-status" method="post">
  <input type="hidden" name="return_to" value="/invoices<%= (q || status || page > 1) ? '?' + ['page='+page, q ? 'q='+encodeURIComponent(q) : '', status ? 'status='+encodeURIComponent(status) : ''].filter(Boolean).join('&') : '' %>">
  <div class="ops-panel ops-table">
    <div class="ops-panel-head">
      <div class="ops-panel-title">Invoice register</div>
      <div class="flex items-center gap-2 flex-wrap justify-end">
        <% if (isAdmin) { %>
          <select name="status" class="list-filter" id="batch-status-select" title="Batch status" disabled>
            <option value="">Change status...</option>
            <% manualStatuses.forEach(function(s){ %>
              <option value="<%= s %>"><%= s.replace(/_/g, ' ') %></option>
            <% }); %>
          </select>
          <button type="submit" class="btn btn-secondary text-sm" id="batch-status-btn" disabled
                  onclick="return confirm('Change status for selected invoices?');">Apply status</button>
        <% } %>
        <button type="submit" formaction="/invoices/batch-csv" class="btn btn-ghost text-sm" id="batch-csv-btn" disabled
                title="Download selected invoices as CSV for QuickBooks import">Download CSV</button>
        <span class="text-xs text-recon-fog"><span id="selected-count">0</span> selected &middot; <%= invoices.length %> shown</span>
      </div>
    </div>
    <div class="ops-panel-body">
    <% if (invoices.length === 0) { %>
      <div class="ops-empty">
        <% if (q || status) { %>
          No invoices match. <a href="/invoices" class="text-recon-red underline">Clear</a>
        <% } else { %>
          No invoices yet. Convert an accepted <a href="/estimates" class="text-recon-red underline">estimate</a>.
        <% } %>
      </div>
    <% } else { %>
      <table class="data">
        <thead>
          <tr>
            <th class="w-10"><input type="checkbox" id="select-all" class="cursor-pointer"></th>
            <th>Number</th>
            <th>Work order</th>
            <th>Customer</th>
            <th>Status</th>
            <th class="text-right">Total</th>
            <th class="text-right">Paid</th>
            <th class="text-right">Balance</th>
            <th>Due</th>
            <th>QuickBooks</th>
          </tr>
        </thead>
        <tbody>
          <% invoices.forEach(function(i){ %>
            <% const balance = (Number(i.total)||0) - (Number(i.amount_paid)||0); %>
            <% const showStatus = isOverdue(i) ? 'overdue' : i.status; %>
            <% const invStatusHint = showStatus === 'sent' ? 'Invoice sent, awaiting payment or QuickBooks completion.'
                                  : showStatus === 'paid' ? 'Full payment recorded. Read-only.'
                                  : showStatus === 'billing_complete' ? 'Invoice sent and synced/closed in billing workflow.'
                                  : showStatus === 'void' ? 'Cancelled. Does not count toward AR.'
                                  : showStatus === 'overdue' ? 'Past due date and not paid. Send a reminder.'
                                  : showStatus; %>
            <% const showStatusLabel = String(showStatus).replace(/_/g, ' '); %>
            <% const qbSynced = i.qb_synced_at ? true : false; %>
            <tr class="row-link" data-href="/invoices/<%= i.id %>">
              <td class="w-10"><input type="checkbox" name="invoice_ids" value="<%= i.id %>" class="row-checkbox cursor-pointer"></td>
              <td class="font-medium">INV-<%= i.wo_display_number %></td>
              <td>WO-<%= i.wo_display_number %></td>
              <td><%= i.customer_name %></td>
              <td><span class="badge badge-<%= showStatus %>" title="<%= invStatusHint %>"><%= showStatusLabel %></span></td>
              <td class="text-right">$<%= fmt(i.total) %></td>
              <td class="text-right">$<%= fmt(i.amount_paid) %></td>
              <td class="text-right font-medium <%= balance > 0 ? 'text-recon-red' : 'text-recon-fog' %>">$<%= fmt(balance) %></td>
              <td><%= (i.due_date || '—').slice(0,10) %></td>
              <td>
                <% if (qbSynced) { %>
                  <span class="text-xs text-green-700 font-medium">✓ Synced</span>
                <% } else { %>
                  <span class="text-xs text-recon-fog">—</span>
                <% } %>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    <% } %>
    </div>
  </div>
  </form>

  <% if (totalPages > 1) { %>
    <div class="flex items-center justify-center gap-2 mt-4">
      <% for (let p = 1; p <= totalPages; p++) { %>
        <% const qs = ['page='+p]; if (q) qs.push('q='+encodeURIComponent(q)); if (status) qs.push('status='+encodeURIComponent(status)); %>
        <% if (p === page) { %><span class="btn btn-primary"><%= p %></span>
        <% } else { %><a href="/invoices?<%= qs.join('&') %>" class="btn btn-ghost"><%= p %></a><% } %>
      <% } %>
    </div>
  <% } %>
</div>

<script>
window.forgeInitInvoiceBatchActions = function(root){
  var scope = root || document;
  var batchForm = scope.querySelector('#batch-form');
  if (!batchForm || batchForm.dataset.batchReady === '1') return;
  batchForm.dataset.batchReady = '1';

  var selectAll = batchForm.querySelector('#select-all');
  var checkboxes = batchForm.querySelectorAll('.row-checkbox');
  var csvBtn = batchForm.querySelector('#batch-csv-btn');
  var statusSelect = batchForm.querySelector('#batch-status-select');
  var statusBtn = batchForm.querySelector('#batch-status-btn');
  var countEl = batchForm.querySelector('#selected-count');

  if (!selectAll || !checkboxes.length) return;

  selectAll.addEventListener('change', function(){
    checkboxes.forEach(function(cb){ cb.checked = selectAll.checked; });
    updateBatchActions();
  });

  checkboxes.forEach(function(cb){
    cb.addEventListener('change', updateBatchActions);
  });

  if (statusSelect) {
    statusSelect.addEventListener('change', updateBatchActions);
  }

  function updateBatchActions() {
    var checked = Array.from(checkboxes).filter(function(cb){ return cb.checked; }).length;
    if (countEl) countEl.textContent = checked;
    if (csvBtn) csvBtn.disabled = checked === 0;
    if (statusSelect) statusSelect.disabled = checked === 0;
    if (statusBtn) statusBtn.disabled = checked === 0 || !statusSelect.value;
  }
};
window.forgeInitInvoiceBatchActions(document);
</script>

<%- include('../layouts/footer') %>
