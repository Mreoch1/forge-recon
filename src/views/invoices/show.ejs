<%- include('../layouts/header', { title: title, currentUser: currentUser, flash: flash, activeNav: activeNav }) %>

<%
function fmt(n) { const num = Number(n); return isFinite(num) ? num.toFixed(2) : '0.00'; }
const balance = (Number(invoice.total) || 0) - (Number(invoice.amount_paid) || 0);
const showCosts = (typeof canSeePrices === 'undefined') ? true : canSeePrices;
const costTotal = Number(invoice.cost_total) || 0;
const subtotal = Number(invoice.subtotal) || 0;
const margin = subtotal - costTotal;
const marginPct = subtotal > 0 ? ((margin / subtotal) * 100).toFixed(1) : '&mdash;';
%>

<div class="max-w-7xl mx-auto px-4 py-6">
  <div class="mb-4">
    <a href="/invoices" class="text-sm text-recon-fog hover:text-recon-red">&larr; Invoices</a>
  </div>

  <div class="flex items-baseline justify-between mb-6 flex-wrap gap-2">
    <div>
      <div class="flex items-center gap-3">
        <h1 class="page-h1"><%= invoice.display_number %></h1>
      </div>
      <p class="page-sub">
        WO: <a href="/work-orders/<%= invoice.wo_id %>" class="hover:text-recon-red">WO-<%= invoice.wo_display_number %></a>
        &middot; Estimate: <a href="/estimates/<%= invoice.estimate_id %>" class="hover:text-recon-red">EST-<%= invoice.wo_display_number %></a>
        &middot; Customer: <a href="/customers/<%= invoice.customer_id %>" class="hover:text-recon-red"><%= invoice.customer_name %></a>
      </p>
    </div>
    <div class="flex flex-wrap items-center gap-2">
      <a href="/invoices/<%= invoice.id %>/pdf" class="btn btn-ghost" target="_blank" rel="noopener"
         title="Open the invoice PDF in a new tab.">View PDF</a>

      <% if (invoice.status === 'sent' || invoice.status === 'overdue') { %>
        <span class="hidden md:inline text-recon-mist px-1" aria-hidden="true">|</span>

        <a href="/invoices/<%= invoice.id %>/edit" class="btn btn-secondary">Edit</a>
        <form action="/invoices/<%= invoice.id %>/send" method="post" class="m-0 inline">
          <button class="btn btn-secondary" title="Email this invoice to the customer billing email with the PDF attached."><%= invoice.sent_at ? 'Send again' : 'Send invoice email' %></button>
        </form>
        <button type="button" onclick="document.getElementById('mark-paid-form').classList.toggle('hidden')" class="btn btn-primary"
                title="Record a customer payment against this invoice. Supports full or partial payments.">Mark paid</button>
      <% } %>
    </div>
  </div>

  <% if (invoice.status === 'sent' || invoice.status === 'overdue') { %>
    <div id="mark-paid-form" class="card p-5 mb-6 hidden bg-green-50 border-green-200">
      <form action="/invoices/<%= invoice.id %>/mark-paid" method="post" class="flex items-end gap-3">
        <div class="flex-1">
          <label class="label" for="amount">Amount paid</label>
          <input type="number" step="0.01" min="0.01" name="amount" id="amount"
                 value="<%= balance.toFixed(2) %>" required class="input">
          <p class="text-xs text-recon-fog mt-1">Defaults to remaining balance ($<%= fmt(balance) %>). Lower amount records partial payment.</p>
        </div>
        <button type="submit" class="btn btn-primary">Record payment</button>
      </form>
    </div>
  <% } %>

  <!-- D-126: single 2-col summary table replacing AI cards + cost strip -->
  <div class="card overflow-hidden mb-6">
    <table class="data">
      <tbody>
        <tr><td class="text-xs uppercase tracking-wide text-recon-fog">Subtotal</td>
            <td class="text-right font-semibold">$<%= fmt(invoice.subtotal) %></td></tr>
        <tr><td class="text-xs uppercase tracking-wide text-recon-fog">Tax (<%= fmt(invoice.tax_rate) %>%)</td>
            <td class="text-right font-semibold">$<%= fmt(invoice.tax_amount) %></td></tr>
        <tr><td class="text-xs uppercase tracking-wide text-recon-fog">Total</td>
            <td class="text-right font-bold text-base">$<%= fmt(invoice.total) %></td></tr>
        <tr><td class="text-xs uppercase tracking-wide text-recon-fog">Balance Due</td>
            <td class="text-right font-bold <%= balance > 0 ? 'text-recon-red' : 'text-green-700' %>">$<%= fmt(balance) %></td></tr>
        <% if (showCosts && costTotal > 0) { %>
          <tr class="border-t border-dashed border-recon-mist"><td colspan="2" class="text-xs text-recon-fog pt-2">Internal — not shown on customer PDFs</td></tr>
          <tr><td class="text-xs uppercase tracking-wide text-recon-fog">Cost</td>
              <td class="text-right font-semibold text-recon-fog">$<%= fmt(costTotal) %></td></tr>
          <tr><td class="text-xs uppercase tracking-wide text-recon-fog">Profit</td>
              <td class="text-right font-semibold <%= margin >= 0 ? 'text-green-700' : 'text-recon-red' %>">$<%= fmt(margin) %></td></tr>
          <tr><td class="text-xs uppercase tracking-wide text-recon-fog">Margin</td>
              <td class="text-right font-semibold <%= marginPct !== '&mdash;' && parseFloat(marginPct) >= 0 ? 'text-green-700' : 'text-recon-red' %>"><%= marginPct %>%</td></tr>
        <% } %>
        <tr><td class="text-xs uppercase tracking-wide text-recon-fog">Terms</td>
            <td class="text-right font-semibold"><%= invoice.payment_terms %></td></tr>
        <tr><td class="text-xs uppercase tracking-wide text-recon-fog">Recipient</td>
            <td class="text-right font-semibold"><%= invoice.customer_billing_email || invoice.customer_email || '—' %></td></tr>
        <% if (invoice.customer_email && invoice.customer_billing_email && invoice.customer_billing_email !== invoice.customer_email) { %>
          <tr><td></td><td class="text-right text-xs text-recon-fog">(estimates to: <%= invoice.customer_email %>)</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>

  <div class="card overflow-hidden mb-6">
    <div class="px-5 py-3 border-b border-recon-mist">
      <h3 class="font-semibold">Items</h3>
    </div>
    <% if (invoice.lines.length === 0) { %>
      <div class="p-6 text-center text-recon-fog text-sm">No items.</div>
    <% } else { %>
      <table class="data">
        <thead>
          <tr>
            <th>Description</th>
            <th class="text-right">Qty</th>
            <th>Unit</th>
            <% if (showCosts) { %><th class="text-right text-recon-fog">Cost</th><% } %>
            <th class="text-right">Rate</th>
            <th class="text-right">Line $</th>
          </tr>
        </thead>
        <tbody>
          <% invoice.lines.forEach(function(li){ %>
            <tr>
              <td><%= li.description %></td>
              <td class="text-right"><%= li.quantity %></td>
              <td><%= li.unit %></td>
              <% if (showCosts) { %><td class="text-right text-recon-fog">$<%= fmt(li.cost) %></td><% } %>
              <td class="text-right">$<%= fmt(li.unit_price) %></td>
              <td class="text-right font-medium">$<%= fmt(li.line_total) %></td>
            </tr>
          <% }); %>
        </tbody>
        <tfoot class="bg-recon-cloud">
          <tr>
            <td colspan="<%= showCosts ? 5 : 4 %>" class="text-right text-sm font-medium">Subtotal</td>
            <td class="text-right font-semibold">$<%= fmt(subtotal) %></td>
          </tr>
          <% if (showCosts) { %>
            <tr>
              <td colspan="5" class="text-right text-sm font-medium text-recon-fog">Cost <span class="text-xs">(internal)</span></td>
              <td class="text-right font-semibold text-recon-fog">$<%= fmt(costTotal) %></td>
            </tr>
          <% } %>
          <tr>
            <td colspan="<%= showCosts ? 5 : 4 %>" class="text-right text-sm font-medium">Tax (<%= fmt(invoice.tax_rate) %>%)</td>
            <td class="text-right font-semibold">$<%= fmt(invoice.tax_amount) %></td>
          </tr>
          <tr>
            <td colspan="<%= showCosts ? 5 : 4 %>" class="text-right text-sm font-semibold uppercase">Total</td>
            <td class="text-right text-lg font-bold text-recon-red">$<%= fmt(invoice.total) %></td>
          </tr>
          <% if (showCosts) { %>
            <tr>
              <td colspan="5" class="text-right text-sm font-medium text-recon-fog">Margin <span class="text-xs">(internal, <%= marginPct %>%)</span></td>
              <td class="text-right font-semibold <%= margin >= 0 ? 'text-green-700' : 'text-recon-red' %>">$<%= fmt(margin) %></td>
        <% if (invoice.customer_email && invoice.customer_billing_email && invoice.customer_billing_email !== invoice.customer_email) { %>
          <tr><td></td><td class="text-right text-xs text-recon-fog">(estimates to: <%= invoice.customer_email %>)</td></tr>
        <% } %>
        <tr class="border-t border-dashed border-recon-mist"><td colspan="2" class="text-xs text-recon-fog pt-2">Dates &amp; terms</td></tr>
        <tr><td class="text-xs uppercase tracking-wide text-recon-fog">Issued</td>
            <td class="text-right font-semibold"><%= (invoice.created_at || '—').slice(0,10) %></td></tr>
        <tr><td class="text-xs uppercase tracking-wide text-recon-fog">Due</td>
            <td class="text-right font-semibold"><%= invoice.due_date ? String(invoice.due_date).slice(0,10) : '—' %></td></tr>
        <% if (invoice.sent_at) { %>
          <tr><td class="text-xs uppercase tracking-wide text-recon-fog">Sent</td>
              <td class="text-right font-semibold"><%= (invoice.sent_at || '').slice(0,10) %><% if (invoice.sent_by_name) { %> by <%= invoice.sent_by_name %><% } %><% if (invoice.sent_to_email) { %> to <%= invoice.sent_to_email %><% } %></td></tr>
        <% } %>
        <% if (invoice.paid_at) { %>
          <tr><td class="text-xs uppercase tracking-wide text-recon-fog">Paid</td>
              <td class="text-right font-semibold"><%= invoice.paid_at %></td></tr>
        <% } %>
      </tbody>
    </table>
  </div>

  <% if (invoice.notes) { %>
    <div class="card p-5 mb-6">
      <h3 class="text-sm font-semibold uppercase tracking-wide text-recon-fog mb-2">Notes</h3>
      <p class="text-sm whitespace-pre-line"><%= invoice.notes %></p>
    </div>
  <% } %>

  <% if (invoice.conditions) { %>
    <div class="card p-5 mb-6">
      <h3 class="text-sm font-semibold uppercase tracking-wide text-recon-fog mb-2">Conditions &amp; terms</h3>
      <p class="text-sm whitespace-pre-line"><%= invoice.conditions %></p>
    </div>
  <% } %>

  <% if (invoice.status !== 'paid') { %>
    <div class="card p-5 border-red-200">
      <h3 class="font-semibold text-recon-red mb-2">Danger zone</h3>
      <% if (invoice.status !== 'void') { %>
        <form action="/invoices/<%= invoice.id %>/void" method="post" class="mb-3"
              onsubmit="return confirm('Void this invoice?');">
          <button class="btn btn-danger" title="Cancel this invoice without deleting it. Removes it from AR totals but keeps history.">Void invoice</button>
        </form>
      <% } %>
      <% if (invoice.status === 'void') { %>
        <form action="/invoices/<%= invoice.id %>/delete" method="post"
              onsubmit="return confirm('Delete <%= invoice.display_number %>?');" class="m-0">
          <button type="submit" class="btn btn-danger" title="Permanently delete this void invoice.">Delete invoice</button>
        </form>
      <% } %>
    </div>
  <% } %>
</div>

<%- include('../layouts/footer') %>
