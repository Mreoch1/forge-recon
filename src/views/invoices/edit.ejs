<%- include('../layouts/header', { title: title, currentUser: currentUser, flash: flash, activeNav: activeNav }) %>

<%
const linesToRender = (invoice.lines && invoice.lines.length) ? invoice.lines : [{
  description: '', quantity: 1, unit: 'ea', unit_price: 0, cost: 0, line_total: 0,
  labor_cost: 0, material_cost: 0, markup_pct: 25
}];
const termPresets = (typeof paymentTermsPresets !== 'undefined') ? paymentTermsPresets : ['Due on receipt', 'Net 15', 'Net 30', 'Net 45', 'Net 60'];
const currentTerms = invoice.payment_terms || 'Net 30';
const termsAreCustom = termPresets.indexOf(currentTerms) === -1;
function moneyFmt(n) { const num = Number(n); return isFinite(num) ? num.toFixed(2) : '0.00'; }
function numberInputValue(n) {
  const num = Number(n);
  return isFinite(num) && num !== 0 ? n : '';
}
%>

<div class="document-edit-shell">
  <div class="mb-4">
    <a href="/invoices/<%= invoice.id %>" class="text-sm text-recon-fog hover:text-recon-red">&larr; <%= invoice.display_number %></a>
  </div>
  <h1 class="page-h1 mb-6">Edit <%= invoice.display_number %></h1>

  <form action="/invoices/<%= invoice.id %>" method="post" class="space-y-6">
    <div class="card p-5">
      <h3 class="text-sm font-semibold uppercase tracking-wide text-recon-fog mb-3">Header</h3>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div>
          <label class="label" for="payment_terms">Payment terms
            <span class="ml-1 text-recon-fog cursor-help" title="When the customer is expected to pay this invoice. Prints on the invoice PDF.">ⓘ</span>
          </label>
          <select name="payment_terms" id="payment_terms" class="input" data-payment-terms-select>
            <% termPresets.forEach(function(p){ %>
              <option value="<%= p %>" <%= currentTerms === p ? 'selected' : '' %>><%= p %></option>
            <% }); %>
            <option value="__custom" <%= termsAreCustom ? 'selected' : '' %>>Custom</option>
          </select>
          <input type="text" name="payment_terms_custom" value="<%= termsAreCustom ? currentTerms : '' %>"
                 class="input mt-2 <%= termsAreCustom ? '' : 'hidden' %>" data-payment-terms-custom
                 placeholder="Custom terms">
        </div>
        <div>
          <label class="label" for="due_date">Due date
            <span class="ml-1 text-recon-fog cursor-help" title="When payment is due. After this date the invoice flips to overdue.">ⓘ</span>
          </label>
          <input type="date" name="due_date" id="due_date"
                 value="<%= invoice.due_date ? String(invoice.due_date).slice(0,10) : '' %>"
                 class="input <%= errors.due_date ? 'border-red-500' : '' %>">
          <% if (errors.due_date) { %><p class="text-sm text-red-600 mt-1"><%= errors.due_date %></p><% } %>
        </div>
        <div>
          <label class="label" for="tax_rate">Tax rate (%)
            <span class="ml-1 text-recon-fog cursor-help" title="Sales tax percentage applied to the subtotal. Enter 0 if tax-exempt.">ⓘ</span>
          </label>
          <input type="number" step="0.001" min="0" name="tax_rate" id="tax_rate"
                 value="<%= invoice.tax_rate || 0 %>" class="input" data-totals="tax_rate">
        </div>
      </div>
    </div>

    <div class="card overflow-hidden">
      <div class="px-5 py-3 border-b border-recon-mist flex items-center justify-between">
        <h3 class="font-semibold">Items</h3>
        <button type="button" data-add-line class="btn btn-secondary text-sm">+ Add item</button>
      </div>
      <% if (errors.lines) { %>
        <div class="px-5 py-2 text-sm text-red-600 bg-red-50 border-b border-red-200"><%= errors.lines %></div>
      <% } %>
      <div class="overflow-x-auto">
        <table class="data invoice-line-table" data-line-items>
          <thead>
            <tr>
              <th title="Customer-visible description of this line item. Appears on the invoice PDF.">Description</th>
              <th class="text-right" title="How many units of this item.">Qty</th>
              <th title="Unit of measure.">Unit</th>
              <th colspan="4" class="text-center text-2xs text-recon-fog uppercase tracking-wider border-l border-recon-mist" title="These columns are INTERNAL — not shown on customer PDFs.">INTERNAL</th>
              <th class="text-right" title="Price per unit charged to the customer.">Rate</th>
              <th class="text-right" title="Qty x Rate for this line.">Line $</th>
              <th></th>
            </tr>
            <tr>
              <th></th>
              <th></th>
              <th></th>
              <th class="text-right text-recon-fog font-normal" title="Internal labor cost per unit.">Labor</th>
              <th class="text-right text-recon-fog font-normal" title="Internal materials cost per unit.">Materials</th>
              <th class="text-right text-recon-fog font-normal" title="Computed cost (labor + materials).">Cost</th>
              <th class="text-right text-recon-fog font-normal" title="Markup percentage applied to cost.">Markup %</th>
              <th></th>
              <th></th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% linesToRender.forEach(function(li, idx){ %>
              <tr class="line-row">
                <td><textarea name="lines[<%= idx %>][description]" data-field="description" rows="1" class="input"><%= li.description || '' %></textarea></td>
                <td class="text-right">
                  <input type="number" step="0.01" min="0" name="lines[<%= idx %>][quantity]" data-field="quantity"
                         value="<%= li.quantity %>" class="input text-right" style="width: 5rem;">
                </td>
                <td>
                  <select name="lines[<%= idx %>][unit]" data-field="unit" class="input">
                    <% units.forEach(function(u){ %>
                      <option value="<%= u %>" <%= li.unit === u ? 'selected' : '' %>><%= u %></option>
                    <% }); %>
                  </select>
                </td>
                <td class="text-right">
                  <input type="number" step="0.01" min="0" name="lines[<%= idx %>][labor_cost]" data-field="labor_cost"
                         value="<%= numberInputValue(li.labor_cost) %>" placeholder="0" class="input text-right" style="width: 6rem;"
                         title="Internal labor cost per unit">
                </td>
                <td class="text-right">
                  <input type="number" step="0.01" min="0" name="lines[<%= idx %>][material_cost]" data-field="material_cost"
                         value="<%= numberInputValue(li.material_cost) %>" placeholder="0" class="input text-right" style="width: 6rem;"
                         title="Internal materials cost per unit">
                </td>
                <td class="text-right">
                  <input type="number" step="0.01" min="0" name="lines[<%= idx %>][cost]" data-field="cost"
                         value="<%= moneyFmt(li.cost) %>" class="input text-right bg-recon-cloud text-recon-fog" style="width: 6rem;"
                         readonly title="Computed cost (labor + materials)">
                </td>
                <td class="text-right">
                  <input type="number" step="0.1" min="0" name="lines[<%= idx %>][markup_pct]" data-field="markup_pct"
                         value="<%= li.markup_pct !== undefined && li.markup_pct !== null ? li.markup_pct : 25 %>" class="input text-right" style="width: 5rem;"
                         title="Markup percentage applied to cost">
                </td>
                <td class="text-right">
                  <input type="number" step="0.01" min="0" name="lines[<%= idx %>][unit_price]" data-field="unit_price"
                         value="<%= moneyFmt(li.unit_price) %>" class="input text-right bg-recon-cloud text-recon-fog" style="width: 7rem;"
                         readonly title="Computed rate (cost x markup)">
                </td>
                <td class="text-right font-medium">
                  <input type="number" step="0.01" min="0" name="lines[<%= idx %>][line_total]" data-field="line_total"
                         value="<%= moneyFmt(li.line_total) %>" class="input text-right bg-recon-cloud text-recon-fog font-medium" style="width: 7rem;"
                         readonly title="Computed line total (rate x qty)">
                </td>
                <td><button type="button" data-remove-line class="text-recon-fog hover:text-recon-red text-sm">remove</button></td>
              </tr>
            <% }); %>

            <tr class="line-row hidden" data-template>
              <td><textarea name="lines[__IDX__][description]" data-field="description" rows="1" class="input"></textarea></td>
              <td class="text-right">
                <input type="number" step="0.01" min="0" name="lines[__IDX__][quantity]" data-field="quantity" value="1" class="input text-right" style="width: 5rem;">
              </td>
              <td>
                <select name="lines[__IDX__][unit]" data-field="unit" class="input">
                  <% units.forEach(function(u){ %>
                    <option value="<%= u %>" <%= u === 'ea' ? 'selected' : '' %>><%= u %></option>
                  <% }); %>
                </select>
              </td>
              <td class="text-right">
                <input type="number" step="0.01" min="0" name="lines[__IDX__][labor_cost]" data-field="labor_cost" value="" placeholder="0" class="input text-right" style="width: 6rem;">
              </td>
              <td class="text-right">
                <input type="number" step="0.01" min="0" name="lines[__IDX__][material_cost]" data-field="material_cost" value="" placeholder="0" class="input text-right" style="width: 6rem;">
              </td>
              <td class="text-right">
                <input type="number" step="0.01" min="0" name="lines[__IDX__][cost]" data-field="cost" value="0.00" class="input text-right bg-recon-cloud text-recon-fog" style="width: 6rem;" readonly>
              </td>
              <td class="text-right">
                <input type="number" step="0.1" min="0" name="lines[__IDX__][markup_pct]" data-field="markup_pct" value="25" class="input text-right" style="width: 5rem;">
              </td>
              <td class="text-right">
                <input type="number" step="0.01" min="0" name="lines[__IDX__][unit_price]" data-field="unit_price" value="0.00" class="input text-right bg-recon-cloud text-recon-fog" style="width: 7rem;" readonly>
              </td>
              <td class="text-right">
                <input type="number" step="0.01" min="0" name="lines[__IDX__][line_total]" data-field="line_total" value="0.00" class="input text-right bg-recon-cloud text-recon-fog font-medium" style="width: 7rem;" readonly>
              </td>
              <td><button type="button" data-remove-line class="text-recon-fog hover:text-recon-red text-sm">remove</button></td>
            </tr>
          </tbody>
          <tfoot class="bg-recon-cloud">
            <tr>
              <td colspan="8" class="text-right text-sm font-medium">Subtotal</td>
              <td class="text-right font-semibold">$<span data-totals="subtotal">0.00</span></td>
              <td></td>
            </tr>
            <tr>
              <td colspan="8" class="text-right text-sm font-medium">Profit / ROI %</td>
              <td class="text-right font-semibold">
                $<span data-totals="profit">0.00</span>
                <span class="text-recon-fog">/</span>
                <span data-totals="roi">--</span>
              </td>
              <td></td>
            </tr>
            <tr>
              <td colspan="8" class="text-right text-sm font-medium">Tax</td>
              <td class="text-right font-semibold">$<span data-totals="tax_amount">0.00</span></td>
              <td></td>
            </tr>
            <tr>
              <td colspan="8" class="text-right text-sm font-medium uppercase">Total</td>
              <td class="text-right text-lg font-bold text-recon-red">$<span data-totals="total">0.00</span></td>
              <td></td>
            </tr>
          </tfoot>
        </table>
      </div>
    </div>

    <div class="card p-5">
      <label class="label" for="notes">Notes
        <span class="ml-1 text-recon-fog cursor-help" title="Customer-visible notes that print on the invoice PDF. Good for payment instructions, thank-yous, or remit-to details.">ⓘ</span>
      </label>
      <textarea name="notes" id="notes" rows="3" class="input"
                placeholder="Payment instructions, thank-you, anything visible to customer."><%= invoice.notes || '' %></textarea>
    </div>

    <div class="card p-5">
      <label class="label" for="conditions">Conditions &amp; terms
        <span class="ml-1 text-recon-fog cursor-help" title="Standard conditions printed on this invoice. Defaults come from company settings but can be edited per invoice.">ⓘ</span>
      </label>
      <textarea name="conditions" id="conditions" rows="4" class="input"><%= invoice.conditions || '' %></textarea>
    </div>

    <div class="flex items-center gap-2 pt-2">
      <button type="submit" class="btn btn-primary">Save changes</button>
      <a href="/invoices/<%= invoice.id %>" class="btn btn-ghost">Cancel</a>
    </div>
  </form>
</div>

<script src="/js/line-items.js"></script>

<%- include('../layouts/footer') %>
