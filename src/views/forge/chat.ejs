<%# D-059 A1: Chat-first landing — full-screen FORGE chat view with futuristic intro panel. %>
<%- include('../layouts/header', { title: 'FORGE AI', activeNav: 'forge', currentUser }) %>

<style>
  /* D-060 + D-083 polish: Futuristic FORGE startup intro panel — cinematic, holds until user clicks */
  #forge-intro {
    min-height: 70vh;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    background:
      radial-gradient(ellipse at 20% 0%, rgba(34,211,238,0.10) 0%, transparent 55%),
      radial-gradient(ellipse at 80% 100%, rgba(99,102,241,0.10) 0%, transparent 55%),
      linear-gradient(135deg, #020617 0%, #0c1228 35%, #172554 60%, #0f172a 100%);
    border-radius: 0.75rem; padding: 3.5rem 2rem; text-align: center;
    position: relative; overflow: hidden;
    transition: opacity 0.6s ease, max-height 0.6s ease;
  }
  #forge-intro.hidden { opacity: 0; max-height: 0; padding: 0; overflow: hidden; pointer-events: none; }

  /* Scanline overlay (CRT vibe) */
  #forge-intro::after {
    content: ''; position: absolute; inset: 0;
    background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(34,211,238,0.04) 2px, rgba(34,211,238,0.04) 4px);
    pointer-events: none;
    animation: forge-scanline 3s ease-in-out infinite;
  }
  @keyframes forge-scanline { 0%, 100% { opacity: 0.1; } 50% { opacity: 0.28; } }

  /* Animated grid floor (perspective-tilted) */
  #forge-intro::before {
    content: ''; position: absolute; left: 0; right: 0; bottom: -20%;
    height: 60%;
    background:
      linear-gradient(transparent 0%, rgba(34,211,238,0.18) 100%) 0 0 / 100% 100%,
      repeating-linear-gradient(90deg, transparent 0 60px, rgba(34,211,238,0.18) 60px 61px),
      repeating-linear-gradient(0deg, transparent 0 60px, rgba(34,211,238,0.18) 60px 61px);
    transform: perspective(600px) rotateX(60deg);
    transform-origin: 50% 100%;
    mask-image: linear-gradient(to top, black, transparent);
    -webkit-mask-image: linear-gradient(to top, black, transparent);
    opacity: 0.55;
    animation: forge-grid-pulse 6s ease-in-out infinite;
    pointer-events: none;
  }
  @keyframes forge-grid-pulse {
    0%, 100% { opacity: 0.35; }
    50% { opacity: 0.7; }
  }

  /* Status pill — top right "● ONLINE" indicator */
  .forge-status {
    position: absolute; top: 1.25rem; right: 1.25rem; z-index: 3;
    display: inline-flex; align-items: center; gap: 0.4rem;
    font-family: 'SF Mono', monospace; font-size: 0.7rem; letter-spacing: 0.15em;
    color: #22d3ee; padding: 0.25rem 0.65rem; border-radius: 999px;
    background: rgba(34,211,238,0.08); border: 1px solid rgba(34,211,238,0.25);
  }
  .forge-status-dot {
    width: 8px; height: 8px; border-radius: 50%; background: #22d3ee;
    box-shadow: 0 0 8px #22d3ee;
    animation: forge-status-pulse 1.6s ease-in-out infinite;
  }
  @keyframes forge-status-pulse {
    0%, 100% { opacity: 0.4; transform: scale(0.85); }
    50% { opacity: 1; transform: scale(1.15); }
  }

  /* Boot terminal (Phase 1) */
  .forge-boot {
    font-family: 'SF Mono', 'Fira Code', monospace; font-size: 0.78rem;
    color: #67e8f9; text-align: left; max-width: 480px; width: 100%;
    min-height: 5.5rem; margin-bottom: 1.75rem;
    line-height: 1.55; letter-spacing: 0.04em;
    position: relative; z-index: 2;
  }
  .forge-boot-line { opacity: 0; transition: opacity 0.25s ease; }
  .forge-boot-line.shown { opacity: 0.85; }
  .forge-boot-line.ok { color: #4ade80; }
  .forge-boot-cursor { display: inline-block; width: 8px; background: #67e8f9; margin-left: 2px;
    animation: forge-blink-cursor 0.7s step-end infinite; }

  /* Wordmark - subtle small FORGE above greeting */
  .forge-wordmark-small {
    font-family: 'Inter', system-ui, sans-serif; font-weight: 900;
    font-size: 0.8rem; letter-spacing: 0.5em; color: #64748b;
    margin-bottom: 1rem; opacity: 0; transition: opacity 0.7s ease;
    position: relative; z-index: 2;
  }
  .forge-wordmark-small.shown { opacity: 1; }

  /* Typewriter greeting (Phase 2) — slower, bigger, more dramatic */
  .forge-typewriter {
    font-family: 'Inter', 'SF Mono', 'Fira Code', monospace;
    font-size: 2.6rem; font-weight: 700; color: #f1f5f9;
    min-height: 3.2rem; letter-spacing: 0.02em;
    border-right: 3px solid #22d3ee;
    animation: forge-blink-cursor 1s step-end infinite;
    margin-bottom: 0.5rem;
    text-shadow: 0 0 24px rgba(34,211,238,0.25);
    position: relative; z-index: 2;
  }
  @keyframes forge-blink-cursor { 50% { border-color: transparent; } }

  /* Subtitle / tagline (Phase 3+) — start hidden, JS reveals */
  .forge-subtitle, .forge-tagline {
    opacity: 0; transform: translateY(8px);
    transition: opacity 0.7s ease, transform 0.7s ease;
    position: relative; z-index: 2;
  }
  .forge-subtitle.shown, .forge-tagline.shown { opacity: 1; transform: translateY(0); }
  .forge-subtitle { font-size: 1.2rem; color: #cbd5e1; margin-bottom: 0.35rem; }
  .forge-tagline { font-size: 0.95rem; color: #94a3b8; font-style: italic; margin-bottom: 2rem; }

  /* CTA wrap (Phase 5) */
  #forge-cta-wrap {
    opacity: 0; transform: translateY(10px); transition: opacity 0.8s ease, transform 0.8s ease;
    margin-top: 1rem; display: flex; flex-direction: column; align-items: center; gap: 0.65rem;
    position: relative; z-index: 2;
  }
  #forge-cta-wrap.shown { opacity: 1; transform: translateY(0); }

  /* Pulsing Get Started button */
  #forge-get-started {
    padding: 0.95rem 2.5rem; font-size: 1.05rem; border-radius: 999px; cursor: pointer;
    border: none; background: linear-gradient(135deg, #22d3ee 0%, #06b6d4 100%);
    color: #020617; font-weight: 800; letter-spacing: 0.04em;
    transition: transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 0 0 0 rgba(34,211,238,0.7), 0 6px 24px rgba(34,211,238,0.25);
    animation: forge-cta-pulse 2.2s ease-in-out infinite;
  }
  #forge-get-started:hover { transform: translateY(-2px) scale(1.04); box-shadow: 0 0 32px rgba(34,211,238,0.6), 0 10px 28px rgba(34,211,238,0.35); }
  @keyframes forge-cta-pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(34,211,238,0.55), 0 6px 24px rgba(34,211,238,0.25); }
    50%      { box-shadow: 0 0 0 14px rgba(34,211,238,0), 0 8px 28px rgba(34,211,238,0.4); }
  }

  /* Side-by-side button row inside the CTA wrap */
  .forge-cta-row {
    display: flex; flex-wrap: wrap; align-items: center; justify-content: center;
    gap: 0.85rem; row-gap: 0.65rem;
  }

  /* Secondary CTA — outline / muted, doesn't compete with Get Started */
  .forge-cta-secondary {
    padding: 0.85rem 1.5rem; font-size: 0.9rem; border-radius: 999px;
    background: transparent; color: #94a3b8;
    border: 1px solid rgba(148,163,184,0.35);
    text-decoration: none; letter-spacing: 0.02em; font-weight: 600;
    transition: all 0.2s; cursor: pointer;
    display: inline-flex; align-items: center; gap: 0.4rem;
  }
  .forge-cta-secondary:hover {
    color: #e2e8f0; border-color: rgba(148,163,184,0.7); background: rgba(148,163,184,0.08);
    transform: translateY(-1px);
  }
  @media (max-width: 480px) {
    .forge-cta-row { flex-direction: column; gap: 0.6rem; }
    .forge-cta-secondary { width: 100%; justify-content: center; }
  }

  .forge-press-enter { font-size: 0.75rem; color: #64748b; letter-spacing: 0.05em; }
  .forge-press-enter kbd { background: #1e293b; color: #e2e8f0; padding: 2px 8px; border-radius: 4px; font-size: 0.7rem; border: 1px solid #334155; }

  /* Input wrap (Phase 6) */
  #forge-intro-input-wrap {
    margin-top: 1.5rem; width: 100%; max-width: 600px;
    opacity: 0; transform: translateY(8px); transition: opacity 0.7s ease, transform 0.7s ease;
    position: relative; z-index: 2;
  }
  #forge-intro-input-wrap.shown { opacity: 1; transform: translateY(0); }

  /* Chips */
  .forge-chips-row { display: flex; flex-wrap: wrap; gap: 0.5rem; justify-content: center; opacity: 0; transition: opacity 0.7s ease; position: relative; z-index: 2; }
  .forge-chips-row.shown { opacity: 1; }
  .forge-chip {
    display: inline-flex; align-items: center; gap: 0.35rem;
    padding: 0.5rem 1rem; border-radius: 999px; cursor: pointer;
    background: rgba(34,211,238,0.08); color: #22d3ee;
    border: 1px solid rgba(34,211,238,0.2); font-size: 0.85rem; font-weight: 500;
    transition: all 0.2s; backdrop-filter: blur(4px);
  }
  .forge-chip:hover { background: rgba(34,211,238,0.18); border-color: rgba(34,211,238,0.4); transform: translateY(-1px); }

  @media (prefers-reduced-motion: reduce) {
    #forge-intro::after, #forge-intro::before { animation: none; }
    .forge-typewriter { border-right: none; }
    .forge-status-dot, #forge-get-started { animation: none; }
    .forge-boot-line, .forge-wordmark-small, .forge-subtitle, .forge-tagline,
    #forge-cta-wrap, #forge-intro-input-wrap, .forge-chips-row
      { opacity: 1; transform: none; transition: none; }
  }

  /* D-083: Cinematic intro — FORGE wordmark reveal, full-page overlay */
  #forge-cinematic {
    position: fixed; inset: 0; z-index: 9999;
    display: none; flex-direction: column; align-items: center; justify-content: center;
    background: linear-gradient(135deg, #020617 0%, #172554 50%, #0f172a 100%);
    opacity: 0; transition: opacity 0.3s ease;
  }
  #forge-cinematic.active { display: flex; opacity: 1; }
  #forge-cinematic.exit { opacity: 0; }
  #forge-cinematic-wordmark {
    font-family: 'Inter', system-ui, sans-serif; font-weight: 900;
    font-size: clamp(3rem, 10vw, 7rem); letter-spacing: 0.12em;
    background: linear-gradient(100deg, #4a4a4a 0%, #8a8a8a 20%, #cfcfcf 35%, #ffffff 48%, #cfcfcf 60%, #8a8a8a 75%, #4a4a4a 100%);
    background-size: 250% 100%; background-position: 100% center;
    -webkit-background-clip: text; background-clip: text;
    -webkit-text-fill-color: transparent; color: transparent;
    animation: forge-cine-shine 3.5s linear infinite;
    text-shadow: 0 2px 8px rgba(255,255,255,0.1);
    transform: scale(0.6); opacity: 0;
    transition: transform 1s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.8s ease;
  }
  #forge-cinematic.active #forge-cinematic-wordmark {
    transform: scale(1); opacity: 1;
  }
  @keyframes forge-cine-shine {
    0% { background-position: 100% center; }
    100% { background-position: -150% center; }
  }
  #forge-cinematic-sub {
    font-size: clamp(1rem, 2.5vw, 1.5rem); color: #64748b;
    margin-top: 1rem; letter-spacing: 0.3em; text-transform: uppercase;
    opacity: 0; transition: opacity 0.6s ease 0.8s;
  }
  #forge-cinematic.active #forge-cinematic-sub { opacity: 1; }
  #forge-cinematic-skip {
    position: absolute; bottom: 2rem; right: 2rem;
    font-size: 0.75rem; color: #64748b; cursor: pointer; text-decoration: underline;
    opacity: 0; transition: opacity 0.3s ease 1.5s; z-index: 2;
  }
  #forge-cinematic.active #forge-cinematic-skip { opacity: 1; }
  #forge-cinematic-continue {
    margin-top: 2rem; font-size: 1rem; color: #22d3ee; cursor: pointer;
    opacity: 0; transition: opacity 0.6s ease; z-index: 2;
    animation: forge-cine-pulse 2s ease-in-out infinite;
    display: none;
  }
  #forge-cinematic-continue.shown { display: block; opacity: 1; }
  #forge-cinematic.active.clickable { cursor: pointer; }
  @keyframes forge-cine-pulse {
    0%, 100% { opacity: 0.5; }
    50% { opacity: 1; }
  }
  @media (prefers-reduced-motion: reduce) {
    #forge-cinematic-wordmark { animation: none; background-position: 50% center; transform: none; opacity: 1; }
    #forge-cinematic-sub { opacity: 1; }
    #forge-cinematic-skip { opacity: 1; }
  }
</style>

<% var firstName = 'there'; try { var nameParts = (currentUser && currentUser.name || '').split(' '); if (nameParts[0]) firstName = nameParts[0]; } catch(e){} %>
<div class="max-w-7xl mx-auto px-4 py-4">
  <!-- Intro panel with visible chat input -->
  <div id="forge-intro">
    <div class="forge-status"><span class="forge-status-dot"></span>STATUS: ONLINE</div>

    <!-- Phase 1: boot terminal -->
    <div class="forge-boot" id="forge-boot">
      <div class="forge-boot-line" data-line="0"><span style="color:#64748b">&gt;</span> FORGE_OS v0.6 &mdash; field operations engine</div>
      <div class="forge-boot-line" data-line="1"><span style="color:#64748b">&gt;</span> initializing workspace<span class="forge-boot-cursor" style="display:none"></span></div>
      <div class="forge-boot-line" data-line="2"><span style="color:#64748b">&gt;</span> loading projects, work orders, schedule</div>
      <div class="forge-boot-line ok" data-line="3"><span style="color:#64748b">&gt;</span> ready.</div>
    </div>

    <!-- Phase 2: small wordmark above greeting -->
    <div class="forge-wordmark-small" id="forge-wordmark-small">F · O · R · G · E</div>

    <!-- Phase 3: typewriter greeting -->
    <div class="forge-typewriter" id="forge-typewriter"></div>
    <div class="forge-subtitle" id="forge-subtitle">I'm FORGE, your assistant.</div>
    <div class="forge-tagline" id="forge-tagline">Ask me anything &mdash; find, schedule, create, send, or explain.</div>

    <!-- Phase 5: CTA -->
    <div id="forge-cta-wrap">
      <div class="forge-cta-row">
        <button id="forge-get-started" type="button">Get Started</button>
        <form method="post" action="/account/landing-mode" style="margin:0;">
          <input type="hidden" name="mode" value="classic">
          <input type="hidden" name="redirect_to" value="/dashboard-classic">
          <button id="forge-go-classic" type="submit" class="forge-cta-secondary">Switch to classic view</button>
        </form>
      </div>
      <span class="forge-press-enter">press <kbd>Enter</kbd> to begin</span>
    </div>

    <!-- Phase 6: chat input -->
    <div id="forge-intro-input-wrap">
      <textarea id="recon-aic-input-intro" rows="1" placeholder="Ask FORGE to find, schedule, create, send, or explain..." style="width:100%;padding:0.75rem 1rem;border-radius:8px;border:1px solid rgba(34,211,238,0.3);background:rgba(15,23,42,0.6);color:#e2e8f0;font-size:0.95rem;outline:none;resize:none;transition:all 0.2s;" class="forge-intro-input"></textarea>
    </div>
  </div>

  <!-- Chat widget (dashboard mode, hidden until intro dismissed) -->
  <div class="card" id="forge-chat-panel" style="min-height: 60vh; display: none;">
    <div id="ai-chat-root" data-mode="dashboard"></div>
  </div>
</div>

<!-- D-083: Cinematic intro overlay + audio -->
<audio id="forge-intro-audio" preload="auto" src="/sounds/forge-intro.mp3"></audio>
<div id="forge-cinematic">
  <div id="forge-cinematic-wordmark">FORGE</div>
  <div id="forge-cinematic-sub">Field Operations &amp; Resource Guidance Engine</div>
  <div id="forge-cinematic-continue">Click anywhere to continue &rarr;</div>
  <div id="forge-cinematic-skip">Skip intro &rarr;</div>
</div>

<script>
(function() {
  var introEl = document.getElementById('forge-intro');
  var chatPanel = document.getElementById('forge-chat-panel');
  var typewriterEl = document.getElementById('forge-typewriter');
  var reduceMotion = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // -----------------------------------------------------------------------
  // Cinematic intro sequence — boot → wordmark → greeting → subtitle → CTA
  // Each phase chains off the previous. Holds INDEFINITELY at the CTA.
  // No auto-dismiss, no time-based exit — only Get Started / Enter / typing
  // moves to the next screen.
  // -----------------------------------------------------------------------

  function delay(ms) { return new Promise(function(r){ setTimeout(r, reduceMotion ? Math.min(ms, 50) : ms); }); }

  function showBootLines() {
    var lines = document.querySelectorAll('#forge-boot .forge-boot-line');
    return lines.length === 0 ? Promise.resolve() : (async function(){
      var stagger = reduceMotion ? 0 : 380;
      for (var i = 0; i < lines.length; i++) {
        lines[i].classList.add('shown');
        await delay(stagger);
      }
    })();
  }

  function showEl(id, klass) {
    var el = document.getElementById(id);
    if (el) el.classList.add(klass || 'shown');
  }

  // Personalized typewriter greeting — "Hello, <firstName>." (slow + dramatic)
  var greeting = <%- JSON.stringify('Hello, ' + firstName + '.') %>;
  function typeGreeting() {
    return new Promise(function(resolve) {
      if (reduceMotion) { typewriterEl.textContent = greeting; return resolve(); }
      var i = 0;
      function step() {
        if (i >= greeting.length) return resolve();
        var ch = greeting.charAt(i);
        typewriterEl.textContent += ch;
        i++;
        // Per-char cadence + extra pause on punctuation for drama
        var base = 85 + Math.random() * 55;            // ≈85-140ms / char
        if (ch === ',') base += 280;
        if (ch === '.') base += 420;
        if (ch === ' ') base += 90;
        setTimeout(step, base);
      }
      step();
    });
  }

  async function runIntro() {
    // Phase 1: boot terminal lines stagger in
    await delay(reduceMotion ? 0 : 200);
    await showBootLines();
    await delay(reduceMotion ? 0 : 350);

    // Phase 2: small FORGE wordmark fades in above greeting
    showEl('forge-wordmark-small');
    await delay(reduceMotion ? 0 : 600);

    // Phase 3: typewriter greeting (the slow money shot)
    await typeGreeting();
    await delay(reduceMotion ? 0 : 450);

    // Phase 4: subtitle
    showEl('forge-subtitle');
    await delay(reduceMotion ? 0 : 600);

    // Phase 5: tagline
    showEl('forge-tagline');
    await delay(reduceMotion ? 0 : 550);

    // Phase 6: CTA appears with pulsing glow
    showEl('forge-cta-wrap');
    await delay(reduceMotion ? 0 : 350);

    // Phase 7: input field
    showEl('forge-intro-input-wrap');
    await delay(reduceMotion ? 0 : 250);

    // HOLD — no further action until user clicks Get Started, types, or hits Enter
    // Autofocus the input AFTER the sequence so user-typed text doesn't race the typewriter
    var introInput = document.getElementById('recon-aic-input-intro');
    if (introInput && !introInput.matches(':focus')) {
      // Only autofocus on desktop — mobile keyboard would pop up jarringly
      if (window.matchMedia && !window.matchMedia('(max-width: 768px)').matches) {
        introInput.focus();
      }
    }
  }

  // Kick off the cinematic sequence
  runIntro();

  function revealChat() {
    // D-083: Cinematic intro — show FORGE wordmark reveal, play audio, then HOLD for user click
    var introEl = document.getElementById('forge-intro');
    var cinematic = document.getElementById('forge-cinematic');
    var audio = document.getElementById('forge-intro-audio');
    var continueEl = document.getElementById('forge-cinematic-continue');

    // Hide the intro panel
    introEl.classList.add('hidden');

    // Show the cinematic overlay and play audio
    cinematic.classList.add('active');
    audio.currentTime = 0;

    function goToTutorial() {
      window.location.href = '/forge/tutorial?return=/forge';
    }

    // After audio ends (or ~5s fallback), show the "click to continue" prompt
    // HOLD — do NOT auto-redirect. User must click to proceed.
    var ready = false;
    var timeoutId = setTimeout(function() {
      ready = true;
      continueEl.classList.add('shown');
      cinematic.classList.add('clickable');
    }, 5000);

    audio.addEventListener('ended', function() {
      clearTimeout(timeoutId);
      ready = true;
      continueEl.classList.add('shown');
      cinematic.classList.add('clickable');
    }, { once: true });

    // Click anywhere on the cinematic overlay to advance
    cinematic.addEventListener('click', function onClick() {
      if (!ready) return;
      goToTutorial();
    });

    // Enter/Space also advances
    function keyHandler(e) {
      if (e.key === 'Enter' || e.key === ' ') {
        if (!ready) return;
        goToTutorial();
      }
      if (e.key === 'Escape') {
        // Esc always skips — go immediately
        goToTutorial();
      }
    }
    document.addEventListener('keydown', keyHandler);

    var playPromise = audio.play();
    if (playPromise !== undefined) {
      playPromise.catch(function() {
        // Autoplay blocked — still show the cinematic, just make it clickable sooner
        clearTimeout(timeoutId);
        ready = true;
        continueEl.classList.add('shown');
        cinematic.classList.add('clickable');
      });
    }
  }

  function openAssistantWithMessage(text) {
    if (introEl) introEl.classList.add('hidden');
    if (chatPanel) chatPanel.style.display = 'block';
    document.dispatchEvent(new CustomEvent('forge:assistant', {
      detail: { message: text }
    }));
  }

  // Intro input: Enter key sends + dismisses; any typing autofocuses
  // (NOTE: deferred focus happens at end of runIntro() so user-typed chars
  // don't race the typewriter sequence.)
  var introInput = document.getElementById('recon-aic-input-intro');
  if (introInput) {
    introInput.addEventListener('keydown', function(e) {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        e.stopPropagation();
        var text = introInput.value.trim();
        if (text) {
          openAssistantWithMessage(text);
        } else {
          revealChat();
        }
      }
    });
    // Also dismiss on any input click (user starts typing)
    introInput.addEventListener('focus', function() {
      // Auto-scroll into view
    });
  }

  // "Get Started" button
  document.getElementById('forge-get-started')?.addEventListener('click', revealChat);

  // Keyboard: pressing Enter on the intro page triggers Get Started
  document.addEventListener('keydown', function(e) {
    if (e.defaultPrevented) return;
    var targetTag = e.target && e.target.tagName ? e.target.tagName.toLowerCase() : '';
    if (targetTag === 'textarea' || targetTag === 'input' || targetTag === 'button' || targetTag === 'a') return;
    if (e.key === 'Enter' && !introEl.classList.contains('hidden')) {
      revealChat();
    }
  });

  // Rotating placeholder hints — rotate every 4s when idle + empty input
  var PLACEHOLDER_HINTS = [
    "Try: 'find the Plymouth Square cabinet invoice'",
    "Try: 'schedule John for Thursday at the Thompson Towers job'",
    "Try: 'show me unpaid invoices'",
    "Try: 'create a work order for Acme Corp'"
  ];
  var hintIdx = 0;
  var hintInterval = setInterval(function() {
    var input = document.getElementById('recon-aic-input');
    if (input && !input.value && !input.disabled) {
      input.placeholder = PLACEHOLDER_HINTS[hintIdx % PLACEHOLDER_HINTS.length];
      hintIdx++;
    }
  }, 4000);
  // Freeze rotation on user typing
  document.addEventListener('input', function(e) {
    if (e.target && e.target.id === 'recon-aic-input') {
      clearInterval(hintInterval);
    }
  }, { once: true });

  // D-083: Skip intro button
  document.getElementById('forge-cinematic-skip')?.addEventListener('click', function() {
    var e = new KeyboardEvent('keydown', { key: 'Escape' });
    document.dispatchEvent(e);
  });
})();
</script>

<%- include('../layouts/footer') %>
