<%# D-066 + D-084: Comprehensive tutorial — single interactive panel, no iframe, no split-pane %>
<%# Coach lives INSIDE the FORGE interactive window — same dark gradient as /forge intro. %>
<%# Builds on D-063 v3 tutorial_session_id columns + D-076 narration interpolation. %>
<%- include('../layouts/header', { title: 'FORGE Tutorial', activeNav: 'forge', currentUser }) %>

<style>
  /* Match /forge intro panel — same dark gradient, scanlines, cyan accents */
  #tutorial-window {
    min-height: 70vh;
    display: flex; flex-direction: column;
    background: linear-gradient(135deg, #020617 0%, #172554 50%, #0f172a 100%);
    border-radius: 0.75rem; padding: 2rem 2rem 1.25rem;
    position: relative; overflow: hidden;
    color: #e2e8f0;
  }
  #tutorial-window::after {
    content: ''; position: absolute; inset: 0;
    background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(34,211,238,0.04) 2px, rgba(34,211,238,0.04) 4px);
    pointer-events: none;
    animation: tw-scanline 3s ease-in-out infinite;
  }
  @keyframes tw-scanline { 0%, 100% { opacity: 0.1; } 50% { opacity: 0.25; } }
  @media (prefers-reduced-motion: reduce) { #tutorial-window::after { animation: none; } }

  /* Coach header — title + progress */
  .tw-header { position: relative; z-index: 2; display: flex; align-items: center; gap: 1rem; margin-bottom: 1rem; }
  .tw-title { font-family: 'Inter', 'SF Mono', monospace; font-size: 1.15rem; font-weight: 700; color: #e2e8f0; letter-spacing: 0.02em; }
  .tw-progress { flex: 1; display: flex; align-items: center; gap: 0.6rem; font-size: 0.75rem; color: #94a3b8; }
  .tw-progress-counter { white-space: nowrap; }
  .tw-progress-bar { flex: 1; height: 4px; background: rgba(148,163,184,0.2); border-radius: 2px; overflow: hidden; }
  .tw-progress-fill { height: 100%; background: linear-gradient(90deg, #22d3ee 0%, #06b6d4 100%); border-radius: 2px; transition: width 0.4s ease; box-shadow: 0 0 8px rgba(34,211,238,0.5); }
  .tw-version { font-size: 0.68rem; color: #475569; font-family: 'SF Mono', monospace; }
  .tw-exit { font-size: 0.75rem; color: #64748b; text-decoration: underline; cursor: pointer; }
  .tw-exit:hover { color: #94a3b8; }

  /* Body — narration + diagrams */
  .tw-body {
    position: relative; z-index: 2; flex: 1; overflow-y: auto; padding: 0.5rem 0;
    scrollbar-width: thin; scrollbar-color: rgba(34,211,238,0.65) rgba(15,23,42,0.45);
  }
  .tw-body:focus { outline: 2px solid rgba(34,211,238,0.45); outline-offset: 4px; border-radius: 8px; }
  .tw-body::-webkit-scrollbar { width: 10px; }
  .tw-body::-webkit-scrollbar-track { background: rgba(15,23,42,0.45); border-radius: 999px; }
  .tw-body::-webkit-scrollbar-thumb { background: rgba(34,211,238,0.65); border-radius: 999px; }
  .tw-scroll-controls {
    position: absolute; right: 1rem; top: 4.6rem; z-index: 4;
    display: none; flex-direction: column; gap: 0.35rem;
  }
  .tw-scroll-controls.visible { display: flex; }
  .tw-scroll-btn {
    width: 2rem; height: 2rem; border-radius: 999px; border: 1px solid rgba(34,211,238,0.4);
    background: rgba(15,23,42,0.88); color: #67e8f9; cursor: pointer; font-weight: 900;
    box-shadow: 0 8px 20px rgba(2,6,23,0.32);
  }
  .tw-scroll-btn:hover { background: rgba(34,211,238,0.16); }
  .tw-scroll-btn:disabled { opacity: 0.35; cursor: default; }
  .tw-scroll-hint {
    position: absolute; right: 3.45rem; top: 5.05rem; z-index: 4;
    display: none; padding: 0.22rem 0.5rem; border-radius: 999px;
    background: rgba(15,23,42,0.86); border: 1px solid rgba(34,211,238,0.22);
    color: #94a3b8; font-size: 0.68rem; white-space: nowrap;
  }
  .tw-scroll-hint.visible { display: block; }
  .tw-narration { font-size: 1rem; line-height: 1.7; color: #e2e8f0; max-width: 720px; margin: 0 auto; }
  .tw-narration p { margin-bottom: 0.85rem; animation: tw-fade-in 0.4s ease forwards; }
  .tw-narration p strong { color: #22d3ee; }
  .tw-narration p code { background: rgba(34,211,238,0.1); padding: 1px 6px; border-radius: 4px; font-size: 0.9em; color: #67e8f9; }
  .tw-diagram { margin: 0 auto 1.25rem; max-width: 640px; display: flex; justify-content: center; }
  .tw-diagram svg { max-width: 100%; height: auto; filter: drop-shadow(0 4px 12px rgba(34,211,238,0.15)); }
  @keyframes tw-fade-in { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: none; } }

  /* Chips — Next / Back / comprehension answers */
  .tw-chip-row { position: relative; z-index: 2; display: flex; flex-wrap: wrap; gap: 0.5rem; justify-content: center; max-width: 720px; margin: 0.75rem auto 0; }
  .tw-chip {
    display: inline-flex; align-items: center; gap: 0.35rem;
    padding: 0.5rem 1rem; border-radius: 999px; cursor: pointer;
    background: rgba(34,211,238,0.08); color: #22d3ee;
    border: 1px solid rgba(34,211,238,0.25); font-size: 0.85rem; font-weight: 500;
    transition: all 0.2s; backdrop-filter: blur(4px);
  }
  .tw-chip:hover { background: rgba(34,211,238,0.18); border-color: rgba(34,211,238,0.4); transform: translateY(-1px); }
  .tw-chip-primary { background: #22d3ee; color: #020617; border-color: #22d3ee; font-weight: 700; box-shadow: 0 0 16px rgba(34,211,238,0.35); }
  .tw-chip-primary:hover { background: #06b6d4; border-color: #06b6d4; }

  /* Input row */
  .tw-input-row { position: relative; z-index: 2; display: flex; gap: 0.5rem; margin-top: 1.25rem; max-width: 720px; margin-left: auto; margin-right: auto; width: 100%; }
  .tw-input {
    flex: 1; padding: 0.7rem 1rem; border-radius: 8px;
    border: 1px solid rgba(34,211,238,0.3); background: rgba(15,23,42,0.6);
    color: #e2e8f0; font-size: 0.95rem; outline: none; transition: all 0.2s;
  }
  .tw-input:focus { border-color: #22d3ee; box-shadow: 0 0 0 2px rgba(34,211,238,0.2); }
  .tw-input::placeholder { color: #64748b; }
  .tw-send {
    background: #22d3ee; color: #020617; border: none; border-radius: 8px;
    padding: 0.7rem 1.4rem; cursor: pointer; font-size: 0.9rem; font-weight: 700;
    transition: all 0.2s; box-shadow: 0 0 14px rgba(34,211,238,0.25);
  }
  .tw-send:hover { background: #06b6d4; transform: translateY(-1px); }

  .tw-practice {
    position: relative; z-index: 2; max-width: 980px; width: 100%;
    margin: 1rem auto 0;
  }
  .tw-practice[hidden] { display: none; }
  .tw-app-surface {
    color: #0f172a; background: #f8fafc; border-radius: 8px; overflow: hidden;
    border: 1px solid rgba(148,163,184,0.45);
    box-shadow: 0 18px 48px rgba(2,6,23,0.35);
  }
  .tw-app-topbar {
    display: flex; align-items: center; justify-content: space-between; gap: 1rem;
    padding: 0.7rem 1rem; background: #ffffff; border-bottom: 1px solid #e2e8f0;
  }
  .tw-app-brand { font-weight: 900; letter-spacing: 0.14em; color: #991b1b; font-size: 0.82rem; }
  .tw-app-nav { display: flex; gap: 0.45rem; flex-wrap: wrap; font-size: 0.78rem; color: #64748b; }
  .tw-app-nav span { padding: 0.28rem 0.5rem; border-radius: 6px; }
  .tw-app-nav .active { color: #0f172a; background: #e0f2fe; font-weight: 800; }
  .tw-app-page { padding: 1rem; }
  .tw-app-heading { display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem; margin-bottom: 0.85rem; }
  .tw-app-kicker { color: #64748b; font-size: 0.76rem; text-transform: uppercase; letter-spacing: 0.08em; font-weight: 800; }
  .tw-app-h1 { margin: 0.15rem 0 0; font-size: 1.35rem; font-weight: 900; color: #0f172a; }
  .tw-badge { display: inline-flex; align-items: center; padding: 0.18rem 0.48rem; border-radius: 999px; font-size: 0.68rem; font-weight: 900; background: #fef3c7; color: #92400e; margin-left: 0.45rem; vertical-align: middle; }
  .tw-status { display: inline-flex; padding: 0.18rem 0.48rem; border-radius: 999px; font-size: 0.7rem; font-weight: 900; background: #dbeafe; color: #1d4ed8; }
  .tw-status.paid { background: #dcfce7; color: #166534; }
  .tw-status.draft { background: #f1f5f9; color: #334155; }
  .tw-app-actions { display: flex; gap: 0.45rem; flex-wrap: wrap; justify-content: flex-end; }
  .tw-app-btn {
    border: 1px solid #cbd5e1; background: #ffffff; color: #0f172a; border-radius: 6px;
    padding: 0.48rem 0.72rem; font-weight: 800; font-size: 0.78rem; cursor: pointer;
  }
  .tw-app-btn.primary { background: #0f172a; color: #ffffff; border-color: #0f172a; }
  .tw-app-btn.accent { background: #c0202b; color: #ffffff; border-color: #c0202b; }
  .tw-app-btn:disabled { opacity: 0.45; cursor: not-allowed; }
  .tw-app-grid { display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 0.75rem; }
  .tw-app-card { background: #ffffff; border: 1px solid #e2e8f0; border-radius: 8px; padding: 0.85rem; }
  .tw-app-card h4 { margin: 0 0 0.65rem; font-size: 0.86rem; font-weight: 900; color: #0f172a; }
  .tw-app-tabs { display: flex; gap: 0.35rem; border-bottom: 1px solid #e2e8f0; margin-bottom: 0.75rem; overflow-x: auto; }
  .tw-app-tab { padding: 0.48rem 0.65rem; color: #64748b; font-size: 0.78rem; white-space: nowrap; border-bottom: 2px solid transparent; }
  .tw-app-tab.active { color: #0f172a; border-bottom-color: #c0202b; font-weight: 900; }
  .tw-app-table { width: 100%; border-collapse: collapse; font-size: 0.78rem; }
  .tw-app-table th, .tw-app-table td { padding: 0.48rem; border-bottom: 1px solid #e2e8f0; text-align: left; }
  .tw-app-table th { color: #64748b; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.06em; }
  .tw-app-form { display: grid; gap: 0.7rem; }
  .tw-app-form.two { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  .tw-app-label { display: grid; gap: 0.25rem; color: #334155; font-size: 0.76rem; font-weight: 800; }
  .tw-app-input, .tw-app-select, .tw-app-textarea {
    width: 100%; border: 1px solid #cbd5e1; background: #ffffff; color: #0f172a;
    border-radius: 6px; padding: 0.55rem 0.65rem; font-size: 0.84rem;
  }
  .tw-app-textarea { min-height: 5.5rem; resize: vertical; }
  .tw-app-muted { color: #64748b; font-size: 0.78rem; }
  .tw-app-total { display: flex; justify-content: flex-end; gap: 1.5rem; font-size: 0.86rem; font-weight: 900; }
  .tw-app-callout { background: #eff6ff; border: 1px solid #bfdbfe; border-radius: 8px; padding: 0.75rem; color: #1e3a8a; font-size: 0.82rem; }
  .tw-app-paid-stamp { transform: rotate(-12deg); color: #15803d; border: 3px solid #22c55e; padding: 0.25rem 0.7rem; font-weight: 900; font-size: 1.4rem; display: inline-block; }
  .tw-app-highlight { outline: 3px solid rgba(34,211,238,0.85); box-shadow: 0 0 0 6px rgba(34,211,238,0.18); }

  @media (max-width: 768px) {
    #tutorial-window { padding: 1.25rem 1rem; min-height: 80vh; }
    .tw-title { font-size: 1rem; }
    .tw-narration { font-size: 0.95rem; }
    .tw-app-grid, .tw-app-form.two { grid-template-columns: 1fr; }
    .tw-app-heading { flex-direction: column; }
    .tw-app-actions { justify-content: flex-start; }
    .tw-scroll-controls { right: 0.55rem; top: 4.25rem; }
    .tw-scroll-hint { right: 2.95rem; top: 4.67rem; }
  }
</style>

<div class="max-w-7xl mx-auto px-4 py-4">
  <div id="tutorial-window" data-tutorial-content-version="<%- tutorialContentVersion || '' %>">
    <div class="tw-header">
      <div class="tw-title">FORGE Tour Guide</div>
      <div class="tw-progress">
        <span class="tw-progress-counter">Chapter <span id="tc-current"><%= (chapterIndex || 0) + 1 %></span>/<span id="tc-total"><%= totalChapters || 11 %></span></span>
        <div class="tw-progress-bar">
          <div class="tw-progress-fill" id="tc-progress-fill" style="width:<%= ((chapterIndex || 0) / Math.max(1,(totalChapters || 11))) * 100 %>%"></div>
        </div>
      </div>
      <span class="tw-version" id="tc-version"><%= String(tutorialContentVersion || '').slice(0, 10) %></span>
      <span class="tw-exit" id="tc-exit">Exit</span>
    </div>

    <div class="tw-scroll-hint" id="tc-scroll-hint">Scroll text</div>
    <div class="tw-scroll-controls" id="tc-scroll-controls" aria-label="Tutorial text scroll controls">
      <button type="button" class="tw-scroll-btn" id="tc-scroll-up" aria-label="Scroll tutorial text up">&uarr;</button>
      <button type="button" class="tw-scroll-btn" id="tc-scroll-down" aria-label="Scroll tutorial text down">&darr;</button>
    </div>

    <div class="tw-body" id="tc-body" tabindex="0" aria-label="Tutorial text and practice area">
      <% var initialStep = typeof currentStep !== 'undefined' && currentStep ? currentStep : ((currentChapter && currentChapter.steps && currentChapter.steps[stepIndex || 0]) || null); %>
      <% var initialDiagramId = (initialStep && initialStep.diagram_id) || (currentChapter && currentChapter.diagram_id); %>
      <div class="tw-diagram" id="tc-diagram">
        <% if (initialDiagramId) { %>
          <%- include('tutorial/diagrams/' + initialDiagramId) %>
        <% } %>
      </div>
      <div class="tw-narration" id="tc-narration">
        <% var initialText = (initialStep && initialStep.coach_text) || (currentChapter && currentChapter.narration); %>
        <% if (initialText) { %>
          <%- ('<p>' + initialText.replace(/\n\n+/g, '</p><p>') + '</p>') %>
        <% } else { %>
          <p>Welcome to the FORGE tutorial. Loading your first chapter&hellip;</p>
        <% } %>
      </div>
      <div class="tw-practice" id="tc-practice" hidden></div>
      <div class="tw-chip-row" id="tc-chips"></div>
    </div>

    <div class="tw-input-row">
      <input type="text" class="tw-input" id="tc-input" placeholder="Type next, back, or a question..." autofocus>
      <button class="tw-send" id="tc-send">Send</button>
    </div>
  </div>
</div>

<div id="tc-diagram-templates" hidden>
  <div data-diagram-id="hierarchy-customer-wo-est-inv"><%- include('tutorial/diagrams/hierarchy-customer-wo-est-inv') %></div>
  <div data-diagram-id="numbering-wo-est-inv"><%- include('tutorial/diagrams/numbering-wo-est-inv') %></div>
  <div data-diagram-id="tutorial-badge-example"><%- include('tutorial/diagrams/tutorial-badge-example') %></div>
  <div data-diagram-id="tutorial-badge-callout"><%- include('tutorial/diagrams/tutorial-badge-callout') %></div>
  <div data-diagram-id="paid-stamp-callout"><%- include('tutorial/diagrams/paid-stamp-callout') %></div>
</div>

<script>
(function() {
  var returnTo = <%- JSON.stringify(returnTo || '/forge') %>;
  var sessionId = <%- JSON.stringify(tutorialSessionId || '') %>;
  var initialChapter = <%- JSON.stringify(currentChapter || null) %>;
  var initialContentVersion = <%- JSON.stringify(tutorialContentVersion || '') %>;
  var initialStepIndex = <%- JSON.stringify(stepIndex || 0) %>;
  var input = document.getElementById('tc-input');
  var sendBtn = document.getElementById('tc-send');
  var body = document.getElementById('tc-body');
  var scrollControls = document.getElementById('tc-scroll-controls');
  var scrollHint = document.getElementById('tc-scroll-hint');
  var scrollUp = document.getElementById('tc-scroll-up');
  var scrollDown = document.getElementById('tc-scroll-down');
  var narration = document.getElementById('tc-narration');
  var diagram = document.getElementById('tc-diagram');
  var diagramTemplates = document.getElementById('tc-diagram-templates');
  var practice = document.getElementById('tc-practice');
  var chips = document.getElementById('tc-chips');
  var progressFill = document.getElementById('tc-progress-fill');
  var currentSpan = document.getElementById('tc-current');
  var totalSpan = document.getElementById('tc-total');
  var versionSpan = document.getElementById('tc-version');
  var autoTimer = null;

  function sendAction(action, payload) {
    if (autoTimer) {
      clearTimeout(autoTimer);
      autoTimer = null;
    }
    fetch('/forge/tutorial/advance', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ action: action, payload: payload || {} }),
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (data.redirect) { window.location.href = data.redirect; return; }
      if (data.done) {
        narration.innerHTML = '<p><strong>Tutorial complete!</strong> Nice work. You can return to FORGE or replay any chapter.</p>';
        renderChips([{ label: 'Return to FORGE', action: 'href', href: returnTo, primary: true }]);
        return;
      }
      updateChapter(data);
    })
    .catch(function(err) {
      console.error('[tutorial] advance error', err);
      narration.innerHTML = '<p style="color:#f87171">Hmm, something hiccuped. Try clicking Next again, or hit Exit and replay from /forge.</p>';
    });
  }

  function updateChapter(data) {
    if (currentSpan && data.chapterIndex !== undefined) currentSpan.textContent = (data.chapterIndex || 0) + 1;
    if (versionSpan && data.tutorialContentVersion) versionSpan.textContent = data.tutorialContentVersion.slice(0, 10);
    var total = parseInt(totalSpan.textContent, 10) || 11;
    if (progressFill) progressFill.style.width = ((data.chapterIndex || 0) / Math.max(1,total) * 100) + '%';

    var stepIndex = data.step || 0;
    var step = data.chapter && data.chapter.steps ? data.chapter.steps[stepIndex] : null;
    var text = (step && step.coach_text) || (data.chapter && data.chapter.narration);
    if (text) narration.innerHTML = '<p>' + text.replace(/\n\n+/g, '</p><p>') + '</p>';
    renderDiagram((step && step.diagram_id) || (data.chapter && data.chapter.diagram_id));
    var hasPractice = renderPractice(step, data.chapter);

    // Build chip row — comprehension chips if provided, else Next/Back fallback
    var chipsList;
    var sourceChips = (step && step.chips) || (data.chapter && data.chapter.comprehension_chips) || [];
    if (sourceChips.length) {
      chipsList = sourceChips.map(function(c) {
        return { label: (typeof c === 'string' ? c : (c.label || 'Continue')), action: 'select_chip', payload: c };
      });
      chipsList.push({ label: 'Back &larr;', action: 'back' });
    } else if (hasPractice) {
      chipsList = [{ label: 'Back &larr;', action: 'back' }];
    } else {
      chipsList = [{ label: 'Next &rarr;', action: 'next', primary: true }, { label: 'Back &larr;', action: 'back' }];
    }
    renderChips(chipsList);
    resetTutorialScroll();
    scheduleAutoAdvance(step, sourceChips.length);
  }

  function updateScrollControls() {
    if (!body || !scrollControls) return;
    var canScroll = body.scrollHeight > body.clientHeight + 4;
    scrollControls.classList.toggle('visible', canScroll);
    if (scrollHint) scrollHint.classList.toggle('visible', canScroll);
    if (!canScroll) return;
    if (scrollUp) scrollUp.disabled = body.scrollTop <= 2;
    if (scrollDown) scrollDown.disabled = body.scrollTop + body.clientHeight >= body.scrollHeight - 2;
  }

  function resetTutorialScroll() {
    if (!body) return;
    body.scrollTop = 0;
    setTimeout(updateScrollControls, 0);
  }

  function scrollTutorialBody(direction) {
    if (!body) return;
    body.scrollBy({ top: direction * Math.max(160, Math.floor(body.clientHeight * 0.6)), behavior: 'smooth' });
    setTimeout(updateScrollControls, 220);
  }

  function renderDiagram(diagramId) {
    if (!diagram) return;
    diagram.innerHTML = '';
    if (!diagramId || !diagramTemplates) return;
    var source = diagramTemplates.querySelector('[data-diagram-id="' + diagramId + '"]');
    if (source) diagram.innerHTML = source.innerHTML;
  }

  function renderChips(items) {
    chips.innerHTML = '';
    items.forEach(function(item) {
      var el = document.createElement('div');
      el.className = 'tw-chip' + (item.primary ? ' tw-chip-primary' : '');
      el.innerHTML = item.label;
      el.addEventListener('click', function() {
        if (item.action === 'href') { window.location.href = item.href; }
        else if (item.action) { sendAction(item.action, item.payload); }
      });
      chips.appendChild(el);
    });
  }

  function renderPractice(step, chapter) {
    if (!practice) return false;
    practice.innerHTML = '';
    practice.hidden = true;
    if (!step) return false;

    var action = step.expected_action;
    var practiceActions = ['click_or_route_change', 'click_or_dom_change', 'form_field_filled', 'form_field_filled_multiple', 'form_submit'];
    var isHandsOn = chapter && /^0[3-8]-/.test(chapter.id || '');
    if (!isHandsOn && practiceActions.indexOf(action) === -1) return false;

    var page = tutorialMockPage(chapter, step);
    if (!page) return false;
    practice.hidden = false;
    practice.innerHTML = page;

    var actionable = practiceActions.indexOf(action) !== -1;
    var fields = step.expected_fields || (step.expected_field ? [step.expected_field] : []);
    var submit = practice.querySelector('[data-tutorial-submit]');
    if (fields.length && !submit) {
      submit = document.createElement('button');
      submit.type = 'button';
      submit.className = 'tw-app-btn primary tw-app-highlight';
      submit.setAttribute('data-tutorial-submit', '1');
      submit.setAttribute('data-tutorial-action', '1');
      submit.textContent = action === 'form_field_filled_multiple' ? 'Done' : 'Continue';
      var target = practice.querySelector('.tw-app-form') || practice.querySelector('.tw-app-page') || practice;
      target.appendChild(submit);
    }

    Array.prototype.forEach.call(practice.querySelectorAll('[data-tutorial-action]'), function(el) {
      el.addEventListener('click', function() { sendAction('next'); });
    });

    if (fields.length && submit) {
      submit.disabled = true;
      var validate = function() {
        submit.disabled = fields.some(function(field) {
          var el = practice.querySelector('[name="' + selectorName(field) + '"]');
          return !el || !String(el.value || '').trim();
        });
      };
      Array.prototype.forEach.call(practice.querySelectorAll('input, textarea, select'), function(el) {
        el.addEventListener('input', validate);
        el.addEventListener('change', validate);
      });
      validate();
    }
    return actionable;
  }

  function tutorialMockPage(chapter, step) {
    var chapterId = chapter && chapter.id || '';
    var stepId = step && step.id || '';
    if (chapterId === '03-create-customer') return customerMock(stepId);
    if (chapterId === '04-create-wo') return workOrderMock(stepId);
    if (chapterId === '05-add-estimate') return estimateMock(stepId, false);
    if (chapterId === '06-convert-to-invoice') return invoiceMock(stepId, false);
    if (chapterId === '07-record-payment') return paymentMock(stepId);
    if (chapterId === '08-side-quest-loose-estimate') return estimateMock(stepId, true);
    return '';
  }

  function appFrame(active, title, body, actions) {
    return [
      '<div class="tw-app-surface">',
        '<div class="tw-app-topbar">',
          '<div class="tw-app-brand">FORGE</div>',
          '<div class="tw-app-nav">',
            navItem('Customers', active === 'customers'),
            navItem('Work Orders', active === 'work-orders'),
            navItem('Estimates', active === 'estimates'),
            navItem('Invoices', active === 'invoices'),
            navItem('Payments', active === 'payments'),
          '</div>',
        '</div>',
        '<div class="tw-app-page">',
          '<div class="tw-app-heading">',
            '<div><div class="tw-app-kicker">Tutorial workspace</div><h3 class="tw-app-h1">' + title + '</h3></div>',
            '<div class="tw-app-actions">' + (actions || '') + '</div>',
          '</div>',
          body,
        '</div>',
      '</div>',
    ].join('');
  }

  function navItem(label, active) {
    return '<span class="' + (active ? 'active' : '') + '">' + label + '</span>';
  }

  function actionButton(label, variant) {
    return '<button type="button" class="tw-app-btn ' + (variant || '') + ' tw-app-highlight" data-tutorial-action>' + label + '</button>';
  }

  function customerMock(stepId) {
    if (stepId === 'spotlight-nav') {
      return appFrame('customers', 'Customers', '<div class="tw-app-card"><h4>Customer list</h4><p class="tw-app-muted">This is where every customer record starts. Open the list to find, add, or review customers.</p></div>', actionButton('Open Customers', 'primary'));
    }
    if (stepId === 'react-on-customers-page') {
      return appFrame('customers', 'Customers', '<div class="tw-app-card"><h4>Recent customers</h4><table class="tw-app-table"><tbody><tr><td class="tw-app-muted">No tutorial customer yet.</td><td></td></tr></tbody></table></div>', actionButton('+ New Customer', 'primary'));
    }
    if (stepId === 'fill-form-intro') {
      return appFrame('customers', 'New Customer', '<div class="tw-app-card"><h4>Customer information</h4><div class="tw-app-form">' + field('name', 'Customer name', 'Tutorial Customer') + '<div class="tw-app-form two">' + field('email', 'Email (optional)', 'manager@example.com') + field('phone', 'Phone (optional)', '(555) 010-1000') + '</div></div></div>');
    }
    if (stepId === 'after-name-typed') {
      return appFrame('customers', 'New Customer', '<div class="tw-app-card"><h4>Customer information</h4><div class="tw-app-form">' + field('name', 'Customer name', 'Tutorial Customer', 'Tutorial Customer') + '<button type="button" class="tw-app-btn primary tw-app-highlight" data-tutorial-submit data-tutorial-action>Save Customer</button></div></div>');
    }
    return customerDetail();
  }

  function customerDetail() {
    return appFrame('customers', 'Tutorial Customer <span class="tw-badge">TUTORIAL</span>',
      '<div class="tw-app-grid"><div class="tw-app-card"><h4>Customer detail</h4><p class="tw-app-muted">Billing contact, job history, payments, files, and notes live here.</p><div class="tw-app-tabs">' + tabs(['Work Orders','Estimates','Invoices','Payments','Files'], 'Work Orders') + '</div><table class="tw-app-table"><tbody><tr><td class="tw-app-muted">No work orders yet.</td><td></td></tr></tbody></table></div><div class="tw-app-card"><h4>Summary</h4><p>Open WOs: <strong>0</strong></p><p>Total billed: <strong>$0.00</strong></p><p>AR balance: <strong>$0.00</strong></p></div></div>',
      '<button class="tw-app-btn">Upload File</button><button class="tw-app-btn primary">+ New WO</button>');
  }

  function workOrderMock(stepId) {
    if (stepId === 'spotlight-new-wo') return customerDetail().replace('+ New WO', '+ New WO').replace('tw-app-btn primary', 'tw-app-btn primary tw-app-highlight" data-tutorial-action="1');
    if (stepId === 'form-arrived' || stepId === 'wo-number-callout' || stepId === 'description-prompt' || stepId === 'status-callout' || stepId === 'assignee-callout') {
      var save = stepId === 'assignee-callout' ? '<button type="button" class="tw-app-btn primary tw-app-highlight" data-tutorial-submit data-tutorial-action>Save Work Order</button>' : '';
      var descValue = stepId === 'description-prompt' ? '' : 'Demo job: kitchen drywall repair, unit 1B';
      return appFrame('work-orders', 'New Work Order',
        '<div class="tw-app-card"><h4>Work order details</h4><div class="tw-app-form"><div class="tw-app-form two">' + field('customer', 'Customer', 'Tutorial Customer', 'Tutorial Customer') + field('display_number', 'WO number', 'WO-0001-0014', 'WO-0001-0014') + '</div>' + textarea('description', 'Description', 'Demo job: kitchen drywall repair, unit 1B', descValue) + '<div class="tw-app-form two">' + selectField('status', 'Status', ['OPEN','SCHEDULED','IN PROGRESS','CLOSED']) + field('assigned_to', 'Assignees (optional)', 'Crew member') + '</div>' + save + '</div></div>');
    }
    return workOrderDetail();
  }

  function workOrderDetail() {
    return appFrame('work-orders', 'WO-0001-0014 <span class="tw-badge">TUTORIAL</span> <span class="tw-status">OPEN</span>',
      '<div class="tw-app-tabs">' + tabs(['Overview','Estimates','Invoices','Files','Schedule','Notes','Activity'], 'Estimates') + '</div><div class="tw-app-grid"><div class="tw-app-card"><h4>Job description</h4><p>Demo job: kitchen drywall repair, unit 1B</p><h4>Estimates</h4><table class="tw-app-table"><tbody><tr><td class="tw-app-muted">No estimates yet.</td><td></td></tr></tbody></table></div><div class="tw-app-card"><h4>Quick stats</h4><p>Customer: <strong>Tutorial Customer</strong></p><p>Estimate total: <strong>$0.00</strong></p><p>Invoice balance: <strong>$0.00</strong></p></div></div>',
      '<button class="tw-app-btn primary">+ New Estimate</button>');
  }

  function estimateMock(stepId, loose) {
    if (loose && stepId === 'spotlight-new-estimate') {
      return appFrame('customers', 'Tutorial Customer <span class="tw-badge">TUTORIAL</span>',
        '<div class="tw-app-tabs">' + tabs(['Work Orders','Estimates','Invoices','Payments','Files'], 'Estimates') + '</div><div class="tw-app-card"><h4>Customer estimates</h4><table class="tw-app-table"><tbody><tr><td class="tw-app-muted">No loose estimates yet.</td><td></td></tr></tbody></table></div>',
        '<button class="tw-app-btn">+ New WO</button><button class="tw-app-btn primary tw-app-highlight" data-tutorial-action>+ New Estimate</button>');
    }
    if (stepId === 'spotlight-estimates-tab') return workOrderDetail();
    if (stepId === 'spotlight-new-estimate') return workOrderDetail().replace('tw-app-btn primary', 'tw-app-btn primary tw-app-highlight" data-tutorial-action="1');
    if (stepId === 'back-to-customer') return customerDetail();
    if (stepId === 'quick-fill' || stepId === 'line-1-description' || stepId === 'line-1-qty-rate' || stepId === 'line-2-add' || stepId === 'line-2-fill' || stepId === 'tax-input' || stepId === 'save' || stepId === 'form-arrived' || stepId === 'line-1-intro') {
      return estimateForm(stepId, loose);
    }
    return estimateDetail(loose);
  }

  function estimateForm(stepId, loose) {
    var number = loose ? 'EST-????-????' : 'EST-0001-0014';
    var line2 = stepId === 'line-2-add' || stepId === 'line-2-fill' || stepId === 'tax-input' || stepId === 'save';
    var save = stepId === 'save' ? '<button type="button" class="tw-app-btn primary tw-app-highlight" data-tutorial-submit data-tutorial-action>Save Estimate</button>' : '';
    var add = stepId === 'line-2-add' ? '<button type="button" class="tw-app-btn primary tw-app-highlight" data-tutorial-action>+ Add line</button>' : '';
    return appFrame('estimates', loose ? 'New Loose Estimate' : 'New Estimate',
      '<div class="tw-app-card"><h4>Estimate form</h4><div class="tw-app-form"><div class="tw-app-form two">' + field('display_number', 'Estimate number', number, number) + field('work_order', 'Work Order', loose ? 'No WO attached' : 'WO-0001-0014', loose ? '' : 'WO-0001-0014') + '</div><table class="tw-app-table"><thead><tr><th>Description</th><th>Qty</th><th>Unit</th><th>Total</th></tr></thead><tbody><tr><td>' + input('line_items[0].description', 'Labor - drywall repair, kitchen wall', stepId === 'line-1-description' ? '' : (loose ? 'Rough quote: bathroom tile' : 'Labor - drywall repair, kitchen wall')) + '</td><td>' + input('line_items[0].qty', '4', loose ? '1' : '4') + '</td><td>' + input('line_items[0].unit_price', '80', loose ? '1500' : '80') + '</td><td>' + (loose ? '$1,500.00' : '$320.00') + '</td></tr>' + (line2 && !loose ? '<tr><td>' + input('line_items[1].description', 'Materials - drywall sheet + compound', stepId === 'line-2-fill' ? '' : 'Materials - drywall sheet + compound') + '</td><td>' + input('line_items[1].qty', '1', '1') + '</td><td>' + input('line_items[1].unit_price', '45', '45') + '</td><td>$45.00</td></tr>' : '') + '</tbody></table>' + add + '<div class="tw-app-form two">' + field('tax_rate', 'Tax rate %', '6', loose ? '0' : (stepId === 'tax-input' ? '' : '6')) + field('status', 'Status', 'DRAFT', 'DRAFT') + '</div><div class="tw-app-total"><span>Subtotal ' + (loose ? '$1,500.00' : '$365.00') + '</span><span>Total ' + (loose ? '$1,500.00' : '$386.90') + '</span></div>' + save + '</div></div>');
  }

  function estimateDetail(loose) {
    return appFrame('estimates', (loose ? 'EST-????-????' : 'EST-0001-0014') + ' <span class="tw-badge">TUTORIAL</span> <span class="tw-status draft">DRAFT</span>',
      '<div class="tw-app-grid"><div class="tw-app-card"><h4>Line items</h4><table class="tw-app-table"><tbody><tr><td>' + (loose ? 'Rough quote: bathroom tile' : 'Labor - drywall repair, kitchen wall') + '</td><td>' + (loose ? '$1,500.00' : '$320.00') + '</td></tr>' + (!loose ? '<tr><td>Materials - drywall sheet + compound</td><td>$45.00</td></tr>' : '') + '</tbody></table><div class="tw-app-total"><span>Total ' + (loose ? '$1,500.00' : '$386.90') + '</span></div></div><div class="tw-app-card"><h4>Source</h4><p>' + (loose ? 'No work order yet. Attach to a WO before invoicing.' : 'Linked to WO-0001-0014.') + '</p></div></div>',
      loose ? '<button class="tw-app-btn">Send PDF</button><button class="tw-app-btn primary">Attach to WO</button>' : '<button class="tw-app-btn">Send PDF</button><button class="tw-app-btn accent">Convert to Invoice</button>');
  }

  function invoiceMock(stepId) {
    if (stepId === 'spotlight-convert-button') return estimateDetail(false).replace('tw-app-btn accent', 'tw-app-btn accent tw-app-highlight" data-tutorial-action="1');
    return appFrame('invoices', 'INV-0001-0014 <span class="tw-badge">TUTORIAL</span> <span class="tw-status">OPEN</span>',
      '<div class="tw-app-grid"><div class="tw-app-card"><h4>Invoice line items</h4><table class="tw-app-table"><tbody><tr><td>Labor - drywall repair, kitchen wall</td><td>$320.00</td></tr><tr><td>Materials - drywall sheet + compound</td><td>$45.00</td></tr></tbody></table><div class="tw-app-callout">Line items are read-only here. Edit the estimate, then re-convert if the bill changes.</div><div class="tw-app-total"><span>Total $386.90</span></div></div><div class="tw-app-card"><h4>Linked records</h4><p>Customer: <strong>Tutorial Customer</strong></p><p>Work Order: <strong>WO-0001-0014</strong></p><p>Linked Estimate: <strong>EST-0001-0014</strong></p></div></div>',
      '<button class="tw-app-btn">Send to customer</button><button class="tw-app-btn primary">Record Payment</button>');
  }

  function paymentMock(stepId) {
    if (stepId === 'spotlight-record-payment') return invoiceMock(stepId).replace('tw-app-btn primary', 'tw-app-btn primary tw-app-highlight" data-tutorial-action="1');
    if (stepId === 'modal-arrived' || stepId === 'amount-prefilled' || stepId === 'date-prefilled' || stepId === 'method-select' || stepId === 'save-payment') {
      return appFrame('payments', 'Record Payment',
        '<div class="tw-app-grid"><div class="tw-app-card"><h4>Payment for INV-0001-0014</h4><div class="tw-app-form"><div class="tw-app-form two">' + field('amount', 'Amount', '386.90', '386.90') + field('payment_date', 'Date', 'Today', 'Today') + '</div>' + selectField('method', 'Method', ['Check','ACH','Card','Cash','Other']) + '<button type="button" class="tw-app-btn primary tw-app-highlight" data-tutorial-submit data-tutorial-action>Save Payment</button></div></div><div class="tw-app-card"><h4>Balance</h4><p>Invoice total: <strong>$386.90</strong></p><p>Amount due after save: <strong>$0.00</strong></p></div></div>');
    }
    if (stepId === 'customer-ledger') return invoicePaid().replace('Tutorial Customer', '<button type="button" class="tw-app-btn primary tw-app-highlight" data-tutorial-action>Tutorial Customer</button>');
    if (stepId === 'ledger-callout') return customerLedger();
    return invoicePaid();
  }

  function invoicePaid() {
    return appFrame('invoices', 'INV-0001-0014 <span class="tw-badge">TUTORIAL</span> <span class="tw-status paid">PAID</span>',
      '<div class="tw-app-grid"><div class="tw-app-card"><h4>Invoice</h4><div class="tw-app-paid-stamp">PAID</div><div class="tw-app-total"><span>Total $386.90</span><span>Balance $0.00</span></div></div><div class="tw-app-card"><h4>Payments</h4><table class="tw-app-table"><tbody><tr><td>Today</td><td>Check</td><td>$386.90</td></tr></tbody></table></div></div>',
      '<button class="tw-app-btn">Download PDF</button><button class="tw-app-btn">Tutorial Customer</button>');
  }

  function customerLedger() {
    return appFrame('customers', 'Tutorial Customer <span class="tw-badge">TUTORIAL</span>',
      '<div class="tw-app-tabs">' + tabs(['Work Orders','Estimates','Invoices','Payments','Files'], 'Payments') + '</div><div class="tw-app-card"><h4>Payment Ledger</h4><table class="tw-app-table"><thead><tr><th>Date</th><th>Invoice</th><th>Method</th><th>Amount</th></tr></thead><tbody><tr><td>Today</td><td>INV-0001-0014</td><td>Check</td><td>$386.90</td></tr></tbody></table></div>');
  }

  function tabs(items, active) {
    return items.map(function(item) { return '<span class="tw-app-tab ' + (item === active ? 'active' : '') + '">' + item + '</span>'; }).join('');
  }

  function field(name, label, placeholder, value) {
    return '<label class="tw-app-label">' + label + '<input class="tw-app-input" name="' + name + '" placeholder="' + placeholder + '" value="' + escapeHtml(value || '') + '"></label>';
  }

  function textarea(name, label, placeholder, value) {
    return '<label class="tw-app-label">' + label + '<textarea class="tw-app-textarea" name="' + name + '" placeholder="' + placeholder + '">' + escapeHtml(value || '') + '</textarea></label>';
  }

  function input(name, placeholder, value) {
    return '<input class="tw-app-input" name="' + name + '" placeholder="' + placeholder + '" value="' + escapeHtml(value || '') + '">';
  }

  function selectField(name, label, options) {
    return '<label class="tw-app-label">' + label + '<select class="tw-app-select" name="' + name + '">' + options.map(function(option) { return '<option>' + option + '</option>'; }).join('') + '</select></label>';
  }

  function selectorName(name) {
    return String(name).replace(/\\/g, '\\\\').replace(/"/g, '\\"');
  }

  function escapeHtml(value) {
    return String(value).replace(/[&<>"']/g, function(ch) {
      return ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[ch];
    });
  }

  function fieldLabel(field) {
    var labels = {
      name: 'Customer name',
      description: 'Work order description',
      tax_rate: 'Tax rate',
      method: 'Payment method',
      'line_items[0].description': 'Line 1 description',
      'line_items[0].qty': 'Line 1 quantity',
      'line_items[0].unit_price': 'Line 1 unit price',
      'line_items[1].description': 'Line 2 description',
      'line_items[1].qty': 'Line 2 quantity',
      'line_items[1].unit_price': 'Line 2 unit price',
    };
    return labels[field] || field;
  }

  function sampleValue(field) {
    var samples = {
      name: 'Tutorial Customer',
      description: 'Demo job: kitchen drywall repair, unit 1B',
      tax_rate: '6',
      'line_items[0].description': 'Labor - drywall repair, kitchen wall',
      'line_items[0].qty': '4',
      'line_items[0].unit_price': '80',
      'line_items[1].description': 'Materials - drywall sheet + compound',
      'line_items[1].qty': '1',
      'line_items[1].unit_price': '45',
    };
    return samples[field] || '';
  }

  function scheduleAutoAdvance(step, choiceCount) {
    if (!step || step.expected_action !== 'auto_advance' || choiceCount) return;
    var delay = Math.max(300, parseInt(step.delay_after_ms, 10) || 1200);
    autoTimer = setTimeout(function() { sendAction('next'); }, delay);
  }

  function handleInput() {
    var val = input.value.trim().toLowerCase();
    input.value = '';
    if (!val) return;
    switch (val) {
      case 'next': case 'n': sendAction('next'); break;
      case 'back': case 'b': sendAction('back'); break;
      case 'skip': sendAction('skip_chapter'); break;
      case 'restart': sendAction('restart_chapter'); break;
      case 'exit': case 'quit': sendAction('exit'); break;
      default: sendAction('select_chip', { query: val }); break;
    }
  }

  input.addEventListener('keydown', function(e) { if (e.key === 'Enter') handleInput(); });
  sendBtn.addEventListener('click', handleInput);
  if (body) body.addEventListener('scroll', updateScrollControls, { passive: true });
  if (scrollUp) scrollUp.addEventListener('click', function() { scrollTutorialBody(-1); });
  if (scrollDown) scrollDown.addEventListener('click', function() { scrollTutorialBody(1); });
  window.addEventListener('resize', updateScrollControls);
  document.getElementById('tc-exit').addEventListener('click', function() {
    if (confirm('Exit the tutorial? Your progress will be saved.')) sendAction('exit');
  });

  updateChapter({ chapter: initialChapter, step: initialStepIndex, chapterIndex: <%- JSON.stringify(chapterIndex || 0) %>, tutorialContentVersion: initialContentVersion });
})();
</script>

<%- include('../layouts/footer', { hideFeedback: true }) %>
