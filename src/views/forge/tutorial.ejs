<%# D-066 Comprehensive tutorial — server-side state machine, split-pane shell %>
<%# Builds on D-063 v3 tutorial_session_id columns %>
<%- include('../layouts/header', { title: 'FORGE Tutorial', activeNav: 'forge', currentUser }) %>

<style>
/* Split-pane layout */
#tutorial-container { display: flex; height: calc(100vh - 120px); min-height: 500px; margin: -1rem -0.5rem; }
#tutorial-live { flex: 1.6; min-width: 0; overflow-y: auto; padding: 1rem; border-right: 1px solid #e5e7eb; }
#tutorial-coach { width: 380px; min-width: 320px; display: flex; flex-direction: column; background: #f9fafb; border-left: 1px solid #e5e7eb; }
.coach-header { padding: 1rem; border-bottom: 1px solid #e5e7eb; background: white; }
.coach-progress { display: flex; align-items: center; gap: 0.5rem; font-size: 0.75rem; color: #6b7280; margin-top: 0.25rem; }
.coach-progress-bar { flex: 1; height: 4px; background: #e5e7eb; border-radius: 2px; overflow: hidden; }
.coach-progress-fill { height: 100%; background: #06b6d4; border-radius: 2px; transition: width 0.3s; }
.coach-body { flex: 1; overflow-y: auto; padding: 1rem; }
.coach-narration { font-size: 0.9rem; line-height: 1.6; color: #1f2937; }
.coach-narration p { margin-bottom: 0.75rem; }
.coach-chip-row { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-top: 1rem; }
.coach-chip { display: inline-flex; align-items: center; gap: 0.3rem; padding: 0.4rem 0.8rem; border-radius: 999px; cursor: pointer; background: white; border: 1px solid #d1d5db; font-size: 0.8rem; color: #374151; transition: all 0.15s; }
.coach-chip:hover { background: #f3f4f6; border-color: #9ca3af; }
.coach-chip-primary { background: #06b6d4; color: white; border-color: #06b6d4; }
.coach-chip-primary:hover { background: #0891b2; }
.coach-footer { padding: 0.75rem 1rem; border-top: 1px solid #e5e7eb; background: white; }
.coach-input-row { display: flex; gap: 0.5rem; }
.coach-input { flex: 1; border: 1px solid #d1d5db; border-radius: 0.375rem; padding: 0.5rem 0.75rem; font-size: 0.85rem; outline: none; }
.coach-input:focus { border-color: #06b6d4; box-shadow: 0 0 0 2px rgba(6,182,212,0.15); }
.coach-send { background: #06b6d4; color: white; border: none; border-radius: 0.375rem; padding: 0.5rem 1rem; cursor: pointer; font-size: 0.85rem; }
.coach-send:hover { background: #0891b2; }
.coach-exit { font-size: 0.75rem; color: #9ca3af; text-decoration: underline; margin-left: auto; cursor: pointer; }
@media (max-width: 768px) {
  #tutorial-container { flex-direction: column; height: auto; }
  #tutorial-live { flex: none; height: 50vh; border-right: none; border-bottom: 1px solid #e5e7eb; }
  #tutorial-coach { width: 100%; min-width: 0; }
}
</style>

<div id="tutorial-container">
  <!-- Live app pane (left) -->
  <div id="tutorial-live">
    <iframe src="/forge?embed=1" style="width:100%;height:100%;border:none;border-radius:0.5rem;background:white;" title="FORGE app"></iframe>
  </div>

  <!-- Coach pane (right) -->
  <div id="tutorial-coach">
    <div class="coach-header">
      <div style="font-weight:600;font-size:0.9rem">FORGE Tour Guide</div>
      <div class="coach-progress">
        <span>Chapter <span id="tc-current"><%= (chapterIndex || 0) + 1 %></span>/<span id="tc-total"><%= totalChapters || 10 %></span></span>
        <div class="coach-progress-bar">
          <div class="coach-progress-fill" id="tc-progress-fill" style="width:<%= ((chapterIndex || 0) / (totalChapters || 10)) * 100 %>%"></div>
        </div>
      </div>
    </div>

    <div class="coach-body" id="tc-body">
      <div class="coach-narration" id="tc-narration">
        <% if (currentChapter) { %>
          <%- (currentChapter.narration || 'Welcome to the FORGE tutorial.').replace(/\n\n/g, '</p><p>').replace(/^/, '<p>').replace(/$/, '</p>') %>
        <% } else { %>
          <p>Welcome to the FORGE tutorial! Your guide will appear here.</p>
        <% } %>
      </div>
      <div class="coach-chip-row" id="tc-chips"></div>
    </div>

    <div class="coach-footer">
      <div class="coach-input-row">
        <input type="text" class="coach-input" id="tc-input" placeholder="Type next, back, or a question..." autofocus>
        <button class="coach-send" id="tc-send">Send</button>
        <span class="coach-exit" id="tc-exit">Exit</span>
      </div>
    </div>
  </div>
</div>

<script>
(function() {
  var returnTo = <%- JSON.stringify(returnTo || '/forge') %>;
  var sessionId = <%- JSON.stringify(tutorialSessionId || '') %>;
  var input = document.getElementById('tc-input');
  var sendBtn = document.getElementById('tc-send');
  var narration = document.getElementById('tc-narration');
  var chips = document.getElementById('tc-chips');
  var progressFill = document.getElementById('tc-progress-fill');
  var currentSpan = document.getElementById('tc-current');
  var totalSpan = document.getElementById('tc-total');

  function sendAction(action, payload) {
    fetch('/forge/tutorial/advance', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ action: action, payload: payload || {} }),
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (data.redirect) { window.location.href = data.redirect; return; }
      if (data.done) {
        narration.innerHTML = '<p><strong>Tutorial complete!</strong> You can close this panel or return to FORGE.</p>';
        renderChips([{ label: 'Return to FORGE', action: 'href', href: returnTo }]);
        return;
      }
      updateChapter(data);
    });
  }

  function updateChapter(data) {
    if (currentSpan) currentSpan.textContent = (data.chapterIndex || 0) + 1;
    var total = parseInt(totalSpan.textContent, 10) || 10;
    if (progressFill) progressFill.style.width = ((data.chapterIndex || 0) / total * 100) + '%';

    if (data.chapter && data.chapter.narration) {
      narration.innerHTML = data.chapter.narration;
    }

    // Default chips
    var chipsList = [{ label: 'Next &rarr;', action: 'next' }, { label: 'Back &larr;', action: 'back' }];
    if (data.chapter && data.chapter.comprehension_chips) {
      chipsList = data.chapter.comprehension_chips.map(function(c) {
        return { label: c.label || c, action: 'select_chip', payload: c };
      });
    }
    renderChips(chipsList);
  }

  function renderChips(items) {
    chips.innerHTML = '';
    items.forEach(function(item) {
      var el = document.createElement('div');
      el.className = 'coach-chip' + (item.primary ? ' coach-chip-primary' : '');
      el.innerHTML = item.label;
      el.addEventListener('click', function() {
        if (item.action === 'href') { window.location.href = item.href; }
        else if (item.action) { sendAction(item.action, item.payload); }
      });
      chips.appendChild(el);
    });
  }

  function handleInput() {
    var val = input.value.trim().toLowerCase();
    input.value = '';
    if (!val) return;
    switch (val) {
      case 'next': sendAction('next'); break;
      case 'back': sendAction('back'); break;
      case 'skip': sendAction('skip_chapter'); break;
      case 'restart': sendAction('restart_chapter'); break;
      case 'exit': sendAction('exit'); break;
      default: sendAction('select_chip', { query: val }); break;
    }
  }

  input.addEventListener('keydown', function(e) { if (e.key === 'Enter') handleInput(); });
  sendBtn.addEventListener('click', handleInput);
  document.getElementById('tc-exit').addEventListener('click', function() {
    if (confirm('Exit the tutorial? Your progress will be saved.')) sendAction('exit');
  });

  // Render initial state
  renderChips([{ label: 'Next &rarr;', action: 'next', primary: true }]);
})();
</script>

<%- include('../layouts/footer') %>
